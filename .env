# -----------------------------------------------------------------------------
# Viet-Contract Auditor - Production Storage Environment Template
# Copy to .env and adjust values for your deployment.
# -----------------------------------------------------------------------------

# --- Storage backend selection for LightRAG ---
KV_STORAGE=PGKVStorage
DOC_STATUS_STORAGE=PGDocStatusStorage
GRAPH_STORAGE=Neo4JStorage
VECTOR_STORAGE=QdrantVectorDBStorage

# --- LightRAG workspace isolation ---
WORKSPACE=viet_contract_prod
POSTGRES_WORKSPACE=viet_contract_prod
NEO4J_WORKSPACE=viet_contract_prod
QDRANT_WORKSPACE=viet_contract_prod
LIGHTRAG_WORKING_DIR=./lightrag_index

# --- Neo4j ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=contract_audit_2024
NEO4J_AUTH=neo4j/contract_audit_2024

# --- Qdrant ---
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# --- PostgreSQL ---
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=55432
POSTGRES_DATABASE=viet_contract
POSTGRES_DB=viet_contract
POSTGRES_USER=rag
POSTGRES_PASSWORD=rag_secure_pwd
POSTGRES_DSN=postgresql://rag:rag_secure_pwd@127.0.0.1:55432/viet_contract

# --- LLM / embedding example for migration script ---
# Replace with your production model configuration as needed.
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
