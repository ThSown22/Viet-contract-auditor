  <data key="d7">1.0</data>
  <data key="d8">Hội đồng trọng tài vụ việc resolves specific disputes and decides on the change of an Trọng tài viên.</data>
  <data key="d9">decision-making,dispute resolution</data>
  <data key="d10">chunk-4ad943b03a3a1bf95a1e1d6e04f2b581</data>
