  <data key="d0">Bên Nhận Bảo Đảm</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">Bên Nhận Bảo Đảm is a party that receives collateral and has the right to process it if the obligations are not fulfilled.&lt;SEP&gt;Bên Nhận Bảo Đảm is a party that receives collateral and has the right to agree on the value of the collateral or to have it valued by an organization.</data>
  <data key="d3">chunk-c152b6a16d5764e941499e3920fc0f1d&lt;SEP&gt;chunk-3cdb3cd8d8583064c0301937b6f4744a</data>
