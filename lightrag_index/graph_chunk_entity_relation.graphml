</edge>
<edge source="Bên thế chấp" target="Điều 320">
  <data key="d7">1.0</data>
  <data key="d8">Bên thế chấp has specific obligations outlined in Điều 320 regarding the management and maintenance of the collateral property.</data>
  <data key="d9">obligations,pledge</data>
  <data key="d10">chunk-0e01f265574843f568ac9f6ea2cd861c</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849951</data>
  <data key="d13"></data>
</edge>
<edge source="Bên thế chấp" target="Hoa lợi">
  <data key="d7">1.0</data>
  <data key="d8">Hoa lợi, the income derived from the collateral property, is returned to the pledging party unless there is a different agreement.</data>
  <data key="d9">collateral,income</data>
