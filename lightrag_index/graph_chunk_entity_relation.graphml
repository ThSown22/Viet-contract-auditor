  <data key="d7">1.0</data>
  <data key="d8">Ngân hàng holds the collateral in a blocked account as determined by Hội đồng trọng tài.</data>
  <data key="d9">collateral holding,emergency measures</data>
  <data key="d10">chunk-b47a7db90a1e526f1797874efef64872</data>
