</node>
<node id="Chủ Nợ">
  <data key="d0">Chủ Nợ</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">Chủ Nợ is a creditor who has the right to demand compensation from the parent company on behalf of the subsidiary.</data>
  <data key="d3">chunk-b12f2587388d6a4e9e558de512dc2860</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773853348</data>
  <data key="d6"></data>
</node>
<node id="Thành Viên, Cổ Đông">
  <data key="d0">Thành Viên, Cổ Đông</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">Thành Viên, Cổ Đông are members or shareholders of the subsidiary company who have the right to demand compensation from the parent company.</data>
  <data key="d3">chunk-b12f2587388d6a4e9e558de512dc2860</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773853348</data>
  <data key="d6"></data>
</node>
