  <data key="d1">HÀNH_VI</data>
  <data key="d2">Điều 243 is a legal provision that states that ownership rights over an asset terminate when the state requisitions the asset according to the law.</data>
  <data key="d3">chunk-053b8a5c1f69c52703201366343dafa1</data>
  <data key="d4">unknown_source</data>
