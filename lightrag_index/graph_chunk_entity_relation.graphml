</edge>
<edge source="Người đại diện theo pháp luật" target="Điều 25">
  <data key="d7">1.0</data>
  <data key="d8">Điều 25 specifies the responsibility of the Legal Representative to sign the amended company charter for various types of companies.</data>
  <data key="d9">regulation,responsibility</data>
  <data key="d10">chunk-65896b1415c5fb67acfcda61d9b89291</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851643</data>
  <data key="d13"></data>
</edge>
<edge source="Người đại diện theo pháp luật" target="Giấy chứng nhận đăng ký doanh nghiệp">
  <data key="d7">1.0</data>
  <data key="d8">The legal representative of a limited liability company or a joint-stock company is included in the Certificate of Business Registration.</data>
  <data key="d9">inclusion,registration</data>
  <data key="d10">chunk-a8de4c57592fe998c634734476be0f10</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851651</data>
  <data key="d13"></data>
</edge>
<edge source="Người đại diện theo pháp luật" target="Đиều 54">
  <data key="d7">1.0</data>
  <data key="d8">Đиều 54 outlines the role of the legal representative of a company.</data>
  <data key="d9">legal provision,legal representation</data>
  <data key="d10">chunk-7934cedd8a058c40a35091be7e3f1c17</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851694</data>
  <data key="d13"></data>
</edge>
<edge source="Người đại diện theo pháp luật" target="Công ty">
  <data key="d7">2.0</data>
  <data key="d8">The Legal Representative is responsible for ensuring the company's legal interests and adhering to the law and the company's charter.&lt;SEP&gt;Công ty is represented legally by the Người đại diện theo pháp luật, who is responsible for publishing information.</data>
  <data key="d9">information publication,legal representation,management,responsibility</data>
  <data key="d10">chunk-e45e97cff69c56c799c5135afa6fb9b2&lt;SEP&gt;chunk-41835b63d2a39e7a4ba760332a2b8046</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773852454</data>
  <data key="d13"></data>
</edge>
<edge source="Người đại diện theo pháp luật" target="Thành viên hợp danh">
  <data key="d7">1.0</data>
  <data key="d8">Người đại diện theo pháp luật has the right to demand the company to stop using the name of a former Thành viên hợp danh.</data>
  <data key="d9">legal representation,rights</data>
  <data key="d10">chunk-45f4215d40e0caccca1eaa62a7f0ec73</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773853252</data>
  <data key="d13"></data>
</edge>
<edge source="Người có khó khăn trong nhận thức, làm chủ hành vi" target="Giao dịch dân sự">
  <data key="d7">2.0</data>
  <data key="d8">Individuals who have difficulties in understanding and controlling their behavior but have not lost their legal capacity can engage in civil transactions with the consent of a legal representative.&lt;SEP&gt;Civil transactions by people who have difficulties in understanding and controlling their actions can be declared invalid.</data>
  <data key="d9">civil transaction,civil transactions,legal capacity,legal incapacity</data>
  <data key="d10">chunk-b10203f42f3e19a8ee82cd4453e46d58&lt;SEP&gt;chunk-6fef2e18615af027f8385abdb8209870</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849117</data>
  <data key="d13"></data>
</edge>
<edge source="Người có khó khăn trong nhận thức, làm chủ hành vi" target="Người đại diện">
  <data key="d7">1.0</data>
  <data key="d8">Individuals with difficulties in perception and control of behavior require a legal representative.</data>
  <data key="d9">guardianship,legal representation</data>
  <data key="d10">chunk-a4a95c6c117e21012baec10d4e1fb78c</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849189</data>
  <data key="d13"></data>
</edge>
<edge source="Người bị hạn chế năng lực hành vi dân sự" target="Giao dịch dân sự">
  <data key="d7">1.0</data>
  <data key="d8">Individuals whose legal capacity is restricted due to drug addiction or other conditions can engage in civil transactions with the consent of a legal representative.</data>
  <data key="d9">civil transactions,legal capacity</data>
  <data key="d10">chunk-b10203f42f3e19a8ee82cd4453e46d58</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849086</data>
  <data key="d13"></data>
</edge>
<edge source="Người bị hạn chế năng lực hành vi dân sự" target="G_2">
  <data key="d7">1.0</data>
  <data key="d8">Civil transactions by people whose capacity for civil conduct is limited can be declared invalid.</data>
  <data key="d9">civil transaction,legal incapacity</data>
  <data key="d10">chunk-6fef2e18615af027f8385abdb8209870</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849117</data>
  <data key="d13"></data>
</edge>
