  <data key="d7">1.0</data>
  <data key="d8">The owner of a private enterprise must comply with labor laws, and the buyer must register the change of ownership.</data>
  <data key="d9">legal compliance,ownership transfer</data>
  <data key="d10">chunk-8d59be88d8f39c9fce708d8b3f0c8014</data>
  <data key="d11">unknown_source</data>
