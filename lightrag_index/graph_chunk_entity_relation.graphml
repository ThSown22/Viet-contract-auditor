  <data key="d0">Điều  42</data>
  <data key="d3">chunk-4ad943b03a3a1bf95a1e1d6e04f2b581</data>
  <data key="d2">Điều 42 outlines the role of Chánh án Tòa án có thẩm quyền in deciding the change of Trọng tài viên.</data>
  <data key="d1">UNKNOWN</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773854050</data>
  <data key="d6"></data>
</node>
<edge source="Cá nhân" target="Quyền thay đổi tên">
  <data key="d7">1.0</data>
  <data key="d8">Cá nhân has the right to request a change in their name under specific circumstances.</data>
  <data key="d9">legal right,name change</data>
  <data key="d10">chunk-1123a80a811093ec5695cec4520ee7d2</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773848799</data>
  <data key="d13"></data>
</edge>
<edge source="Cá nhân" target="Quyền xác định, xác định lại dân tộc">
  <data key="d7">1.0</data>
  <data key="d8">Cá nhân has the right to determine or re-determine their ethnic identity under certain conditions.</data>
  <data key="d9">ethnicity determination,legal right</data>
  <data key="d10">chunk-1123a80a811093ec5695cec4520ee7d2</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773848799</data>
  <data key="d13"></data>
</edge>
<edge source="Cá nhân" target="Cơ quan nhà nước có thẩm quyền">
  <data key="d7">1.0</data>
  <data key="d8">Cá nhân can request the authorized government agencies to recognize changes in their name.</data>
  <data key="d9">legal authority,name change request</data>
  <data key="d10">chunk-1123a80a811093ec5695cec4520ee7d2</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773848800</data>
  <data key="d13"></data>
</edge>
<edge source="Cá nhân" target="Cha đẻ, mẹ đẻ">
  <data key="d7">1.0</data>
  <data key="d8">Cha đẻ, mẹ đẻ can request changes in their child's name or ethnicity.</data>
  <data key="d9">name change request,parental rights</data>
  <data key="d10">chunk-1123a80a811093ec5695cec4520ee7d2</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773848800</data>
  <data key="d13"></data>
</edge>
<edge source="Cá nhân" target="Cha nuôi, mẹ nuôi">
  <data key="d7">1.0</data>
  <data key="d8">Cha nuôi, mẹ nuôi can request changes in their adopted child's name.</data>
  <data key="d9">adoptive rights,name change request</data>
  <data key="d10">chunk-1123a80a811093ec5695cec4520ee7d2</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773848800</data>
  <data key="d13"></data>
</edge>
<edge source="Cá nhân" target="Người bị lưu lạc">
  <data key="d7">1.0</data>
  <data key="d8">Người bị lưu lạc can request a change in their name after being found.</data>
  <data key="d9">lost individual rights,name change request</data>
  <data key="d10">chunk-1123a80a811093ec5695cec4520ee7d2</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773848800</data>
  <data key="d13"></data>
</edge>
<edge source="Cá nhân" target="Vợ, chồng">
  <data key="d7">1.0</data>
  <data key="d8">Vợ, chồng can request a change in their name to comply with foreign laws.</data>
  <data key="d9">name change request,spousal rights</data>
  <data key="d10">chunk-1123a80a811093ec5695cec4520ee7d2</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773848800</data>
  <data key="d13"></data>
</edge>
<edge source="Cá nhân" target="Người đã xác định lại giới tính, người đã chuyển đổi giới tính">
  <data key="d7">1.0</data>
  <data key="d8">Người đã xác định lại giới tính, người đã chuyển đổi giới tính can request a change in their name after legally changing their gender.</data>
  <data key="d9">gender change rights,name change request</data>
  <data key="d10">chunk-1123a80a811093ec5695cec4520ee7d2</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773848800</data>
  <data key="d13"></data>
</edge>
<edge source="Cá nhân" target="Trẻ em bị bỏ rơi">
  <data key="d7">1.0</data>
  <data key="d8">Trẻ em bị bỏ rơi can have their ethnic identity determined by foster parents or the institution taking care of them.</data>
  <data key="d9">abandoned child rights,ethnicity determination</data>
  <data key="d10">chunk-1123a80a811093ec5695cec4520ee7d2</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773848800</data>
  <data key="d13"></data>
</edge>
<edge source="Cá nhân" target="Quyền được khai sinh, khai tử">
  <data key="d7">1.0</data>
  <data key="d8">Cá nhân has the right to be registered at birth and death, as stipulated in Article 30.</data>
  <data key="d9">legal rights,registration</data>
  <data key="d10">chunk-985db81e6c3d846511cb280c2983fbf0</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773848837</data>
  <data key="d13"></data>
</edge>
<edge source="Cá nhân" target="Quyền đối với quốc tịch">
  <data key="d7">1.0</data>
  <data key="d8">Cá nhân has the right to have a nationality, as stipulated in Article 31.</data>
  <data key="d9">legal rights,nationality</data>
  <data key="d10">chunk-985db81e6c3d846511cb280c2983fbf0</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773848837</data>
  <data key="d13"></data>
</edge>
<edge source="Cá nhân" target="Quyền của cá nhân đối với hình ảnh">
  <data key="d7">1.0</data>
  <data key="d8">Cá nhân has the right to control their own image, as stipulated in Article 32.</data>
  <data key="d9">image rights,legal rights</data>
  <data key="d10">chunk-985db81e6c3d846511cb280c2983fbf0</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773848837</data>
  <data key="d13"></data>
</edge>
<edge source="Cá nhân" target="Quyền sống, quyền được bảo đảm an toàn về tính mạng, sức khỏe, thân thể">
  <data key="d7">1.0</data>
  <data key="d8">Cá nhân has the right to life and safety of life, health, and body, as stipulated in Article 33.</data>
  <data key="d9">legal rights,life safety</data>
  <data key="d10">chunk-985db81e6c3d846511cb280c2983fbf0</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773848837</data>
  <data key="d13"></data>
</edge>
<edge source="Cá nhân" target="Quan hệ dân sự">
  <data key="d7">1.0</data>
  <data key="d8">Individuals participate in civil relations with rights and obligations.</data>
  <data key="d9">participation,rights and obligations</data>
  <data key="d10">chunk-4c55b09e479fc060292314cb4f8f8302</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849050</data>
  <data key="d13"></data>
</edge>
<edge source="Cá nhân" target="Người đại diện theo ủy quyền">
  <data key="d7">1.0</data>
  <data key="d8">Cá nhân can designate a representative for civil transactions.</data>
  <data key="d9">authorization,representation</data>
  <data key="d10">chunk-737848ae2370b96df322ed1b985e715f</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849397</data>
  <data key="d13"></data>
</edge>
<edge source="Cá nhân" target="Điều 138">
  <data key="d7">1.0</data>
  <data key="d8">Điều 138 defines the representation by authorization for individuals.</data>
  <data key="d9">legal provision,representation</data>
  <data key="d10">chunk-737848ae2370b96df322ed1b985e715f</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849397</data>
  <data key="d13"></data>
</edge>
<edge source="Cá nhân" target="Doanh nghiệp tư nhân">
  <data key="d7">1.0</data>
  <data key="d8">Doanh nghiệp tư nhân is owned and operated by an individual who is fully responsible for its activities.</data>
  <data key="d9">ownership,responsibility</data>
  <data key="d10">chunk-45f4215d40e0caccca1eaa62a7f0ec73</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773853252</data>
  <data key="d13"></data>
</edge>
<edge source="Quyền thay đổi tên" target="Điều 28">
  <data key="d7">1.0</data>
  <data key="d8">Điều 28 is the legal provision that grants the right to change one's name under specific circumstances.</data>
  <data key="d9">legal provision,name change rights</data>
  <data key="d10">chunk-1123a80a811093ec5695cec4520ee7d2</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773848800</data>
  <data key="d13"></data>
</edge>
<edge source="Quyền xác định, xác định lại dân tộc" target="Điều 29">
  <data key="d7">1.0</data>
  <data key="d8">Điều 29 is the legal provision that grants the right to determine or re-determine one's ethnic identity under certain conditions.</data>
  <data key="d9">ethnicity determination rights,legal provision</data>
  <data key="d10">chunk-1123a80a811093ec5695cec4520ee7d2</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773848800</data>
  <data key="d13"></data>
</edge>
<edge source="Cơ quan nhà nước có thẩm quyền" target="Thời hiệu hưởng quyền dân sự">
  <data key="d7">1.0</data>
  <data key="d8">Cơ quan nhà nước có thẩm quyền has the authority to make decisions regarding the time limit for enjoying civil rights.</data>
  <data key="d9">authority,legal concept</data>
  <data key="d10">chunk-6b3f59800e76e08387285066f5f36cdf</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849144</data>
  <data key="d13"></data>
</edge>
<edge source="Cơ quan nhà nước có thẩm quyền" target="Thời hiệu miễn trừ nghĩa vụ dân sự">
  <data key="d7">1.0</data>
  <data key="d8">Cơ quan nhà nước có thẩm quyền has the authority to make decisions regarding the time limit for exemption from civil obligations.</data>
  <data key="d9">authority,legal concept</data>
  <data key="d10">chunk-6b3f59800e76e08387285066f5f36cdf</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849144</data>
