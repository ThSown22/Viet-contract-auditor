  <data key="d0">Quy chế hoạt động Ủy ban kiểm toán</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Quy chế hoạt động Ủy ban kiểm toán is the operational regulations for the Audit Committee that govern its decision-making process.</data>
  <data key="d3">chunk-8031309e714112ffe63df75b002d2d14</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773853082</data>
  <data key="d6"></data>
</node>
<node id="Thành viên Hội đồng quản trị không điều hành">
  <data key="d0">Thành viên Hội đồng quản trị không điều hành</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">Thành viên Hội đồng quản trị không điều hành refers to non-operational members of the Hội đồng quản trị who do not have management responsibilities.</data>
  <data key="d3">chunk-8031309e714112ffe63df75b002d2d14</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773853082</data>
  <data key="d6"></data>
</node>
<node id="Cuộc Hẹp Thường Niên">
  <data key="d0">Cuộc Hẹp Thường Niên</data>
  <data key="d1">HÀNH_VI</data>
  <data key="d2">Cuộc Hẹp Thường Niên is an annual meeting where shareholders of a company gather to discuss and vote on important matters related to the company.</data>
  <data key="d3">chunk-65e07d9d273b5f52fb62308b1cffe434</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773853130</data>
  <data key="d6"></data>
</node>
<node id="Luật Thu Nhập Doanh Nghiệp">
  <data key="d0">Luật Thu Nhập Doanh Nghiệp</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Luật Thu Nhập Doanh Nghiệp is a legal framework that governs the taxation of business income.</data>
  <data key="d3">chunk-65e07d9d273b5f52fb62308b1cffe434</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773853130</data>
  <data key="d6"></data>
</node>
<node id="Báo Cáo Tài Chính Hằng Năm">
  <data key="d0">Báo Cáo Tài Chính Hằng Năm</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Báo Cáo Tài Chính Hằng Năm is an annual financial report that provides a summary of a company's financial performance and position.&lt;SEP&gt;Báo Cáo Tài Chính Hằng Năm is the annual financial report of the company that includes the total profit to be distributed and the profit to be distributed to each member.</data>
  <data key="d3">chunk-65e07d9d273b5f52fb62308b1cffe434&lt;SEP&gt;chunk-925f6a057b7d8e551fd4f47576508ca0</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773853204</data>
  <data key="d6"></data>
</node>
<node id="Danh Sách Người Có Liên Quan">
  <data key="d0">Danh Sách Người Có Liên Quan</data>
  <data key="d1">VĂN_BẢN_PHÁP_LUẬT</data>
  <data key="d2">Danh Sách Người Có Liên Quan is a list of individuals who have a relationship with the company, including their interests and connections.</data>
  <data key="d3">chunk-65e07d9d273b5f52fb62308b1cffe434</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773853130</data>
  <data key="d6"></data>
</node>
<node id="Điều 164">
  <data key="d0">Điều 164</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Điều 164 is a legal provision that outlines the requirements for disclosing the interests and relationships of individuals associated with a company.</data>
  <data key="d3">chunk-65e07d9d273b5f52fb62308b1cffe434</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773853130</data>
  <data key="d6"></data>
</node>
<node id="Ban Kiểm Soát">
  <data key="d0">Ban Kiểm Soát</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">Ban Kiểm Soát is a supervisory body within a company responsible for ensuring compliance with laws and regulations.</data>
  <data key="d3">chunk-65e07d9d273b5f52fb62308b1cffe434</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773853131</data>
  <data key="d6"></data>
</node>
<node id="Đại diện Theo Ủy Quyền của Cổ Đông">
  <data key="d0">Đại diện Theo Ủy Quyền của Cổ Đông</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">Đại diện Theo Ủy Quyền của Cổ Đông is a person appointed by a shareholder to represent their interests in the company's decision-making process.</data>
  <data key="d3">chunk-65e07d9d273b5f52fb62308b1cffe434</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773853131</data>
  <data key="d6"></data>
</node>
<node id="Tiền Lương">
  <data key="d0">Tiền Lương</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Tiền Lương refers to the salary paid to the Director or General Director and other managers, which is included in the company's business expenses.</data>
  <data key="d3">chunk-65e07d9d273b5f52fb62308b1cffe434</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773853131</data>
  <data key="d6"></data>
</node>
<node id="Thành viên độc lập Hội đồng quản trị">
  <data key="d0">Thành viên độc lập Hội đồng quản trị</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">Thành viên độc lập Hội đồng quản trị is an independent member of the board of directors who must meet certain standards and conditions.</data>
  <data key="d3">chunk-952bef1a1bafd78690b17fd797f3d33e</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773853145</data>
  <data key="d6"></data>
</node>
<node id="Người đại diện phần vốn nhà nước tại công ty mẹ">
  <data key="d0">Người đại diện phần vốn nhà nước tại công ty mẹ</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">Người đại diện phần vốn nhà nước tại công ty mẹ is a representative of state equity at the parent company, and Kiểm soát viên cannot be this person.</data>
  <data key="d3">chunk-b8bb762ad781038843f3cf2f3790105d</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773853165</data>
  <data key="d6"></data>
</node>
<node id="Người đại diện phần vốn nhà nước tại công ty">
  <data key="d0">Người đại diện phần vốn nhà nước tại công ty</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">Người đại diện phần vốn nhà nước tại công ty is a representative of state equity at the company, and Kiểm soát viên cannot be this person.</data>
  <data key="d3">chunk-b8bb762ad781038843f3cf2f3790105d</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773853165</data>
  <data key="d6"></data>
</node>
<node id="Điều 17">
  <data key="d0">Điều 17</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Điều 17 is a legal provision that specifies certain disqualifications for the position of Kiểm soát viên.</data>
  <data key="d3">chunk-b8bb762ad781038843f3cf2f3790105d</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773853165</data>
  <data key="d6"></data>
</node>
<node id="Công ty hợp danh">
  <data key="d0">Công ty hợp danh</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">Công ty hợp danh is a type of business entity where there are at least two partners who share ownership and responsibility for the business.&lt;SEP&gt;Công ty hợp danh is a type of partnership company that a private enterprise can be converted into.</data>
  <data key="d3">chunk-1efb55d02317343a2ef5f32d5d741bc9&lt;SEP&gt;chunk-8da64b48c80fc4788c324e08350a340e</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773853284</data>
  <data key="d6"></data>
</node>
<node id="Thành viên góp vốn">
  <data key="d0">Thành viên góp vốn</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">Thành viên góp vốn refers to the members who contribute capital to the company but are only liable up to the amount of their contribution.&lt;SEP&gt;Thành viên góp vốn is a member who contributes capital to the company and has specific rights and obligations.</data>
  <data key="d3">chunk-1efb55d02317343a2ef5f32d5d741bc9&lt;SEP&gt;chunk-45f4215d40e0caccca1eaa62a7f0ec73</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773853244</data>
  <data key="d6"></data>
</node>
<node id="Thành Viên Hợp Danh">
  <data key="d0">Thành Viên Hợp Danh</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">Thành viên hợp danh is a person who has specific duties and rights within a company, including managing and conducting business activities in good faith and providing regular reports on business activities.&lt;SEP&gt;Thành viên hợp danh is a type of member in a company who has specific rights and obligations as defined by the law.</data>
  <data key="d3">chunk-925f6a057b7d8e551fd4f47576508ca0&lt;SEP&gt;chunk-111878a66be557377de6fec57d456ed2</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773853426</data>
  <data key="d6"></data>
</node>
<node id="Điều Lệ Công Ty">
  <data key="d0">Điều Lệ Công Ty</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Điều Lệ Công Ty is the charter of the company that outlines the rules and regulations governing the company's operations and the rights and responsibilities of its members.&lt;SEP&gt;Điều Lệ Công Ty is the charter or bylaws of the company that specifies the rights and obligations of the members.</data>
  <data key="d3">chunk-925f6a057b7d8e551fd4f47576508ca0&lt;SEP&gt;chunk-111878a66be557377de6fec57d456ed2</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773853426</data>
  <data key="d6"></data>
</node>
<node id="Quyết Định">
  <data key="d0">Quyết Định</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Quyết Định refers to the resolutions or decisions made by the governing body of a company on various business matters.</data>
  <data key="d3">chunk-925f6a057b7d8e551fd4f47576508ca0</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773853204</data>
  <data key="d6"></data>
</node>
<node id="Triệu Tập Hợp">
  <data key="d0">Triệu Tập Hợp</data>
  <data key="d1">HÀNH_VI</data>
  <data key="d2">Triệu Tập Hợp is the event of convening a meeting of the governing body of a company to discuss and make decisions on business matters.</data>
  <data key="d3">chunk-925f6a057b7d8e551fd4f47576508ca0</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773853204</data>
  <data key="d6"></data>
</node>
<node id="Triệu Tập Hợp Hội Đồng Thành Viên">
  <data key="d0">Triệu Tập Hợp Hội Đồng Thành Viên</data>
  <data key="d1">HÀNH_VI</data>
  <data key="d2">Triệu Tập Hợp Hội Đồng Thành Viên is the event of convening a meeting of the governing body of a company to discuss and make decisions on business matters.</data>
  <data key="d3">chunk-925f6a057b7d8e551fd4f47576508ca0</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773853204</data>
  <data key="d6"></data>
</node>
<node id="Hội Đồng Thành Vi员">
  <data key="d0">Hội Đồng Thành Vi员</data>
  <data key="d3">chunk-925f6a057b7d8e551fd4f47576508ca0</data>
  <data key="d2">Tổng Giám Đốc is a person who may be appointed by Hội Đồng Thành Viên to manage the company's operations.</data>
  <data key="d1">UNKNOWN</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773853204</data>
  <data key="d6"></data>
</node>
<node id="Công ty Trách Nhiệm Hữu Hạn">
  <data key="d0">Công ty Trách Nhiệm Hữu Hạn</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">A type of company that can divide its assets, rights, and obligations to form new companies.&lt;SEP&gt;A limited liability company is a type of company that can be split by transferring assets, rights, obligations, members, and shareholders to form one or more new limited liability companies.</data>
  <data key="d3">chunk-9aff8a680816d92d14d4a77e34dbfc7d&lt;SEP&gt;chunk-20a5aa4a830d11b31ecf4b23667e2bb4</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773853308</data>
  <data key="d6"></data>
</node>
<node id="Công ty Cổ Phần">
  <data key="d0">Công ty Cổ Phần</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">A type of company that can divide its assets, rights, and obligations to form new companies.&lt;SEP&gt;A joint-stock company is a type of company that can be split by transferring assets, rights, obligations, members, and shareholders to form one or more new joint-stock companies.</data>
  <data key="d3">chunk-9aff8a680816d92d14d4a77e34dbfc7d&lt;SEP&gt;chunk-20a5aa4a830d11b31ecf4b23667e2bb4</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773853308</data>
  <data key="d6"></data>
</node>
<node id="Công Ty Bị Chia">
  <data key="d0">Công Ty Bị Chia</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">The company that is being divided to form new companies.</data>
  <data key="d3">chunk-9aff8a680816d92d14d4a77e34dbfc7d</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773853233</data>
  <data key="d6"></data>
</node>
<node id="Công Ty Mới">
  <data key="d0">Công Ty Mới</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">The new companies formed from the division of the original company.</data>
  <data key="d3">chunk-9aff8a680816d92d14d4a77e34dbfc7d</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773853233</data>
  <data key="d6"></data>
</node>
<node id="Thủ Tục Chia Công Ty">
  <data key="d0">Thủ Tục Chia Công Ty</data>
  <data key="d1">HÀNH_VI</data>
  <data key="d2">The procedures for dividing a company into new companies.</data>
  <data key="d3">chunk-9aff8a680816d92d14d4a77e34dbfc7d</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773853233</data>
  <data key="d6"></data>
</node>
<node id="Nghị Quyết, Quyết Định Chia Công Ty">
  <data key="d0">Nghị Quyết, Quyết Định Chia Công Ty</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">The resolution or decision to divide a company, which includes details about the division process.</data>
  <data key="d3">chunk-9aff8a680816d92d14d4a77e34dbfc7d</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773853233</data>
  <data key="d6"></data>
</node>
<node id="Cơ Sở Dữ Liệu Quốc Gia Về Đăng Ký Doanh Nghiệp">
  <data key="d0">Cơ Sở Dữ Liệu Quốc Gia Về Đăng Ký Doanh Nghiệp</data>
  <data key="d1">VĂN_BẢN_PHÁP_LUẬT</data>
  <data key="d2">The national database for business registration that is updated when new companies are formed.&lt;SEP&gt;The National Database on Business Registration is where the legal status of the company being split is updated.&lt;SEP&gt;Cơ Sở Dữ Liệu Quốc Gia Về Đăng Ký Doanh Nghiệp is a national database that stores information about registered enterprises.</data>
  <data key="d3">chunk-9aff8a680816d92d14d4a77e34dbfc7d&lt;SEP&gt;chunk-20a5aa4a830d11b31ecf4b23667e2bb4&lt;SEP&gt;chunk-c5a052d442484a7e21099fd9dda00e96</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773853724</data>
  <data key="d6"></data>
</node>
<node id="Bản Sao Báo Cáo">
  <data key="d0">Bản Sao Báo Cáo</data>
  <data key="d1">VĂN_BẢN_PHÁP_LUẬT</data>
  <data key="d2">Copies of reports and documents must be stored at the branch of the parent company in Vietnam.</data>
  <data key="d3">chunk-9aff8a680816d92d14d4a77e34dbfc7d</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773853233</data>
  <data key="d6"></data>
</node>
<node id="Chi Nhánh Công Ty Mẹ">
  <data key="d0">Chi Nhánh Công Ty Mẹ</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">The branch of the parent company in Vietnam where copies of reports and documents must be stored.</data>
  <data key="d3">chunk-9aff8a680816d92d14d4a77e34dbfc7d</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773853233</data>
  <data key="d6"></data>
</node>
<node id="Công Ty Trách Nhiệm Hữu Hạn">
  <data key="d0">Công Ty Trách Nhiệm Hữu Hạn</data>
  <data key="d3">chunk-9aff8a680816d92d14d4a77e34dbfc7d</data>
  <data key="d2">The procedures for dividing a limited liability company into new companies.</data>
  <data key="d1">UNKNOWN</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773853233</data>
  <data key="d6"></data>
</node>
<node id="Công Ty Cổ Phần">
  <data key="d0">Công Ty Cổ Phần</data>
  <data key="d3">chunk-9aff8a680816d92d14d4a77e34dbfc7d</data>
  <data key="d2">The procedures for dividing a joint-stock company into new companies.</data>
  <data key="d1">UNKNOWN</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773853234</data>
  <data key="d6"></data>
</node>
<node id="Doanh nghiệp tư nhân">
  <data key="d0">Doanh nghiệp tư nhân</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">Doanh nghiệp tư nhân is a privately-owned business run by an individual who is fully responsible for its activities.&lt;SEP&gt;Doanh nghiệp tư nhân is a type of private enterprise that can be converted into other types of companies.</data>
  <data key="d3">chunk-45f4215d40e0caccca1eaa62a7f0ec73&lt;SEP&gt;chunk-8da64b48c80fc4788c324e08350a340e</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773853284</data>
  <data key="d6"></data>
</node>
<node id="Tài liệu">
  <data key="d0">Tài liệu</data>
  <data key="d1">VĂN_BẢN_PHÁP_LUẬT</data>
  <data key="d2">Tài liệu is a document.</data>
  <data key="d3">chunk-45f4215d40e0caccca1eaa62a7f0ec73</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773853244</data>
  <data key="d6"></data>
</node>
<node id="Chứng khoán">
  <data key="d0">Chứng khoán</data>
  <data key="d1">VĂN_BẢN_PHÁP_LUẬT</data>
  <data key="d2">Chứng khoán is a security or stock.</data>
  <data key="d3">chunk-45f4215d40e0caccca1eaa62a7f0ec73</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773853244</data>
  <data key="d6"></data>
</node>
<node id="Chủ Doanh Nghiệp Tư Nhân">
  <data key="d0">Chủ Doanh Nghiệp Tư Nhân</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">The owner of a private enterprise is responsible for the management and operations of the business and must comply with labor laws.</data>
  <data key="d3">chunk-8d59be88d8f39c9fce708d8b3f0c8014</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773853269</data>
  <data key="d6"></data>
</node>
<node id="Người Mua Doanh Nghiệp Tư Nhân">
  <data key="d0">Người Mua Doanh Nghiệp Tư Nhân</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">The buyer of a private enterprise must register the change of ownership according to the law.</data>
  <data key="d3">chunk-8d59be88d8f39c9fce708d8b3f0c8014</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773853269</data>
  <data key="d6"></data>
</node>
<node id="Tổng Công Ty">
  <data key="d0">Tổng Công Ty</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">A holding company is a group of companies with interrelated ownership through shares or other forms of association.</data>
  <data key="d3">chunk-8d59be88d8f39c9fce708d8b3f0c8014</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773853269</data>
