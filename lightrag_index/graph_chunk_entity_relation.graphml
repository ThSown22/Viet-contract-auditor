  <data key="d7">1.0</data>
  <data key="d8">Hội đồng thành viên follows the procedures outlined in Điều 98 for conducting meetings and making decisions.</data>
  <data key="d9">regulation,working procedures</data>
  <data key="d10">chunk-64e6d8ee78ba16dc478897165155df59</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773852342</data>
