  <data key="d13"></data>
</edge>
<edge source="Điều 69" target="Công ty">
  <data key="d7">1.0</data>
  <data key="d8">Công ty can distribute profits to its members according to the conditions outlined in Điều  69.</data>
  <data key="d9">legal provision,profit distribution</data>
  <data key="d10">chunk-03d808b04d1d049b480a85951d6f999f</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773852116</data>
  <data key="d13"></data>
</edge>
<edge source="Điều 69" target="Thành viên">
  <data key="d7">1.0</data>
  <data key="d8">Thành viên can receive profits from the company according to the conditions outlined in Điều 69.</data>
  <data key="d9">legal provision,profit distribution</data>
  <data key="d10">chunk-03d808b04d1d049b480a85951d6f999f</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773852116</data>
  <data key="d13"></data>
</edge>
<edge source="Điều 70" target="Công ty">
  <data key="d7">1.0</data>
  <data key="d8">Công ty can reclaim distributed capital or profits according to the conditions outlined in Điều 70.</data>
  <data key="d9">capital recovery,legal provision</data>
  <data key="d10">chunk-03d808b04d1d049b480a85951d6f999f</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773852116</data>
  <data key="d13"></data>
</edge>
<edge source="Điều 70" target="Thành viên">
  <data key="d7">1.0</data>
  <data key="d8">Thành viên must return distributed capital or profits according to the conditions outlined in Điều 70.</data>
  <data key="d9">capital recovery,legal provision</data>
  <data key="d10">chunk-03d808b04d1d049b480a85951d6f999f</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773852116</data>
  <data key="d13"></data>
</edge>
<edge source="Điều 70" target="Đơn yêu cầu huỷ phán quyết trọng tài">
  <data key="d7">1.0</data>
  <data key="d8">Đơn yêu cầu huỷ phán quyết trọng tài must meet the requirements specified in Điều  70 to be considered valid.</data>
  <data key="d9">legal submission,requirements</data>
  <data key="d10">chunk-5c9e86e115e2f87b380e003f8d31484e</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773853801</data>
  <data key="d13"></data>
</edge>
<edge source="Điều 71" target="Công ty">
  <data key="d7">1.0</data>
  <data key="d8">Article 71 outlines the responsibilities of the Chairman of the Board of Members, Director, General Director, other managers, Legal Representative, and Inspector within the company.</data>
  <data key="d9">legal framework,responsibilities</data>
  <data key="d10">chunk-e45e97cff69c56c799c5135afa6fb9b2</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773852187</data>
  <data key="d13"></data>
</edge>
<edge source="Điều 72" target="Công ty">
  <data key="d7">1.0</data>
  <data key="d8">Article 72 outlines the procedures for initiating a lawsuit against managers for failing to fulfill their responsibilities within the company.</data>
  <data key="d9">legal framework,responsibilities</data>
  <data key="d10">chunk-e45e97cff69c56c799c5135afa6fb9b2</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773852187</data>
  <data key="d13"></data>
</edge>
<edge source="Cơ quan có thẩm quyền" target="Quyền dân sự">
  <data key="d7">1.0</data>
  <data key="d8">Cơ quan có thẩm quyền is responsible for protecting and enforcing civil rights.</data>
  <data key="d9">legal enforcement,protection</data>
  <data key="d10">chunk-40ff7c22fcf50ef4a68ba24e88d00b7b</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773848886</data>
  <data key="d13"></data>
</edge>
<edge source="Cơ quan có thẩm quyền" target="Hủy quyết định cá biệt trái pháp luật">
  <data key="d7">1.0</data>
  <data key="d8">Cơ quan có thẩm quyền has the authority to revoke unlawful individual decisions.</data>
  <data key="d9">legal authority,revocation</data>
  <data key="d10">chunk-40ff7c22fcf50ef4a68ba24e88d00b7b</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773848886</data>
  <data key="d13"></data>
</edge>
<edge source="Quyền dân sự" target="Điều 2">
  <data key="d7">1.0</data>
  <data key="d8">Article 2 of the Civil Code addresses the recognition, respect, protection, and assurance of civil rights.</data>
  <data key="d9">protection,recognition</data>
  <data key="d10">chunk-4c55b09e479fc060292314cb4f8f8302</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849050</data>
  <data key="d13"></data>
</edge>
<edge source="Quyền dân sự" target="Bộ luật này">
  <data key="d7">1.0</data>
  <data key="d8">The Civil Code ensures the protection and assurance of civil rights according to the Constitution and laws.</data>
  <data key="d9">legal assurance,protection</data>
  <data key="d10">chunk-4c55b09e479fc060292314cb4f8f8302</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849050</data>
  <data key="d13"></data>
</edge>
<edge source="Quyền nhân thân" target="Người đại diện theo pháp luật">
  <data key="d7">1.0</data>
  <data key="d8">Người đại diện theo pháp luật acts on behalf of individuals with limited or no legal capacity in matters related to personal rights.</data>
  <data key="d9">legal representation,personal rights</data>
  <data key="d10">chunk-b10203f42f3e19a8ee82cd4453e46d58</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849086</data>
  <data key="d13"></data>
</edge>
<edge source="Quyền nhân thân" target="Thời hiệu khởi kiện">
  <data key="d7">1.0</data>
  <data key="d8">Thời hiệu khởi kiện does not apply to personal rights that are not tied to property.</data>
  <data key="d9">exclusion,legal protection</data>
  <data key="d10">chunk-a4a95c6c117e21012baec10d4e1fb78c</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849189</data>
  <data key="d13"></data>
</edge>
<edge source="Quyền sở hữu" target="Thời hiệu khởi kiện">
  <data key="d7">1.0</data>
  <data key="d8">Thời hiệu khởi kiện does not apply to the right of ownership over property, except where otherwise provided by law.</data>
  <data key="d9">exclusion,legal protection</data>
