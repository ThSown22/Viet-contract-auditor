  <data key="d0">Đиều 26</data>
  <data key="d3">chunk-65896b1415c5fb67acfcda61d9b89291</data>
  <data key="d2">Đиều 26 specifies the responsibility of the Business Registration Application to be submitted to the Business Registration Authority for registering a business.</data>
  <data key="d1">UNKNOWN</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773851643</data>
  <data key="d6"></data>
</node>
<node id="Mã số doanh nghiệp">
  <data key="d0">Mã số doanh nghiệp</data>
  <data key="d1">VĂN_BẢN_PHÁP_LUẬT</data>
  <data key="d2">The Business Registration Number is a unique series of numbers assigned to a business entity upon establishment and recorded on the Certificate of Business Registration.</data>
  <data key="d3">chunk-a8de4c57592fe998c634734476be0f10</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773851651</data>
  <data key="d6"></data>
</node>
<node id="Ngành, nghề đăng ký kinh doanh">
  <data key="d0">Ngành, nghề đăng ký kinh doanh</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">The industry and business activities registered by the business entity must not be prohibited by law.</data>
  <data key="d3">chunk-a8de4c57592fe998c634734476be0f10</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773851651</data>
  <data key="d6"></data>
</node>
<node id="Lệ phí đăng ký doanh nghiệp">
  <data key="d0">Lệ phí đăng ký doanh nghiệp</data>
  <data key="d1">VĂN_BẢN_PHÁP_LUẬT</data>
  <data key="d2">The registration fee for a business entity must be paid according to the law.</data>
  <data key="d3">chunk-a8de4c57592fe998c634734476be0f10</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773851651</data>
  <data key="d6"></data>
</node>
<node id="Địa chỉ trụ sở chính của doanh nghiệp">
  <data key="d0">Địa chỉ trụ sở chính của doanh nghiệp</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">The main office address of the business entity is included in the Certificate of Business Registration.</data>
  <data key="d3">chunk-a8de4c57592fe998c634734476be0f10</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773851651</data>
  <data key="d6"></data>
</node>
<node id="Thành viên hợp danh">
  <data key="d0">Thành viên hợp danh</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">The partner members of a partnership company are included in the Certificate of Business Registration.&lt;SEP&gt;Thành viên hợp danh refers to the partners in a công ty hợp danh who are personally responsible for the company's debts.&lt;SEP&gt;Thành viên hợp danh is a partner in the company who is jointly and severally liable for the company's debts and financial obligations.&lt;SEP&gt;Partners in the business are responsible for the accuracy of the dissolution file.</data>
  <data key="d3">chunk-a8de4c57592fe998c634734476be0f10&lt;SEP&gt;chunk-1efb55d02317343a2ef5f32d5d741bc9&lt;SEP&gt;chunk-45f4215d40e0caccca1eaa62a7f0ec73&lt;SEP&gt;chunk-c9f7a6499f6482b84c0cafd640523108</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773853649</data>
  <data key="d6"></data>
</node>
<node id="Chủ doanh nghiệp">
  <data key="d0">Chủ doanh nghiệp</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">The owner of a private business entity is included in the Certificate of Business Registration.</data>
  <data key="d3">chunk-a8de4c57592fe998c634734476be0f10</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773851651</data>
  <data key="d6"></data>
</node>
<node id="Thành viên là cá nhân">
  <data key="d0">Thành viên là cá nhân</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">The individual members of a limited liability company are included in the Certificate of Business Registration.</data>
  <data key="d3">chunk-a8de4c57592fe998c634734476be0f10</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773851651</data>
  <data key="d6"></data>
</node>
<node id="Thành viên là tổ chức">
  <data key="d0">Thành viên là tổ chức</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">The organizational members of a limited liability company are included in the Certificate of Business Registration.</data>
  <data key="d3">chunk-a8de4c57592fe998c634734476be0f10</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773851651</data>
  <data key="d6"></data>
</node>
<node id="Vốn đầu tư">
  <data key="d0">Vốn đầu tư</data>
  <data key="d1">VĂN_BẢN_PHÁP_LUẬT</data>
  <data key="d2">The investment capital of a private business entity is included in the Certificate of Business Registration.</data>
  <data key="d3">chunk-a8de4c57592fe998c634734476be0f10</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773851651</data>
  <data key="d6"></data>
</node>
<node id="Điều 53">
  <data key="d0">Điều 53</data>
  <data key="d1">HÀNH_VI</data>
  <data key="d2">Điều 53 is a legal provision that outlines the handling of capital contributions in special circumstances.</data>
  <data key="d3">chunk-7934cedd8a058c40a35091be7e3f1c17</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773851690</data>
  <data key="d6"></data>
</node>
<node id="Điều 54">
  <data key="d0">Điều 54</data>
  <data key="d1">HÀNH_VI</data>
  <data key="d2">Điều 54 is a legal provision that outlines the organizational structure for managing a company.</data>
  <data key="d3">chunk-7934cedd8a058c40a35091be7e3f1c17</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773851690</data>
  <data key="d6"></data>
</node>
<node id="Thành viên công ty">
  <data key="d0">Thành viên công ty</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">Thành viên công ty refers to the members of a company, who can be individuals or organizations.&lt;SEP&gt;Thành viên công ty are the members of the company who participate in the meetings and vote on decisions.</data>
  <data key="d3">chunk-7934cedd8a058c40a35091be7e3f1c17&lt;SEP&gt;chunk-ba435d4c67d66b1792235911ac871358</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773851841</data>
  <data key="d6"></data>
</node>
<node id="Công ty trách nhiệm hữu hạn một thành viên">
  <data key="d0">Công ty trách nhiệm hữu hạn một thành viên</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">Công ty trách nhiệm hữu hạn một thành viên is a type of company with a single member.&lt;SEP&gt;Công ty trách nhiệm hữu hạn một thành viên is a type of company with limited liability and only one member.&lt;SEP&gt;Công ty trách nhiệm hữu hạn một thành viên is a type of company with a single shareholder, which can be managed in two models: with a Chairman, Director, or General Director, or with a Board of Members, Director, or General Director.&lt;SEP&gt;A company owned by a single entity or individual, responsible for the company's debts within the limit of the registered capital.&lt;SEP&gt;A single-member limited liability company that can be formed by converting a joint-stock company.</data>
  <data key="d3">chunk-7934cedd8a058c40a35091be7e3f1c17&lt;SEP&gt;chunk-4c4083a7e93b6ad10b316c67434aca7b&lt;SEP&gt;chunk-a4cc0849888b2ab85d179a3c3efe5e7f&lt;SEP&gt;chunk-21e60fc19506b5cf181276cb00664680&lt;SEP&gt;chunk-0359f960f337b0c62d24c54f784fc5c1</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773853411</data>
  <data key="d6"></data>
</node>
<node id="Công ty trách nhiệm hữu hạn hai thành viên trở lên">
  <data key="d0">Công ty trách nhiệm hữu hạn hai thành viên trở lên</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">Công ty trách nhiệm hữu hạn hai thành viên trở lên is a type of company with two or more members.&lt;SEP&gt;A limited liability company with two or more members.&lt;SEP&gt;Công ty trách nhiệm hữu hạn hai thành viên trở lên is a type of company with limited liability and at least two members.&lt;SEP&gt;This type of company is required to disclose information according to specific legal provisions.&lt;SEP&gt;Công ty trách nhiệm hữu hạn hai thành viên trở lên is a type of company that can be formed by converting a công ty cổ phần.</data>
  <data key="d3">chunk-7934cedd8a058c40a35091be7e3f1c17&lt;SEP&gt;chunk-2eb9bbbcf6b6e613956612e1bdbdc127&lt;SEP&gt;chunk-4c4083a7e93b6ad10b316c67434aca7b&lt;SEP&gt;chunk-21e60fc19506b5cf181276cb00664680&lt;SEP&gt;chunk-a788d203fae6d3c78c81ae71ea9171e4</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773853453</data>
  <data key="d6"></data>
</node>
<node id="Ban kiểm soát">
  <data key="d0">Ban kiểm soát</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">Ban kiểm soát is a supervisory board that must be established in certain state-owned enterprises and companies with state-owned enterprises as shareholders. It is part of the management structure of state-owned enterprises and serves as the Supervisory Board of a company, overseeing the activities of the Board of Directors and the company's operations. The Ban kiểm soát is responsible for reviewing specific issues related to the management and operation of the company upon request by shareholders, acting as an audit committee to ensure oversight and accountability. It oversees the company's financial activities and ensures compliance with regulations. The supervisory board has the right to access information and reports from the company and is responsible for reviewing financial reports and internal controls. Typically, Ban kiểm soát consists of 3 to 5 kiểm soát viên with a term not exceeding 5 years.&lt;SEP&gt;Ban kiểm soát is a supervisory board within a company that reviews and audits the company's activities.&lt;SEP&gt;Ban kiểm soát is a supervisory body within a company that monitors the activities of the management and ensures compliance with regulations.</data>
  <data key="d3">chunk-7934cedd8a058c40a35091be7e3f1c17&lt;SEP&gt;chunk-a4cc0849888b2ab85d179a3c3efe5e7f&lt;SEP&gt;chunk-246618b082091a628ff89e93d59fc956&lt;SEP&gt;chunk-33f981a65016c41f688ba0ac17a35ac7&lt;SEP&gt;chunk-c8778f64e7716832bf2ad7d755875a3d&lt;SEP&gt;chunk-705217d07d78fdf7f9b9f642d9c62131&lt;SEP&gt;chunk-01b556fba8ab897e9f334300f225003e&lt;SEP&gt;chunk-202753da85e57657b151764c6fce4516&lt;SEP&gt;chunk-0e1d93dc94342974419c33affd5c6109&lt;SEP&gt;chunk-98602a1920269703e171e36e577b9933&lt;SEP&gt;chunk-8245b988239aa1f9c2e280f1734f8ac5&lt;SEP&gt;chunk-2ec32bc0d8c57985cdac3f5a1383a2dc&lt;SEP&gt;chunk-4d51643ce273eae22725bc9b7424a745&lt;SEP&gt;chunk-373a8f0d009c4c6073d5e556bc2411e7&lt;SEP&gt;chunk-795fb9faa3ff64c104def58573301724&lt;SEP&gt;chunk-b0cdd7174a5289f85d735aa45cd8829d&lt;SEP&gt;chunk-954105a0b477a911ae8062a76843dd6d</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773853042</data>
  <data key="d6"></data>
</node>
<node id="Giám đốc hoặc Tổng giám đốc">
  <data key="d0">Giám đốc hoặc Tổng giám đốc</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">Giám đốc hoặc Tổng giám đốc refers to the director or general manager of a company. This individual is a senior executive responsible for the day-to-day management and operations of the company. They are appointed or removed by the governing body, which in this context is the Hội đồng quản trị or Board of Directors. The Giám đốc hoặc Tổng giám đốc is accountable for managing the company's operations and reporting to the governing body. Additionally, they are responsible for the accuracy of the dissolution file when the company undergoes dissolution.</data>
  <data key="d3">chunk-7934cedd8a058c40a35091be7e3f1c17&lt;SEP&gt;chunk-ba435d4c67d66b1792235911ac871358&lt;SEP&gt;chunk-8245b988239aa1f9c2e280f1734f8ac5&lt;SEP&gt;chunk-2ec32bc0d8c57985cdac3f5a1383a2dc&lt;SEP&gt;chunk-4d51643ce273eae22725bc9b7424a745&lt;SEP&gt;chunk-795fb9faa3ff64c104def58573301724&lt;SEP&gt;chunk-df9831e320198a4b066f7cdd1b9bbfe0&lt;SEP&gt;chunk-c9f7a6499f6482b84c0cafd640523108</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773853651</data>
  <data key="d6"></data>
</node>
<node id="59/2020/qh14">
  <data key="d0">59/2020/qh14</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">59/2020/qh14 is the legal document or law that contains the provisions mentioned in the text.&lt;SEP&gt;59/2020/qh14 is a legal document or law that contains the regulations for the governing body of a company.</data>
  <data key="d3">chunk-7934cedd8a058c40a35091be7e3f1c17&lt;SEP&gt;chunk-0941ba0e34f54b5fcc1460ed44a10cff</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773851899</data>
  <data key="d6"></data>
</node>
<node id="Bộ luật Dân sự">
  <data key="d0">Bộ luật Dân sự</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Bộ luật Dân sự is the civil code that defines the legal framework for inheritance and other civil matters.</data>
  <data key="d3">chunk-7934cedd8a058c40a35091be7e3f1c17</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773851690</data>
  <data key="d6"></data>
</node>
<node id="Điều  53">
  <data key="d0">Điều  53</data>
  <data key="d3">chunk-7934cedd8a058c40a35091be7e3f1c17</data>
  <data key="d2">Điều 53 specifies the role of the court in declaring a member missing or incapacitated and issuing decisions regarding the cessation of business activities.</data>
  <data key="d1">UNKNOWN</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773851694</data>
  <data key="d6"></data>
</node>
<node id="Đиều 54">
  <data key="d0">Đиều 54</data>
  <data key="d3">chunk-7934cedd8a058c40a35091be7e3f1c17</data>
  <data key="d2">Đиều 54 specifies the establishment of a supervisory board in certain state-owned enterprises.</data>
  <data key="d1">UNKNOWN</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773851694</data>
  <data key="d6"></data>
</node>
<node id="Người được tặng cho">
  <data key="d0">Người được tặng cho</data>
  <data key="d3">chunk-7934cedd8a058c40a35091be7e3f1c17</data>
  <data key="d2">Bộ luật Dân sự defines the legal framework for the rights of individuals who receive gifts of capital contributions.</data>
  <data key="d1">UNKNOWN</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773851694</data>
  <data key="d6"></data>
</node>
<node id="Cơ quan quản lý nhà nước về đăng ký kinh doanh">
  <data key="d0">Cơ quan quản lý nhà nước về đăng ký kinh doanh</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">The State Management Agency for Business Registration is responsible for providing information on business registration content.</data>
  <data key="d3">chunk-64b8fad75bc3785889ce216fbcf53556</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773851713</data>
  <data key="d6"></data>
</node>
<node id="Tài sản góp vốn">
  <data key="d0">Tài sản góp vốn</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Capital contribution assets include Vietnamese Dong, freely convertible foreign currency, gold, land use rights, intellectual property rights, technology, trade secrets, and other assets that can be valued in Vietnamese Dong.&lt;SEP&gt;Tài sản góp vốn refers to assets contributed to capital, which must be valued and expressed in Vietnamese Dong.</data>
  <data key="d3">chunk-64b8fad75bc3785889ce216fbcf53556&lt;SEP&gt;chunk-32bedb7a710b05aeaa67ceee9734170a</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773851899</data>
  <data key="d6"></data>
</node>
<node id="Thành viên công ty trách nhiệm hữu hạn">
  <data key="d0">Thành viên công ty trách nhiệm hữu hạn</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">Members of a limited liability company are required to transfer ownership of their capital contribution assets to the company.</data>
  <data key="d3">chunk-64b8fad75bc3785889ce216fbcf53556</data>
  <data key="d4">unknown_source</data>
