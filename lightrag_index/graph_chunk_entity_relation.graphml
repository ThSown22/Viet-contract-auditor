  <data key="d0">Tổ chức khác</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">Tổ chức khác refers to other organizations that may have the function of maintaining the shareholder register.</data>
  <data key="d3">chunk-dc2c4537017d8abf8400a3fc36e9aa3e</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773852299</data>
  <data key="d6"></data>
</node>
<node id="Cổ tức">
  <data key="d0">Cổ tức</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Dividends are payments made to shareholders based on the decisions of the General Shareholders' Meeting.&lt;SEP&gt;Cổ tức refers to dividends paid to shareholders of a company.</data>
  <data key="d3">chunk-c8778f64e7716832bf2ad7d755875a3d&lt;SEP&gt;chunk-8245b988239aa1f9c2e280f1734f8ac5</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773852818</data>
  <data key="d6"></data>
</node>
<node id="Tài sản còn lại">
  <data key="d0">Tài sản còn lại</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Remaining assets are the assets distributed to shareholders when the company is dissolved or bankrupt, proportional to their share ownership.</data>
  <data key="d3">chunk-c8778f64e7716832bf2ad7d755875a3d</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773852299</data>
  <data key="d6"></data>
</node>
