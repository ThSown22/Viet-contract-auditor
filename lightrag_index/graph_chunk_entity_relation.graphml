  <data key="d0">Điều 23</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Điều 23 is a section of the law that outlines the functions of the arbitration center.</data>
  <data key="d3">chunk-1881019a36e766412bad88d7a1e3d088</data>
