  <data key="d7">1.0</data>
  <data key="d8">Người Thân Thích can appoint a supervisor for the guardianship or make decisions regarding the guardianship.</data>
  <data key="d9">appointment,supervision</data>
  <data key="d10">chunk-651dc401f3963fbef4dfe8d51ab78119</data>
