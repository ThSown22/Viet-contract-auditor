<edge source="Chủ nợ" target="Giải thể doanh nghiệp">
  <data key="d7">1.0</data>
  <data key="d8">Creditors of the business are notified of the dissolution process and provided with information on debt repayment.</data>
  <data key="d9">debt repayment,notification</data>
