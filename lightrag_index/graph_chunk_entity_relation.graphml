  <data key="d11">unknown_source</data>
  <data key="d12">1773849505</data>
  <data key="d13"></data>
</edge>
<edge source="Tòa án" target="Bảo vệ việc chiếm hữu">
  <data key="d7">1.0</data>
  <data key="d8">Tòa án can be requested to enforce the cessation of infringement and restoration of the original state of the property.</data>
  <data key="d9">court,protection</data>
  <data key="d10">chunk-32dad3b53fda840a78aa833f5592a4d7</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849696</data>
  <data key="d13"></data>
</edge>
<edge source="Tòa án" target="Đиều 223">
  <data key="d7">1.0</data>
  <data key="d8">Đиều 223 establishes ownership rights through contracts, with decisions made by the court.</data>
  <data key="d9">legal provision,ownership rights</data>
