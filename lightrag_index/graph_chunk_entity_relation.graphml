  <data key="d0">Thời Gian Thanh Toán</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Thời Gian Thanh Toán refers to the agreed-upon time for payment in the contract.</data>
  <data key="d3">chunk-4623833cd0cb1b86833b9050e09612fd</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850373</data>
  <data key="d6"></data>
</node>
