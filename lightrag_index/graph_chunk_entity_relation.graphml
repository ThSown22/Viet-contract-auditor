  <data key="d7">1.0</data>
  <data key="d8">A business entity must pay the registration fee according to the law.</data>
  <data key="d9">compliance,payment</data>
  <data key="d10">chunk-a8de4c57592fe998c634734476be0f10</data>
  <data key="d11">unknown_source</data>
