  <data key="d7">1.0</data>
  <data key="d8">The decision to cancel emergency measures must be sent to the parties involved in the dispute.</data>
  <data key="d9">cancellation,notification</data>
  <data key="d10">chunk-a36e099bae803eeaad0a5160e83464d5</data>
  <data key="d11">unknown_source</data>
