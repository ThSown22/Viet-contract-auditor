  <data key="d7">1.0</data>
  <data key="d8">Người đại diện theo ủy quyền represents the interests of the shareholders, members, or owners at the general meeting of shareholders.</data>
  <data key="d9">representation,responsibility</data>
  <data key="d10">chunk-2619cf455665fecc350d8c72d83e850d</data>
