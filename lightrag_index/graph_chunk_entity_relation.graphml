<edge source="Thực hiện công việc không có ủy quyền" target="Người thực hiện công việc không có ủy quyền">
  <data key="d7">1.0</data>
  <data key="d8">The person performing work without authorization has the obligation to perform the work in accordance with their abilities and conditions.</data>
  <data key="d9">obligation,voluntary work</data>
  <data key="d10">chunk-50c919d97de369bc8d7562186f764b91</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850908</data>
