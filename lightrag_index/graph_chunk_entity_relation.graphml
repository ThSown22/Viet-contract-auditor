  <data key="d0">Cổ đông sở hữu cổ phần ưu đãi hoàn lại</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">Cổ đông sở hữu cổ phần ưu đãi hoàn lại are shareholders who hold preferred shares with a right to be repaid first in the event of liquidation.</data>
  <data key="d3">chunk-705217d07d78fdf7f9b9f642d9c62131</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773852331</data>
  <data key="d6"></data>
