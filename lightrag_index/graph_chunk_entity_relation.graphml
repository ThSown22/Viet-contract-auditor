</edge>
<edge source="Tài sản thế chấp" target="Tổ chức bảo hiểm">
  <data key="d7">1.0</data>
  <data key="d8">Tổ chức bảo hiểm provides insurance for the collateral property.</data>
  <data key="d9">collateral,insurance</data>
  <data key="d10">chunk-0e01f265574843f568ac9f6ea2cd861c</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849951</data>
