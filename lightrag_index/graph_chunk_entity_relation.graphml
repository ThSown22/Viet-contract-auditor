  <data key="d11">unknown_source</data>
  <data key="d12">1773850168</data>
  <data key="d13"></data>
</edge>
<edge source="Hợp đồng" target="Điều 428">
  <data key="d7">1.0</data>
  <data key="d8">Điều 428 outlines the conditions under which one party can unilaterally terminate a contract without compensation.</data>
  <data key="d9">contract termination,unilateral termination</data>
