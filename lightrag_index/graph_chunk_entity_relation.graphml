  <data key="d7">1.0</data>
  <data key="d8">Chủ Sở Hữu has the right to sell, exchange, gift, lend, inherit, abandon ownership, consume, destroy, or perform other forms of disposition of property according to the law.</data>
  <data key="d9">disposition rights,property rights</data>
  <data key="d10">chunk-7d82c525b3c62a646037cf7bc6fec6a5</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849534</data>
  <data key="d13"></data>
</edge>
