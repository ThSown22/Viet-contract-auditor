  <data key="d7">1.0</data>
  <data key="d8">Individuals with restricted legal capacity require a legal representative.</data>
  <data key="d9">guardianship,legal representation</data>
  <data key="d10">chunk-a4a95c6c117e21012baec10d4e1fb78c</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849189</data>
