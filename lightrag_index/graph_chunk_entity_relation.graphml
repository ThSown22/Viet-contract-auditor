  <data key="d12">1773848944</data>
  <data key="d13"></data>
</edge>
<edge source="Người Giám Hộ" target="Chấm Dứt Việc Giám Hộ">
  <data key="d7">1.0</data>
  <data key="d8">Người Giám Hộ is involved in the process of terminating guardianship under certain conditions.</data>
  <data key="d9">responsibility,termination</data>
  <data key="d10">chunk-72f8448fcb5f40c271736a6505e9763f</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773848944</data>
  <data key="d13"></data>
</edge>
<edge source="Người Giám Hộ" target="Quản Lý Tài Sản">
  <data key="d7">1.0</data>
  <data key="d8">Người Giám Hộ is responsible for managing the assets of Người Được Giám Hộ.</data>
  <data key="d9">asset management,responsibility</data>
  <data key="d10">chunk-72f8448fcb5f40c271736a6505e9763f</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773848944</data>
  <data key="d13"></data>
</edge>
<edge source="Người Giám Hộ" target="Tài Sản">
  <data key="d7">1.0</data>
  <data key="d8">Người Giám Hộ is responsible for managing and transferring the Tài Sản of the person under guardianship during the termination of guardianship.</data>
  <data key="d9">asset management,responsibility</data>
  <data key="d10">chunk-72f8448fcb5f40c271736a6505e9763f</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773848944</data>
  <data key="d13"></data>
</edge>
<edge source="Người Giám Hộ" target="Người Thừa Kế">
  <data key="d7">1.0</data>
  <data key="d8">Người Giám Hộ is responsible for transferring the assets to the Người Thừa Kế upon the death of the person under guardianshood.</data>
  <data key="d9">inheritance,transfer</data>
  <data key="d10">chunk-72f8448fcb5f40c271736a6505e9763f</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773848944</data>
  <data key="d13"></data>
</edge>
<edge source="Người Giám Hộ" target="Người Quản Lý Di Sản">
  <data key="d7">1.0</data>
  <data key="d8">Người Giám Hộ is responsible for transferring the assets to the Người Quản Lý Di Sản if the person under guardianship has died and the heirs have not been determined.</data>
  <data key="d9">estate management,responsibility</data>
  <data key="d10">chunk-72f8448fcb5f40c271736a6505e9763f</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773848944</data>
  <data key="d13"></data>
</edge>
<edge source="Người Giám Hộ" target="Pháp Nhân">
  <data key="d7">1.0</data>
  <data key="d8">Pháp Nhân can act as a guardian if they meet the necessary conditions.</data>
  <data key="d9">guardianship,legal entity</data>
  <data key="d10">chunk-651dc401f3963fbef4dfe8d51ab78119</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849024</data>
  <data key="d13"></data>
</edge>
