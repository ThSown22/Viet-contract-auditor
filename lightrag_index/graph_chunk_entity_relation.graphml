  <data key="d7">1.0</data>
  <data key="d8">The person transferring the right to claim must provide necessary information and transfer documents to the person taking over the right to claim.</data>
  <data key="d9">document transfer,information transfer</data>
  <data key="d10">chunk-7676f54dc24423d8f0801960c11c6cf7</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850154</data>
  <data key="d13"></data>
</edge>
