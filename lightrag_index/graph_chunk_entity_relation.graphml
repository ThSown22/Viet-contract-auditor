<edge source="Các bên" target="Điều 42">
  <data key="d7">1.0</data>
  <data key="d8">Điều 42 grants the right to Các bên to request a change in the Trọng tài viên under specified conditions.</data>
  <data key="d9">regulation,rights</data>
