  <data key="d0">Nghĩa vụ của người giám hộ</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">The duties of a guardian towards the person under guardianship.</data>
  <data key="d3">chunk-215d052b0c761e4d27801c92b8990219</data>
