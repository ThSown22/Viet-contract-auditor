<edge source="Bên Mua" target="Thủ Tục Đăng Ký">
  <data key="d7">1.0</data>
  <data key="d8">Bên Mua may be required to complete registration procedures for certain types of assets.</data>
  <data key="d9">contract enforcement,registration procedures</data>
  <data key="d10">chunk-b7c9b850c56df03c6a0092f33eddd51c</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850316</data>
  <data key="d13"></data>
</edge>
<edge source="Bên Mua" target="Chi Phí Vận Chuyển">
  <data key="d7">1.0</data>
  <data key="d8">Bên Mua may be responsible for transportation costs unless otherwise agreed upon.</data>
  <data key="d9">contract enforcement,transportation costs</data>
  <data key="d10">chunk-b7c9b850c56df03c6a0092f33eddd51c</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850316</data>
  <data key="d13"></data>
</edge>
