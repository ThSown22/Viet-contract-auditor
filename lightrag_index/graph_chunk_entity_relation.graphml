  <data key="d0">Thỏa Thuận Khác</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Thỏa Thuận Khác refers to an agreement that differs from the standard legal provisions.&lt;SEP&gt;Thỏa Thuận Khác refers to an alternative agreement that may override the invalid terms in a contract.</data>
  <data key="d3">chunk-e38fe034461862746b38b34d7647cf44&lt;SEP&gt;chunk-57605bee043e497a16d0db0a26012d1e</data>
