<node id="Bên Bảo Đảm">
  <data key="d0">Bên Bảo Đảm</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">Bên Bảo Đảm is a party that provides collateral and is responsible for fulfilling obligations.&lt;SEP&gt;Bên Bảo Đảm is a party that provides collateral and has the obligation to transfer ownership of the collateral to the receiving party.</data>
  <data key="d3">chunk-c152b6a16d5764e941499e3920fc0f1d&lt;SEP&gt;chunk-3cdb3cd8d8583064c0301937b6f4744a</data>
