<node id="Giá Thị Trường">
  <data key="d0">Giá Thị Trường</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Giá Thị Trường refers to the market price used to determine the price of assets when there is no clear agreement between the parties.&lt;SEP&gt;Giá Thị Trường refers to the market price of the service at the time and location of the contract.&lt;SEP&gt;Giá Thị Trường refers to the market price at the location and time of contract signing as defined in the legal provisions.</data>
  <data key="d3">chunk-4623833cd0cb1b86833b9050e09612fd&lt;SEP&gt;chunk-e729376fa2e1544912532baf7015b267&lt;SEP&gt;chunk-d1dd682bb7148dad05854b2b5ef20db9</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850827</data>
  <data key="d6"></data>
</node>
