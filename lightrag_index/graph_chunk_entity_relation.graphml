</edge>
<edge source="Bên thế quyền ưu tiên thanh toán" target="Bên cầm cố">
  <data key="d7">1.0</data>
  <data key="d8">Bên thế quyền ưu tiên thanh toán has priority in payment within the scope of the collateral provided by Bên cầm cố.</data>
  <data key="d9">collateral,priority payment</data>
  <data key="d10">chunk-ae8ba811869db57b94f6d4864d7901d2</data>
