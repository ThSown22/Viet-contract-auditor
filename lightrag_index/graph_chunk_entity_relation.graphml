<edge source="Doanh Nghiệp Nhà Nước" target="Chính Phủ">
  <data key="d7">1.0</data>
  <data key="d8">The government specifies the detailed regulations for state-owned enterprises.</data>
  <data key="d9">management,regulation</data>
  <data key="d10">chunk-823e07d4a480b69d7f6ec00924cb4793</data>
