  <data key="d0">Cậu ruột</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">A paternal or maternal uncle who may become a guardian if there is no other guardian.</data>
  <data key="d3">chunk-215d052b0c761e4d27801c92b8990219</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773849064</data>
  <data key="d6"></data>
</node>
<node id="Cô ruột">
  <data key="d0">Cô ruột</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">A paternal or maternal aunt who may become a guardian if there is no other guardian.</data>
  <data key="d3">chunk-215d052b0c761e4d27801c92b8990219</data>
