<node id="Thời hạn 45 ngày">
  <data key="d0">Thời hạn 45 ngày</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Thời hạn 45 ngày refers to the 45-day period within which certain actions related to arbitration decisions must be taken.</data>
  <data key="d3">chunk-105aefb96d31bdf83eb8694998c59506</data>
