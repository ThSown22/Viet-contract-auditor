  <data key="d0">Rủi ro</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Rủi ro refers to the risks associated with the use of an item during the trial period or the ownership of property.</data>
  <data key="d3">chunk-fb927ff207ca7e0465d21f05d999a0f9</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850409</data>
