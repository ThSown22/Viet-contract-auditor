  <data key="d7">1.0</data>
  <data key="d8">Người Chiếm Hữu Cây Cối is responsible for compensating for any damage caused by Cây Cối.</data>
  <data key="d9">liability,possession</data>
  <data key="d10">chunk-71c1c580c8f92c3838ab0f997647d588</data>
  <data key="d11">unknown_source</data>
