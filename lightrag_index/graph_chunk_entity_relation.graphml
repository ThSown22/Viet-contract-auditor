  <data key="d12">1773851262</data>
  <data key="d13"></data>
</edge>
<edge source="Luật" target="Tiêu Chí">
  <data key="d7">1.0</data>
  <data key="d8">Luật này quy định các tiêu chí mà doanh nghiệp xã hội phải đáp ứng.</data>
  <data key="d9">criteria,legal framework</data>
  <data key="d10">chunk-902fe4ca615a8ea2fb07c3876622d200</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851262</data>
