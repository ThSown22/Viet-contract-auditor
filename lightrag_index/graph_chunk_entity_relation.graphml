<edge source="Quyền Sở Hữu" target="Điều 242">
  <data key="d7">1.0</data>
  <data key="d8">Điều 242 states that ownership rights over an asset terminate when the asset is consumed or destroyed.</data>
  <data key="d9">legal provision,ownership termination</data>
  <data key="d10">chunk-053b8a5c1f69c52703201366343dafa1</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849505</data>
