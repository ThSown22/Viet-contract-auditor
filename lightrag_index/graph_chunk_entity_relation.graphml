  <data key="d7">1.0</data>
  <data key="d8">Tiểu mục 3. Thế Chấp Tài Sản includes the content of Điều 310, which defines the effectiveness of property pledge.</data>
  <data key="d9">legal article,section content</data>
  <data key="d10">chunk-ae8ba811869db57b94f6d4864d7901d2</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850097</data>
