  <data key="d1">VĂN_BẢN_PHÁP_LUẬT</data>
  <data key="d2">Phần Hoặc Bộ Phận Đã Nhận refers to the parts or components of the delivered items that have already been received by the buyer.</data>
  <data key="d3">chunk-4623833cd0cb1b86833b9050e09612fd</data>
