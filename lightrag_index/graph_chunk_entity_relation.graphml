  <data key="d13"></data>
</edge>
<edge source="Nợ thuế" target="Công ty được chuyển đổi">
  <data key="d7">1.0</data>
  <data key="d8">Công ty được chuyển đổi takes responsibility for the tax debts of the private enterprise.</data>
  <data key="d9">inheritance,responsibility</data>
  <data key="d10">chunk-8da64b48c80fc4788c324e08350a340e</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773853285</data>
  <data key="d13"></data>
</edge>
<edge source="Công Ty Bị Tách" target="Công Ty Được Tách">
  <data key="d7">2.0</data>
  <data key="d8">The company being split and the new companies formed are jointly liable for the debts and obligations of the original company.&lt;SEP&gt;The company being split transfers assets, rights, obligations, members, and shareholders to form one or more new companies.</data>
  <data key="d9">asset transfer,company split,debt,liability</data>
  <data key="d10">chunk-20a5aa4a830d11b31ecf4b23667e2bb4</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773853315</data>
  <data key="d13"></data>
</edge>
<edge source="Điều 206" target="Ngành, nghề kinh doanh có điều kiện">
  <data key="d7">1.0</data>
  <data key="d8">Regulated industries and professions can be temporarily suspended or terminated if they do not meet the required conditions.</data>
  <data key="d9">regulation,suspension</data>
  <data key="d10">chunk-4751985bdb7ed5cd1ede693d8fa04ae4</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773853316</data>
  <data key="d13"></data>
</edge>
<edge source="Điều 206" target="Quản lý thuế">
  <data key="d7">1.0</data>
  <data key="d8">Tax management regulations can lead to the temporary suspension of business operations.</data>
  <data key="d9">regulation,suspension</data>
  <data key="d10">chunk-4751985bdb7ed5cd1ede693d8fa04ae4</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773853316</data>
  <data key="d13"></data>
</edge>
<edge source="Điều 206" target="Môi trường">
  <data key="d7">1.0</data>
  <data key="d8">Environmental regulations can lead to the temporary suspension of business operations.</data>
  <data key="d9">regulation,suspension</data>
  <data key="d10">chunk-4751985bdb7ed5cd1ede693d8fa04ae4</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773853316</data>
  <data key="d13"></data>
</edge>
<edge source="Công ty bị sáp nhập" target="Công ty nhận sáp nhập">
  <data key="d7">1.0</data>
  <data key="d8">Công ty bị sáp nhập transfers all assets, rights, obligations, and legal interests to Công ty nhận sáp nhập during a merger.</data>
  <data key="d9">asset transfer,merger</data>
  <data key="d10">chunk-e4a657b345d0676b5a5d6451a2c7c13d</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773853385</data>
  <data key="d13"></data>
</edge>
<edge source="Công ty bị sáp nhập" target="Điều 201">
  <data key="d7">1.0</data>
  <data key="d8">Điều 201 outlines the procedures for the merger of companies, including the transfer of assets and legal status updates.</data>
  <data key="d9">merger process,regulation</data>
  <data key="d10">chunk-e4a657b345d0676b5a5d6451a2c7c13d</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773853385</data>
  <data key="d13"></data>
</edge>
<edge source="Luật Cạnh tranh" target="Công ty hợp nhất">
  <data key="d7">1.0</data>
  <data key="d8">Công ty hợp nhất must comply with the regulations outlined in Luật Cạnh tranh regarding the merger of companies.</data>
  <data key="d9">legal compliance,merger regulations</data>
  <data key="d10">chunk-87d8fe2bdf778bad13a2e66311b71743</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773853442</data>
