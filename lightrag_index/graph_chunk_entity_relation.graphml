  <data key="d0">Quản lý rủi ro</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Quản lý rủi ro is the concept of risk management within the company.&lt;SEP&gt;Risk management practices that are reviewed by the Audit Committee.</data>
  <data key="d3">chunk-795fb9faa3ff64c104def58573301724&lt;SEP&gt;chunk-df9831e320198a4b066f7cdd1b9bbfe0</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773853003</data>
  <data key="d6"></data>
</node>
