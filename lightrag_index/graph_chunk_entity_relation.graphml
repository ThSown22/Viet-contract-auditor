<node id="Tài sản">
  <data key="d0">Tài sản</data>
  <data key="d1">VĂN_BẢN_PHÁP_LUẬT</data>
  <data key="d2">Tài sản refers to property that is involved in civil transactions and can be transferred to a third party.&lt;SEP&gt;Tài sản refers to the property or assets that are subject to ownership rights and legal provisions.&lt;SEP&gt;Tài sản refers to property or assets.&lt;SEP&gt;Tài sản refers to property or assets that can be owned and divided.&lt;SEP&gt;Tài sản is an asset.</data>
  <data key="d3">chunk-482a66c12f2040cbc0eabb425e1b6d97&lt;SEP&gt;chunk-79babcd2cf4aac518b57f409f34a0382&lt;SEP&gt;chunk-b2acb4f3dcdc42f5db6c9c4797e01299&lt;SEP&gt;chunk-e8a3f543a1762069fe562fe6a382e1b2&lt;SEP&gt;chunk-45f4215d40e0caccca1eaa62a7f0ec73</data>
