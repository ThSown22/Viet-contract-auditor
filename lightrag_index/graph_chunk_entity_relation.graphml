  <data key="d11">unknown_source</data>
  <data key="d12">1773849452</data>
  <data key="d13"></data>
</edge>
<edge source="Tòa án" target="Quyền Sở Hữu">
  <data key="d7">1.0</data>
  <data key="d8">Tòa án makes decisions that can lead to the termination of ownership rights over assets.</data>
  <data key="d9">legal decision,ownership termination</data>
