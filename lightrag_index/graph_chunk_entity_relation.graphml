  <data key="d13"></data>
</edge>
<edge source="Phần Vốn Góp" target="Thành Viên">
  <data key="d7">1.0</data>
  <data key="d8">Thành Viên contributes capital to the company and is liable for the company's debts within the scope of their contributions.</data>
  <data key="d9">capital contribution,liability</data>
  <data key="d10">chunk-fef4d2c27b6430834254a2ffeefda111</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851866</data>
