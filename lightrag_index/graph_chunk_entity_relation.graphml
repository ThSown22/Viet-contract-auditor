</edge>
<edge source="Công ty cổ phần" target="Quyền sử dụng đất">
  <data key="d7">1.0</data>
  <data key="d8">Quyền sử dụng đất is the right to use land used as a form of payment in the company.</data>
  <data key="d9">payment method,transaction</data>
  <data key="d10">chunk-9b892718f9850a0f9775f9a075fb4282</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773852753</data>
  <data key="d13"></data>
</edge>
<edge source="Công ty cổ phần" target="Công nghệ">
  <data key="d7">1.0</data>
  <data key="d8">Công nghệ is technology used as a form of payment in the company.</data>
  <data key="d9">payment method,transaction</data>
