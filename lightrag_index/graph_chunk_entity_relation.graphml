  <data key="d0">Công Trình Xây Dựng Khác</data>
  <data key="d1">VĂN_BẢN_PHÁP_LUẬT</data>
  <data key="d2">Công Trình Xây Dựng Khác refers to other construction projects that may cause damage.</data>
  <data key="d3">chunk-71c1c580c8f92c3838ab0f997647d588</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773851024</data>
  <data key="d6"></data>
</node>
