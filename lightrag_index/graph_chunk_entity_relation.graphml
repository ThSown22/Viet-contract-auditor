  <data key="d0">Trách Nhiệm Do Giao Tài Sản Không Đúng Số Lượng</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Trách Nhiệm Do Giao Tài Sản Không Đúng Số Lượng refers to the responsibilities and rights of the buyer and seller when the quantity of assets delivered does not match the agreed-upon quantity.</data>
  <data key="d3">chunk-4623833cd0cb1b86833b9050e09612fd</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850373</data>
  <data key="d6"></data>
</node>
<node id="Trách Nhiệm Do Giao Vật Không Đồng Bộ">
  <data key="d0">Trách Nhiệm Do Giao Vật Không Đồng Bộ</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Trách Nhiệm Do Giao Vật Không Đồng Bộ refers to the responsibilities and rights of the buyer and seller when the delivered items are not complete or synchronized as required.</data>
  <data key="d3">chunk-4623833cd0cb1b86833b9050e09612fd</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850373</data>
  <data key="d6"></data>
</node>
