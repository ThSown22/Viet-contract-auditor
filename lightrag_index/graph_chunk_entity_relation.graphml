  <data key="d7">1.0</data>
  <data key="d8">Bên Mua may be responsible for costs associated with transferring ownership of the goods.</data>
  <data key="d9">contract enforcement,ownership transfer costs</data>
  <data key="d10">chunk-b7c9b850c56df03c6a0092f33eddd51c</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850316</data>
  <data key="d13"></data>
</edge>
<edge source="Bên Mua" target="Thông Tin Cần Thiết">
  <data key="d7">1.0</data>
  <data key="d8">Bên Mua has the right to receive necessary information about the goods.</data>
  <data key="d9">contract enforcement,information rights</data>
  <data key="d10">chunk-b7c9b850c56df03c6a0092f33eddd51c</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850316</data>
  <data key="d13"></data>
</edge>
<edge source="Bên Mua" target="Hướng Dẫn Cách Sử Dụng">
  <data key="d7">1.0</data>
  <data key="d8">Bên Mua has the right to receive instructions on how to use the goods.</data>
  <data key="d9">contract enforcement,usage instructions</data>
  <data key="d10">chunk-b7c9b850c56df03c6a0092f33eddd51c</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850316</data>
  <data key="d13"></data>
</edge>
<edge source="Bên Mua" target="Tài Sản Mua Bán">
  <data key="d7">1.0</data>
  <data key="d8">Bên Mua has the right to inspect the quality of the purchased item and request repairs, replacements, or refunds for any defects.</data>
  <data key="d9">purchase,quality inspection</data>
  <data key="d10">chunk-6fb0e6ef087a638bbb3f5e1626539a69</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850374</data>
  <data key="d13"></data>
</edge>
<edge source="Bên Mua" target="Thời Hạn Bảo Hành">
  <data key="d7">1.0</data>
  <data key="d8">Bên Mua has the right to request repairs, replacements, or refunds for defective items within the warranty period.</data>
  <data key="d9">repair rights,warranty period</data>
  <data key="d10">chunk-6fb0e6ef087a638bbb3f5e1626539a69</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850374</data>
  <data key="d13"></data>
</edge>
<edge source="Bên Mua" target="Bồi Thường Thiệt Hại">
  <data key="d7">1.0</data>
  <data key="d8">Bên Mua has the right to request compensation for damages caused by technical defects within the warranty period.</data>
  <data key="d9">damage compensation,warranty rights</data>
  <data key="d10">chunk-6fb0e6ef087a638bbb3f5e1626539a69</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850374</data>
  <data key="d13"></data>
</edge>
<edge source="Bên Mua" target="Phần Hợp Đồng Liên Quan">
  <data key="d7">1.0</data>
  <data key="d8">The buyer (Bên Mua) has the right to cancel the part of the contract related to a specific breach (Phần Hợp Đồng Liên Quan).</data>
  <data key="d9">breach of contract,contractual agreement</data>
  <data key="d10">chunk-4623833cd0cb1b86833b9050e09612fd</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850378</data>
  <data key="d13"></data>
</edge>
<edge source="Bên Mua" target="Phần Hoặc Bộ Phận Đã Nhận">
  <data key="d7">1.0</data>
  <data key="d8">The buyer (Bên Mua) has received the parts or components (Phần Hoặc Bộ Phận Đã Nhận) of the items.</data>
  <data key="d9">contractual agreement,delivery acceptance</data>
  <data key="d10">chunk-4623833cd0cb1b86833b9050e09612fd</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850378</data>
  <data key="d13"></data>
</edge>
<edge source="Bên Mua" target="Số Tiền Đã Trả">
  <data key="d7">1.0</data>
  <data key="d8">The amount of money (Số Tiền Đã Trả) that has already been paid by the buyer (Bên Mua).</data>
  <data key="d9">financial transaction,payment</data>
  <data key="d10">chunk-4623833cd0cb1b86833b9050e09612fd</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850378</data>
  <data key="d13"></data>
</edge>
<edge source="Bên Mua" target="Lãi Suất Thỏa Thuận">
  <data key="d7">1.0</data>
  <data key="d8">The interest rate (Lãi Suất Thỏa Thuận) agreed upon by the parties in the contract.</data>
  <data key="d9">financial agreement,interest rate</data>
  <data key="d10">chunk-4623833cd0cb1b86833b9050e09612fd</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850378</data>
  <data key="d13"></data>
</edge>
<edge source="Tài Sản Thuê" target="Chất Lượng">
  <data key="d7">1.0</data>
  <data key="d8">The quality and condition of the Tài Sản Thuê must meet the agreed-upon standards as specified in the lease agreement.</data>
  <data key="d9">condition,quality</data>
  <data key="d10">chunk-ce15824853c084575e7d85b3e8d79015</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850554</data>
