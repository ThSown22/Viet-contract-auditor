  <data key="d7">1.0</data>
  <data key="d8">The state organization law governs the establishment, operation, and dissolution of non-commercial entities.</data>
  <data key="d9">non-commercial entity,state organization law</data>
  <data key="d10">chunk-12ce4f076c1ad11637bf7e2f3ae95048</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849153</data>
  <data key="d13"></data>
</edge>
<edge source="Tranh chấp về quyền sử dụng đất" target="Luật đất đai">
  <data key="d7">1.0</data>
  <data key="d8">The land law regulates disputes over land use rights.</data>
  <data key="d9">legal regulation,property rights</data>
