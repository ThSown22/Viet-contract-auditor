  <data key="d7">1.0</data>
  <data key="d8">Bên Sử Dụng Dịch Vụ must provide information, documents, and means to the service provider as per the agreement.</data>
  <data key="d9">agreement,provision</data>
  <data key="d10">chunk-e729376fa2e1544912532baf7015b267</data>
