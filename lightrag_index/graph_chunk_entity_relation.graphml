  <data key="d0">Thẩm quyền của Hội đồng trọng tài áp dụng biện pháp khẩn cấp tạm thời</data>
  <data key="d1">HÀNH_VI</data>
  <data key="d2">This event describes the authority of the arbitration board to apply temporary emergency measures.</data>
