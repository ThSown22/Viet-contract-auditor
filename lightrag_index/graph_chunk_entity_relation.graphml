  <data key="d0">Cha, mẹ</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Cha, mẹ refers to parents who are legal representatives for minors.</data>
  <data key="d3">chunk-482a66c12f2040cbc0eabb425e1b6d97</data>
  <data key="d4">unknown_source</data>
