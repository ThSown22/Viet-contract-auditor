</node>
<node id="Cơ Quan Thi Hành Án Dân Sự">
  <data key="d0">Cơ Quan Thi Hành Án Dân Sự</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">Cơ Quan Thi Hành Án Dân Sự is the organization responsible for enforcing civil judgments.&lt;SEP&gt;Cơ Quan Thi Hành Án Dân Sự is the authority responsible for enforcing the arbitration decision.</data>
  <data key="d3">chunk-a36e099bae803eeaad0a5160e83464d5&lt;SEP&gt;chunk-6520e05120076623f2042182e932b3ec</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773854008</data>
  <data key="d6"></data>
</node>
<node id="Chánh Án Tòa Án">
  <data key="d0">Chánh Án Tòa Án</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">Chánh Án Tòa Án is the chief judge of the court who assigns a judge to examine and resolve requests for emergency measures.&lt;SEP&gt;Chánh Án Tòa Án is the head of the court responsible for assigning a judge to examine the registration of an arbitration decision.</data>
  <data key="d3">chunk-a36e099bae803eeaad0a5160e83464d5&lt;SEP&gt;chunk-6520e05120076623f2042182e932b3ec</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773854008</data>
  <data key="d6"></data>
</node>
