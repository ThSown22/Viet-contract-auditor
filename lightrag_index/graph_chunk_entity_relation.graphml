  <data key="d7">1.0</data>
  <data key="d8">The transfer of the right to claim includes any security measures for the fulfillment of the obligation.</data>
  <data key="d9">obligation transfer,security measures</data>
  <data key="d10">chunk-7676f54dc24423d8f0801960c11c6cf7</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850154</data>
  <data key="d13"></data>
</edge>
<edge source="Người thế nghĩa vụ" target="Điều 370">
  <data key="d7">1.0</data>
  <data key="d8">When an obligation is transferred, the person taking over the obligation becomes the new obligor, as per Article 370.</data>
  <data key="d9">new obligor,obligation transfer</data>
  <data key="d10">chunk-7676f54dc24423d8f0801960c11c6cf7</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850154</data>
  <data key="d13"></data>
</edge>
<edge source="Người thế nghĩa vụ" target="Điều 371">
  <data key="d7">1.0</data>
  <data key="d8">When an obligation with security measures is transferred, the security measures are terminated unless there is a different agreement, as per Article 371.</data>
  <data key="d9">obligation transfer,security measures</data>
  <data key="d10">chunk-7676f54dc24423d8f0801960c11c6cf7</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850154</data>
  <data key="d13"></data>
</edge>
<edge source="Người thế nghĩa vụ" target="Nghĩa vụ">
  <data key="d7">1.0</data>
  <data key="d8">When an obligation is transferred, the person taking over the obligation becomes the new obligor.</data>
  <data key="d9">new obligor,obligation transfer</data>
  <data key="d10">chunk-7676f54dc24423d8f0801960c11c6cf7</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850154</data>
