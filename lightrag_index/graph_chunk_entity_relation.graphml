</edge>
<edge source="Đại hội đồng cổ đông" target="Phiếu biểu quyết">
  <data key="d7">1.0</data>
  <data key="d8">Phiếu biểu quyết is used by shareholders to cast their votes at the meeting.</data>
  <data key="d9">meeting participation,voting</data>
