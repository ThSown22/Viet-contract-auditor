<edge source="Người chuyển giao quyền yêu cầu" target="Điều 366">
  <data key="d7">1.0</data>
  <data key="d8">The person transferring the right to claim must provide necessary information and transfer documents to the person taking over the right to claim as per Article 366.</data>
  <data key="d9">information transfer,obligation</data>
  <data key="d10">chunk-7676f54dc24423d8f0801960c11c6cf7</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850154</data>
  <data key="d13"></data>
</edge>
<edge source="Người chuyển giao quyền yêu cầu" target="Điều 367">
  <data key="d7">1.0</data>
  <data key="d8">The person transferring the right to claim is not responsible for the obligor's ability to fulfill the obligation after the transfer, except in cases of different agreements, as per Article 367.</data>
  <data key="d9">responsibility,transfer</data>
  <data key="d10">chunk-7676f54dc24423d8f0801960c11c6cf7</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850154</data>
  <data key="d13"></data>
</edge>
<edge source="Người chuyển giao quyền yêu cầu" target="Điều 368">
  <data key="d7">1.0</data>
  <data key="d8">The transfer of the right to claim includes any security measures for the fulfillment of the obligation, as per Article 368.</data>
  <data key="d9">security measures,transfer</data>
  <data key="d10">chunk-7676f54dc24423d8f0801960c11c6cf7</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850154</data>
  <data key="d13"></data>
</edge>
