<node id="Pháp Luật Việt Nam">
  <data key="d0">Pháp Luật Việt Nam</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Pháp Luật Việt Nam is the legal framework that governs various legal behaviors and actions within the country.</data>
  <data key="d3">chunk-e84a045f0415483bb286ca0fb434f2f9</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773851355</data>
  <data key="d6"></data>
</node>
<node id="Hành Vi Pháp Lý Đơn Phương">
  <data key="d0">Hành Vi Pháp Lý Đơn Phương</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Hành Vi Pháp Lý Đơn Phương refers to unilateral legal acts, which are governed by the law of the country where the individual establishing the act resides or where the legal entity is established.</data>
  <data key="d3">chunk-e84a045f0415483bb286ca0fb434f2f9</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773851355</data>
  <data key="d6"></data>
</node>
<node id="Nghĩa Vụ Hoàn Trả">
  <data key="d0">Nghĩa Vụ Hoàn Trả</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Nghĩa Vụ Hoàn Trả is the obligation to return assets or benefits obtained without legal basis, determined by the law of the country where the assets were held or where the benefits were derived.</data>
  <data key="d3">chunk-e84a045f0415483bb286ca0fb434f2f9</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773851355</data>
  <data key="d6"></data>
</node>
<node id="Thực Hiện Công Việc Không Có Ủy Quyền">
  <data key="d0">Thực Hiện Công Việc Không Có Ủy Quyền</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Thực Hiện Công Việc Không Có Ủy Quyền refers to performing tasks without authorization, where the applicable law is chosen by agreement or is the law of the country where the task is performed.</data>
  <data key="d3">chunk-e84a045f0415483bb286ca0fb434f2f9</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773851355</data>
  <data key="d6"></data>
</node>
<node id="Bồi Thường Thiệt Hại Ngoài Hợp Đồng">
  <data key="d0">Bồi Thường Thiệt Hại Ngoài Hợp Đồng</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Bồi Thường Thiệt Hại Ngoài Hợp Đồng is the compensation for damages outside of a contract, where the applicable law is chosen by agreement or is the law of the country where the damage occurred.</data>
  <data key="d3">chunk-e84a045f0415483bb286ca0fb434f2f9</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773851355</data>
  <data key="d6"></data>
</node>
<node id="Điều Khoản Chuyển Tiếp">
  <data key="d0">Điều Khoản Chuyển Tiếp</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Điều Khoản Chuyển Tiếp outlines the transitional provisions for civil transactions established before the new law takes effect.</data>
  <data key="d3">chunk-e84a045f0415483bb286ca0fb434f2f9</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773851355</data>
  <data key="d6"></data>
</node>
<node id="Bộ Luật Dân Sự Số 33/2005/QH11">
  <data key="d0">Bộ Luật Dân Sự Số 33/2005/QH11</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Bộ Luật Dân Sự Số 33/2005/QH11 is the previous civil code that continues to apply to certain civil transactions under the transitional provisions.</data>
  <data key="d3">chunk-e84a045f0415483bb286ca0fb434f2f9</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773851355</data>
  <data key="d6"></data>
</node>
<node id="Giao Dịch Dân Sự">
  <data key="d0">Giao Dịch Dân Sự</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Giao Dịch Dân Sự refers to civil transactions that are governed by the legal framework outlined in the transitional provisions.</data>
  <data key="d3">chunk-e84a045f0415483bb286ca0fb434f2f9</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773851355</data>
  <data key="d6"></data>
</node>
<node id="Người Có Quan Hệ Gia Đình">
