<edge source="Công ty cổ phần" target="Thời hạn 10 ngày">
  <data key="d7">1.0</data>
  <data key="d8">Công ty cổ phần must register changes to its capital within 10 days after converting bonds into shares.</data>
  <data key="d9">capital change,registration period</data>
  <data key="d10">chunk-9b892718f9850a0f9775f9a075fb4282</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773852753</data>
  <data key="d13"></data>
</edge>
<edge source="Công ty cổ phần" target="Thời hạn 30 ngày">
  <data key="d7">1.0</data>
  <data key="d8">Công ty cổ phần must communicate the decision to repurchase shares within 30 days to all shareholders.</data>
  <data key="d9">communication period,share repurchase</data>
  <data key="d10">chunk-9b892718f9850a0f9775f9a075fb4282</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773852753</data>
  <data key="d13"></data>
</edge>
<edge source="Công ty cổ phần" target="Thời hạn 90 ngày">
  <data key="d7">1.0</data>
  <data key="d8">Công ty cổ phần must repurchase shares within 90 days after receiving a shareholder's request.</data>
  <data key="d9">repurchase period,share repurchase</data>
  <data key="d10">chunk-9b892718f9850a0f9775f9a075fb4282</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773852753</data>
  <data key="d13"></data>
</edge>
<edge source="Công ty cổ phần" target="Cơ quan đăng ký kinh doanh">
  <data key="d7">2.0</data>
  <data key="d8">Công ty cổ phần must register and report to Cơ quan đăng ký kinh doanh regarding changes in ownership and other relevant information.&lt;SEP&gt;Công ty cổ phần must register its formation with the business registration agency, which updates the company's legal status in the National Database on Business Registration.</data>
  <data key="d9">legal registration,registration,reporting,status update</data>
  <data key="d10">chunk-b0cdd7174a5289f85d735aa45cd8829d&lt;SEP&gt;chunk-e4a657b345d0676b5a5d6451a2c7c13d</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773853385</data>
  <data key="d13"></data>
</edge>
<edge source="Công ty cổ phần" target="Báo cáo kiểm toán">
  <data key="d7">1.0</data>
  <data key="d8">Công ty cổ phần must submit the Báo cáo kiểm toán to the Đại hội đồng cổ đông.</data>
  <data key="d9">reporting,submission</data>
  <data key="d10">chunk-b0cdd7174a5289f85d735aa45cd8829d</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773852993</data>
  <data key="d13"></data>
</edge>
<edge source="Công ty cổ phần" target="Trụ sở chính của công ty">
  <data key="d7">1.0</data>
  <data key="d8">Công ty cổ phần must store certain reports at the Trụ sở chính of the company.</data>
  <data key="d9">location,report storage</data>
  <data key="d10">chunk-b0cdd7174a5289f85d735aa45cd8829d</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773852994</data>
  <data key="d13"></data>
</edge>
<edge source="Công ty cổ phần" target="Luật về kế toán">
  <data key="d7">1.0</data>
  <data key="d8">Công ty cổ phần must comply with the regulations outlined in the Luật về kế toán.</data>
  <data key="d9">compliance,regulation</data>
  <data key="d10">chunk-b0cdd7174a5289f85d735aa45cd8829d</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773852994</data>
  <data key="d13"></data>
</edge>
<edge source="Công ty cổ phần" target="Sơ yếu lý lịch">
  <data key="d7">1.0</data>
  <data key="d8">Công ty cổ phần must publish the Sơ yếu lý lịch of the members of the Hội đồng quản trị, Kiểm soát viên, Giám đốc, or Tổng giám đốc on its electronic information site.</data>
  <data key="d9">disclosure,publication</data>
  <data key="d10">chunk-b0cdd7174a5289f85d735aa45cd8829d</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773852994</data>
  <data key="d13"></data>
</edge>
<edge source="Công ty cổ phần" target="Báo cáo đánh giá kết quả hoạt động hằng năm">
  <data key="d7">1.0</data>
  <data key="d8">Công ty cổ phần must publish the Báo cáo đánh giá kết quả hoạt động hằng năm on its electronic information site.</data>
  <data key="d9">disclosure,publication</data>
  <data key="d10">chunk-b0cdd7174a5289f85d735aa45cd8829d</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773852994</data>
  <data key="d13"></data>
</edge>
<edge source="Công ty cổ phần" target="Doanh nghiệp tư nhân">
  <data key="d7">1.0</data>
  <data key="d8">Doanh nghiệp tư nhân can be converted into a Công ty cổ phần.</data>
  <data key="d9">business type,conversion</data>
  <data key="d10">chunk-8da64b48c80fc4788c324e08350a340e</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773853285</data>
  <data key="d13"></data>
</edge>
<edge source="Công ty cổ phần" target="Công ty trách nhiệm hữu hạn một thành viên">
  <data key="d7">1.0</data>
  <data key="d8">A joint-stock company can be converted into a single-member limited liability company.</data>
  <data key="d9">conversion,legal transformation</data>
  <data key="d10">chunk-0359f960f337b0c62d24c54f784fc5c1</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773853411</data>
  <data key="d13"></data>
</edge>
<edge source="Công ty cổ phần" target="Tổ chức">
  <data key="d7">1.0</data>
  <data key="d8">An organization can receive the transfer of all shares from a joint-stock company.</data>
  <data key="d9">non-shareholder acquisition,share transfer</data>
  <data key="d10">chunk-0359f960f337b0c62d24c54f784fc5c1</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773853412</data>
