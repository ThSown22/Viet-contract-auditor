  <data key="d7">1.0</data>
  <data key="d8">Article 143 outlines the consequences of civil transactions conducted by representatives who exceed their authorized scope.</data>
  <data key="d9">exceeding scope,legal provision</data>
  <data key="d10">chunk-5cb7db3cfef705b914008825e4c276e6</data>
