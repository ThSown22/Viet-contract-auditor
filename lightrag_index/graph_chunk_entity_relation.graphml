</node>
<node id="Cơ sở khám bệnh, chữa bệnh">
  <data key="d0">Cơ sở khám bệnh, chữa bệnh</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">Cơ sở khám bệnh, chữa bệnh refers to healthcare facilities, which have responsibilities in treating patients and conducting medical procedures.</data>
  <data key="d3">chunk-985db81e6c3d846511cb280c2983fbf0</data>
