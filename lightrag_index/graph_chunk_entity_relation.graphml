  <data key="d0">Tiêu Chuẩn Riêng</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Tiêu Chuẩn Riêng refers to specific quality criteria that are suitable for the purpose of the contract and aligned with the Law on Consumer Protection.</data>
  <data key="d3">chunk-4623833cd0cb1b86833b9050e09612fd</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850373</data>
  <data key="d6"></data>
