</edge>
<edge source="Người quản lý tài sản" target="Điều 53">
  <data key="d7">1.0</data>
  <data key="d8">Điều 53 outlines the role of the asset manager for a member declared missing by the court.</data>
  <data key="d9">asset management,legal provision</data>
