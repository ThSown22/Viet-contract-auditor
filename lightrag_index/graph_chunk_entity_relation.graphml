</edge>
<edge source="Giao dịch dân sự" target="Người đại diện">
  <data key="d7">1.0</data>
  <data key="d8">The representative is authorized to conduct civil transactions on behalf of another party.</data>
  <data key="d9">legal representation,transaction authority</data>
  <data key="d10">chunk-5cb7db3cfef705b914008825e4c276e6</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849276</data>
  <data key="d13"></data>
</edge>
<edge source="Giao dịch dân sự" target="Điều 133">
  <data key="d7">1.0</data>
  <data key="d8">Điều 133 provides legal provisions regarding the validity of civil transactions and the protection of rights for a bona fide third party.</data>
  <data key="d9">legal provision,transaction validity</data>
  <data key="d10">chunk-482a66c12f2040cbc0eabb425e1b6d97</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849362</data>
  <data key="d13"></data>
</edge>
<edge source="Bất động sản" target="Điều 310">
  <data key="d7">1.0</data>
  <data key="d8">The pledge of immovable property has specific legal requirements for effectiveness against third parties.</data>
  <data key="d9">immovable property,legal requirement</data>
  <data key="d10">chunk-ae8ba811869db57b94f6d4864d7901d2</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850097</data>
  <data key="d13"></data>
</edge>
<edge source="Người đại diện" target="Giao dịch dân sự vô hiệu">
  <data key="d7">1.0</data>
  <data key="d8">Legal representatives can request the court to declare civil transactions invalid.</data>
  <data key="d9">invalidation,legal representation</data>
  <data key="d10">chunk-6fef2e18615af027f8385abdb8209870</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849117</data>
  <data key="d13"></data>
</edge>
<edge source="Người đại diện" target="Phạm vi đại diện">
  <data key="d7">1.0</data>
  <data key="d8">The representative is authorized to conduct civil transactions within the scope of representation.</data>
  <data key="d9">legal authority,representation scope</data>
  <data key="d10">chunk-5cb7db3cfef705b914008825e4c276e6</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849276</data>
  <data key="d13"></data>
</edge>
<edge source="Người đại diện" target="Người không có quyền đại diện">
  <data key="d7">1.0</data>
  <data key="d8">An unauthorized representative is an individual or entity that conducts civil transactions without proper authorization.</data>
  <data key="d9">legal consequence,unauthorized representation</data>
  <data key="d10">chunk-5cb7db3cfef705b914008825e4c276e6</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849276</data>
  <data key="d13"></data>
</edge>
<edge source="Người đại diện" target="Người đã giao dịch">
  <data key="d7">1.0</data>
  <data key="d8">The representative is authorized to conduct civil transactions with another party.</data>
  <data key="d9">legal representation,transaction authority</data>
  <data key="d10">chunk-5cb7db3cfef705b914008825e4c276e6</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849276</data>
  <data key="d13"></data>
</edge>
<edge source="Người đại diện" target="Điều 144">
  <data key="d7">1.0</data>
  <data key="d8">Điều 144 states that if a representative and a person engaging in a transaction intentionally establish or execute a civil transaction beyond the scope of representation, causing damage to the represented party, they must jointly bear the responsibility for compensation.</data>
  <data key="d9">legal responsibility,transaction</data>
  <data key="d10">chunk-7fce420202370c7c711321549129cd6e</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849299</data>
  <data key="d13"></data>
</edge>
<edge source="Người đại diện" target="Người giao dịch">
  <data key="d7">1.0</data>
  <data key="d8">Người đại diện and Người giao dịch are involved in a transaction where they may bear joint responsibility if they exceed the scope of representation and cause damage to the represented party.</data>
  <data key="d9">legal responsibility,transaction</data>
  <data key="d10">chunk-7fce420202370c7c711321549129cd6e</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849299</data>
  <data key="d13"></data>
</edge>
<edge source="Người đại diện" target="Người được đại diện">
  <data key="d7">1.0</data>
  <data key="d8">Người đại diện acts on behalf of Người được đại diện and may be held responsible for any damage caused by exceeding the scope of representation.</data>
  <data key="d9">legal responsibility,representation</data>
  <data key="d10">chunk-7fce420202370c7c711321549129cd6e</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849299</data>
  <data key="d13"></data>
</edge>
<edge source="Người đại diện" target="Điều 134">
  <data key="d7">1.0</data>
  <data key="d8">Điều 134 defines the role of a representative who acts on behalf of another for civil transactions.</data>
  <data key="d9">legal action,representation</data>
  <data key="d10">chunk-482a66c12f2040cbc0eabb425e1b6d97</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849361</data>
  <data key="d13"></data>
</edge>
<edge source="Người đại diện" target="Điều 135">
  <data key="d7">1.0</data>
  <data key="d8">Điều 135 establishes the basis for the right of representation, including authorization and legal designation.</data>
  <data key="d9">legal basis,representation rights</data>
  <data key="d10">chunk-482a66c12f2040cbc0eabb425e1b6d97</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849361</data>
  <data key="d13"></data>
</edge>
<edge source="Người đại diện" target="Người thực hiện công việc không có ủy quyền">
  <data key="d7">1.0</data>
  <data key="d8">If the person for whom the work is performed dies, the person performing the work without authorization must continue the work until the representative takes over.</data>
  <data key="d9">representation,work continuation</data>
  <data key="d10">chunk-50c919d97de369bc8d7562186f764b91</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850908</data>
  <data key="d13"></data>
</edge>
<edge source="Người đại diện" target="Điều 53">
  <data key="d7">1.0</data>
  <data key="d8">Điều 53 specifies the role of the representative for a member who is restricted or incapacitated.</data>
  <data key="d9">legal provision,representation rights</data>
  <data key="d10">chunk-7934cedd8a058c40a35091be7e3f1c17</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851694</data>
