  <data key="d0">Hình Thức Di Chúc</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Hình thức di chúc refers to the form of a di chúc, which is determined by the law of the country where the di chúc is made.</data>
  <data key="d3">chunk-b0cda21c37a8b4d265d1fff1cf5f7aea</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773851572</data>
