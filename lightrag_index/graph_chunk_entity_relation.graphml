</edge>
<edge source="Giao dịch dân sự" target="Người từ đủ mười lăm tuổi đến chưa đủ mười tám tuổi">
  <data key="d7">1.0</data>
  <data key="d8">Individuals between the ages of 15 and 18 can independently engage in civil transactions, except for certain types of transactions.</data>
  <data key="d9">civil transactions,legal capacity</data>
  <data key="d10">chunk-b10203f42f3e19a8ee82cd4453e46d58</data>
  <data key="d11">unknown_source</data>
