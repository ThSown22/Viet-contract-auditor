  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Thu nhập và lợi ích khác refers to additional income and benefits that a Kiểm soát viên may receive, which must be returned to the company if obtained through a violation.</data>
  <data key="d3">chunk-b0cdd7174a5289f85d735aa45cd8829d</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773852988</data>
