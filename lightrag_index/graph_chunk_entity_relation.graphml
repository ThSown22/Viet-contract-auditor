</edge>
<edge source="Người bị tuyên bố là đã chết" target="Quan hệ nhân thân">
  <data key="d7">1.0</data>
  <data key="d8">The personal relations of a person declared dead are restored when the court revokes the declaration.</data>
  <data key="d9">personal relations,restoration</data>
  <data key="d10">chunk-12ce4f076c1ad11637bf7e2f3ae95048</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849153</data>
  <data key="d13"></data>
</edge>
<edge source="Người bị tuyên bố là đã chết" target="Vợ hoặc chồng">
  <data key="d7">1.0</data>
  <data key="d8">The spouse of a person declared dead may have been granted a divorce or remarried, which remains legally valid.</data>
  <data key="d9">divorce,marriage</data>
  <data key="d10">chunk-12ce4f076c1ad11637bf7e2f3ae95048</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849153</data>
  <data key="d13"></data>
</edge>
<edge source="Người bị tuyên bố là đã chết" target="Người thừa kế">
  <data key="d7">1.0</data>
  <data key="d8">Heirs of a person declared dead must return the inherited property if the person is found to be alive.</data>
  <data key="d9">inheritance,restitution</data>
  <data key="d10">chunk-12ce4f076c1ad11637bf7e2f3ae95048</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849153</data>
  <data key="d13"></data>
</edge>
<edge source="Quan hệ nhân thân" target="Luật hôn nhân và gia đình">
  <data key="d7">1.0</data>
  <data key="d8">The marriage and family law governs the personal relations of individuals, including those declared dead.</data>
  <data key="d9">marriage law,personal relations</data>
  <data key="d10">chunk-12ce4f076c1ad11637bf7e2f3ae95048</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849153</data>
  <data key="d13"></data>
</edge>
<edge source="Người thừa kế" target="Người thực hiện công việc không có ủy quyền">
  <data key="d7">1.0</data>
  <data key="d8">If the person for whom the work is performed dies, the person performing the work without authorization must continue the work until the heir takes over.</data>
  <data key="d9">inheritance,work continuation</data>
  <data key="d10">chunk-50c919d97de369bc8d7562186f764b91</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850908</data>
  <data key="d13"></data>
</edge>
<edge source="Người thừa kế" target="Thời hiệu thừa kế">
  <data key="d7">1.0</data>
  <data key="d8">Thời hiệu thừa kế is the time limit within which Người thừa kế can claim inheritance.</data>
  <data key="d9">inheritance claim,time limit</data>
  <data key="d10">chunk-47d8802df9ec7324759d67fe67eaf612</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850994</data>
  <data key="d13"></data>
</edge>
<edge source="Người thừa kế" target="Di chúc">
  <data key="d7">2.0</data>
  <data key="d8">Người thừa kế is designated in Di chúc to inherit assets from the deceased.&lt;SEP&gt;Người thừa kế is a beneficiary named in a will, with legal rights to the assets specified.</data>
  <data key="d9">asset transfer,beneficiary,inheritance,legal rights</data>
  <data key="d10">chunk-47d8802df9ec7324759d67fe67eaf612&lt;SEP&gt;chunk-c6c45985a08d6e2c0940eda170510a01</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851043</data>
  <data key="d13"></data>
</edge>
<edge source="Người thừa kế" target="Nghĩa vụ tài sản">
  <data key="d7">1.0</data>
  <data key="d8">Người thừa kế is responsible for fulfilling the financial obligations left by the deceased.</data>
  <data key="d9">financial obligation,inheritance responsibility</data>
  <data key="d10">chunk-2dbdbb74ad11a83bf1856f95ecdfa309</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851096</data>
  <data key="d13"></data>
</edge>
<edge source="Người thừa kế" target="Thời điểm mở thừa kế">
  <data key="d7">1.0</data>
  <data key="d8">Người thừa kế must be alive or born and alive after the time of inheritance but conceived before the death of the deceased.</data>
  <data key="d9">inheritance eligibility,time of inheritance</data>
  <data key="d10">chunk-2dbdbb74ad11a83bf1856f95ecdfa309</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851096</data>
  <data key="d13"></data>
</edge>
<edge source="Người thừa kế" target="Di sản">
  <data key="d7">2.0</data>
  <data key="d8">Người thừa kế inherits the estate of the deceased.&lt;SEP&gt;The heirs have the right to inherit the estate or refuse it.</data>
  <data key="d9">estate management,inheritance,refusal</data>
  <data key="d10">chunk-2dbdbb74ad11a83bf1856f95ecdfa309&lt;SEP&gt;chunk-fd15f05b480bf5c4a3b4b4e068a412cd</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851130</data>
  <data key="d13"></data>
</edge>
<edge source="Người thừa kế" target="Người quản lý di sản">
  <data key="d7">1.0</data>
  <data key="d8">The person managing the estate can represent the heirs and is entitled to compensation.</data>
  <data key="d9">compensation,representation</data>
  <data key="d10">chunk-fd15f05b480bf5c4a3b4b4e068a412cd</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851130</data>
  <data key="d13"></data>
</edge>
<edge source="Người thừa kế" target="Từ chối nhận di sản">
  <data key="d7">1.0</data>
  <data key="d8">The heirs have the right to refuse the inheritance under certain conditions.</data>
  <data key="d9">inheritance,refusal</data>
  <data key="d10">chunk-fd15f05b480bf5c4a3b4b4e068a412cd</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851130</data>
  <data key="d13"></data>
</edge>
<edge source="Người thừa kế" target="Điều 53">
  <data key="d7">1.0</data>
  <data key="d8">Điều 53 specifies the rights of heirs to become members of a company.</data>
  <data key="d9">inheritance rights,legal provision</data>
  <data key="d10">chunk-7934cedd8a058c40a35091be7e3f1c17</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851694</data>
