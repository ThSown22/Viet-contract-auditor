  <data key="d0">Vận Đơn</data>
  <data key="d1">VĂN_BẢN_PHÁP_LUẬT</data>
  <data key="d2">Vận Đơn is a transport document or equivalent that is used to verify the authenticity of the assets being transported.</data>
  <data key="d3">chunk-9ff345e6f27025707a8c3c4dd1e82b5a</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850607</data>
  <data key="d6"></data>
</node>
<node id="Chi Phí">
  <data key="d0">Chi Phí</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Chi Phí refers to the costs associated with the transportation of assets, including transportation fees and insurance.</data>
  <data key="d3">chunk-9ff345e6f27025707a8c3c4dd1e82b5a</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850607</data>
  <data key="d6"></data>
</node>
<node id="Bên Đặt Gia Công">
  <data key="d0">Bên Đặt Gia Công</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">Bên Đặt Gia Công is the party that commissions the processing work and is responsible for providing specifications and paying for the work.</data>
  <data key="d3">chunk-b1c19a83d55829491343a14f74bec683</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850651</data>
  <data key="d6"></data>
</node>
<node id="Bên Nhận Gia Công">
  <data key="d0">Bên Nhận Gia Công</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">Bên Nhận Gia Công is the party that performs the processing work according to the specifications provided by the other party.</data>
  <data key="d3">chunk-b1c19a83d55829491343a14f74bec683</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850651</data>
  <data key="d6"></data>
</node>
<node id="Sản Phẩm Gia Công">
  <data key="d0">Sản Phẩm Gia Công</data>
  <data key="d1">VĂN_BẢN_PHÁP_LUẬT</data>
  <data key="d2">Sản Phẩm Gia Công refers to the finished product resulting from the processing work.</data>
  <data key="d3">chunk-b1c19a83d55829491343a14f74bec683</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850651</data>
  <data key="d6"></data>
</node>
<node id="Hợp Đồng Gia Công">
  <data key="d0">Hợp Đồng Gia Công</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Hợp Đồng Gia Công is the contract that outlines the terms and conditions of the processing work between the two parties.</data>
  <data key="d3">chunk-b1c19a83d55829491343a14f74bec683</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850651</data>
  <data key="d6"></data>
</node>
<node id="Hợp Đồng Gửi Giữ Tài Sản">
  <data key="d0">Hợp Đồng Gửi Giữ Tài Sản</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Hợp Đồng Gửi Giữ Tài Sản is a contract where one party entrusts assets to another for safekeeping and return.</data>
  <data key="d3">chunk-b1c19a83d55829491343a14f74bec683</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850651</data>
  <data key="d6"></data>
</node>
<node id="Trách Nhiệm Chấp Rủi Ro">
  <data key="d0">Trách Nhiệm Chấp Rủi Ro</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Trách Nhiệm Chấp Rủi Ro refers to the responsibility for bearing risks associated with the raw materials or finished products.</data>
  <data key="d3">chunk-b1c19a83d55829491343a14f74bec683</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850651</data>
  <data key="d6"></data>
</node>
<node id="Chậm Giao, Chậm Nhận Sản Phẩm Gia Công">
  <data key="d0">Chậm Giao, Chậm Nhận Sản Phẩm Gia Công</data>
  <data key="d1">HÀNH_VI</data>
  <data key="d2">Chậm Giao, Chậm Nhận Sản Phẩm Gia Công refers to the events where either party delays the delivery or acceptance of the finished product.</data>
  <data key="d3">chunk-b1c19a83d55829491343a14f74bec683</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850651</data>
  <data key="d6"></data>
</node>
<node id="Đơn Phương Chấm Dứt Thực Hiện Hợp Đồng Gia Công">
  <data key="d0">Đơn Phương Chấm Dứt Thực Hiện Hợp Đồng Gia Công</data>
  <data key="d1">HÀNH_VI</data>
  <data key="d2">Đơn Phương Chấm Dứt Thực Hiện Hợp Đồng Gia Công refers to the unilateral termination of the processing contract by either party.</data>
  <data key="d3">chunk-b1c19a83d55829491343a14f74bec683</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850651</data>
  <data key="d6"></data>
</node>
<node id="Trả Tiền Công">
  <data key="d0">Trả Tiền Công</data>
  <data key="d1">HÀNH_VI</data>
  <data key="d2">Trả Tiền Công refers to the payment of the processing fee by the commissioning party to the processing party.</data>
  <data key="d3">chunk-b1c19a83d55829491343a14f74bec683</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850651</data>
  <data key="d6"></data>
</node>
<node id="Thanh Lý Nguyên Vật Liệu">
  <data key="d0">Thanh Lý Nguyên Vật Liệu</data>
  <data key="d1">HÀNH_VI</data>
  <data key="d2">Thanh Lý Nguyên Vật Liệu refers to the settlement and return of remaining raw materials when the processing contract ends.</data>
  <data key="d3">chunk-b1c19a83d55829491343a14f74bec683</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850651</data>
  <data key="d6"></data>
</node>
<node id="Điều 548">
  <data key="d0">Điều 548</data>
  <data key="d1">HÀNH_VI</data>
  <data key="d2">Điều 548 is a legal provision that outlines the responsibility for bearing risks associated with raw materials or finished products until they are delivered.</data>
  <data key="d3">chunk-b1c19a83d55829491343a14f74bec683</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850651</data>
  <data key="d6"></data>
</node>
<node id="Điều 549">
  <data key="d0">Điều 549</data>
  <data key="d1">HÀNH_VI</data>
  <data key="d2">Điều  549 is a legal provision that specifies the terms for the delivery and acceptance of the finished product.</data>
  <data key="d3">chunk-b1c19a83d55829491343a14f74bec683</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850651</data>
  <data key="d6"></data>
</node>
<node id="Điều 550">
  <data key="d0">Điều 550</data>
  <data key="d1">HÀNH_VI</data>
  <data key="d2">Điều 550 is a legal provision that addresses the consequences of delays in the delivery or acceptance of the finished product.</data>
  <data key="d3">chunk-b1c19a83d55829491343a14f74bec683</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850651</data>
  <data key="d6"></data>
</node>
<node id="Điều 551">
  <data key="d0">Điều 551</data>
  <data key="d1">HÀNH_VI</data>
  <data key="d2">Điều 551 is a legal provision that outlines the conditions under which either party can unilaterally terminate the processing contract.</data>
  <data key="d3">chunk-b1c19a83d55829491343a14f74bec683</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850651</data>
  <data key="d6"></data>
</node>
<node id="Điều 552">
  <data key="d0">Điều 552</data>
  <data key="d1">HÀNH_VI</data>
  <data key="d2">Điều 552 is a legal provision that specifies the terms for the payment of the processing fee.</data>
  <data key="d3">chunk-b1c19a83d55829491343a14f74bec683</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850651</data>
  <data key="d6"></data>
</node>
<node id="Điều 553">
  <data key="d0">Điều 553</data>
  <data key="d1">HÀNH_VI</data>
  <data key="d2">Điều 553 is a legal provision that outlines the settlement and return of remaining raw materials when the contract ends.</data>
  <data key="d3">chunk-b1c19a83d55829491343a14f74bec683</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850652</data>
  <data key="d6"></data>
</node>
<node id="Điều 554">
  <data key="d0">Điều 554</data>
  <data key="d1">HÀNH_VI</data>
  <data key="d2">Điều 554 is a legal provision that defines the terms of a contract for the safekeeping of assets.</data>
  <data key="d3">chunk-b1c19a83d55829491343a14f74bec683</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850652</data>
  <data key="d6"></data>
</node>
