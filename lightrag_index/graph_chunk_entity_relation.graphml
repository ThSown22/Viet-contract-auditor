<node id="Hợp Đồng Theo Mẫu">
  <data key="d0">Hợp Đồng Theo Mẫu</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Hợp đồng theo mẫu is a contract with terms proposed by one party for the other party to respond within a reasonable time; if accepted, it is considered the full acceptance of the contract terms.</data>
  <data key="d3">chunk-57605bee043e497a16d0db0a26012d1e</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850297</data>
  <data key="d6"></data>
</node>
<node id="Điều Kiện Giao Dịch Chung">
  <data key="d0">Điều Kiện Giao Dịch Chung</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Điều kiện giao dịch chung refers to stable terms published by one party to be generally applied to the party being proposed to enter into a contract; if accepted, these terms are considered accepted.</data>
  <data key="d3">chunk-57605bee043e497a16d0db0a26012d1e</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850297</data>
  <data key="d6"></data>
</node>
<node id="Hợp Đồng Vô Hiệu">
  <data key="d0">Hợp Đồng Vô Hiệu</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Hợp đồng vô hiệu refers to contracts that are invalid due to various reasons, such as the inability to perform the contract's subject matter.</data>
  <data key="d3">chunk-57605bee043e497a16d0db0a26012d1e</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850297</data>
  <data key="d6"></data>
</node>
