  <data key="d7">1.0</data>
  <data key="d8">Responsibility for compensating damages caused by the violation of obligations is related to the damages caused by the violation of obligations.</data>
  <data key="d9">compensation,damages</data>
  <data key="d10">chunk-428a1a2119667172b8e431b501835f64</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850228</data>
