  <data key="d1">VĂN_BẢN_PHÁP_LUẬT</data>
  <data key="d2">Cổ Phiếu is a certificate that confirms ownership of shares in the company.</data>
  <data key="d3">chunk-af079df7102c58f84652bfeb21c7a17a</data>
