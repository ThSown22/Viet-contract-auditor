<node id="Tòa án có thẩm quyền">
  <data key="d0">Tòa án có thẩm quyền</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">Tòa án có thẩm quyền is the competent court that can appoint an arbitrator if the parties cannot agree.</data>
  <data key="d3">chunk-d4b1824dac8b182589cb4f697dad3e4f</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773853974</data>
