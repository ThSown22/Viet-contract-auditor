</node>
<node id="Chủ Sở Hữu Súc Vật">
  <data key="d0">Chủ Sở Hữu Súc Vật</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">Chủ Sở Hữu Súc Vật is the owner of livestock or domestic animals who is responsible for compensating for any damage caused.</data>
  <data key="d3">chunk-71c1c580c8f92c3838ab0f997647d588</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773851024</data>
