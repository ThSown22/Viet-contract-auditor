  <data key="d0">Điều 123</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Điều 123 is a legal provision that is referenced in the context of civil transactions.&lt;SEP&gt;Điều 123 is a legal provision that outlines the rules for selling shares in a company.</data>
  <data key="d3">chunk-482a66c12f2040cbc0eabb425e1b6d97&lt;SEP&gt;chunk-e71cfa12d80240b04312d94d8b626b87</data>
