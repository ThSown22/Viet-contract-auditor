</edge>
<edge source="Tài Sản Bảo Đảm" target="Bên Bảo Đảm">
  <data key="d7">2.0</data>
  <data key="d8">Bên Bảo Đảm provides collateral and is responsible for fulfilling obligations.&lt;SEP&gt;Bên Bảo Đảm provides collateral as part of their legal obligation.</data>
  <data key="d9">collateral provision,legal obligation,obligation fulfillment</data>
  <data key="d10">chunk-c152b6a16d5764e941499e3920fc0f1d&lt;SEP&gt;chunk-3cdb3cd8d8583064c0301937b6f4744a</data>
