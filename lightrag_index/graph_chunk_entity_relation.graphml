<edge source="Kiểm soát viên" target="Cuộc họp Hội đồng quản trị">
  <data key="d7">1.0</data>
  <data key="d8">The Supervisor has the right to attend the Board of Directors meeting and discuss but not vote.</data>
  <data key="d9">attendance,discussion</data>
  <data key="d10">chunk-2ec32bc0d8c57985cdac3f5a1383a2dc</data>
