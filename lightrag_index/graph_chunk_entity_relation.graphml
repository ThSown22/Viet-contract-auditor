<edge source="Tài Sản" target="Nhà Nước">
  <data key="d7">1.0</data>
  <data key="d8">Nhà Nước ensures that the assets and investments of enterprises and their owners are protected by the law and cannot be nationalized or confiscated without proper compensation.</data>
  <data key="d9">legal protection,nationalization</data>
  <data key="d10">chunk-870356636a26bb390c46554c34ceb657</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851504</data>
  <data key="d13"></data>
</edge>
<edge source="Tài Sản" target="Doanh Nghiệp">
  <data key="d7">1.0</data>
  <data key="d8">Doanh Nghiệp has the right to own and manage its assets and investments, and can use them freely within the legal framework.</data>
  <data key="d9">management,ownership</data>
  <data key="d10">chunk-870356636a26bb390c46554c34ceb657</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851504</data>
  <data key="d13"></data>
</edge>
<edge source="Tài Sản" target="Nghị quyết, quyết định">
  <data key="d7">1.0</data>
  <data key="d8">Decisions regarding the sale or restructuring of assets are made by the governing body.</data>
