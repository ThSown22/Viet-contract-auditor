<edge source="Lỗi Trong Trách Nhiệm Dân Sự" target="Article 364">
  <data key="d7">1.0</data>
  <data key="d8">Article 364 of the Civil Code defines fault in civil liability, including intentional and unintentional fault.</data>
  <data key="d9">fault,legal provision</data>
  <data key="d10">chunk-428a1a2119667172b8e431b501835f64</data>
  <data key="d11">unknown_source</data>
