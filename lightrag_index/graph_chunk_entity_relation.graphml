<node id="Năng Lực Lập Di Chúc">
  <data key="d0">Năng Lực Lập Di Chúc</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Năng lực lập di chúc refers to the legal capacity to create, modify, or revoke a di chúc, which is determined by the law of the country where the testator had citizenship at the time of the action.</data>
  <data key="d3">chunk-b0cda21c37a8b4d265d1fff1cf5f7aea</data>
