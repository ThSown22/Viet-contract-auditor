  <data key="d7">1.0</data>
  <data key="d8">Người đại diện theo ủy quyền must comply with the specific law that outlines their responsibilities and conditions.</data>
  <data key="d9">legal compliance,responsibility</data>
  <data key="d10">chunk-2619cf455665fecc350d8c72d83e850d</data>
