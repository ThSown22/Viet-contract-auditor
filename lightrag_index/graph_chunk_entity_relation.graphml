<edge source="Bất Động Sản" target="Thừa Kế">
  <data key="d7">1.0</data>
  <data key="d8">The applicable law for inheritance involving real estate is determined by the law of the country where the real estate is located.</data>
  <data key="d9">inheritance law,real estate</data>
  <data key="d10">chunk-b0cda21c37a8b4d265d1fff1cf5f7aea</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851577</data>
  <data key="d13"></data>
</edge>
<edge source="Thỏa Thuận Khác" target="Bên Soạn Thảo">
  <data key="d7">1.0</data>
  <data key="d8">An alternative agreement may override the invalid terms in a contract drafted by the drafting party.</data>
  <data key="d9">alternative agreement,contract drafting</data>
  <data key="d10">chunk-57605bee043e497a16d0db0a26012d1e</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850298</data>
  <data key="d13"></data>
</edge>
<edge source="Lãi Suất" target="Bên Mua">
  <data key="d7">1.0</data>
  <data key="d8">Bên Mua may be entitled to interest on late payments according to the agreed-upon interest rate.</data>
  <data key="d9">contract enforcement,interest calculation</data>
  <data key="d10">chunk-b7c9b850c56df03c6a0092f33eddd51c</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850316</data>
  <data key="d13"></data>
</edge>
<edge source="Lãi Suất" target="Bên Bán">
  <data key="d7">1.0</data>
  <data key="d8">Bên Bán may be required to pay interest on late payments according to the agreed-upon interest rate.</data>
  <data key="d9">contract enforcement,interest calculation</data>
  <data key="d10">chunk-b7c9b850c56df03c6a0092f33eddd51c</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850316</data>
  <data key="d13"></data>
</edge>
<edge source="Lãi Suất" target="Hợp Đồng Vay Tài Sản">
  <data key="d7">1.0</data>
  <data key="d8">In a Hợp Đồng Vay Tài Sản, the interest rate agreed upon is subject to a maximum limit of 20% per year unless otherwise specified by law.</data>
  <data key="d9">agreement terms,interest rate</data>
  <data key="d10">chunk-e641f370052e6c1c0a156d3d338c15a4</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850866</data>
  <data key="d13"></data>
</edge>
<edge source="Lãi Suất" target="Đиều 468">
  <data key="d7">1.0</data>
  <data key="d8">Đиều 468 defines the interest rate in a lending contract.</data>
  <data key="d9">interest rate,legal provision</data>
  <data key="d10">chunk-e641f370052e6c1c0a156d3d338c15a4</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850866</data>
  <data key="d13"></data>
</edge>
<edge source="Quyền Bề Mặt" target="Chủ Thể Quyền Bề Mặt">
  <data key="d7">2.0</data>
  <data key="d8">Chủ Thể Quyền Bề Mặt has the right to use the surface of the land, water, and airspace above the land and water that belongs to another entity.&lt;SEP&gt;Chủ Thể Quyền Bề Mặt holds the rights associated with the surface of land, water, and airspace.</data>
  <data key="d9">legal rights,ownership,right,use</data>
  <data key="d10">chunk-c10afe4eee3cae5b91c443db8d0e7f12&lt;SEP&gt;chunk-4e4f3de95acd7468b8d781714a57816a</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850056</data>
  <data key="d13"></data>
</edge>
<edge source="Quyền Bề Mặt" target="Di Chúc">
  <data key="d7">1.0</data>
  <data key="d8">Quyền Bề Mặt can be established based on a legal document such as a Di Chúc.</data>
  <data key="d9">establishment,legal document</data>
  <data key="d10">chunk-c10afe4eee3cae5b91c443db8d0e7f12</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849925</data>
  <data key="d13"></data>
</edge>
<edge source="Chủ Thể Quyền Bề Mặt" target="Chủ Thể Quyền Sử Dụng Đất">
  <data key="d7">1.0</data>
  <data key="d8">Chủ Thể Quyền Sử Dụng Đất can transfer the right to use the surface of the land, water, and airspace above the land and water to another entity.</data>
  <data key="d9">transfer,use</data>
  <data key="d10">chunk-c10afe4eee3cae5b91c443db8d0e7f12</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849925</data>
  <data key="d13"></data>
</edge>
<edge source="Chủ Thể Quyền Bề Mặt" target="Chủ Thể Có Quyền Sử Dụng Đất">
  <data key="d7">1.0</data>
  <data key="d8">When the rights of the surface are transferred, the recipient inherits the rights according to the conditions and extent of the transferred rights.</data>
  <data key="d9">land use rights,transfer</data>
  <data key="d10">chunk-4e4f3de95acd7468b8d781714a57816a</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850056</data>
  <data key="d13"></data>
</edge>
<edge source="Hoa Lợi, Lợi Tức" target="Người Chiếm Hữu">
  <data key="d7">1.0</data>
  <data key="d8">A person who possesses another's property without legal basis must return any income or profits derived from it.</data>
  <data key="d9">income return,legal obligation</data>
  <data key="d10">chunk-821c3a34361b8add641406062fd4a10e</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851194</data>
  <data key="d13"></data>
</edge>
<edge source="Hoa Lợi, Lợi Tức" target="Người Sử Dụng Tài Sản">
  <data key="d7">1.0</data>
  <data key="d8">A person who uses another's property without legal basis must return any income or profits derived from it.</data>
  <data key="d9">income return,legal obligation</data>
  <data key="d10">chunk-821c3a34361b8add641406062fd4a10e</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851194</data>
  <data key="d13"></data>
</edge>
<edge source="Quyền Sử Dụng Đất" target="Chủ Thể Quyền Sử Dụng Đất">
  <data key="d7">1.0</data>
  <data key="d8">Chủ Thể Quyền Sử Dụng Đất has the right to use land.</data>
  <data key="d9">right,use</data>
  <data key="d10">chunk-c10afe4eee3cae5b91c443db8d0e7f12</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849924</data>
  <data key="d13"></data>
</edge>
<edge source="Quyền Sử Dụng Đất" target="Hợp Đồng Về Quyền Sử Dụng Đất">
  <data key="d7">1.0</data>
  <data key="d8">Hợp đồng về quyền sử dụng đất involves transferring or granting quyền sử dụng đất to another party.</data>
  <data key="d9">agreement terms,land use rights</data>
  <data key="d10">chunk-9006f99cc5f37528caabd57619fb67d8</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850826</data>
  <data key="d13"></data>
</edge>
<edge source="Di Chúc" target="Người Lập Di Chúc">
  <data key="d7">2.0</data>
  <data key="d8">The will is created by the testator, expressing their wishes regarding the distribution of their estate.&lt;SEP&gt;Người Lập Di Chúc creates and signs the di chúc, specifying the distribution of their assets.</data>
  <data key="d9">creation,legal document,signing,testator</data>
  <data key="d10">chunk-9d35ed796002742aa2467cef9894f826&lt;SEP&gt;chunk-a522f9aff4b603ac455ec99a8440d150</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851182</data>
  <data key="d13"></data>
</edge>
<edge source="Di Chúc" target="Người Làm Chứng">
  <data key="d7">2.0</data>
  <data key="d8">The will is witnessed by individuals to ensure its legal validity.&lt;SEP&gt;Người Làm Chứng attests to the authenticity of the di chúc, ensuring that the signatures or marks are genuine.</data>
  <data key="d9">authentication,legal validity,witness,witnessing</data>
  <data key="d10">chunk-9d35ed796002742aa2467cef9894f826&lt;SEP&gt;chunk-a522f9aff4b603ac455ec99a8440d150</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851182</data>
  <data key="d13"></data>
</edge>
<edge source="Di Chúc" target="Cơ Quan, Tổ Chức">
  <data key="d7">1.0</data>
  <data key="d8">The will can designate organizations as beneficiaries.</data>
  <data key="d9">beneficiary,organization</data>
  <data key="d10">chunk-9d35ed796002742aa2467cef9894f826</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850949</data>
  <data key="d13"></data>
</edge>
<edge source="Di Chúc" target="Thời Điểm Mở Thừa Kế">
  <data key="d7">1.0</data>
  <data key="d8">The will takes effect at the time of inheritance distribution.</data>
  <data key="d9">inheritance distribution,legal effect</data>
  <data key="d10">chunk-9d35ed796002742aa2467cef9894f826</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850949</data>
  <data key="d13"></data>
</edge>
<edge source="Di Chúc" target="Di Sản">
  <data key="d7">1.0</data>
  <data key="d8">The will specifies the distribution of the estate.</data>
  <data key="d9">estate distribution,legal document</data>
  <data key="d10">chunk-9d35ed796002742aa2467cef9894f826</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850949</data>
  <data key="d13"></data>
</edge>
<edge source="Di Chúc" target="Thời Hiệu Yêu Cầu Chia Di Sản">
  <data key="d7">1.0</data>
  <data key="d8">The period during which claims for the division of the estate can be made is relevant to the will's legal effect.</data>
  <data key="d9">inheritance distribution,legal effect</data>
  <data key="d10">chunk-9d35ed796002742aa2467cef9894f826</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850949</data>
  <data key="d13"></data>
</edge>
<edge source="Di Chúc" target="Di Chúc Bị Thất Lạc, Hư Hại">
  <data key="d7">1.0</data>
  <data key="d8">The event where a will is lost or damaged to the point where it cannot be fully understood affects the will's validity.</data>
  <data key="d9">damage,loss</data>
  <data key="d10">chunk-9d35ed796002742aa2467cef9894f826</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850949</data>
  <data key="d13"></data>
</edge>
<edge source="Di Chúc" target="Hiệu Lực Của Di Chúc">
  <data key="d7">1.0</data>
  <data key="d8">The legal validity and enforceability of a will are determined by its effectiveness.</data>
  <data key="d9">enforceability,legal validity</data>
  <data key="d10">chunk-9d35ed796002742aa2467cef9894f826</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850949</data>
  <data key="d13"></data>
</edge>
<edge source="Di Chúc" target="Người Thừa Kế Không Là Cá Nhân">
  <data key="d7">1.0</data>
  <data key="d8">Di Chúc determines the distribution of inheritance to Người Thừa Kế Không Là Cá Nhân.</data>
  <data key="d9">inheritance,legal document</data>
  <data key="d10">chunk-71c1c580c8f92c3838ab0f997647d588</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851025</data>
  <data key="d13"></data>
</edge>
<edge source="Di Chúc" target="Tổ Chức Hành Nghề Công Chứng">
  <data key="d7">1.0</data>
  <data key="d8">Di Chúc can be stored and managed by an organization that handles notarization.</data>
  <data key="d9">management,storage</data>
  <data key="d10">chunk-65946ae20fedf99884e4b9e9ee2eea91</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851100</data>
  <data key="d13"></data>
</edge>
<edge source="Di Chúc" target="Công Chứng Viên">
  <data key="d7">2.0</data>
  <data key="d8">Công Chứng Viên is responsible for announcing the will if it is stored at an organization that handles notarization.&lt;SEP&gt;Công Chứng Viên authenticates and witnesses the signing of a di chúc.</data>
  <data key="d9">announcement,authentication,management,witnessing</data>
  <data key="d10">chunk-65946ae20fedf99884e4b9e9ee2eea91&lt;SEP&gt;chunk-a522f9aff4b603ac455ec99a8440d150</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851182</data>
  <data key="d13"></data>
</edge>
<edge source="Di Chúc" target="Nghĩa Vụ Tài Sản">
  <data key="d7">1.0</data>
  <data key="d8">The estate specified in the Di Chúc must settle the financial obligations of the deceased.</data>
  <data key="d9">obligation,settlement</data>
  <data key="d10">chunk-65946ae20fedf99884e4b9e9ee2eea91</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851100</data>
  <data key="d13"></data>
</edge>
<edge source="Di Chúc" target="Người Phân Chia Di Sản">
  <data key="d7">1.0</data>
  <data key="d8">The person responsible for dividing the estate according to the terms of the will.</data>
  <data key="d9">executor,will execution</data>
  <data key="d10">chunk-f1bc911a64bb7c617404a95f58c39105</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851550</data>
  <data key="d13"></data>
</edge>
<edge source="Di Chúc" target="Người Để Lại Di Sản">
  <data key="d7">1.0</data>
  <data key="d8">The person who left the estate and created the will.</data>
  <data key="d9">testator,will creation</data>
  <data key="d10">chunk-f1bc911a64bb7c617404a95f58c39105</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851550</data>
  <data key="d13"></data>
</edge>
<edge source="Di Chúc" target="Năng Lực Lập Di Chúc">
  <data key="d7">1.0</data>
  <data key="d8">The legal capacity to create, modify, or revoke a di chúc is determined by the law of the country where the testator had citizenship at the time of the action.</data>
  <data key="d9">legal capacity,testamentary action</data>
  <data key="d10">chunk-b0cda21c37a8b4d265d1fff1cf5f7aea</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851577</data>
  <data key="d13"></data>
</edge>
<edge source="Di Chúc" target="Hình Thức Di Chúc">
  <data key="d7">1.0</data>
  <data key="d8">The form of a di chúc is determined by the law of the country where the di chúc is made.</data>
  <data key="d9">legal form,testamentary document</data>
  <data key="d10">chunk-b0cda21c37a8b4d265d1fff1cf5f7aea</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851577</data>
  <data key="d13"></data>
</edge>
<edge source="Tài sản thế chấp" target="Bên thế chấp">
  <data key="d7">2.0</data>
  <data key="d8">Bên thế chấp has the right to use and manage the collateral asset, subject to certain conditions.&lt;SEP&gt;Bên thế chấp uses their own property as collateral to secure an obligation.</data>
  <data key="d9">asset use,collateral,collateral management,pledge</data>
  <data key="d10">chunk-35e5b9d9646a1753edafbdf0516edae4&lt;SEP&gt;chunk-0e01f265574843f568ac9f6ea2cd861c</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849951</data>
  <data key="d13"></data>
</edge>
<edge source="Tài sản thế chấp" target="Điều 299">
  <data key="d7">1.0</data>
  <data key="d8">Điều 299 outlines the conditions under which the collateral asset can be processed.</data>
  <data key="d9">legal provision,processing conditions</data>
  <data key="d10">chunk-35e5b9d9646a1753edafbdf0516edae4</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849946</data>
