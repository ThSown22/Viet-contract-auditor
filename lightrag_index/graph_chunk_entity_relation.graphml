</edge>
<edge source="Trọng tài viên" target="Điều 42">
  <data key="d7">1.0</data>
  <data key="d8">Điều  42 outlines the conditions under which Trọng tài viên can be changed in dispute resolution processes.</data>
  <data key="d9">change,regulation</data>
  <data key="d10">chunk-4ad943b03a3a1bf95a1e1d6e04f2b581</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773854050</data>
  <data key="d13"></data>
</edge>
<edge source="Trọng tài viên" target="Thẩm phán">
  <data key="d7">1.0</data>
  <data key="d8">Thẩm phán designates an Trọng tài viên to resolve disputes.</data>
  <data key="d9">assignment,designation</data>
  <data key="d10">chunk-4ad943b03a3a1bf95a1e1d6e04f2b581</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773854050</data>
  <data key="d13"></data>
</edge>
<edge source="Bộ Tư pháp" target="Quản lý nhà nước về Trọng tài">
  <data key="d7">1.0</data>
  <data key="d8">Bộ Tư pháp is responsible for state management of arbitration on behalf of the government.</data>
  <data key="d9">arbitration,state management</data>
