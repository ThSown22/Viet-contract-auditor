<edge source="Bên Nhận Bảo Đảm" target="Đиều 305">
  <data key="d7">1.0</data>
  <data key="d8">Đиều 305 allows the receiver to take possession of collateral as a substitute for the debtor's obligations.</data>
  <data key="d9">collateral possession,obligation substitution</data>
