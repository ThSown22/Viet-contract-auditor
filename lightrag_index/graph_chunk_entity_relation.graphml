  <data key="d7">1.0</data>
  <data key="d8">Doanh nghiệp tư nhân must meet the conditions specified in Article 27, Clause 1 of the Law to be converted into another type of company.</data>
  <data key="d9">conversion,requirement</data>
  <data key="d10">chunk-8da64b48c80fc4788c324e08350a340e</data>
  <data key="d11">unknown_source</data>
