</edge>
<edge source="Công ty cổ phần" target="Tổ chức thẩm định giá">
  <data key="d7">1.0</data>
  <data key="d8">Tổ chức thẩm định giá is an organization that provides valuation services for transactions in the company.</data>
  <data key="d9">transaction,valuation service</data>
