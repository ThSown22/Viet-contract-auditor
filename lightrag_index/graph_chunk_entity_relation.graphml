  <data key="d0">Điều 506</data>
  <data key="d1">HÀNH_VI</data>
  <data key="d2">Đиều 506 describes the common property of cooperative members, including assets contributed, jointly created, and other assets as per the law, and the conditions for disposing of these assets.</data>
  <data key="d3">chunk-8d2cf1280fe7dc5dd2f57d5818548506</data>
  <data key="d4">unknown_source</data>
