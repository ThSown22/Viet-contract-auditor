  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">Chủ Thể Có Quyền Sử Dụng Đất refers to the individual or entity that has the right to use the land.</data>
  <data key="d3">chunk-4e4f3de95acd7468b8d781714a57816a</data>
