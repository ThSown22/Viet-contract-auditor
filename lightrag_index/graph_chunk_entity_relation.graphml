<node id="Tiếp tục hợp đồng dịch vụ">
  <data key="d0">Tiếp tục hợp đồng dịch vụ</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Tiếp tục hợp đồng dịch vụ refers to the continuation of a service contract when the work is not completed by the initial deadline and the service user is aware but does not object.</data>
  <data key="d3">chunk-ab83736c7458e42bbefffad0de52acd0</data>
