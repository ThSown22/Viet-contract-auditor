<edge source="Bên Bán" target="Khuyết Tật">
  <data key="d7">1.0</data>
  <data key="d8">Bên Bán is responsible for repairing or replacing defective items within the warranty period.</data>
  <data key="d9">defect responsibility,repair obligation</data>
