  <data key="d12">1773852018</data>
  <data key="d13"></data>
</edge>
<edge source="Hội đồng thành viên" target="Công ty trách nhiệm hữu hạn">
  <data key="d7">1.0</data>
  <data key="d8">Hội đồng thành viên is part of the management structure of a Công ty trách nhiệm hữu hạn.</data>
  <data key="d9">board representation,management structure</data>
  <data key="d10">chunk-246618b082091a628ff89e93d59fc956</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773852018</data>
  <data key="d13"></data>
</edge>
<edge source="Hội đồng thành viên" target="Quy định khác của pháp luật có liên quan">
  <data key="d7">1.0</data>
  <data key="d8">Hội đồng thành viên performs the rights and obligations of the company according to other related legal provisions.</data>
  <data key="d9">legal compliance,rights and obligations</data>
  <data key="d10">chunk-246618b082091a628ff89e93d59fc956</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773852018</data>
  <data key="d13"></data>
</edge>
<edge source="Hội đồng thành viên" target="Công ty cổ phần">
  <data key="d7">1.0</data>
  <data key="d8">Hội đồng thành viên is part of the management structure of a Công ty cổ phần.</data>
  <data key="d9">board representation,management structure</data>
  <data key="d10">chunk-246618b082091a628ff89e93d59fc956</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773852018</data>
  <data key="d13"></data>
</edge>
<edge source="Hội đồng thành viên" target="Điều 93">
  <data key="d7">1.0</data>
  <data key="d8">Điều 93 sets the criteria and conditions for the members of the Hội đồng thành viên.</data>
  <data key="d9">conditions,criteria</data>
  <data key="d10">chunk-246618b082091a628ff89e93d59fc956</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773852019</data>
  <data key="d13"></data>
</edge>
<edge source="Hội đồng thành viên" target="Kiểm soát viên">
  <data key="d7">1.0</data>
  <data key="d8">The Supervisor ensures compliance with the law, the company charter, and the decisions of the company owner.</data>
  <data key="d9">responsibility,supervision</data>
  <data key="d10">chunk-96b35fb948543da5055202eeb7113790</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773852026</data>
  <data key="d13"></data>
</edge>
<edge source="Hội đồng thành viên" target="Điều lệ công ty">
  <data key="d7">2.0</data>
  <data key="d8">The Board of Members must comply with the company charter and is responsible for making decisions regarding the company's operations.&lt;SEP&gt;Hội đồng thành viên operates according to the rules and procedures outlined in Điều lệ công ty.</data>
  <data key="d9">compliance,governance,procedure,responsibility</data>
  <data key="d10">chunk-96b35fb948543da5055202eeb7113790&lt;SEP&gt;chunk-258ace9c6b166d80918c8f05daed0816</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773852125</data>
  <data key="d13"></data>
</edge>
<edge source="Hội đồng thành viên" target="Phiếu lấy ý kiến">
  <data key="d7">1.0</data>
  <data key="d8">The Phiếu lấy ý kiến is used to collect opinions from members of the Hội đồng thành viên to make decisions.</data>
  <data key="d9">decision-making,opinion collection</data>
  <data key="d10">chunk-6291a8ad95bfac807fb62b2e4b103f5a</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773852082</data>
  <data key="d13"></data>
</edge>
<edge source="Hội đồng thành viên" target="Điều 61">
  <data key="d7">1.0</data>
  <data key="d8">Điều 61 outlines the procedures for passing resolutions and decisions of the Hội đồng thành viên through written opinions.</data>
  <data key="d9">organizational process,regulation</data>
  <data key="d10">chunk-6291a8ad95bfac807fb62b2e4b103f5a</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773852082</data>
  <data key="d13"></data>
</edge>
<edge source="Hội đồng thành viên" target="Biên bản họp">
  <data key="d7">2.0</data>
  <data key="d8">The Biên bản họp records the decisions and resolutions made by the Hội đồng thành viên.&lt;SEP&gt;The minutes of the meeting (Biên bản họp) must be recorded and approved by the Board of Members (Hội đồng thành viên).</data>
  <data key="d9">decision record,meeting documentation,organizational process,record keeping</data>
  <data key="d10">chunk-6291a8ad95bfac807fb62b2e4b103f5a&lt;SEP&gt;chunk-a4225ac646c0bc252a11873ee034ed86</data>
