  <data key="d0">Bảo hiểm trách nhiệm dân sự</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Bảo hiểm trách nhiệm dân sự is a form of insurance that covers civil liability for damages caused during transportation.</data>
  <data key="d3">chunk-1baf5b4c5d9b239e30e1e81e061a24dd</data>
  <data key="d4">unknown_source</data>
