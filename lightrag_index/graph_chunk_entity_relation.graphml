  <data key="d5">1773849064</data>
  <data key="d6"></data>
</node>
<node id="Người giám hộ được chỉ định">
  <data key="d0">Người giám hộ được chỉ định</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">A guardian appointed by a court or local government body.</data>
