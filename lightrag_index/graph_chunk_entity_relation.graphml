</edge>
<edge source="Bên Cho Thuê" target="Giao Tài Sản Thuê">
  <data key="d7">1.0</data>
  <data key="d8">Bên Cho Thuê is responsible for delivering the leased property as agreed upon in the lease agreement.</data>
