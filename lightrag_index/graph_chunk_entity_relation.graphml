  <data key="d0">Lãi Suất Thỏa Thuận</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Lãi Suất Thỏa Thuận refers to the interest rate agreed upon by the parties in the contract.</data>
  <data key="d3">chunk-4623833cd0cb1b86833b9050e09612fd</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850374</data>
  <data key="d6"></data>
</node>
