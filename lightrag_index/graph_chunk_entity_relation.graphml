  <data key="d0">Cổ Phần</data>
  <data key="d1">VĂN_BẢN_PHÁP_LUẬT</data>
  <data key="d2">Cổ Phần refers to shares of the company that can be repurchased and paid out to shareholders.</data>
  <data key="d3">chunk-af079df7102c58f84652bfeb21c7a17a</data>
  <data key="d4">unknown_source</data>
