</edge>
<edge source="Chánh án Tòa án" target="Quyết định giải quyết khiếu nại">
  <data key="d7">1.0</data>
  <data key="d8">Chánh án Tòa án makes the final decision in resolving complaints.</data>
  <data key="d9">complaint resolution,decision making</data>
