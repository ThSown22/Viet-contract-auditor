</node>
<node id="Điều 134">
  <data key="d0">Điều 134</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Điều 134 is a legal provision that defines representation, where an individual or legal entity acts on behalf of another for civil transactions.&lt;SEP&gt;Điều 134 is a legal provision that outlines the conditions for payment and handling of repurchased shares.</data>
  <data key="d3">chunk-482a66c12f2040cbc0eabb425e1b6d97&lt;SEP&gt;chunk-af079df7102c58f84652bfeb21c7a17a</data>
  <data key="d4">unknown_source</data>
