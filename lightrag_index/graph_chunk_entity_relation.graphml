</edge>
<edge source="Trọng tài viên duy nhất" target="Tòa án có thẩm quyền">
  <data key="d7">1.0</data>
  <data key="d8">The competent court can appoint a single arbitrator if the parties cannot agree and do not request an arbitration center to appoint one.</data>
  <data key="d9">appointment,arbitration</data>
  <data key="d10">chunk-d4b1824dac8b182589cb4f697dad3e4f</data>
