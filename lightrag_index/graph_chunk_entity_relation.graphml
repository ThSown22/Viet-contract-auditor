  <data key="d7">1.0</data>
  <data key="d8">Chủ Sở Hữu Nhà Cửa, Công Trình Xây Dựng Khác is responsible for compensating for any damage caused by Nhà Cửa, Công Trình Xây Dựng Khác.</data>
  <data key="d9">liability,ownership</data>
  <data key="d10">chunk-71c1c580c8f92c3838ab0f997647d588</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851025</data>
  <data key="d13"></data>
</edge>
<edge source="Người Chiếm Hữu Nhà Cửa, Công Trình Xây Dựng Khác" target="Nhà Cửa, Công Trình Xây Dựng Khác">
  <data key="d7">1.0</data>
  <data key="d8">Người Chiếm Hữu Nhà Cửa, Công Trình Xây Dựng Khác is responsible for compensating for any damage caused by Nhà Cửa, Công Trình Xây Dựng Khác.</data>
  <data key="d9">liability,possession</data>
  <data key="d10">chunk-71c1c580c8f92c3838ab0f997647d588</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851025</data>
  <data key="d13"></data>
</edge>
<edge source="Người Được Giao Quản Lý, Sử Dụng Nhà Cửa, Công Trình Xây Dựng Khác" target="Nhà Cửa, Công Trình Xây Dựng Khác">
  <data key="d7">1.0</data>
  <data key="d8">Người Được Giao Quản Lý, Sử Dụng Nhà Cửa, Công Trình Xây Dựng Khác is responsible for compensating for any damage caused by Nhà Cửa, Công Trình Xây Dựng Khác.</data>
  <data key="d9">liability,management</data>
  <data key="d10">chunk-71c1c580c8f92c3838ab0f997647d588</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851025</data>
  <data key="d13"></data>
</edge>
<edge source="Người Thi Công" target="Nhà Cửa, Công Trình Xây Dựng Khác">
  <data key="d7">1.0</data>
  <data key="d8">Người Thi Công is responsible for compensating for any damage caused by Nhà Cửa, Công Trình Xây Dựng Khác during construction.</data>
  <data key="d9">construction,liability</data>
  <data key="d10">chunk-71c1c580c8f92c3838ab0f997647d588</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851025</data>
  <data key="d13"></data>
</edge>
<edge source="Người Tiêu Dùng" target="Cá Nhân, Pháp Nhân Sản Xuất, Kinh Doanh Hàng Hóa, Dịch Vụ">
  <data key="d7">1.0</data>
  <data key="d8">Cá Nhân, Pháp Nhân Sản Xuất, Kinh Doanh Hàng Hóa, Dịch Vụ is responsible for compensating for any damage caused to Người Tiêu Dùng.</data>
  <data key="d9">liability,production</data>
  <data key="d10">chunk-71c1c580c8f92c3838ab0f997647d588</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851025</data>
  <data key="d13"></data>
</edge>
<edge source="Mức Lương Cơ Sở" target="Bồi Thường">
  <data key="d7">1.0</data>
  <data key="d8">Mức Lương Cơ Sở is used as a standard for calculating compensation.</data>
  <data key="d9">compensation,legal standard</data>
  <data key="d10">chunk-71c1c580c8f92c3838ab0f997647d588</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851025</data>
  <data key="d13"></data>
</edge>
<edge source="Mức Lương Cơ Sở" target="Thiệt Hại Do Sức Khỏe Bị Xâm Phạm">
  <data key="d7">1.0</data>
  <data key="d8">The responsible party must compensate for mental distress in cases of damage to health, with the maximum compensation being no more than fifty times the mức lương cơ sở.</data>
  <data key="d9">compensation limit,mental distress</data>
  <data key="d10">chunk-8a3e7fbb7046ed06cc0347b21e0435f1</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851073</data>
  <data key="d13"></data>
</edge>
<edge source="Mức Lương Cơ Sở" target="Thiệt Hại Do Danh Dự, Nhân Phẩm, Uy Tín Bị Xâm Phạm">
  <data key="d7">1.0</data>
  <data key="d8">The responsible party must compensate for mental distress in cases of damage to reputation, with the maximum compensation being no more than ten times the mức lương cơ sở.</data>
  <data key="d9">compensation limit,mental distress</data>
  <data key="d10">chunk-8a3e7fbb7046ed06cc0347b21e0435f1</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851073</data>
  <data key="d13"></data>
</edge>
<edge source="Mức Lương Cơ Sở" target="Thiệt Hại Do Tính Mạng Bị Xâm Phạm">
  <data key="d7">1.0</data>
  <data key="d8">The responsible party must compensate for mental distress in cases of damage to life, with the maximum compensation being no more than one hundred times the mức lương cơ sở.</data>
  <data key="d9">compensation limit,mental distress</data>
  <data key="d10">chunk-8a3e7fbb7046ed06cc0347b21e0435f1</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851073</data>
  <data key="d13"></data>
</edge>
<edge source="Bản di chúc" target="Người giao">
  <data key="d7">1.0</data>
  <data key="d8">Người giao is responsible for transferring the will to another party.</data>
  <data key="d9">legal document,transfer</data>
  <data key="d10">chunk-c6c45985a08d6e2c0940eda170510a01</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851043</data>
  <data key="d13"></data>
</edge>
<edge source="Bản di chúc" target="Người nhận">
  <data key="d7">1.0</data>
  <data key="d8">Người nhận is responsible for receiving the will from another party.</data>
  <data key="d9">legal document,receipt</data>
  <data key="d10">chunk-c6c45985a08d6e2c0940eda170510a01</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851043</data>
  <data key="d13"></data>
</edge>
<edge source="Điều 593" target="Người bị thiệt hại">
  <data key="d7">1.0</data>
  <data key="d8">Điều 593 provides the duration for compensation for damages suffered by the person who has been harmed.</data>
  <data key="d9">compensation,legal provision</data>
  <data key="d10">chunk-8f476c4f267fa92420ccea7f2351f4dd</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851062</data>
  <data key="d13"></data>
</edge>
<edge source="Điều 593" target="Mức bồi thường bù đắp tổn thất về tinh thần">
  <data key="d7">1.0</data>
  <data key="d8">Điều 593 specifies the conditions and limits for compensation for mental suffering.</data>
  <data key="d9">compensation,legal provision</data>
  <data key="d10">chunk-8f476c4f267fa92420ccea7f2351f4dd</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851062</data>
  <data key="d13"></data>
</edge>
<edge source="Điều 594" target="Người gây thiệt hại">
  <data key="d7">1.0</data>
  <data key="d8">Điều 594 specifies that compensation is required if the limits of justifiable defense are exceeded.</data>
  <data key="d9">compensation,justifiable defense</data>
  <data key="d10">chunk-8f476c4f267fa92420ccea7f2351f4dd</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851062</data>
  <data key="d13"></data>
</edge>
<edge source="Điều 595" target="Người gây thiệt hại">
  <data key="d7">1.0</data>
  <data key="d8">Điều 595 addresses compensation for damages caused by exceeding the requirements of a critical situation.</data>
  <data key="d9">compensation,critical situation</data>
  <data key="d10">chunk-8f476c4f267fa92420ccea7f2351f4dd</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851062</data>
  <data key="d13"></data>
</edge>
<edge source="Điều 596" target="Người gây thiệt hại">
  <data key="d7">1.0</data>
  <data key="d8">Đиều 596 deals with compensation for damages caused by individuals under the influence of stimulants.</data>
  <data key="d9">compensation,stimulant use</data>
  <data key="d10">chunk-8f476c4f267fa92420ccea7f2351f4dd</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851062</data>
  <data key="d13"></data>
</edge>
<edge source="Trường học" target="Đиều 599">
  <data key="d7">1.0</data>
  <data key="d8">Đиều 599 outlines compensation for damages caused by individuals under 15 years old while under the direct management of an educational institution.</data>
  <data key="d9">compensation,educational institution</data>
  <data key="d10">chunk-8f476c4f267fa92420ccea7f2351f4dd</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851062</data>
  <data key="d13"></data>
</edge>
<edge source="Bệnh viện" target="Đиều 599">
  <data key="d7">1.0</data>
  <data key="d8">Đиều 599 outlines compensation for damages caused by individuals lacking civil capacity while under the direct management of a hospital.</data>
  <data key="d9">compensation,hospital</data>
  <data key="d10">chunk-8f476c4f267fa92420ccea7f2351f4dd</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851062</data>
  <data key="d13"></data>
</edge>
<edge source="Cha, mẹ, người giám hộ" target="Đиều 599">
  <data key="d7">1.0</data>
  <data key="d8">Đиều 599 specifies that parents or guardians must compensate if the educational institution, hospital, or other legal entity is not at fault.</data>
  <data key="d9">compensation,parental responsibility</data>
  <data key="d10">chunk-8f476c4f267fa92420ccea7f2351f4dd</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851062</data>
  <data key="d13"></data>
</edge>
<edge source="Mức bồi thường bù đắp tổn thất về tinh thần" target="mức lương cơ sở">
  <data key="d7">1.0</data>
  <data key="d8">The maximum compensation for mental suffering is calculated based on the state's base salary.</data>
  <data key="d9">base salary,compensation limit</data>
  <data key="d10">chunk-8f476c4f267fa92420ccea7f2351f4dd</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851062</data>
  <data key="d13"></data>
</edge>
<edge source="Thiệt Hại Do Sức Khỏe Bị Xâm Phạm" target="Thiệt Hại Do Tính Mạng Bị Xâm Phạm">
  <data key="d7">1.0</data>
  <data key="d8">Thiệt hại do sức khỏe bị xâm phạm is included in the damages for tính mạng bị xâm phạm, and the responsible party must compensate for these damages and a separate amount for mental distress.</data>
  <data key="d9">compensation,damage inclusion</data>
  <data key="d10">chunk-8a3e7fbb7046ed06cc0347b21e0435f1</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851073</data>
  <data key="d13"></data>
</edge>
<edge source="Thiệt Hại Do Sức Khỏe Bị Xâm Phạm" target="Người Chịu Trách Nhiệm Bồi Thường">
  <data key="d7">1.0</data>
  <data key="d8">Người chịu trách nhiệm bồi thường must compensate for the damages as prescribed in Article 590 and a separate amount for mental distress.</data>
  <data key="d9">compensation responsibility</data>
  <data key="d10">chunk-8a3e7fbb7046ed06cc0347b21e0435f1</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851073</data>
  <data key="d13"></data>
</edge>
<edge source="Thiệt Hại Do Tính Mạng Bị Xâm Phạm" target="Người Chịu Trách Nhiệm Bồi Thường">
  <data key="d7">1.0</data>
  <data key="d8">Người chịu trách nhiệm bồi thường must compensate for the damages as prescribed in Article  591 and a separate amount for mental distress for close relatives.</data>
  <data key="d9">compensation responsibility</data>
  <data key="d10">chunk-8a3e7fbb7046ed06cc0347b21e0435f1</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851073</data>
  <data key="d13"></data>
</edge>
<edge source="Thiệt Hại Do Danh Dự, Nhân Phẩm, Uy Tín Bị Xâm Phạm" target="Người Chịu Trách Nhiệm Bồi Thường">
  <data key="d7">1.0</data>
  <data key="d8">Người chịu trách nhiệm bồi thường must compensate for the damages as prescribed in Article 592 and a separate amount for mental distress.</data>
  <data key="d9">compensation responsibility</data>
  <data key="d10">chunk-8a3e7fbb7046ed06cc0347b21e0435f1</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851073</data>
  <data key="d13"></data>
</edge>
<edge source="Người chết" target="Địa điểm mở thừa kế">
  <data key="d7">1.0</data>
  <data key="d8">The last place of residence of the deceased determines the location for opening the estate.</data>
  <data key="d9">estate location,residence</data>
  <data key="d10">chunk-2dbdbb74ad11a83bf1856f95ecdfa309</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851096</data>
  <data key="d13"></data>
</edge>
<edge source="Người quản lý di sản" target="Người để lại di sản">
  <data key="d7">1.0</data>
  <data key="d8">The person managing the estate has an agreement with the person who left the estate regarding the management of the estate.</data>
  <data key="d9">agreement,management</data>
  <data key="d10">chunk-fd15f05b480bf5c4a3b4b4e068a412cd</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851130</data>
  <data key="d13"></data>
</edge>
<edge source="Người quản lý di sản" target="Nghĩa vụ của người quản lý di sản">
  <data key="d7">1.0</data>
  <data key="d8">The person managing the estate has specific duties related to managing and preserving the estate.</data>
  <data key="d9">duties,management</data>
  <data key="d10">chunk-fd15f05b480bf5c4a3b4b4e068a412cd</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851130</data>
  <data key="d13"></data>
</edge>
<edge source="Người quản lý di sản" target="Quyền của người quản lý di sản">
  <data key="d7">1.0</data>
  <data key="d8">The person managing the estate has specific rights related to managing and preserving the estate.</data>
  <data key="d9">management,rights</data>
  <data key="d10">chunk-fd15f05b480bf5c4a3b4b4e068a412cd</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851130</data>
  <data key="d13"></data>
</edge>
<edge source="Người quản lý di sản" target="Thỏa thuận về thù lao">
  <data key="d7">1.0</data>
  <data key="d8">The person managing the estate has an agreement with the heirs regarding compensation for their services.</data>
  <data key="d9">agreement,compensation</data>
  <data key="d10">chunk-fd15f05b480bf5c4a3b4b4e068a412cd</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851130</data>
  <data key="d13"></data>
</edge>
<edge source="Di Tặng" target="Người Được Di Tặng">
  <data key="d7">1.0</data>
  <data key="d8">Người Được Di Tặng is the individual who receives a portion of the estate as specified in the will.</data>
  <data key="d9">allocation,inheritance</data>
  <data key="d10">chunk-65946ae20fedf99884e4b9e9ee2eea91</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851100</data>
  <data key="d13"></data>
</edge>
<edge source="Thừa Kế Theo Pháp Luật" target="Phần Di Sản Không Được Định Đoạt Trong Di Chúc">
  <data key="d7">1.0</data>
  <data key="d8">Parts of the estate not specified in the will are inherited according to the legal order.</data>
  <data key="d9">inheritance,legal order</data>
  <data key="d10">chunk-65946ae20fedf99884e4b9e9ee2eea91</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851100</data>
  <data key="d13"></data>
</edge>
<edge source="Nghĩa Vụ Tài Sản" target="Phần Di Sản">
  <data key="d7">1.0</data>
  <data key="d8">Phần Di Sản is used to settle the financial obligations of the deceased.</data>
  <data key="d9">obligation,settlement</data>
  <data key="d10">chunk-65946ae20fedf99884e4b9e9ee2eea91</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851100</data>
  <data key="d13"></data>
