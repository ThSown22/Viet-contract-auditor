<edge source="Hội đồng quản trị" target="Thành viên độc lập">
  <data key="d7">2.0</data>
  <data key="d8">At least 20% of the board members must be independent members in certain company structures.&lt;SEP&gt;Hội đồng quản trị includes independent members who are not involved in the company's management.</data>
  <data key="d9">governance,independent board members,membership</data>
  <data key="d10">chunk-8245b988239aa1f9c2e280f1734f8ac5&lt;SEP&gt;chunk-8031309e714112ffe63df75b002d2d14</data>
