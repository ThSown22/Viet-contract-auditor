  <data key="d7">1.0</data>
  <data key="d8">Members of Công Ty Trách Nhiệm Hữu Hạn Hai Thành Viên Trở Lên are liable for the company's debts and financial obligations within the scope of their capital contributions.</data>
  <data key="d9">capital contribution,liability</data>
  <data key="d10">chunk-fef4d2c27b6430834254a2ffeefda111</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851866</data>
