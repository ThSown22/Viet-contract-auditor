<edge source="Hợp đồng" target="Bên vi phạm">
  <data key="d7">1.0</data>
  <data key="d8">Bên vi phạm is the party in a contract who has breached the terms of the agreement.</data>
  <data key="d9">contract breach,party violation</data>
