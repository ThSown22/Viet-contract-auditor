  <data key="d1">VĂN_BẢN_PHÁP_LUẬT</data>
  <data key="d2">Ghi chép kế toán is the accounting record or journal.</data>
  <data key="d3">chunk-795fb9faa3ff64c104def58573301724</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773852942</data>
