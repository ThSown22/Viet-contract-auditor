</edge>
<edge source="Giao dịch dân sự" target="Hậu quả pháp lý">
  <data key="d7">1.0</data>
  <data key="d8">An invalid civil transaction has legal consequences, including the restoration of the original state and compensation for damages.</data>
  <data key="d9">legal consequences,transaction invalidity</data>
  <data key="d10">chunk-e91add69ab34542976bf62b9aca43ffa</data>
  <data key="d11">unknown_source</data>
