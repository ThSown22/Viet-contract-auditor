</edge>
<edge source="Tài Sản" target="Người Sử Dụng Tài Sản">
  <data key="d7">1.0</data>
  <data key="d8">A person who uses another's property without legal basis must return the entire property.</data>
  <data key="d9">legal obligation,property use</data>
