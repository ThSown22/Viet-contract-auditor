  <data key="d0">Quyết định công nhận sự thỏa thuận</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Quyết định công nhận sự thỏa thuận is a decision that officially recognizes an agreement between parties in a dispute.</data>
  <data key="d3">chunk-803a122f8a9fdbd56cf33836597c6521</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773853933</data>
  <data key="d6"></data>
</node>
