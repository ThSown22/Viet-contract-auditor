  <data key="d0">Bí quyết kỹ thuật</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Bí quyết kỹ thuật refers to trade secrets that can be used as capital contribution assets.&lt;SEP&gt;Bí quyết kỹ thuật refers to technical know-how used as a form of payment.</data>
  <data key="d3">chunk-64b8fad75bc3785889ce216fbcf53556&lt;SEP&gt;chunk-9b892718f9850a0f9775f9a075fb4282</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773852748</data>
  <data key="d6"></data>
</node>
<node id="Lệ phí trước bạ">
  <data key="d0">Lệ phí trước bạ</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Lệ phí trước bạ refers to the stamp duty that is not applicable when transferring ownership of capital contribution assets.</data>
  <data key="d3">chunk-64b8fad75bc3785889ce216fbcf53556</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773851714</data>
