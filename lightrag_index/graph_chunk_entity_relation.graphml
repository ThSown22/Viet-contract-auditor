  <data key="d0">Bên tranh chấp</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">Bên tranh chấp refers to the parties involved in the dispute.</data>
  <data key="d3">chunk-967ef50a189d7b94846c22abc99c1f09</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773853867</data>
  <data key="d6"></data>
</node>
<node id="Chánh án Tòa án">
  <data key="d0">Chánh án Tòa án</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">Chánh án Tòa án is responsible for making the final decision in resolving complaints.&lt;SEP&gt;Chánh án Tòa án is the chief judge who assigns a judge to handle summoning requests.&lt;SEP&gt;Chánh án Tòa án is the chief judge of the court responsible for assigning judges to handle requests for evidence collection.</data>
  <data key="d3">chunk-105aefb96d31bdf83eb8694998c59506&lt;SEP&gt;chunk-c0133fbf4562d8d0b8d51451c1447d8e&lt;SEP&gt;chunk-868a62477b36c9e43bd19ac6e811469e</data>
