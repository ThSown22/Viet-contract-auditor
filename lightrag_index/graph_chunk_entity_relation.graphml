  <data key="d12">1773852384</data>
  <data key="d13"></data>
</edge>
<edge source="Hội đồng quản trị" target="Tài liệu, chứng cứ">
  <data key="d7">1.0</data>
  <data key="d8">Documents and evidence must be provided regarding violations by the Board of Directors.</data>
  <data key="d9">evidence,violations</data>
