<edge source="Thực hiện công việc không có ủy quyền" target="Điều 574">
  <data key="d7">1.0</data>
  <data key="d8">Article 574 defines the concept of performing work without authorization.</data>
  <data key="d9">definition,legal concept</data>
  <data key="d10">chunk-50c919d97de369bc8d7562186f764b91</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850908</data>
  <data key="d13"></data>
</edge>
<edge source="Thực hiện công việc không có ủy quyền" target="Điều 578">
  <data key="d7">1.0</data>
  <data key="d8">Article 578 defines the conditions under which the performance of work without authorization is terminated.</data>
  <data key="d9">legal requirement,termination</data>
  <data key="d10">chunk-50c919d97de369bc8d7562186f764b91</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850908</data>
  <data key="d13"></data>
</edge>
<edge source="Người thực hiện công việc không có ủy quyền" target="Người có công việc được thực hiện">
  <data key="d7">2.0</data>
  <data key="d8">The person performing work without authorization must report the progress and results of the work to the person for whom the work is performed if requested.&lt;SEP&gt;The person for whom the work is performed must accept the work and pay reasonable expenses incurred by the person performing the work without authorization.</data>
  <data key="d9">payment,work acceptance,work performance</data>
  <data key="d10">chunk-50c919d97de369bc8d7562186f764b91</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850908</data>
  <data key="d13"></data>
</edge>
<edge source="Người thực hiện công việc không có ủy quyền" target="Khoản 5 Điều 575">
  <data key="d7">1.0</data>
  <data key="d8">The person performing work without authorization must continue the work according to the conditions specified in Clause  5 of Article 575.</data>
  <data key="d9">legal clause,work continuation</data>
  <data key="d10">chunk-50c919d97de369bc8d7562186f764b91</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850908</data>
  <data key="d13"></data>
</edge>
