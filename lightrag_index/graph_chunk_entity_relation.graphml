  <data key="d7">1.0</data>
  <data key="d8">Bộ luật Dân sự defines the legal framework for inheritance rights of heirs.</data>
  <data key="d9">inheritance rights,legal framework</data>
  <data key="d10">chunk-7934cedd8a058c40a35091be7e3f1c17</data>
  <data key="d11">unknown_source</data>
