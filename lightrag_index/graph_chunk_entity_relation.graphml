</edge>
<edge source="Hội đồng xét đơn yêu cầu" target="Kiểm sát viên">
  <data key="d7">1.0</data>
  <data key="d8">Kiểm sát viên participates as a prosecutor in the examination process.</data>
  <data key="d9">participation,prosecution role</data>
  <data key="d10">chunk-967ef50a189d7b94846c22abc99c1f09</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773853868</data>
