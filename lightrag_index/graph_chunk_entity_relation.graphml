  <data key="d7">1.0</data>
  <data key="d8">Tổ Chức Tín Dụng manages the tài khoản phong tỏa where the collateral is deposited.</data>
  <data key="d9">collateral deposit,financial management</data>
  <data key="d10">chunk-3baa9f51dbe3abee94b2d6af0d80324d</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850113</data>
