<node id="Hoa lợi">
  <data key="d0">Hoa lợi</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Hoa lợi refers to the income or benefits derived from the collateral property, which is returned to the pledging party unless there is a different agreement.&lt;SEP&gt;Hoa lợi refers to the benefits or profits derived from the use of an item during the trial period.</data>
  <data key="d3">chunk-0e01f265574843f568ac9f6ea2cd861c&lt;SEP&gt;chunk-fb927ff207ca7e0465d21f05d999a0f9</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850409</data>
  <data key="d6"></data>
</node>
<node id="Lợi tức">
  <data key="d0">Lợi tức</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Lợi tức refers to the profit or income derived from the collateral property, which is returned to the pledging party unless there is a different agreement.</data>
  <data key="d3">chunk-0e01f265574843f568ac9f6ea2cd861c</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773849950</data>
