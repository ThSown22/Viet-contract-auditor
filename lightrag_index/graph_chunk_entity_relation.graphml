  <data key="d13"></data>
</edge>
<edge source="Giao dịch dân sự vô hiệu" target="Cưỡng ép">
  <data key="d7">1.0</data>
  <data key="d8">Coercion can invalidate a civil transaction.</data>
  <data key="d9">coercion,invalidation</data>
