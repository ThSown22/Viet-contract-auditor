</edge>
<edge source="Chủ sở hữu" target="Thỏa thuận">
  <data key="d7">1.0</data>
  <data key="d8">Thỏa thuận establishes the rights of the owner over the produce or income from a property.</data>
  <data key="d9">agreement,ownership rights</data>
