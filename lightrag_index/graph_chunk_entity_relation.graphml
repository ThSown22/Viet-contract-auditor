  <data key="d0">Quyền của cổ đông phổ thông</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Quyền của cổ đông phổ thông refers to the rights of common shareholders, including the right to nominate individuals to the Board of Directors and Supervisory Board.</data>
  <data key="d3">chunk-01b556fba8ab897e9f334300f225003e</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773852383</data>
