  <data key="d7">1.0</data>
  <data key="d8">Người đại diện theo ủy quyền represents the interests of the shareholders, members, or owners and is responsible for their actions towards the person with the authority to appoint the company manager.</data>
  <data key="d9">representation,responsibility</data>
