  <data key="d0">Bên Tranh Chấp</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">Bên Tranh Chấp refers to the parties involved in a dispute.</data>
  <data key="d3">chunk-a36e099bae803eeaad0a5160e83464d5</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773853927</data>
