  <data key="d7">1.0</data>
  <data key="d8">Thành viên are members of the company and have rights and obligations as defined by the Hội đồng Thành viên.</data>
  <data key="d9">governance,membership</data>
  <data key="d10">chunk-4c4083a7e93b6ad10b316c67434aca7b</data>
