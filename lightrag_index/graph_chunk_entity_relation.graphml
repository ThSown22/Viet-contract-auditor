<node id="Chuyển lợi nhuận ra nước ngoài">
  <data key="d0">Chuyển lợi nhuận ra nước ngoài</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Chuyển lợi nhuận ra nước ngoài refers to the transfer of profits to foreign countries, which must be conducted through accounts as per foreign exchange management regulations.</data>
  <data key="d3">chunk-64b8fad75bc3785889ce216fbcf53556</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773851714</data>
  <data key="d6"></data>
</node>
