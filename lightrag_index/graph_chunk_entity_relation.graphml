  <data key="d7">1.0</data>
  <data key="d8">Hội đồng trọng tài makes decisions regarding the validity and enforceability of arbitration agreements and issues Quyết định của Hội đồng trọng tài.</data>
  <data key="d9">authority,decision making</data>
