  <data key="d0">Điều 136</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Điều 136 is a legal provision that specifies legal representation for individuals, including parents for minors and guardians for those under guardianship.</data>
  <data key="d3">chunk-482a66c12f2040cbc0eabb425e1b6d97</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773849361</data>
