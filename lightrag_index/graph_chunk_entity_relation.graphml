  <data key="d12">1773851504</data>
  <data key="d13"></data>
</edge>
<edge source="Doanh Nghiệp" target="Thu Nhập">
  <data key="d7">1.0</data>
  <data key="d8">Doanh Nghiệp has the right to own and manage its income, and can use it freely within the legal framework.</data>
