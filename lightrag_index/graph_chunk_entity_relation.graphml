  <data key="d11">unknown_source</data>
  <data key="d12">1773850097</data>
  <data key="d13"></data>
</edge>
<edge source="Người thứ ba" target="Điều 417">
  <data key="d7">1.0</data>
  <data key="d8">Điều 417 ensures that a contract for the benefit of a third party cannot be modified or canceled without the third party's consent, protecting the interests of the third party.</data>
  <data key="d9">contractual protection,third party benefits</data>
  <data key="d10">chunk-f99273835b3b6031602578494c58acd7</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850193</data>
  <data key="d13"></data>
</edge>
<edge source="Bên Bảo Đảm" target="Đиều 302">
  <data key="d7">1.0</data>
  <data key="d8">Đиều 302 grants the right to reclaim collateral if obligations are fulfilled.</data>
  <data key="d9">collateral reclamation,obligation fulfillment</data>
