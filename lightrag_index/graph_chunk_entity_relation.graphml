  <data key="d7">1.0</data>
  <data key="d8">Chủ Tịch Trung Tâm Trọng Tài has the authority to appoint arbitrators.</data>
  <data key="d9">appointment,legal process</data>
  <data key="d10">chunk-4467037e5832a3ba479e5bed20f265c7</data>
