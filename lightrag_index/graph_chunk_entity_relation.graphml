  <data key="d0">Điều 216</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Điều 216 is a legal provision that outlines the responsibilities and authorities of the Cơ quan đăng ký kinh doanh.</data>
  <data key="d3">chunk-09d578fe732c3cb08c15e944096d74cd</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773853595</data>
  <data key="d6"></data>
</node>
<node id="Tổ chức trọng tài nước ngoài">
  <data key="d0">Tổ chức trọng tài nước ngoài</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">Tổ chức trọng tài nước ngoài refers to foreign arbitration organizations that have branches or representative offices in Vietnam.&lt;SEP&gt;Tổ chức trọng tài nước ngoài is a foreign arbitration organization that operates legally in its home country and is permitted to operate in Vietnam.&lt;SEP&gt;Tổ chức trọng tài nước ngoài is a foreign arbitration organization that establishes a representative office in Vietnam.</data>
  <data key="d3">chunk-f4e87b9226945fe55349146eaa7dc3c3&lt;SEP&gt;chunk-d91f2a7788f7464204ab346b8f178828&lt;SEP&gt;chunk-44b958e89c37ebae08442548c41df280</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773854043</data>
  <data key="d6"></data>
</node>
