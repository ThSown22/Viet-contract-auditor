</edge>
<edge source="Giao dịch dân sự" target="Quy định về hình thức">
  <data key="d7">1.0</data>
  <data key="d8">A civil transaction can be declared invalid if it does not comply with the formal requirements.</data>
  <data key="d9">formal requirements,transaction validity</data>
  <data key="d10">chunk-e91add69ab34542976bf62b9aca43ffa</data>
  <data key="d11">unknown_source</data>
