<edge source="Ký Quỹ" target="Điều 330">
  <data key="d7">1.0</data>
  <data key="d8">Điều 330 defines the concept of ký quỹ, which involves depositing collateral into a blocked account at a financial institution to ensure the fulfillment of obligations.</data>
  <data key="d9">definition,legal provision</data>
  <data key="d10">chunk-3baa9f51dbe3abee94b2d6af0d80324d</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850113</data>
  <data key="d13"></data>
</edge>
<edge source="Bảo Lưu Quyền Sở Hữu" target="Bên Bán">
  <data key="d7">1.0</data>
  <data key="d8">Bên Bán retains ownership of the asset until the buyer has fully fulfilled their payment obligations.</data>
  <data key="d9">ownership retention,payment obligation</data>
  <data key="d10">chunk-3baa9f51dbe3abee94b2d6af0d80324d</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850113</data>
  <data key="d13"></data>
</edge>
<edge source="Bảo Lưu Quyền Sở Hữu" target="Bên Mua">
  <data key="d7">1.0</data>
  <data key="d8">Bên Mua purchases an asset and has the right to use it during the period of retained ownership.</data>
  <data key="d9">ownership retention,payment obligation</data>
  <data key="d10">chunk-3baa9f51dbe3abee94b2d6af0d80324d</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850113</data>
  <data key="d13"></data>
</edge>
<edge source="Bảo Lưu Quyền Sở Hữu" target="Điều 331">
  <data key="d7">1.0</data>
  <data key="d8">Điều 331 defines the concept of bảo lưu quyền sở hữu, which involves the seller retaining ownership of an asset until the buyer has fully fulfilled their payment obligations.</data>
  <data key="d9">definition,legal provision</data>
  <data key="d10">chunk-3baa9f51dbe3abee94b2d6af0d80324d</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850113</data>
  <data key="d13"></data>
</edge>
<edge source="Bảo Lãnh" target="Điều 335">
  <data key="d7">1.0</data>
  <data key="d8">Điều 335 defines the concept of bảo lãnh, which involves a third party guaranteeing the obligations of another party.</data>
  <data key="d9">definition,legal provision</data>
  <data key="d10">chunk-3baa9f51dbe3abee94b2d6af0d80324d</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850113</data>
  <data key="d13"></data>
</edge>
<edge source="Bên Bán" target="Điều 439">
  <data key="d7">1.0</data>
  <data key="d8">Bên Bán is responsible for delivering the correct type of goods or compensating for damages if the goods do not match the agreed-upon type.</data>
  <data key="d9">contract enforcement,seller responsibilities</data>
  <data key="d10">chunk-b7c9b850c56df03c6a0092f33eddd51c</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850315</data>
  <data key="d13"></data>
</edge>
<edge source="Bên Bán" target="Điều 440">
  <data key="d7">1.0</data>
  <data key="d8">Bên Bán is entitled to receive payment for the goods according to the terms of the contract.</data>
  <data key="d9">contract enforcement,payment obligations</data>
  <data key="d10">chunk-b7c9b850c56df03c6a0092f33eddd51c</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850315</data>
  <data key="d13"></data>
</edge>
<edge source="Bên Bán" target="Điều 441">
  <data key="d7">1.0</data>
  <data key="d8">Bên Bán assumes the risk of the goods until they are transferred to the buyer.</data>
  <data key="d9">contract enforcement,risk transfer</data>
  <data key="d10">chunk-b7c9b850c56df03c6a0092f33eddd51c</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850316</data>
  <data key="d13"></data>
</edge>
<edge source="Bên Bán" target="Điều 442">
  <data key="d7">1.0</data>
  <data key="d8">Bên Bán is responsible for transportation costs unless otherwise agreed upon.</data>
  <data key="d9">contract enforcement,transportation costs</data>
  <data key="d10">chunk-b7c9b850c56df03c6a0092f33eddd51c</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850316</data>
  <data key="d13"></data>
</edge>
<edge source="Bên Bán" target="Điều 443">
  <data key="d7">1.0</data>
  <data key="d8">Bên Bán is obligated to provide necessary information and instructions on the use of the goods.</data>
  <data key="d9">contract enforcement,information obligations</data>
  <data key="d10">chunk-b7c9b850c56df03c6a0092f33eddd51c</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850316</data>
  <data key="d13"></data>
</edge>
<edge source="Bên Bán" target="Thiệt Hại">
  <data key="d7">1.0</data>
  <data key="d8">Bên Bán may be required to compensate for damages if they fail to fulfill their obligations under the contract.</data>
  <data key="d9">contract enforcement,damage compensation</data>
  <data key="d10">chunk-b7c9b850c56df03c6a0092f33eddd51c</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850316</data>
  <data key="d13"></data>
</edge>
<edge source="Bên Bán" target="Thủ Tục Đăng Ký">
  <data key="d7">1.0</data>
  <data key="d8">Bên Bán may be required to complete registration procedures for certain types of assets.</data>
  <data key="d9">contract enforcement,registration procedures</data>
  <data key="d10">chunk-b7c9b850c56df03c6a0092f33eddd51c</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850316</data>
  <data key="d13"></data>
</edge>
<edge source="Bên Bán" target="Chi Phí Vận Chuyển">
  <data key="d7">1.0</data>
  <data key="d8">Bên Bán may be responsible for transportation costs unless otherwise agreed upon.</data>
  <data key="d9">contract enforcement,transportation costs</data>
  <data key="d10">chunk-b7c9b850c56df03c6a0092f33eddd51c</data>
  <data key="d11">unknown_source</data>
