<edge source="Chủ sở hữu" target="Hoa lợi thu được từ cây">
  <data key="d7">1.0</data>
  <data key="d8">The owner shares the produce from trees that serve as boundary markers between properties.</data>
  <data key="d9">boundary marker,produce sharing</data>
  <data key="d10">chunk-7b345fbbc1125fb4f691693608eb8ffa</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849591</data>
  <data key="d13"></data>
</edge>
<edge source="Chủ sở hữu" target="Thỏa thuận khác">
  <data key="d7">1.0</data>
  <data key="d8">The owner can enter into an alternative agreement regarding the use and maintenance of shared trees.</data>
  <data key="d9">alternative agreement,boundary marker</data>
  <data key="d10">chunk-7b345fbbc1125fb4f691693608eb8ffa</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849591</data>
  <data key="d13"></data>
</edge>
<edge source="Chủ sở hữu" target="Bất động sản liền kề và xung quanh">
  <data key="d7">1.0</data>
  <data key="d8">The owner has a legal obligation to protect adjacent and surrounding properties from potential damage.</data>
  <data key="d9">legal obligation,property protection</data>
  <data key="d10">chunk-7b345fbbc1125fb4f691693608eb8ffa</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849591</data>
  <data key="d13"></data>
</edge>
<edge source="Chủ sở hữu" target="Giới hạn ngăn cách tường của mình">
  <data key="d7">1.0</data>
  <data key="d8">The owner is allowed to modify the wall up to their boundary limit.</data>
  <data key="d9">boundary limit,property modification</data>
  <data key="d10">chunk-7b345fbbc1125fb4f691693608eb8ffa</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849591</data>
  <data key="d13"></data>
</edge>
<edge source="Chủ sở hữu" target="Công trình vệ sinh">
  <data key="d7">1.0</data>
  <data key="d8">The owner must build sanitary facilities at a specified distance from boundary markers.</data>
  <data key="d9">legal regulation,sanitary facility</data>
  <data key="d10">chunk-7b345fbbc1125fb4f691693608eb8ffa</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849591</data>
  <data key="d13"></data>
</edge>
<edge source="Chủ sở hữu" target="Kho chứa chất độc hại">
  <data key="d7">1.0</data>
  <data key="d8">The owner must build storage facilities for hazardous materials at a specified distance from boundary markers.</data>
  <data key="d9">hazardous material storage,legal regulation</data>
  <data key="d10">chunk-7b345fbbc1125fb4f691693608eb8ffa</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849591</data>
  <data key="d13"></data>
</edge>
<edge source="Chủ sở hữu" target="Đường đi chung">
  <data key="d7">1.0</data>
  <data key="d8">The owner must comply with legal regulations regarding the opening of doors and windows towards shared pathways.</data>
  <data key="d9">legal regulation,shared pathway</data>
  <data key="d10">chunk-7b345fbbc1125fb4f691693608eb8ffa</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849591</data>
  <data key="d13"></data>
</edge>
<edge source="Chủ sở hữu" target="Mái che trên cửa ra vào">
  <data key="d7">1.0</data>
  <data key="d8">The owner must ensure the roof over the entrance door is at least 2.5 meters above the ground.</data>
  <data key="d9">entrance door,roof regulation</data>
  <data key="d10">chunk-7b345fbbc1125fb4f691693608eb8ffa</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849591</data>
  <data key="d13"></data>
</edge>
<edge source="Chủ sở hữu" target="Mái che cửa sổ quay ra đường đi chung">
  <data key="d7">1.0</data>
  <data key="d8">The owner must ensure the roof over the window facing the shared pathway is at least 2.5 meters above the ground.</data>
  <data key="d9">roof regulation,window facing shared pathway</data>
  <data key="d10">chunk-7b345fbbc1125fb4f691693608eb8ffa</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849591</data>
  <data key="d13"></data>
</edge>
<edge source="Chủ sở hữu" target="Điều 166">
  <data key="d7">1.0</data>
  <data key="d8">Chủ sở hữu has the right to demand the return of their property from unlawful possessors under Điều 166.</data>
  <data key="d9">legal right,property return</data>
  <data key="d10">chunk-b802398ca6d8541021416cdaf49468d1</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849602</data>
  <data key="d13"></data>
</edge>
<edge source="Chủ sở hữu" target="Điều 168">
  <data key="d7">1.0</data>
  <data key="d8">Chủ sở hữu has the right to demand the return of registered movable property or immovable property from good faith possessors under Điều 168.</data>
  <data key="d9">legal right,property return</data>
  <data key="d10">chunk-b802398ca6d8541021416cdaf49468d1</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849602</data>
  <data key="d13"></data>
</edge>
<edge source="Chủ sở hữu" target="Điều 169">
  <data key="d7">1.0</data>
  <data key="d8">Chủ sở hữu has the right to demand the cessation of unlawful acts that obstruct the exercise of their rights under Điều 169.</data>
  <data key="d9">cessation of obstruction,legal right</data>
  <data key="d10">chunk-b802398ca6d8541021416cdaf49468d1</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849602</data>
  <data key="d13"></data>
</edge>
<edge source="Chủ sở hữu" target="Điều 170">
  <data key="d7">1.0</data>
  <data key="d8">Chủ sở hữu has the right to demand compensation for damages caused by unlawful acts that infringe upon their rights under Điều 170.</data>
  <data key="d9">compensation for damages,legal right</data>
  <data key="d10">chunk-b802398ca6d8541021416cdaf49468d1</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849603</data>
  <data key="d13"></data>
</edge>
<edge source="Chủ sở hữu" target="Điều 171">
  <data key="d7">1.0</data>
  <data key="d8">Chủ sở hữu has the right and obligations in situations of emergency under Điều 171.</data>
  <data key="d9">emergency situation,legal right</data>
  <data key="d10">chunk-b802398ca6d8541021416cdaf49468d1</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849603</data>
  <data key="d13"></data>
</edge>
<edge source="Chủ sở hữu" target="Điều 172">
  <data key="d7">1.0</data>
  <data key="d8">Chủ sở hữu has the obligation to protect the environment when exercising their rights under Điều 172.</data>
  <data key="d9">environmental protection,legal obligation</data>
  <data key="d10">chunk-b802398ca6d8541021416cdaf49468d1</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849603</data>
  <data key="d13"></data>
</edge>
<edge source="Chủ sở hữu" target="Tình thế cấp thiết">
  <data key="d7">1.0</data>
  <data key="d8">Chủ sở hữu is not allowed to obstruct others from using their property or causing damage to it in a situation of emergency to prevent a greater harm under Điều 171.</data>
  <data key="d9">emergency situation,legal obligation</data>
  <data key="d10">chunk-b802398ca6d8541021416cdaf49468d1</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849603</data>
  <data key="d13"></data>
</edge>
<edge source="Chủ sở hữu" target="Đấu giá tài sản">
  <data key="d7">1.0</data>
  <data key="d8">Chủ sở hữu decides to sell property through an auction.</data>
  <data key="d9">auction,decision</data>
  <data key="d10">chunk-fb927ff207ca7e0465d21f05d999a0f9</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850409</data>
  <data key="d13"></data>
</edge>
<edge source="Chủ sở hữu" target="Điều 25">
  <data key="d7">1.0</data>
  <data key="d8">Điều 25 specifies the responsibility of the Owner to sign the amended company charter for a one-member limited liability company.</data>
  <data key="d9">regulation,responsibility</data>
  <data key="d10">chunk-65896b1415c5fb67acfcda61d9b89291</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851643</data>
  <data key="d13"></data>
</edge>
<edge source="Chủ sở hữu" target="Điều 36">
  <data key="d7">1.0</data>
  <data key="d8">Chủ sở hữu is involved in the valuation of assets contributed to capital as per Điều 36.</data>
  <data key="d9">asset valuation,ownership</data>
  <data key="d10">chunk-32bedb7a710b05aeaa67ceee9734170a</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851903</data>
  <data key="d13"></data>
</edge>
<edge source="Chủ sở hữu chung" target="Điều 219">
  <data key="d7">1.0</data>
  <data key="d8">Điều 219 outlines the conditions under which joint owners can divide jointly owned property.</data>
  <data key="d9">legal provision,ownership division</data>
  <data key="d10">chunk-e8a3f543a1762069fe562fe6a382e1b2</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849756</data>
  <data key="d13"></data>
</edge>
<edge source="Chủ sở hữu chung" target="Điều 222">
  <data key="d7">1.0</data>
  <data key="d8">Đиều 222 establishes ownership rights over property obtained through lawful labor, production, business activities, and creative activities.</data>
  <data key="d9">legal provision,ownership rights</data>
  <data key="d10">chunk-e8a3f543a1762069fe562fe6a382e1b2</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849756</data>
  <data key="d13"></data>
</edge>
<edge source="Chủ sở hữu chung" target="Đấu giá tài sản">
  <data key="d7">1.0</data>
  <data key="d8">Chủ sở hữu chung must agree to sell property through an auction.</data>
  <data key="d9">agreement,auction</data>
  <data key="d10">chunk-fb927ff207ca7e0465d21f05d999a0f9</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850409</data>
  <data key="d13"></data>
</edge>
<edge source="Điều 223" target="Người được giao tài sản">
  <data key="d7">1.0</data>
  <data key="d8">Điều 223 establishes that the person who receives property through a contract gains ownership rights over it.</data>
  <data key="d9">contract,ownership rights</data>
  <data key="d10">chunk-79babcd2cf4aac518b57f409f34a0382</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849467</data>
  <data key="d13"></data>
</edge>
<edge source="Điều 223" target="Hợp đồng">
  <data key="d7">1.0</data>
  <data key="d8">Điều 223 establishes ownership rights through various types of contracts.</data>
  <data key="d9">contract,ownership rights</data>
  <data key="d10">chunk-79babcd2cf4aac518b57f409f34a0382</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849468</data>
  <data key="d13"></data>
</edge>
<edge source="Điều 224" target="Người sử dụng tài sản">
  <data key="d7">1.0</data>
  <data key="d8">Điều 224 establishes that the user of a property has rights over the produce or income from the property, starting from the time it is obtained.</data>
  <data key="d9">ownership rights,produce</data>
  <data key="d10">chunk-79babcd2cf4aac518b57f409f34a0382</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849468</data>
  <data key="d13"></data>
</edge>
<edge source="Điều 225" target="Vật chính, vật phụ">
  <data key="d7">1.0</data>
  <data key="d8">Điều 225 governs the rights and obligations of the main and secondary assets involved in the merger of properties.</data>
  <data key="d9">legal provision,merger</data>
  <data key="d10">chunk-79babcd2cf4aac518b57f409f34a0382</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849468</data>
  <data key="d13"></data>
</edge>
<edge source="Điều 225" target="Vật mới">
  <data key="d7">1.0</data>
  <data key="d8">Điều 225 governs the rights and obligations of the new asset created through the merger of properties.</data>
  <data key="d9">legal provision,merger</data>
  <data key="d10">chunk-79babcd2cf4aac518b57f409f34a0382</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849468</data>
  <data key="d13"></data>
</edge>
<edge source="Điều 225" target="Người sáp nhập tài sản">
  <data key="d7">1.0</data>
  <data key="d8">Điều 225 governs the rights and obligations of the person who merges their property with another's.</data>
  <data key="d9">legal provision,merger</data>
  <data key="d10">chunk-79babcd2cf4aac518b57f409f34a0382</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849468</data>
  <data key="d13"></data>
</edge>
<edge source="Điều 225" target="Sáp nhập">
  <data key="d7">1.0</data>
  <data key="d8">Điều 225 governs the rights and obligations in cases of the merger of assets.</data>
  <data key="d9">legal provision,merger</data>
  <data key="d10">chunk-79babcd2cf4aac518b57f409f34a0382</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849468</data>
  <data key="d13"></data>
</edge>
<edge source="Điều 226" target="Vật mới">
  <data key="d7">1.0</data>
  <data key="d8">Điều 226 governs the rights and obligations of the new asset created through the mixing of properties.</data>
  <data key="d9">legal provision,mixing</data>
  <data key="d10">chunk-79babcd2cf4aac518b57f409f34a0382</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849468</data>
  <data key="d13"></data>
</edge>
<edge source="Điều 226" target="Trộn lẫn">
  <data key="d7">1.0</data>
  <data key="d8">Điều 226 governs the rights and obligations in cases of mixing assets.</data>
  <data key="d9">legal provision,mixing</data>
  <data key="d10">chunk-79babcd2cf4aac518b57f409f34a0382</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849468</data>
  <data key="d13"></data>
</edge>
<edge source="Điều 226" target="Người sáp nhập tài sản">
  <data key="d7">1.0</data>
  <data key="d8">Điều 226 governs the rights and obligations of the person who mixes their property with another's.</data>
  <data key="d9">legal provision,mixing</data>
  <data key="d10">chunk-79babcd2cf4aac518b57f409f34a0382</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849468</data>
  <data key="d13"></data>
</edge>
<edge source="Người sử dụng tài sản" target="Hoa lợi, lợi tức">
  <data key="d7">1.0</data>
  <data key="d8">Người sử dụng tài sản has rights over the produce or income from a property.</data>
  <data key="d9">ownership rights,produce</data>
  <data key="d10">chunk-79babcd2cf4aac518b57f409f34a0382</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849468</data>
  <data key="d13"></data>
</edge>
<edge source="Người sử dụng tài sản" target="Thỏa thuận">
  <data key="d7">1.0</data>
  <data key="d8">Thỏa thuận establishes the rights of the user over the produce or income from a property.</data>
  <data key="d9">agreement,ownership rights</data>
  <data key="d10">chunk-79babcd2cf4aac518b57f409f34a0382</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849468</data>
  <data key="d13"></data>
</edge>
<edge source="Người sử dụng tài sản" target="Điều 166">
  <data key="d7">1.0</data>
  <data key="d8">Người sử dụng tài sản can be required to return the property to the owner under Điều 166 if they do not have legal basis for use.</data>
  <data key="d9">legal right,property return</data>
  <data key="d10">chunk-b802398ca6d8541021416cdaf49468d1</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849602</data>
  <data key="d13"></data>
</edge>
<edge source="Người sáp nhập tài sản" target="Vật mới">
  <data key="d7">1.0</data>
  <data key="d8">Người sáp nhập tài sản merges their property with another's, creating new ownership rights and obligations over the new asset.</data>
  <data key="d9">merger,ownership rights</data>
  <data key="d10">chunk-79babcd2cf4aac518b57f409f34a0382</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849467</data>
  <data key="d13"></data>
</edge>
<edge source="Hợp đồng" target="Điều 421">
  <data key="d7">1.0</data>
  <data key="d8">Điều 421 outlines the conditions and procedures for modifying a contract.</data>
  <data key="d9">contract modification,legal provision</data>
  <data key="d10">chunk-4ab904047371ae7e8fd73b147f7f0612</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850167</data>
  <data key="d13"></data>
</edge>
<edge source="Hợp đồng" target="Điều 422">
  <data key="d7">1.0</data>
  <data key="d8">Điều 422 specifies the circumstances under which a contract can be terminated.</data>
  <data key="d9">contract termination,legal provision</data>
  <data key="d10">chunk-4ab904047371ae7e8fd73b147f7f0612</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850167</data>
  <data key="d13"></data>
</edge>
<edge source="Hợp đồng" target="Điều 423">
  <data key="d7">1.0</data>
  <data key="d8">Điều 423 details the conditions under which a contract can be canceled and the rights of the parties involved.</data>
  <data key="d9">contract cancellation,legal provision</data>
  <data key="d10">chunk-4ab904047371ae7e8fd73b147f7f0612</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850167</data>
  <data key="d13"></data>
</edge>
<edge source="Hợp đồng" target="Điều 424">
  <data key="d7">1.0</data>
  <data key="d8">Điều 424 describes the circumstances under which a contract can be canceled due to a party's failure to perform its obligations within a reasonable time.</data>
  <data key="d9">contract cancellation,legal provision</data>
  <data key="d10">chunk-4ab904047371ae7e8fd73b147f7f0612</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850167</data>
  <data key="d13"></data>
</edge>
<edge source="Hợp đồng" target="Điều 425">
  <data key="d7">1.0</data>
  <data key="d8">Điều 425 outlines the conditions under which a contract can be canceled due to a party's inability to perform its obligations.</data>
  <data key="d9">contract cancellation,legal provision</data>
  <data key="d10">chunk-4ab904047371ae7e8fd73b147f7f0612</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850167</data>
  <data key="d13"></data>
</edge>
<edge source="Hợp đồng" target="Điều 426">
  <data key="d7">1.0</data>
  <data key="d8">Điều 426 specifies the circumstances under which a contract can be canceled due to the loss or damage of the subject matter of the contract.</data>
  <data key="d9">contract cancellation,legal provision</data>
  <data key="d10">chunk-4ab904047371ae7e8fd73b147f7f0612</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850167</data>
  <data key="d13"></data>
</edge>
<edge source="Hợp đồng" target="Điều 427">
  <data key="d7">1.0</data>
  <data key="d8">Điều 427 describes the consequences of canceling a contract, including the obligations of the parties and the resolution of disputes.</data>
  <data key="d9">contract cancellation,legal provision</data>
  <data key="d10">chunk-4ab904047371ae7e8fd73b147f7f0612</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850168</data>
  <data key="d13"></data>
</edge>
<edge source="Hợp đồng" target="Người có nghĩa vụ">
  <data key="d7">1.0</data>
  <data key="d8">Người có nghĩa vụ is the party in a contract who is responsible for performing certain obligations.</data>
  <data key="d9">contract obligation,party responsibility</data>
  <data key="d10">chunk-4ab904047371ae7e8fd73b147f7f0612</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850168</data>
  <data key="d13"></data>
</edge>
<edge source="Hợp đồng" target="Người có quyền">
  <data key="d7">1.0</data>
  <data key="d8">Người có quyền is the party in a contract who has the right to demand the performance of certain obligations from the other party.</data>
  <data key="d9">contract right,party entitlement</data>
  <data key="d10">chunk-4ab904047371ae7e8fd73b147f7f0612</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850168</data>
  <data key="d13"></data>
</edge>
<edge source="Hợp đồng" target="Bên kia">
  <data key="d7">1.0</data>
  <data key="d8">Bên kia refers to the other party in a contract, typically in the context of one party's obligations or rights.</data>
  <data key="d9">contract party,counterpart</data>
  <data key="d10">chunk-4ab904047371ae7e8fd73b147f7f0612</data>
  <data key="d11">unknown_source</data>
