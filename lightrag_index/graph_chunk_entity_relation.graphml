  <data key="d7">1.0</data>
  <data key="d8">Tổ Chức Chính Trị - Xã Hội operates within enterprises according</data>
  <data key="d9">operation,political and social organization</data>
  <data key="d10">chunk-870356636a26bb390c46554c34ceb657</data>
  <data key="d11">unknown_source</data>
