  <data key="d11">unknown_source</data>
  <data key="d12">1773850555</data>
  <data key="d13"></data>
</edge>
<edge source="Bên Thuê" target="Chấm Dứt Hợp Đồng">
  <data key="d7">1.0</data>
  <data key="d8">Bên Thuê has the right to terminate the lease agreement under certain conditions.</data>
  <data key="d9">conditions,termination</data>
