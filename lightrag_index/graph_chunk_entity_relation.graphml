  <data key="d7">1.0</data>
  <data key="d8">The asset method is used to determine the market value of shares during the conversion process.</data>
  <data key="d9">market value determination,valuation method</data>
  <data key="d10">chunk-0359f960f337b0c62d24c54f784fc5c1</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773853411</data>
