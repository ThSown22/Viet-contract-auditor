<edge source="Người Hứa Thưởng" target="Người Thực Hiện Công Việc">
  <data key="d7">1.0</data>
  <data key="d8">Người Hứa Thưởng promises a reward to Người Thực Hiện Công Việc for completing a specific task.</data>
  <data key="d9">reward,task completion</data>
  <data key="d10">chunk-25258e0d46bb04acb5e0308a2108c231</data>
