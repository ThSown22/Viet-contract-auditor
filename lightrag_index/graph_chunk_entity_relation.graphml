</edge>
<edge source="Hội đồng quản trị" target="Ban kiểm soát">
  <data key="d7">2.0</data>
  <data key="d8">Ban kiểm soát supervises the management and operations of the company, including the activities of the Hội đồng quản trị.&lt;SEP&gt;Hội đồng quản trị oversees the activities of the Ban kiểm soát to ensure compliance with regulations.</data>
  <data key="d9">management,oversight,supervision</data>
  <data key="d10">chunk-795fb9faa3ff64c104def58573301724&lt;SEP&gt;chunk-954105a0b477a911ae8062a76843dd6d</data>
