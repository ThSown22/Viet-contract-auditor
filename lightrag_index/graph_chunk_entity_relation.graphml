  <data key="d0">Tiêu Chuẩn Thông Thường</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Tiêu Chuẩn Thông Thường refers to the standard quality criteria used when no specific standards have been published or established by the authorities or industry.</data>
  <data key="d3">chunk-4623833cd0cb1b86833b9050e09612fd</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850373</data>
  <data key="d6"></data>
</node>
