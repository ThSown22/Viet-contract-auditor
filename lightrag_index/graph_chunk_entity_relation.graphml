</edge>
<edge source="Người Thừa Kế" target="Quyền Sở Hữu">
  <data key="d7">1.0</data>
  <data key="d8">Người Thừa Kế gains Quyền Sở Hữu through inheritance as defined by the legal code.</data>
  <data key="d9">inheritance,ownership</data>
  <data key="d10">chunk-63e06b29bf3043507cfbd43beb81a47f</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849736</data>
