<node id="Cầm cố tài sản">
  <data key="d0">Cầm cố tài sản</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Cầm cố tài sản is the act of one party (the pledgor) handing over their property to another party (the pledgee) as collateral for the fulfillment of obligations.</data>
  <data key="d3">chunk-ae8ba811869db57b94f6d4864d7901d2</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850096</data>
  <data key="d6"></data>
</node>
<node id="Bên cầm cố">
  <data key="d0">Bên cầm cố</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Bên cầm cố is the party that hands over their property as collateral to the pledgee.</data>
  <data key="d3">chunk-ae8ba811869db57b94f6d4864d7901d2</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850096</data>
  <data key="d6"></data>
</node>
<node id="Bên nhận cầm cố">
  <data key="d0">Bên nhận cầm cố</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Bên nhận cầm cố is the party that receives the property as collateral from the pledgor.</data>
  <data key="d3">chunk-ae8ba811869db57b94f6d4864d7901d2</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850096</data>
  <data key="d6"></data>
</node>
<node id="Hợp đồng cầm cố tài sản">
  <data key="d0">Hợp đồng cầm cố tài sản</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Hợp đồng cầm cố tài sản is the contract for the pledge of property, which becomes effective upon signing unless otherwise agreed or stipulated by law.</data>
  <data key="d3">chunk-ae8ba811869db57b94f6d4864d7901d2</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850096</data>
  <data key="d6"></data>
</node>
