  <data key="d7">1.0</data>
  <data key="d8">Bên nhận thế chấp receives the property as collateral for an obligation.</data>
  <data key="d9">pledge,receiving collateral</data>
  <data key="d10">chunk-0e01f265574843f568ac9f6ea2cd861c</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849951</data>
  <data key="d13"></data>
</edge>
