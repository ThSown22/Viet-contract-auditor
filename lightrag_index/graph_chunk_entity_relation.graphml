  <data key="d0">Cuộc họp Hội đồng quản trị</data>
  <data key="d1">HÀNH_VI</data>
  <data key="d2">The Board of Directors meeting is a gathering where the Board discusses and makes decisions.</data>
  <data key="d3">chunk-2ec32bc0d8c57985cdac3f5a1383a2dc</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773852853</data>
  <data key="d6"></data>
</node>
<node id="Thành viên Hội đồng quản trị">
  <data key="d0">Thành viên Hội đồng quản trị</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">Board of Directors members are responsible for attending and voting at Board meetings.&lt;SEP&gt;Thành viên Hội đồng quản trị is a member of the governing body of a company responsible for making decisions and overseeing the management of the company.</data>
  <data key="d3">chunk-2ec32bc0d8c57985cdac3f5a1383a2dc&lt;SEP&gt;chunk-954105a0b477a911ae8062a76843dd6d</data>
