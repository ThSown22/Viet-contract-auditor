</edge>
<edge source="Đơn khởi kiện" target="Nguyên đơn">
  <data key="d7">1.0</data>
  <data key="d8">Nguyên đơn files the Đơn khởi kiện to initiate arbitration proceedings.</data>
  <data key="d9">document filing,legal action</data>
  <data key="d10">chunk-ed4ad4b6755ec955ac613350fdb8b3a5</data>
