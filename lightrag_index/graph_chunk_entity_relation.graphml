  <data key="d7">1.0</data>
  <data key="d8">Doanh nghiệp must include the list of founding shareholders in its registration information.</data>
  <data key="d9">founder shareholders,registration information</data>
  <data key="d10">chunk-64b8fad75bc3785889ce216fbcf53556</data>
  <data key="d11">unknown_source</data>
