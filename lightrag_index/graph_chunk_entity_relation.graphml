  <data key="d7">1.0</data>
  <data key="d8">The termination of collateralization can occur when the collateral asset has been processed.</data>
  <data key="d9">asset processing,termination condition</data>
  <data key="d10">chunk-ef30533c311bc88d4ba5ae54e8e8cca7</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849809</data>
  <data key="d13"></data>
</edge>
