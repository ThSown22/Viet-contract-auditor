<edge source="Điều 200" target="Doanh Nghiệp">
  <data key="d7">1.0</data>
  <data key="d8">Doanh Nghiệp manages and uses state-invested assets according to the law.</data>
  <data key="d9">enterprise role,property management</data>
  <data key="d10">chunk-7d82c525b3c62a646037cf7bc6fec6a5</data>
