  <data key="d11">unknown_source</data>
  <data key="d12">1773852277</data>
  <data key="d13"></data>
</edge>
<edge source="Luật" target="Điều 102">
  <data key="d7">1.0</data>
  <data key="d8">Điều 102 is a part of the law that specifies the conditions for the removal and dismissal of Directors, General Directors, and other managers of a company.</data>
  <data key="d9">legal regulation,removal</data>
  <data key="d10">chunk-33f981a65016c41f688ba0ac17a35ac7</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773852277</data>
  <data key="d13"></data>
</edge>
<edge source="Luật" target="Điều 103">
  <data key="d7">1.0</data>
  <data key="d8">Điều 103 is a part of the law that details the establishment of the Supervisory Board and the qualifications for Supervisors of a company.</data>
  <data key="d9">legal regulation,supervisory board</data>
  <data key="d10">chunk-33f981a65016c41f688ba0ac17a35ac7</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773852277</data>
  <data key="d13"></data>
</edge>
