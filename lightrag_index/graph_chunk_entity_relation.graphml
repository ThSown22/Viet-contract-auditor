  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Quyết định áp dụng biện pháp khẩn cấp tạm thời is a decision made by Hội đồng trọng tài to apply emergency measures.</data>
  <data key="d3">chunk-b47a7db90a1e526f1797874efef64872</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773853990</data>
  <data key="d6"></data>
</node>
<node id="Đơn yêu cầu áp dụng biện pháp khẩn cấp tạm thời">
  <data key="d0">Đơn yêu cầu áp dụng biện pháp khẩn cấp tạm thời</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Đơn yêu cầu áp dụng biện pháp khẩn cấp tạm thời is a request document submitted by Bên yêu cầu to Hội đồng trọng tài.</data>
  <data key="d3">chunk-b47a7db90a1e526f1797874efef64872</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773853990</data>
  <data key="d6"></data>
</node>
<node id="Chứng cứ">
  <data key="d0">Chứng cứ</data>
  <data key="d1">VĂN_BẢN_PHÁP_LUẬT</data>
  <data key="d2">Chứng cứ is evidence provided by Bên yêu cầu to prove the necessity of applying emergency measures.</data>
  <data key="d3">chunk-b47a7db90a1e526f1797874efef64872</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773853990</data>
  <data key="d6"></data>
</node>
<node id="Khoản tiền, kim khí quý, đá quý hoặc giấy tờ có giá">
  <data key="d0">Khoản tiền, kim khí quý, đá quý hoặc giấy tờ có giá</data>
  <data key="d1">VĂN_BẢN_PHÁP_LUẬT</data>
  <data key="d2">Khoản tiền, kim khí quý, đá quý hoặc giấy tờ có giá is collateral provided by Bên yêu cầu to protect the interests of Bên bị áp dụng.</data>
  <data key="d3">chunk-b47a7db90a1e526f1797874efef64872</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773853990</data>
  <data key="d6"></data>
</node>
<node id="Điều 50">
  <data key="d0">Điều 50</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Điều 50 is a legal concept that outlines the procedures for applying emergency measures by Hội đồng trọng tài.</data>
  <data key="d3">chunk-b47a7db90a1e526f1797874efef64872</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773853990</data>
  <data key="d6"></data>
</node>
<node id="Điều 51">
  <data key="d0">Điều 51</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Điều 51 is a legal concept that outlines the authority and procedures for changing, supplementing, or canceling emergency measures by Hội đồng trọng tài.</data>
  <data key="d3">chunk-b47a7db90a1e526f1797874efef64872</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773853990</data>
  <data key="d6"></data>
</node>
<node id="Điều  51">
  <data key="d0">Điều  51</data>
  <data key="d3">chunk-b47a7db90a1e526f1797874efef64872</data>
  <data key="d2">Điều 51 outlines the authority and procedures for Hội đồng trọng tài to change, supplement, or cancel emergency measures.</data>
  <data key="d1">UNKNOWN</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773853991</data>
  <data key="d6"></data>
</node>
<node id="Phán Quyết Trọng Tài">
  <data key="d0">Phán Quyết Trọng Tài</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Phán Quyết Trọng Tài is the formal written decision made by the Hội Đồng Trọng Tài to resolve a dispute.</data>
  <data key="d3">chunk-6520e05120076623f2042182e932b3ec</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773854008</data>
  <data key="d6"></data>
</node>
<node id="Đăng Ký Phán Quyết Trọng Tài">
  <data key="d0">Đăng Ký Phán Quyết Trọng Tài</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Đăng Ký Phán Quyết Trọng Tài is the process of registering an arbitration decision at a court.</data>
  <data key="d3">chunk-6520e05120076623f2042182e932b3ec</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773854008</data>
  <data key="d6"></data>
</node>
<node id="Cơ quan, tổ chức, cá nhân">
  <data key="d0">Cơ quan, tổ chức, cá nhân</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">Cơ quan, tổ chức, cá nhân are the entities responsible for managing and providing evidence to the court.</data>
  <data key="d3">chunk-868a62477b36c9e43bd19ac6e811469e</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773854019</data>
  <data key="d6"></data>
</node>
<node id="Sở Tư Pháp">
  <data key="d0">Sở Tư Pháp</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">Sở Tư Pháp is the legal affairs department where the representative office must report its activities annually.</data>
  <data key="d3">chunk-44b958e89c37ebae08442548c41df280</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773854043</data>
  <data key="d6"></data>
</node>
<node id="Luật Trọng Tài">
  <data key="d0">Luật Trọng Tài</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Luật Trọng Tài is the law that governs the establishment, registration, and activities of representative offices and branches of foreign arbitration organizations in Vietnam.</data>
  <data key="d3">chunk-44b958e89c37ebae08442548c41df280</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773854043</data>
  <data key="d6"></data>
</node>
<node id="Cộng Hòa Xã Hội Chủ Nghĩa Việt Nam">
  <data key="d0">Cộng Hòa Xã Hội Chủ Nghĩa Việt Nam</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">Cộng Hòa Xã Hội Chủ Nghĩa Việt Nam is the full name of the Socialist Republic of Vietnam, a member of international treaties.</data>
  <data key="d3">chunk-44b958e89c37ebae08442548c41df280</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773854043</data>
  <data key="d6"></data>
</node>
<node id="Pháp Lệnh Trọng Tài Thương Mại">
  <data key="d0">Pháp Lệnh Trọng Tài Thương Mại</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Pháp Lệnh Trọng Tài Thương Mại is a commercial arbitration decree that becomes obsolete when the new law takes effect.</data>
  <data key="d3">chunk-44b958e89c37ebae08442548c41df280</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773854043</data>
  <data key="d6"></data>
</node>
<node id="Giấy phép thành lập">
  <data key="d0">Giấy phép thành lập</data>
  <data key="d1">VĂN_BẢN_PHÁP_LUẬT</data>
  <data key="d2">Giấy phép thành lập is a permit required for the establishment of a representative office or branch of a foreign arbitration organization in Vietnam.</data>
  <data key="d3">chunk-44b958e89c37ebae08442548c41df280</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773854043</data>
  <data key="d6"></data>
</node>
<node id="Giấy đăng ký hoạt động">
  <data key="d0">Giấy đăng ký hoạt động</data>
  <data key="d1">VĂN_BẢN_PHÁP_LUẬT</data>
  <data key="d2">Giấy đăng ký hoạt động is a registration document required for the operation of a representative office or branch of a foreign arbitration organization in Vietnam.</data>
  <data key="d3">chunk-44b958e89c37ebae08442548c41df280</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773854043</data>
  <data key="d6"></data>
</node>
<node id="Các bên">
  <data key="d0">Các bên</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">Các bên refers to the parties involved in the dispute who have the right to request a change in the Arbitrator.</data>
  <data key="d3">chunk-4ad943b03a3a1bf95a1e1d6e04f2b581</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773854048</data>
  <data key="d6"></data>
</node>
<node id="Điều 42">
  <data key="d0">Điều 42</data>
  <data key="d1">HÀNH_VI</data>
  <data key="d2">Điều 42 is a regulation concerning the change of Arbitrators in dispute resolution processes.</data>
  <data key="d3">chunk-4ad943b03a3a1bf95a1e1d6e04f2b581</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773854048</data>
