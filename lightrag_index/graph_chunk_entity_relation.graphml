</edge>
<edge source="Điều 309" target="Bên Cầm Cố">
  <data key="d7">1.0</data>
  <data key="d8">Bên Cầm Cố is involved in the pledge of assets as per the regulations outlined in Điều 309.</data>
  <data key="d9">asset pledge,legal obligation</data>
  <data key="d10">chunk-3cdb3cd8d8583064c0301937b6f4744a</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850053</data>
  <data key="d13"></data>
</edge>
<edge source="Điều 309" target="Bên Nhận Cầm Cố">
  <data key="d7">1.0</data>
  <data key="d8">Bên Nhận Cầm Cố has the right to receive assets as collateral as per the regulations outlined in Điều 309.</data>
  <data key="d9">asset receipt,legal right</data>
  <data key="d10">chunk-3cdb3cd8d8583064c0301937b6f4744a</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850053</data>
  <data key="d13"></data>
</edge>
<edge source="Điều 309" target="Tiểu mục 2. Cầm Cố Tài Sản">
  <data key="d7">1.0</data>
  <data key="d8">Tiểu mục 2. Cầm Cố Tài Sản includes the content of Điều 309, which defines the concept of property pledge.</data>
  <data key="d9">legal article,section content</data>
