  <data key="d7">1.0</data>
  <data key="d8">Article 575 outlines the obligations of the person performing work without authorization.</data>
  <data key="d9">legal requirement,obligation</data>
  <data key="d10">chunk-50c919d97de369bc8d7562186f764b91</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850909</data>
