  <data key="d11">unknown_source</data>
  <data key="d12">1773851062</data>
  <data key="d13"></data>
</edge>
<edge source="Tập quán" target="Điều 5">
  <data key="d7">1.0</data>
  <data key="d8">Article 5 of the Civil Code addresses the application of customs.</data>
  <data key="d9">application,legal reference</data>
