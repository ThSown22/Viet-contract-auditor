<edge source="Pháp nhân" target="Quan hệ dân sự">
  <data key="d7">1.0</data>
  <data key="d8">Legal entities participate in civil relations with rights and obligations.</data>
  <data key="d9">participation,rights and obligations</data>
  <data key="d10">chunk-4c55b09e479fc060292314cb4f8f8302</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849050</data>
  <data key="d13"></data>
</edge>
<edge source="Pháp nhân" target="Pháp nhân thương mại">
  <data key="d7">1.0</data>
  <data key="d8">A commercial legal entity has the primary goal of seeking profit and distributing it to members.</data>
  <data key="d9">commercial entity,profit distribution</data>
  <data key="d10">chunk-12ce4f076c1ad11637bf7e2f3ae95048</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849153</data>
  <data key="d13"></data>
</edge>
<edge source="Pháp nhân" target="Pháp nhân phi thương mại">
  <data key="d7">1.0</data>
  <data key="d8">A non-commercial legal entity does not have the primary goal of seeking profit and does not distribute profits to members.</data>
  <data key="d9">non-commercial entity,non-profit distribution</data>
  <data key="d10">chunk-12ce4f076c1ad11637bf7e2f3ae95048</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849153</data>
  <data key="d13"></data>
</edge>
<edge source="Pháp nhân" target="Điều 85">
  <data key="d7">1.0</data>
  <data key="d8">Điều 85 defines the representation of a legal entity, which can be either legal representation or representation by authorization.</data>
  <data key="d9">legal entity,representation</data>
  <data key="d10">chunk-6d584ac3c571de434dd905552d6d296b</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849345</data>
  <data key="d13"></data>
</edge>
<edge source="Pháp nhân" target="Điều 86">
  <data key="d7">1.0</data>
  <data key="d8">Điều 86 outlines the civil legal capacity of a legal entity, which is the ability to have civil rights and obligations.</data>
  <data key="d9">civil legal capacity,rights and obligations</data>
  <data key="d10">chunk-6d584ac3c571de434dd905552d6d296b</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849345</data>
  <data key="d13"></data>
</edge>
<edge source="Pháp nhân" target="Điều 87">
  <data key="d7">1.0</data>
  <data key="d8">Điều 87 details the civil liability of a legal entity, which includes responsibility for actions taken by its representatives.</data>
  <data key="d9">civil liability,responsibility</data>
  <data key="d10">chunk-6d584ac3c571de434dd905552d6d296b</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849345</data>
  <data key="d13"></data>
</edge>
<edge source="Pháp nhân" target="Điều 88">
  <data key="d7">1.0</data>
  <data key="d8">Điều 88 describes the merger of legal entities, where multiple entities can merge into a new entity.</data>
  <data key="d9">merger,new entity</data>
  <data key="d10">chunk-6d584ac3c571de434dd905552d6d296b</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849345</data>
  <data key="d13"></data>
</edge>
<edge source="Pháp nhân" target="Đиều 89">
  <data key="d7">1.0</data>
  <data key="d8">Đиều 89 explains the absorption of one legal entity into another.</data>
  <data key="d9">absorption,new entity</data>
  <data key="d10">chunk-6d584ac3c571de434dd905552d6d296b</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849345</data>
  <data key="d13"></data>
</edge>
<edge source="Pháp nhân" target="Đиều 90">
  <data key="d7">1.0</data>
  <data key="d8">Đиều 90 covers the division of a legal entity into multiple entities.</data>
  <data key="d9">division,new entities</data>
  <data key="d10">chunk-6d584ac3c571de434dd905552d6d296b</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849345</data>
  <data key="d13"></data>
</edge>
<edge source="Pháp nhân" target="Đиều 91">
  <data key="d7">1.0</data>
  <data key="d8">Đиều 91 discusses the separation of a legal entity into multiple entities.</data>
  <data key="d9">new entities,separation</data>
  <data key="d10">chunk-6d584ac3c571de434dd905552d6d296b</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849345</data>
  <data key="d13"></data>
</edge>
<edge source="Pháp nhân" target="Đиều 92">
  <data key="d7">1.0</data>
  <data key="d8">Đиều 92 addresses the transformation of a legal entity into a different form.</data>
  <data key="d9">new form,transformation</data>
  <data key="d10">chunk-6d584ac3c571de434dd905552d6d296b</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849345</data>
  <data key="d13"></data>
</edge>
<edge source="Pháp nhân" target="Người đại diện">
  <data key="d7">1.0</data>
  <data key="d8">Pháp nhân has representatives (Người đại diện) who can act either by legal authority or by authorization.</data>
  <data key="d9">legal entity,representation</data>
  <data key="d10">chunk-6d584ac3c571de434dd905552d6d296b</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849345</data>
  <data key="d13"></data>
</edge>
<edge source="Pháp nhân" target="Sáng lập viên">
  <data key="d7">1.0</data>
  <data key="d8">Pháp nhân has founders (Sáng lập viên) who are responsible for establishing the entity.</data>
  <data key="d9">founder,legal entity</data>
  <data key="d10">chunk-6d584ac3c571de434dd905552d6d296b</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849345</data>
  <data key="d13"></data>
</edge>
<edge source="Pháp nhân" target="Trách nhiệm dân sự">
  <data key="d7">1.0</data>
  <data key="d8">Pháp nhân has civil liability (Trách nhiệm dân sự), which includes responsibility for actions taken by its representatives.</data>
  <data key="d9">civil liability,responsibility</data>
  <data key="d10">chunk-6d584ac3c571de434dd905552d6d296b</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849345</data>
  <data key="d13"></data>
</edge>
<edge source="Pháp nhân" target="Hợp nhất pháp nhân">
  <data key="d7">1.0</data>
  <data key="d8">Pháp nhân can undergo a merger (Hợp nhất pháp nhân) to form a new entity.</data>
  <data key="d9">merger,new entity</data>
  <data key="d10">chunk-6d584ac3c571de434dd905552d6d296b</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849345</data>
  <data key="d13"></data>
</edge>
<edge source="Pháp nhân" target="Sáp nhập pháp nhân">
  <data key="d7">1.0</data>
  <data key="d8">Pháp nhân can be absorbed (Sáp nhập pháp nhân) into another entity.</data>
  <data key="d9">absorption,new entity</data>
  <data key="d10">chunk-6d584ac3c571de434dd905552d6d296b</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849345</data>
  <data key="d13"></data>
</edge>
<edge source="Pháp nhân" target="Chia pháp nhân">
  <data key="d7">1.0</data>
  <data key="d8">Pháp nhân can be divided (Chia pháp nhân) into multiple entities.</data>
  <data key="d9">division,new entities</data>
  <data key="d10">chunk-6d584ac3c571de434dd905552d6d296b</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849345</data>
  <data key="d13"></data>
</edge>
<edge source="Pháp nhân" target="Tách pháp nhân">
  <data key="d7">1.0</data>
  <data key="d8">Pháp nhân can be separated (Tách pháp nhân) into multiple entities.</data>
  <data key="d9">new entities,separation</data>
  <data key="d10">chunk-6d584ac3c571de434dd905552d6d296b</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849345</data>
  <data key="d13"></data>
</edge>
<edge source="Pháp nhân" target="Chuyển đổi hình thức của pháp nhân">
  <data key="d7">1.0</data>
  <data key="d8">Pháp nhân can be transformed (Chuyển đổi hình thức của pháp nhân) into a different form.</data>
  <data key="d9">new form,transformation</data>
  <data key="d10">chunk-6d584ac3c571de434dd905552d6d296b</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849345</data>
  <data key="d13"></data>
</edge>
<edge source="Pháp nhân" target="Người đứng đầu chi nhánh">
  <data key="d7">1.0</data>
  <data key="d8">Pháp nhân authorizes Người đứng đầu chi nhánh to perform tasks within the scope and duration of the authorization.</data>
  <data key="d9">authorization,representation</data>
  <data key="d10">chunk-6d584ac3c571de434dd905552d6d296b</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849345</data>
  <data key="d13"></data>
</edge>
<edge source="Pháp nhân" target="Văn phòng đại diện">
  <data key="d7">1.0</data>
  <data key="d8">Pháp nhân authorizes Văn phòng đại diện to perform tasks within the scope and duration of the authorization.</data>
  <data key="d9">authorization,representation</data>
  <data key="d10">chunk-6d584ac3c571de434dd905552d6d296b</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849345</data>
  <data key="d13"></data>
</edge>
<edge source="Pháp nhân" target="Giao dịch dân sự">
  <data key="d7">1.0</data>
  <data key="d8">Pháp nhân has civil rights and obligations arising from civil transactions performed by its branches or representative offices.</data>
  <data key="d9">civil rights,obligations</data>
  <data key="d10">chunk-6d584ac3c571de434dd905552d6d296b</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849345</data>
  <data key="d13"></data>
</edge>
<edge source="Pháp nhân" target="Điều 137">
  <data key="d7">1.0</data>
  <data key="d8">Điều 137 defines the legal representation of a legal entity.</data>
  <data key="d9">legal provision,representation</data>
  <data key="d10">chunk-737848ae2370b96df322ed1b985e715f</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849397</data>
  <data key="d13"></data>
</edge>
<edge source="Pháp nhân" target="Người đại diện theo pháp luật">
  <data key="d7">1.0</data>
  <data key="d8">Pháp nhân can designate a legal representative by the entity itself, by law, or by the court.</data>
  <data key="d9">designation,legal representation</data>
  <data key="d10">chunk-737848ae2370b96df322ed1b985e715f</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849397</data>
  <data key="d13"></data>
</edge>
<edge source="Pháp nhân" target="Đиều 597">
  <data key="d7">1.0</data>
  <data key="d8">Đиều 597 covers compensation for damages caused by individuals acting on behalf of a legal entity.</data>
  <data key="d9">compensation,legal entity</data>
