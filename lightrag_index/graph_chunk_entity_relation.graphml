  <data key="d12">1773852817</data>
  <data key="d13"></data>
</edge>
<edge source="Đại hội đồng cổ đông" target="Dự thảo nghị quyết">
  <data key="d7">1.0</data>
  <data key="d8">Dự thảo nghị quyết is a draft resolution to be discussed and voted on at the meeting.</data>
  <data key="d9">meeting outcomes,resolution</data>
  <data key="d10">chunk-3c9b32b2b806556ed1dd36c13de6e313</data>
