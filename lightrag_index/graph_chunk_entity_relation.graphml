  <data key="d7">1.0</data>
  <data key="d8">Bên Đề Nghị can receive a notification of acceptance of the proposal to enter into a contract.</data>
  <data key="d9">acceptance,notification</data>
  <data key="d10">chunk-b76bceedbe3231fcd1a7081ac9ec062b</data>
  <data key="d11">unknown_source</data>
