  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Biện pháp khẩn cấp tạm thời refers to temporary emergency measures that can be applied to prevent adverse actions during the arbitration process.</data>
  <data key="d3">chunk-c0133fbf4562d8d0b8d51451c1447d8e</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773853899</data>
