</edge>
<edge source="Thỏa thuận trọng tài" target="Hình thức thoả thuận trọng tài">
  <data key="d7">1.0</data>
  <data key="d8">Thỏa thuận trọng tài can be established in various forms as specified in the legal framework.</data>
  <data key="d9">arbitration agreement,form</data>
  <data key="d10">chunk-f4e87b9226945fe55349146eaa7dc3c3</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773853605</data>
