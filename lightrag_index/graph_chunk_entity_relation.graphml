<edge source="Điều 141" target="Danh sách cổ đông">
  <data key="d7">1.0</data>
  <data key="d8">Điều 141 outlines the process for creating the Danh sách cổ đông for the Đại hội đồng cổ đông.</data>
  <data key="d9">creation process,regulation</data>
  <data key="d10">chunk-29365a5c3fbe3ae076f76826fc009a7a</data>
  <data key="d11">unknown_source</data>
