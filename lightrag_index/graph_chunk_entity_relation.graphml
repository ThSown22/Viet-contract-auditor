  <data key="d0">Điều 502</data>
  <data key="d1">HÀNH_VI</data>
  <data key="d2">Điều 502 outlines the form and procedures for implementing land use rights contracts.</data>
  <data key="d3">chunk-8d2cf1280fe7dc5dd2f57d5818548506</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850536</data>
  <data key="d6"></data>
</node>
<node id="Điều 503">
  <data key="d0">Điều 503</data>
  <data key="d1">HÀNH_VI</data>
  <data key="d2">Điều 503 specifies the effectiveness of transferring land use rights, which takes effect from the registration date as per the Land Law.</data>
  <data key="d3">chunk-8d2cf1280fe7dc5dd2f57d5818548506</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850536</data>
  <data key="d6"></data>
</node>
<node id="Điều 504">
  <data key="d0">Điều 504</data>
  <data key="d1">HÀNH_VI</data>
  <data key="d2">Điều 504 defines the cooperative contract as an agreement between individuals or legal entities to contribute assets and labor for a specific task, share profits, and assume responsibilities.</data>
  <data key="d3">chunk-8d2cf1280fe7dc5dd2f57d5818548506</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850537</data>
  <data key="d6"></data>
</node>
<node id="Điều 505">
  <data key="d0">Điều 505</data>
  <data key="d1">HÀNH_VI</data>
  <data key="d2">Điều 505 details the content of a cooperative contract, including purposes, duration, names and addresses of individuals, assets contributed, labor contributions, profit-sharing methods, rights and obligations of members, and conditions for joining and leaving the contract.</data>
  <data key="d3">chunk-8d2cf1280fe7dc5dd2f57d5818548506</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850537</data>
  <data key="d6"></data>
</node>
