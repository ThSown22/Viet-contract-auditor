<edge source="Hợp đồng hợp tác" target="Đиều 504">
  <data key="d7">1.0</data>
  <data key="d8">Đиều 504 defines the cooperative contract as an agreement between individuals or legal entities to contribute assets and labor for a specific task, share profits, and assume responsibilities.</data>
  <data key="d9">agreement terms,contract definition</data>
  <data key="d10">chunk-8d2cf1280fe7dc5dd2f57d5818548506</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850537</data>
  <data key="d13"></data>
</edge>
<edge source="Hợp đồng hợp tác" target="Đиều 505">
  <data key="d7">1.0</data>
  <data key="d8">Đиều 505 details the content of a cooperative contract, including purposes, duration, names and addresses of individuals, assets contributed, labor contributions, profit-sharing methods, rights and obligations of members, and conditions for joining and leaving the contract.</data>
  <data key="d9">agreement terms,contract content</data>
  <data key="d10">chunk-8d2cf1280fe7dc5dd2f57d5818548506</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850537</data>
  <data key="d13"></data>
</edge>
<edge source="Tài sản chung của các thành viên hợp tác" target="Đиều 506">
  <data key="d7">1.0</data>
  <data key="d8">Đиều 506 describes the common property of cooperative members, including assets contributed, jointly created, and other assets as per the law, and the conditions for disposing of these assets.</data>
  <data key="d9">asset contribution,shared ownership</data>
