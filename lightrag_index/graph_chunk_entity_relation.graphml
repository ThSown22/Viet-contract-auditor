  <data key="d0">Thủ tục chuyển đổi loại hình doanh nghiệp</data>
  <data key="d1">HÀNH_VI</data>
  <data key="d2">Thủ tục chuyển đổi loại hình doanh nghiệp is a process for changing the type of business entity.</data>
