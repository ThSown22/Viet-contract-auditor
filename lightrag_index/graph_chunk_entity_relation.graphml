<node id="Người Chiếm Hữu">
  <data key="d0">Người Chiếm Hữu</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">A person who possesses or uses another's property without legal basis and must return it to the rightful owner.</data>
  <data key="d3">chunk-821c3a34361b8add641406062fd4a10e</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773851194</data>
  <data key="d6"></data>
</node>
<node id="Người Sử Dụng Tài Sản">
  <data key="d0">Người Sử Dụng Tài Sản</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">A person who uses another's property without legal basis and must return it to the rightful owner.</data>
  <data key="d3">chunk-821c3a34361b8add641406062fd4a10e</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773851194</data>
  <data key="d6"></data>
</node>
<node id="Chủ Thể Có Quyền Khác">
  <data key="d0">Chủ Thể Có Quyền Khác</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">A person with other rights over a property who is entitled to have it returned if it was possessed or used without legal basis.</data>
  <data key="d3">chunk-821c3a34361b8add641406062fd4a10e</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773851194</data>
  <data key="d6"></data>
</node>
<node id="Người Được Lợi">
  <data key="d0">Người Được Lợi</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">A person who benefits from another's property without legal basis and must return the benefit to the person who suffered a loss.</data>
  <data key="d3">chunk-821c3a34361b8add641406062fd4a10e</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773851194</data>
  <data key="d6"></data>
</node>
<node id="Người Bị Thiệt Hại">
  <data key="d0">Người Bị Thiệt Hại</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">A person who suffers a loss due to another's benefit from their property without legal basis and is entitled to have the benefit returned.</data>
  <data key="d3">chunk-821c3a34361b8add641406062fd4a10e</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773851194</data>
  <data key="d6"></data>
</node>
