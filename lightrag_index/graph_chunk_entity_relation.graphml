<node id="Hộ Tịch">
  <data key="d0">Hộ Tịch</data>
  <data key="d1">VĂN_BẢN_PHÁP_LUẬT</data>
  <data key="d2">A legal document that records personal information and changes related to an individual's identity.&lt;SEP&gt;Hộ tịch refers to the legal record of an individual's personal information, which can be updated after a gender transition according to the law.</data>
  <data key="d3">chunk-ba16bb9ed3be84682d4bd14bebf5eaba&lt;SEP&gt;chunk-846633705870effa2d882763f1693f90</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773848981</data>
  <data key="d6"></data>
</node>
<node id="Quyền Được Bảo Vệ Danh Dự, Nhân Phẩm, Uy Tín">
  <data key="d0">Quyền Được Bảo Vệ Danh Dự, Nhân Phẩm, Uy Tín</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">The right to have one's dignity, reputation, and honor protected by law.</data>
  <data key="d3">chunk-ba16bb9ed3be84682d4bd14bebf5eaba</data>
  <data key="d4">unknown_source</data>
