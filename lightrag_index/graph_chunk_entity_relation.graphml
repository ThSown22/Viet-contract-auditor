<node id="Hồ sơ">
  <data key="d0">Hồ sơ</data>
  <data key="d1">VĂN_BẢN_PHÁP_LUẬT</data>
  <data key="d2">Hồ sơ refers to the documents and records required for the registration and change of business registration content.&lt;SEP&gt;Hồ sơ is a file or record.</data>
  <data key="d3">chunk-3fed1e090b51d7382ec575f352792a42&lt;SEP&gt;chunk-45f4215d40e0caccca1eaa62a7f0ec73</data>
