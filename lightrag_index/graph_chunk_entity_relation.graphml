  <data key="d7">1.0</data>
  <data key="d8">Bên Nhận Thế Chấp receives the collateral asset and is involved in its management.</data>
  <data key="d9">asset receipt,collateral management</data>
  <data key="d10">chunk-ef30533c311bc88d4ba5ae54e8e8cca7</data>
