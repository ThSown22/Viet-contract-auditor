<edge source="Tòa án" target="Chủ sở hữu các căn hộ">
  <data key="d7">1.0</data>
  <data key="d8">Tòa án makes decisions regarding the division of shared property among apartment owners.</data>
  <data key="d9">legal decision,property division</data>
