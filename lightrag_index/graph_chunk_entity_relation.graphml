  <data key="d0">Báo Cáo Tài Chính Hợp Nhất</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Báo Cáo Tài Chính Hợp Nhất is a consolidated financial report that includes the financial information of both the parent and subsidiary companies.</data>
  <data key="d3">chunk-b12f2587388d6a4e9e558de512dc2860</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773853348</data>
  <data key="d6"></data>
</node>
