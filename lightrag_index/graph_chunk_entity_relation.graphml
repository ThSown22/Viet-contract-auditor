<node id="Bên Thuê Vận Chuyển">
  <data key="d0">Bên Thuê Vận Chuyển</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">Bên Thuê Vận Chuyển is the party that hires the transportation service and has rights and obligations as defined in the legal text.</data>
  <data key="d3">chunk-9ff345e6f27025707a8c3c4dd1e82b5a</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850606</data>
