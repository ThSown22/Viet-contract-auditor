<edge source="Hợp đồng" target="Công ty">
  <data key="d7">2.0</data>
  <data key="d8">Công ty must disclose information about contracts and agreements with related parties.&lt;SEP&gt;Hợp đồng is a contract or agreement related to the company.</data>
  <data key="d9">agreements,contracts</data>
  <data key="d10">chunk-41835b63d2a39e7a4ba760332a2b8046&lt;SEP&gt;chunk-45f4215d40e0caccca1eaa62a7f0ec73</data>
