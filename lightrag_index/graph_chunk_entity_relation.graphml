</edge>
<edge source="Bên Thuê Khoán" target="Khấu Hao">
  <data key="d7">1.0</data>
  <data key="d8">Bên Thuê Khoán must return the Tài Sản Thuê Khoán in a condition consistent with the agreed-upon depreciation at the end of the lease.</data>
  <data key="d9">depreciation,property return</data>
  <data key="d10">chunk-c98a39a79e1becf58880e1971e3ad611</data>
  <data key="d11">unknown_source</data>
