  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Hợp đồng mua trả chậm hoặc trả dần is a contract where the buyer agrees to pay for the purchased property in installments over a specified period.</data>
  <data key="d3">chunk-fb927ff207ca7e0465d21f05d999a0f9</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850409</data>
  <data key="d6"></data>
</node>
<node id="Giấy tờ về quyền sở hữu">
  <data key="d0">Giấy tờ về quyền sở hữu</data>
  <data key="d1">VĂN_BẢN_PHÁP_LUẬT</data>
  <data key="d2">Giấy tờ về quyền sở hữu are documents that transfer ownership rights from the seller to the buyer.</data>
  <data key="d3">chunk-fb927ff207ca7e0465d21f05d999a0f9</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850409</data>
  <data key="d6"></data>
</node>
