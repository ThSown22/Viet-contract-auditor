</edge>
<edge source="Luật này" target="Trọng tài viên">
  <data key="d7">1.0</data>
  <data key="d8">Luật này governs the procedures for selecting and designating a replacement Trọng tài viên.</data>
  <data key="d9">legal framework,procedure</data>
  <data key="d10">chunk-4ad943b03a3a1bf95a1e1d6e04f2b581</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773854050</data>
  <data key="d13"></data>
</edge>
<edge source="Hội đồng thành viên" target="Điều 53">
  <data key="d7">1.0</data>
  <data key="d8">Điều 53 outlines the role of the board of members in deciding the acceptance of new members.</data>
  <data key="d9">board decision,legal provision</data>
  <data key="d10">chunk-7934cedd8a058c40a35091be7e3f1c17</data>
