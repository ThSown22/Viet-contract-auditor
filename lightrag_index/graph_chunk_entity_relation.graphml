<node id="Viện kiểm sát">
  <data key="d0">Viện kiểm sát</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">Viện kiểm sát is an organization that oversees the legal process and ensures the proper execution of decisions.&lt;SEP&gt;Viện kiểm sát is the prosecution office that performs its functions and duties according to the law.</data>
  <data key="d3">chunk-c0133fbf4562d8d0b8d51451c1447d8e&lt;SEP&gt;chunk-868a62477b36c9e43bd19ac6e811469e</data>
