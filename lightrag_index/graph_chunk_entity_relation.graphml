  <data key="d1">HÀNH_VI</data>
  <data key="d2">Điều 408 is a legal provision that outlines the rules for contracts that are invalid due to an unperformable subject matter.</data>
  <data key="d3">chunk-57605bee043e497a16d0db0a26012d1e</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850297</data>
