</edge>
<edge source="Doanh nghiệp" target="Ngành, nghề đăng ký kinh doanh">
  <data key="d7">1.0</data>
  <data key="d8">A business entity must register its industry and business activities, which must not be prohibited by law.</data>
  <data key="d9">compliance,registration</data>
  <data key="d10">chunk-a8de4c57592fe998c634734476be0f10</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851651</data>
