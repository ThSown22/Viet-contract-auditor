  <data key="d13"></data>
</edge>
<edge source="Chấm Dứt Thế Chấp Tài Sản" target="Nghĩa Vụ">
  <data key="d7">1.0</data>
  <data key="d8">The termination of collateralization can occur when the obligations secured by the collateral are fulfilled.</data>
  <data key="d9">obligation fulfillment,termination condition</data>
  <data key="d10">chunk-ef30533c311bc88d4ba5ae54e8e8cca7</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849809</data>
  <data key="d13"></data>
</edge>
