  <data key="d11">unknown_source</data>
  <data key="d12">1773849756</data>
  <data key="d13"></data>
</edge>
<edge source="Tòa án" target="Hợp đồng">
  <data key="d7">1.0</data>
  <data key="d8">Tòa án resolves disputes and enforces the terms of contracts.</data>
  <data key="d9">dispute resolution,legal enforcement</data>
  <data key="d10">chunk-4ab904047371ae7e8fd73b147f7f0612</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850168</data>
  <data key="d13"></data>
</edge>
<edge source="Tòa án" target="Điều 420">
  <data key="d7">1.0</data>
  <data key="d8">Tòa án can decide on the modification or termination of a contract in the event of a fundamental change in circumstances, as outlined in Điều 420.</data>
  <data key="d9">contract modification,court decision</data>
  <data key="d10">chunk-f99273835b3b6031602578494c58acd7</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850193</data>
  <data key="d13"></data>
</edge>
<edge source="Tòa án" target="Điều 429">
  <data key="d7">1.0</data>
  <data key="d8">Đиều 429 specifies the statute of limitations for initiating a lawsuit regarding contract disputes in court.</data>
  <data key="d9">lawsuit initiation,statute of limitations</data>
  <data key="d10">chunk-fd76a1e6d7896b3bdcaa4bbcae2b9dea</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850248</data>
  <data key="d13"></data>
</edge>
<edge source="Tòa án" target="Người chết">
  <data key="d7">1.0</data>
  <data key="d8">Tòa án can declare a person as deceased.</data>
  <data key="d9">death announcement,legal declaration</data>
  <data key="d10">chunk-2dbdbb74ad11a83bf1856f95ecdfa309</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851096</data>
  <data key="d13"></data>
</edge>
<edge source="Tòa án" target="Điều 662">
  <data key="d7">1.0</data>
  <data key="d8">Tòa án has the authority to extend the time limit for dividing an estate if it affects the family's livelihood, as outlined in Điều 662.</data>
  <data key="d9">judicial authority,legal provision</data>
  <data key="d10">chunk-651ba86aa84dcd7fdcb6fe6cfa6aacef</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851459</data>
  <data key="d13"></data>
</edge>
<edge source="Tòa án" target="bên còn sống">
  <data key="d7">1.0</data>
  <data key="d8">bên còn sống can request an extension of the time limit for dividing an estate, which is granted by Tòa án.</data>
  <data key="d9">judicial authority,request</data>
  <data key="d10">chunk-651ba86aa84dcd7fdcb6fe6cfa6aacef</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851459</data>
  <data key="d13"></data>
</edge>
<edge source="Tòa án" target="Thông báo thay đổi nội dung đăng ký doanh nghiệp">
  <data key="d7">1.0</data>
  <data key="d8">Tòa án can issue decisions that affect the notification of changes in business registration content.</data>
  <data key="d9">legal decision,registration change</data>
  <data key="d10">chunk-3fed1e090b51d7382ec575f352792a42</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851613</data>
  <data key="d13"></data>
</edge>
<edge source="Tòa án" target="Giấy chứng nhận đăng ký doanh nghiệp">
  <data key="d7">2.0</data>
  <data key="d8">The Court can make decisions that lead to changes in the content of the Certificate of Business Registration.&lt;SEP&gt;Tòa án can make decisions to revoke a business's registration certificate.</data>
  <data key="d9">change,decision,judicial decision,revocation</data>
  <data key="d10">chunk-a8de4c57592fe998c634734476be0f10&lt;SEP&gt;chunk-45f9f1328d58ac04c74cf2a1422490ab</data>
