  <data key="d7">1.0</data>
  <data key="d8">Damages caused by the violation of obligations are related to the obligation to prevent and limit damages.</data>
  <data key="d9">damage,prevention</data>
  <data key="d10">chunk-428a1a2119667172b8e431b501835f64</data>
  <data key="d11">unknown_source</data>
