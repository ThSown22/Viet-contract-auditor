  <data key="d0">Cổ đông hoặc nhóm cổ đông</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">Cổ đông hoặc nhóm cổ đông refers to shareholders or groups of shareholders.</data>
  <data key="d3">chunk-795fb9faa3ff64c104def58573301724</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773852942</data>
  <data key="d6"></data>
</node>
<node id="Kiểm soát viên công ty đại chúng">
  <data key="d0">Kiểm soát viên công ty đại chúng</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">Kiểm soát viên công ty đại chúng is a public company supervisor who must not have familial relationships with company managers.</data>
  <data key="d3">chunk-795fb9faa3ff64c104def58573301724</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773852942</data>
  <data key="d6"></data>
</node>
<node id="Người quản lý doanh nghiệp">
  <data key="d0">Người quản lý doanh nghiệp</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">Người quản lý doanh nghiệp is a company manager who must not have familial relationships with supervisors.</data>
  <data key="d3">chunk-795fb9faa3ff64c104def58573301724</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773852942</data>
  <data key="d6"></data>
</node>
<node id="Người đại diện phần vốn của doanh nghiệp">
  <data key="d0">Người đại diện phần vốn của doanh nghiệp</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">Người đại diện phần vốn của doanh nghiệp is a representative of the company's equity.&lt;SEP&gt;Người đại diện phần vốn của doanh nghiệp is a representative of the company's equity, and Kiểm soát viên cannot be this person.</data>
  <data key="d3">chunk-795fb9faa3ff64c104def58573301724&lt;SEP&gt;chunk-b8bb762ad781038843f3cf2f3790105d</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773853165</data>
  <data key="d6"></data>
</node>
