</edge>
<edge source="Điều 373" target="Nghĩa vụ">
  <data key="d7">1.0</data>
  <data key="d8">Article 373 defines the completion of an obligation when the obligor has fulfilled the obligation or the party with the right has waived the remaining part.</data>
  <data key="d9">completion,fulfillment</data>
