</edge>
<edge source="Bên Bán" target="Nghĩa Vụ Cung Cấp Thông Tin">
  <data key="d7">1.0</data>
  <data key="d8">Bên Bán is obligated to provide necessary information about the purchased property and guide the buyer on its use.</data>
  <data key="d9">information provision,obligation</data>
