  <data key="d3">chunk-b1c19a83d55829491343a14f74bec683</data>
  <data key="d2">Điều 549 specifies the legal provision for the delivery and acceptance of the finished product.</data>
  <data key="d1">UNKNOWN</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850652</data>
  <data key="d6"></data>
</node>
<node id="Thành Viên Hợp Tác">
  <data key="d0">Thành Viên Hợp Tác</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">Thành viên hợp tác refers to the members of a cooperative who are responsible for the cooperative's civil liabilities and have the right to join or leave the cooperative under certain conditions.</data>
  <data key="d3">chunk-63bea5bd12d1af991f494c7882f65825</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850693</data>
  <data key="d6"></data>
</node>
<node id="Hợp Đồng Hợp Tác">
  <data key="d0">Hợp Đồng Hợp Tác</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Hợp đồng hợp tác is a contract among members of a cooperative that defines their rights and obligations, including the conditions for joining, leaving, and the dissolution of the cooperative.</data>
  <data key="d3">chunk-63bea5bd12d1af991f494c7882f65825</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850693</data>
  <data key="d6"></data>
</node>
<node id="Tài Sản Chung">
  <data key="d0">Tài Sản Chung</data>
  <data key="d1">VĂN_BẢN_PHÁP_LUẬT</data>
  <data key="d2">Tài sản chung refers to the collective assets of a cooperative that are used to fulfill the cooperative's obligations.</data>
  <data key="d3">chunk-63bea5bd12d1af991f494c7882f65825</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850693</data>
  <data key="d6"></data>
</node>
<node id="Tài Sản Riêng">
  <data key="d0">Tài Sản Riêng</data>
  <data key="d1">VĂN_BẢN_PHÁP_LUẬT</data>
  <data key="d2">Tài sản riêng refers to the individual assets of a cooperative member that may be used to fulfill the cooperative's obligations if the collective assets are insufficient.</data>
  <data key="d3">chunk-63bea5bd12d1af991f494c7882f65825</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850693</data>
  <data key="d6"></data>
</node>
<node id="Hợp Đồng Dịch Vụ">
  <data key="d0">Hợp Đồng Dịch Vụ</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Hợp đồng dịch vụ is a contract between service providers and service users, where the service provider performs work for the service user, and the service user pays for the service.&lt;SEP&gt;Hợp Đồng Dịch Vụ is a contract between the service provider and the service user that outlines the terms and conditions of the service.</data>
  <data key="d3">chunk-63bea5bd12d1af991f494c7882f65825&lt;SEP&gt;chunk-e729376fa2e1544912532baf7015b267</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850702</data>
  <data key="d6"></data>
</node>
<node id="Bên Cung Ứng Dịch Vụ">
  <data key="d0">Bên Cung Ứng Dịch Vụ</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Bên cung ứng dịch vụ refers to the party in a service contract that provides services to the service user.&lt;SEP&gt;Bên Cung Ứng Dịch Vụ is a party that provides a service and has rights and obligations as defined in the legal text.</data>
  <data key="d3">chunk-63bea5bd12d1af991f494c7882f65825&lt;SEP&gt;chunk-e729376fa2e1544912532baf7015b267</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850702</data>
  <data key="d6"></data>
</node>
<node id="Bên Sử Dụng Dịch Vụ">
  <data key="d0">Bên Sử Dụng Dịch Vụ</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Bên sử dụng dịch vụ refers to the party in a service contract that receives services and pays for them.&lt;SEP&gt;Bên Sử Dụng Dịch Vụ is a party that uses a service and has rights and obligations as defined in the legal text.</data>
  <data key="d3">chunk-63bea5bd12d1af991f494c7882f65825&lt;SEP&gt;chunk-e729376fa2e1544912532baf7015b267</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850702</data>
  <data key="d6"></data>
</node>
<node id="Điều 509">
  <data key="d0">Điều 509</data>
  <data key="d1">HÀNH_VI</data>
  <data key="d2">Điều 509 is a legal provision that outlines the civil liability of cooperative members.</data>
  <data key="d3">chunk-63bea5bd12d1af991f494c7882f65825</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850693</data>
  <data key="d6"></data>
</node>
<node id="Điều 510">
  <data key="d0">Điều 510</data>
  <data key="d1">HÀNH_VI</data>
  <data key="d2">Điều  510 is a legal provision that outlines the conditions under which a member can leave a cooperative and the responsibilities associated with leaving.</data>
  <data key="d3">chunk-63bea5bd12d1af991f494c7882f65825</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850693</data>
  <data key="d6"></data>
</node>
<node id="Điều 511">
  <data key="d0">Điều 511</data>
  <data key="d1">HÀNH_VI</data>
  <data key="d2">Điều 511 is a legal provision that outlines the conditions for new members to join a cooperative.</data>
  <data key="d3">chunk-63bea5bd12d1af991f494c7882f65825</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850693</data>
  <data key="d6"></data>
</node>
<node id="Điều 512">
  <data key="d0">Điều 512</data>
  <data key="d1">HÀNH_VI</data>
  <data key="d2">Điều 512 is a legal provision that outlines the conditions under which a cooperative contract can be terminated.</data>
  <data key="d3">chunk-63bea5bd12d1af991f494c7882f65825</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850693</data>
  <data key="d6"></data>
</node>
<node id="Điều 513">
  <data key="d0">Điều 513</data>
  <data key="d1">HÀNH_VI</data>
  <data key="d2">Điều 513 is a legal provision that defines what a service contract is.</data>
  <data key="d3">chunk-63bea5bd12d1af991f494c7882f65825</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850693</data>
  <data key="d6"></data>
</node>
<node id="Điều 514">
  <data key="d0">Điều 514</data>
  <data key="d1">HÀNH_VI</data>
  <data key="d2">Điều 514 is a legal provision that defines the subject matter of a service contract.</data>
  <data key="d3">chunk-63bea5bd12d1af991f494c7882f65825</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850693</data>
  <data key="d6"></data>
</node>
<node id="Điều 515">
  <data key="d0">Điều 515</data>
  <data key="d1">HÀNH_VI</data>
  <data key="d2">Đиều 515 is a legal provision that outlines the obligations of the service user in a service contract.</data>
  <data key="d3">chunk-63bea5bd12d1af991f494c7882f65825</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850693</data>
  <data key="d6"></data>
</node>
<node id="Đиều 515">
  <data key="d0">Đиều 515</data>
  <data key="d3">chunk-63bea5bd12d1af991f494c7882f65825</data>
  <data key="d2">Đиều 515 outlines the obligations of the Bên Sử Dụng Dịch Vụ in a service contract.</data>
  <data key="d1">UNKNOWN</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850693</data>
  <data key="d6"></data>
</node>
<node id="Tiền Dịch Vụ">
  <data key="d0">Tiền Dịch Vụ</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Tiền Dịch Vụ is the payment made by the service user to the service provider for the service provided.</data>
  <data key="d3">chunk-e729376fa2e1544912532baf7015b267</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850702</data>
  <data key="d6"></data>
</node>
<node id="Thông Tin">
  <data key="d0">Thông Tin</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Thông Tin refers to the information provided by the service user to the service provider to facilitate the service.</data>
  <data key="d3">chunk-e729376fa2e1544912532baf7015b267</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850702</data>
  <data key="d6"></data>
</node>
<node id="Tài Liệu">
  <data key="d0">Tài Liệu</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Tài Liệu refers to the documents provided by the service user to the service provider to facilitate the service.</data>
  <data key="d3">chunk-e729376fa2e1544912532baf7015b267</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850702</data>
  <data key="d6"></data>
</node>
<node id="Phương Tiện">
  <data key="d0">Phương Tiện</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Phương Tiện refers to the means or tools provided by the service user to the service provider to facilitate the service.</data>
  <data key="d3">chunk-e729376fa2e1544912532baf7015b267</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850702</data>
  <data key="d6"></data>
</node>
<node id="Số Lượng">
  <data key="d0">Số Lượng</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Số Lượng refers to the quantity of the service provided.</data>
  <data key="d3">chunk-e729376fa2e1544912532baf7015b267</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850702</data>
  <data key="d6"></data>
</node>
<node id="Thời Hạn">
  <data key="d0">Thời Hạn</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Thời Hạn refers to the time frame within which the service must be provided.</data>
  <data key="d3">chunk-e729376fa2e1544912532baf7015b267</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850702</data>
  <data key="d6"></data>
</node>
<node id="Địa Điểm">
  <data key="d0">Địa Điểm</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Địa Điểm refers to the location where the service is to be provided.</data>
  <data key="d3">chunk-e729376fa2e1544912532baf7015b267</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850703</data>
  <data key="d6"></data>
</node>
<node id="Bảo Mật Thông Tin">
  <data key="d0">Bảo Mật Thông Tin</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Bảo Mật Thông Tin refers to the confidentiality of information that the service provider must maintain during the service.</data>
  <data key="d3">chunk-e729376fa2e1544912532baf7015b267</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850703</data>
  <data key="d6"></data>
</node>
<node id="Đơn Phương Chấm Dứt Hợp Đồng">
  <data key="d0">Đơn Phương Chấm Dứt Hợp Đồng</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Đơn Phương Chấm Dứt Hợp Đồng refers to the unilateral termination of the service contract by either party.</data>
  <data key="d3">chunk-e729376fa2e1544912532baf7015b267</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850703</data>
  <data key="d6"></data>
</node>
<node id="Tiếp Tục Hợp Đồng Dịch Vụ">
  <data key="d0">Tiếp Tục Hợp Đồng Dịch Vụ</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Tiếp Tục Hợp Đồng Dịch Vụ refers to the automatic continuation of the service contract after the initial term if the service is still being provided and the service user does not object.</data>
  <data key="d3">chunk-e729376fa2e1544912532baf7015b267</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850703</data>
  <data key="d6"></data>
</node>
<node id="Thông Tin, Tài Liệu, Phương Tiện">
  <data key="d0">Thông Tin, Tài Liệu, Phương Tiện</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Thông Tin, Tài Liệu, Phương Tiện refers to the information, documents, and means provided by the service user to the service provider to facilitate the service.</data>
  <data key="d3">chunk-e729376fa2e1544912532baf7015b267</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850703</data>
  <data key="d6"></data>
</node>
<node id="Bên Thuê Khoán">
  <data key="d0">Bên Thuê Khoán</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">Bên Thuê Khoán is a party in a lease agreement who is responsible for using the leased property and making payments as agreed.</data>
  <data key="d3">chunk-c98a39a79e1becf58880e1971e3ad611</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850787</data>
  <data key="d6"></data>
</node>
<node id="Bên Cho Thuê Khoán">
  <data key="d0">Bên Cho Thuê Khoán</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">Bên Cho Thuê Khoán is a party in a lease agreement who owns the leased property and is entitled to receive payments and ensure proper use of the property.</data>
  <data key="d3">chunk-c98a39a79e1becf58880e1971e3ad611</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850787</data>
  <data key="d6"></data>
</node>
<node id="Tài Sản Thuê Khoán">
  <data key="d0">Tài Sản Thuê Khoán</data>
  <data key="d1">VĂN_BẢN_PHÁP_LUẬT</data>
  <data key="d2">Tài Sản Thuê Khoán refers to the property or asset that is leased under a lease agreement.</data>
  <data key="d3">chunk-c98a39a79e1becf58880e1971e3ad611</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850787</data>
  <data key="d6"></data>
</node>
<node id="Hợp Đồng Thuê Khoán">
  <data key="d0">Hợp Đồng Thuê Khoán</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Hợp Đồng Thuê Khoán is a lease agreement that outlines the terms and conditions for the use of leased property.</data>
  <data key="d3">chunk-c98a39a79e1becf58880e1971e3ad611</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850787</data>
  <data key="d6"></data>
</node>
<node id="Hợp Đồng Mượn Tài Sản">
  <data key="d0">Hợp Đồng Mượn Tài Sản</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Hợp Đồng Mượn Tài Sản is an agreement where one party lends property to another for use without payment, and the property must be returned at the end of the agreed period.&lt;SEP&gt;Hợp đồng mượn tài sản is a legal agreement where one party lends an asset to another party for use without payment, and the borrower must return the asset when the agreed period or purpose is completed.</data>
  <data key="d3">chunk-c98a39a79e1becf58880e1971e3ad611&lt;SEP&gt;chunk-9006f99cc5f37528caabd57619fb67d8</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850826</data>
  <data key="d6"></data>
</node>
<node id="Thời Hạn Trả Tiền Thuê Khoán">
  <data key="d0">Thời Hạn Trả Tiền Thuê Khoán</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Thời Hạn Trả Tiền Thuê Khoán refers to the agreed-upon period for payment of lease fees, defaulting to the end of each month if not specified.</data>
  <data key="d3">chunk-c98a39a79e1becf58880e1971e3ad611</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850787</data>
  <data key="d6"></data>
</node>
<node id="Chu Kỳ Sản Xuất, Kinh Doanh">
  <data key="d0">Chu Kỳ Sản Xuất, Kinh Doanh</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Chu Kỳ Sản Xuất, Kinh Doanh is a period defined by production and business cycles, during which lease payments must be made upon completion.</data>
  <data key="d3">chunk-c98a39a79e1becf58880e1971e3ad611</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850787</data>
  <data key="d6"></data>
</node>
<node id="Tình Trạng Tài Sản">
  <data key="d0">Tình Trạng Tài Sản</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Tình Trạng Tài Sản refers to the condition of the leased property, which must be reported periodically by the tenant to the landlord.</data>
  <data key="d3">chunk-c98a39a79e1becf58880e1971e3ad611</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850787</data>
  <data key="d6"></data>
</node>
<node id="Bảo Quản, Bảo Dưỡng Tài Sản Thuê Khoán">
  <data key="d0">Bảo Quản, Bảo Dưỡng Tài Sản Thuê Khoán</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Bảo Quản, Bảo Dưỡng Tài Sản Thuê Khoán refers to the tenant's responsibility to maintain and preserve the leased property at their own expense.</data>
  <data key="d3">chunk-c98a39a79e1becf58880e1971e3ad611</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850787</data>
  <data key="d6"></data>
</node>
<node id="Hoa Lợi, Thiệt Hại Về Gia Súc Thuê Khoán">
  <data key="d0">Hoa Lợi, Thiệt Hại Về Gia Súc Thuê Khoán</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Hoa Lợi, Thiệt Hại Về Gia Súc Thuê Khoán refers to the sharing of profits and losses related to leased livestock, typically split equally between the tenant and landlord.</data>
  <data key="d3">chunk-c98a39a79e1becf58880e1971e3ad611</data>
  <data key="d4">unknown_source</data>
