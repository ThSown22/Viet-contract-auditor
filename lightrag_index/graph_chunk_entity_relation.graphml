  <data key="d0">Người Chiếm Hữu Nhà Cửa, Công Trình Xây Dựng Khác</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">Người Chiếm Hữu Nhà Cửa, Công Trình Xây Dựng Khác is the possessor of houses or other construction projects who is responsible for compensating for any damage caused.</data>
  <data key="d3">chunk-71c1c580c8f92c3838ab0f997647d588</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773851025</data>
  <data key="d6"></data>
</node>
<node id="Người Được Giao Quản Lý, Sử Dụng Nhà Cửa, Công Trình Xây Dựng Khác">
  <data key="d0">Người Được Giao Quản Lý, Sử Dụng Nhà Cửa, Công Trình Xây Dựng Khác</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">Người Được Giao Quản Lý, Sử Dụng Nhà Cửa, Công Trình Xây Dựng Khác is the person entrusted with managing or using houses or other construction projects who is responsible for compensating for any damage caused.</data>
  <data key="d3">chunk-71c1c580c8f92c3838ab0f997647d588</data>
