  <data key="d1">HÀNH_VI</data>
  <data key="d2">Thủ tục đăng ký thay đổi refers to the procedures for registering changes in business registration content.</data>
  <data key="d3">chunk-3fed1e090b51d7382ec575f352792a42</data>
