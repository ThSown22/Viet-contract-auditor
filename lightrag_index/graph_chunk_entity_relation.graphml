<edge source="Ban kiểm soát" target="Đиều 54">
  <data key="d7">1.0</data>
  <data key="d8">Đиều 54 specifies the establishment of a supervisory board in certain state-owned enterprises.</data>
  <data key="d9">legal provision,supervisory board</data>
