</node>
<node id="Hợp Đồng Mua Bán">
  <data key="d0">Hợp Đồng Mua Bán</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Hợp Đồng Mua Bán is a contract for the sale and purchase of assets, detailing terms such as price, payment methods, delivery times, and locations.</data>
  <data key="d3">chunk-4623833cd0cb1b86833b9050e09612fd</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850373</data>
  <data key="d6"></data>
</node>
