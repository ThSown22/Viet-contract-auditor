  <data key="d0">Quyết Định Hủy Bỏ Biện Pháp Khẩn Cấp Tạm Thời</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Quyết Định Hủy Bỏ Biện Pháp Khẩn Cấp Tạm Thời refers to the decision to cancel emergency measures that were temporarily applied.</data>
  <data key="d3">chunk-a36e099bae803eeaad0a5160e83464d5</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773853928</data>
