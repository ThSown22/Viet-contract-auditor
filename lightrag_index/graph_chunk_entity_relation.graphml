</edge>
<edge source="Thiệt Hại Do Vi Phạm Nghĩa Vụ" target="Article 361">
  <data key="d7">1.0</data>
  <data key="d8">Article 361 of the Civil Code defines the damages caused by the violation of obligations, including material and non-material damages.</data>
  <data key="d9">damages,legal provision</data>
  <data key="d10">chunk-428a1a2119667172b8e431b501835f64</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850228</data>
