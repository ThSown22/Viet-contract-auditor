  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Báo Cáo Tổng Hợp Kết Quả Kinh Doanh is a report that summarizes the annual business results of both the parent and subsidiary companies.</data>
  <data key="d3">chunk-b12f2587388d6a4e9e558de512dc2860</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773853348</data>
  <data key="d6"></data>
</node>
