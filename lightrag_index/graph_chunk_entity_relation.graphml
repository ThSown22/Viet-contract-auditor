<edge source="Quyền Sở Hữu" target="Điều 244">
  <data key="d7">1.0</data>
  <data key="d8">Điều 244 states that ownership rights over an asset terminate when the asset is confiscated due to criminal or administrative violations.</data>
  <data key="d9">legal provision,ownership termination</data>
