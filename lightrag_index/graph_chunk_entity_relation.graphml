<node id="Quyền sở hữu trí tuệ">
  <data key="d0">Quyền sở hữu trí tuệ</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Quyền sở hữu trí tuệ refers to intellectual property rights.&lt;SEP&gt;Quyền sở hữu trí tuệ refers to intellectual property rights that can be used as capital contribution assets.&lt;SEP&gt;Quyền sở hữu trí tuệ refers to intellectual property rights used as a form of payment.</data>
  <data key="d3">chunk-e8a3f543a1762069fe562fe6a382e1b2&lt;SEP&gt;chunk-64b8fad75bc3785889ce216fbcf53556&lt;SEP&gt;chunk-9b892718f9850a0f9775f9a075fb4282</data>
