  <data key="d0">Tổ chức khác có chức năng lưu giữ sổ đăng ký cổ đông</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">Other organizations with the function of maintaining the shareholder register.</data>
  <data key="d3">chunk-dc2c4537017d8abf8400a3fc36e9aa3e</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773852299</data>
