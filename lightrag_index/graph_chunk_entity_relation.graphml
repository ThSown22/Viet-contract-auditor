  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Báo cáo thẩm định của Ban kiểm soát is a report from the Ban kiểm soát that must be submitted to the Đại hội đồng cổ đông.</data>
  <data key="d3">chunk-b0cdd7174a5289f85d735aa45cd8829d</data>
