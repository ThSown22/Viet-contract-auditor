  <data key="d7">1.0</data>
  <data key="d8">Tổng giám đốc is responsible for the highest-level management of the company and is overseen by the Hội đồng quản trị.</data>
  <data key="d9">management oversight,responsibility</data>
  <data key="d10">chunk-954105a0b477a911ae8062a76843dd6d</data>
