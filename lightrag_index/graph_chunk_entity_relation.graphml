<edge source="Chiếm hữu ngay tình" target="Đиều 180">
  <data key="d7">1.0</data>
  <data key="d8">Đиều 180 defines good faith possession.</data>
  <data key="d9">definition,legal concept</data>
  <data key="d10">chunk-7b345fbbc1125fb4f691693608eb8ffa</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849590</data>
  <data key="d13"></data>
</edge>
<edge source="Chiếm hữu không ngay tình" target="Đиều 181">
  <data key="d7">1.0</data>
  <data key="d8">Đиều 181 defines bad faith possession.</data>
  <data key="d9">definition,legal concept</data>
  <data key="d10">chunk-7b345fbbc1125fb4f691693608eb8ffa</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849590</data>
  <data key="d13"></data>
</edge>
<edge source="Trổ cửa nhìn sang bất động sản liền kề" target="Đиều 178">
  <data key="d7">1.0</data>
  <data key="d8">Đиều 178 regulates the opening of doors and windows towards adjacent properties.</data>
  <data key="d9">building code,legal regulation</data>
  <data key="d10">chunk-7b345fbbc1125fb4f691693608eb8ffa</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849590</data>
  <data key="d13"></data>
</edge>
<edge source="Đиều 180" target="Thành viên hợp danh">
  <data key="d7">1.0</data>
  <data key="d8">Đиều 180 outlines the restrictions on the rights of thành viên hợp danh.</data>
  <data key="d9">rights restrictions</data>
  <data key="d10">chunk-1efb55d02317343a2ef5f32d5d741bc9</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773853200</data>
  <data key="d13"></data>
</edge>
<edge source="Chủ thể có quyền khác đối với tài sản" target="Điều 166">
  <data key="d7">1.0</data>
  <data key="d8">Chủ thể có quyền khác đối với tài sản has the right to demand the return of their property from unlawful possessors under Điều 166.</data>
  <data key="d9">legal right,property return</data>
  <data key="d10">chunk-b802398ca6d8541021416cdaf49468d1</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849602</data>
  <data key="d13"></data>
</edge>
<edge source="Chủ thể có quyền khác đối với tài sản" target="Điều 169">
  <data key="d7">1.0</data>
  <data key="d8">Chủ thể có quyền khác đối với tài sản has the right to demand the cessation of unlawful acts that obstruct the exercise of their rights under Điều 169.</data>
  <data key="d9">cessation of obstruction,legal right</data>
  <data key="d10">chunk-b802398ca6d8541021416cdaf49468d1</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849602</data>
  <data key="d13"></data>
</edge>
<edge source="Chủ thể có quyền khác đối với tài sản" target="Điều 170">
  <data key="d7">1.0</data>
  <data key="d8">Chủ thể có quyền khác đối với tài sản has the right to demand compensation for damages caused by unlawful acts that infringe upon their rights under Điều 170.</data>
  <data key="d9">compensation for damages,legal right</data>
  <data key="d10">chunk-b802398ca6d8541021416cdaf49468d1</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849602</data>
  <data key="d13"></data>
</edge>
<edge source="Chủ thể có quyền khác đối với tài sản" target="Tình thế cấp thiết">
  <data key="d7">1.0</data>
  <data key="d8">Chủ thể có quyền khác đối với tài sản is not allowed to obstruct others from using their property or causing damage to it in a situation of emergency to prevent a greater harm under Điều 171.</data>
  <data key="d9">emergency situation,legal obligation</data>
  <data key="d10">chunk-b802398ca6d8541021416cdaf49468d1</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849603</data>
  <data key="d13"></data>
</edge>
<edge source="Người chiếm hữu" target="Điều 166">
  <data key="d7">1.0</data>
  <data key="d8">Người chiếm hữu can be required to return the property to the owner under Điều 166 if they do not have legal basis for possession.</data>
  <data key="d9">legal right,property return</data>
  <data key="d10">chunk-b802398ca6d8541021416cdaf49468d1</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849602</data>
  <data key="d13"></data>
</edge>
<edge source="Người chiếm hữu" target="Suy đoán về tình trạng và quyền của người chiếm hữu">
  <data key="d7">1.0</data>
  <data key="d8">Người chiếm hữu is presumed to be in good faith unless proven otherwise.</data>
  <data key="d9">possession,presumption</data>
  <data key="d10">chunk-32dad3b53fda840a78aa833f5592a4d7</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849696</data>
  <data key="d13"></data>
</edge>
<edge source="Người chiếm hữu" target="Người có tranh chấp với người chiếm hữu">
  <data key="d7">1.0</data>
  <data key="d8">Người có tranh chấp với người chiếm hữu has a dispute with the possessor over the rights to the property.</data>
  <data key="d9">dispute,possession</data>
  <data key="d10">chunk-32dad3b53fda840a78aa833f5592a4d7</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849696</data>
  <data key="d13"></data>
</edge>
<edge source="Người được lợi về tài sản" target="Điều 166">
  <data key="d7">1.0</data>
  <data key="d8">Người được lợi về tài sản can be required to return the property to the owner under Điều 166 if they do not have legal basis for benefit.</data>
  <data key="d9">legal right,property return</data>
  <data key="d10">chunk-b802398ca6d8541021416cdaf49468d1</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849603</data>
  <data key="d13"></data>
</edge>
<edge source="Người chiếm hữu ngay tình" target="Điều 168">
  <data key="d7">1.0</data>
  <data key="d8">Người chiếm hữu ngay tình can be required to return registered movable property or immovable property to the owner under Điều 168, except in certain cases.</data>
  <data key="d9">legal right,property return</data>
  <data key="d10">chunk-b802398ca6d8541021416cdaf49468d1</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849603</data>
  <data key="d13"></data>
</edge>
<edge source="Điều 169" target="Kiểm soát viên">
  <data key="d7">1.0</data>
  <data key="d8">The position of Kiểm soát viên is governed by the standards and conditions outlined in Điều 169.</data>
  <data key="d9">legal provision,standards</data>
  <data key="d10">chunk-b8bb762ad781038843f3cf2f3790105d</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773853166</data>
  <data key="d13"></data>
</edge>
<edge source="Điều 171" target="Tình thế cấp thiết">
  <data key="d7">1.0</data>
  <data key="d8">Tình thế cấp thiết is defined and regulated under Điều 171, which outlines the rights and obligations of owners and other right holders in situations of emergency.</data>
  <data key="d9">emergency situation,legal provision</data>
  <data key="d10">chunk-b802398ca6d8541021416cdaf49468d1</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849603</data>
  <data key="d13"></data>
</edge>
<edge source="Chủ Sở Hữu Bất Động Sản" target="Nước Mưa">
  <data key="d7">1.0</data>
  <data key="d8">Chủ sở hữu bất động sản must manage the drainage of rainwater to prevent it from flowing onto neighboring properties.</data>
  <data key="d9">drainage,property management</data>
  <data key="d10">chunk-9c073500583c9779361c25123a562132</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849631</data>
  <data key="d13"></data>
</edge>
<edge source="Chủ Sở Hữu Bất Động Sản" target="Nước Thải">
  <data key="d7">1.0</data>
  <data key="d8">Chủ sở hữu bất động sản must manage the drainage of wastewater to prevent it from flowing onto neighboring properties or public areas.</data>
  <data key="d9">drainage,property management</data>
  <data key="d10">chunk-9c073500583c9779361c25123a562132</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849631</data>
  <data key="d13"></data>
</edge>
<edge source="Chủ Sở Hữu Bất Động Sản" target="Đường Dẫn Nước">
  <data key="d7">1.0</data>
  <data key="d8">Chủ sở hữu bất động sản must install drainage systems to manage rainwater and wastewater.</data>
  <data key="d9">drainage,property management</data>
  <data key="d10">chunk-9c073500583c9779361c25123a562132</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849631</data>
  <data key="d13"></data>
</edge>
<edge source="Chủ Sở Hữu Bất Động Sản" target="Cống Ngầm">
  <data key="d7">1.0</data>
  <data key="d8">Chủ sở hữu bất động sản must install underground sewers to manage wastewater.</data>
  <data key="d9">drainage,property management</data>
  <data key="d10">chunk-9c073500583c9779361c25123a562132</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849631</data>
  <data key="d13"></data>
</edge>
<edge source="Chủ Sở Hữu Bất Động Sản" target="Lối Đi">
  <data key="d7">1.0</data>
  <data key="d8">Chủ sở hữu bất động sản must provide pathways to ensure access to their property.</data>
  <data key="d9">access,property management</data>
  <data key="d10">chunk-9c073500583c9779361c25123a562132</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849632</data>
  <data key="d13"></data>
</edge>
<edge source="Chủ Sở Hữu Bất Động Sản" target="Đường Công Cộng">
  <data key="d7">1.0</data>
  <data key="d8">Chủ sở hữu bất động sản must ensure that their drainage systems do not affect public roads.</data>
  <data key="d9">access,property management</data>
  <data key="d10">chunk-9c073500583c9779361c25123a562132</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849632</data>
  <data key="d13"></data>
</edge>
<edge source="Chủ Sở Hữu Bất Động Sản" target="Tưới Nước">
  <data key="d7">1.0</data>
  <data key="d8">Chủ sở hữu bất động sản must provide pathways for watering crops through neighboring properties.</data>
  <data key="d9">access,agricultural method</data>
  <data key="d10">chunk-9c073500583c9779361c25123a562132</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849632</data>
  <data key="d13"></data>
</edge>
<edge source="Chủ Sở Hữu Bất Động Sản" target="Tiêu Nước">
  <data key="d7">1.0</data>
  <data key="d8">Chủ sở hữu bất động sản must provide pathways for draining water from crops through neighboring properties.</data>
  <data key="d9">access,agricultural method</data>
  <data key="d10">chunk-9c073500583c9779361c25123a562132</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849632</data>
  <data key="d13"></data>
</edge>
<edge source="Chủ Sở Hữu Bất Động Sản" target="Đường Dây Tải Điện">
  <data key="d7">1.0</data>
  <data key="d8">Chủ sở hữu bất động sản can install electrical lines through neighboring properties.</data>
  <data key="d9">installation,property management</data>
  <data key="d10">chunk-9c073500583c9779361c25123a562132</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849632</data>
  <data key="d13"></data>
</edge>
<edge source="Chủ Sở Hữu Bất Động Sản" target="Thông Tin Liên Lạc">
  <data key="d7">1.0</data>
  <data key="d8">Chủ sở hữu bất động sản can install communication lines through neighboring properties.</data>
  <data key="d9">installation,property management</data>
  <data key="d10">chunk-9c073500583c9779361c25123a562132</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849632</data>
  <data key="d13"></data>
</edge>
<edge source="Chủ Sở Hữu Bất Động Sản" target="Chủ Sở Hữu Bất Động Sản Liền Kề">
  <data key="d7">1.0</data>
  <data key="d8">Chủ sở hữu bất động sản must ensure that their drainage systems do not affect neighboring property owners.</data>
  <data key="d9">drainage,property management</data>
  <data key="d10">chunk-9c073500583c9779361c25123a562132</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849632</data>
  <data key="d13"></data>
</edge>
<edge source="Chủ Sở Hữu Bất Động Sản" target="Người Sử Dụng Lối Đi">
  <data key="d7">1.0</data>
  <data key="d8">Người sử dụng lối đi must limit damage to the property of the owner through whom they are using a pathway and compensate if damage occurs.</data>
  <data key="d9">access,compensation</data>
  <data key="d10">chunk-9c073500583c9779361c25123a562132</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849632</data>
  <data key="d13"></data>
</edge>
<edge source="Chủ Sở Hữu Bất Động Sản" target="Người Sử Dụng Đất Canh Tác">
  <data key="d7">1.0</data>
  <data key="d8">Người sử dụng đất canh tác can request pathways through neighboring properties for watering or draining crops, and the property owner must comply.</data>
  <data key="d9">access,agricultural method</data>
  <data key="d10">chunk-9c073500583c9779361c25123a562132</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849632</data>
  <data key="d13"></data>
</edge>
<edge source="Rãnh Thoát Nước" target="Chủ Sở Hữu B_Đ_S">
  <data key="d7">1.0</data>
  <data key="d8">Chủ sở hữu bất động sản must install drainage ditches to manage wastewater.</data>
  <data key="d9">drainage,property management</data>
  <data key="d10">chunk-9c073500583c9779361c25123a562132</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849631</data>
  <data key="d13"></data>
</edge>
<edge source="Gia súc" target="Người bắt được gia súc">
  <data key="d7">1.0</data>
  <data key="d8">Người bắt được gia súc captures lost livestock and may be entitled to ownership under certain conditions.</data>
  <data key="d9">capture,ownership</data>
  <data key="d10">chunk-b2acb4f3dcdc42f5db6c9c4797e01299</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849663</data>
  <data key="d13"></data>
</edge>
<edge source="Gia súc" target="Điều 231">
  <data key="d7">1.0</data>
  <data key="d8">Điều 231 provides the legal framework for establishing ownership of lost livestock.</data>
  <data key="d9">legal provision,ownership</data>
  <data key="d10">chunk-b2acb4f3dcdc42f5db6c9c4797e01299</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849663</data>
  <data key="d13"></data>
</edge>
<edge source="Gia cầm" target="Người bắt được gia cầm">
  <data key="d7">1.0</data>
  <data key="d8">Người bắt được gia cầm captures lost poultry and may be entitled to ownership under certain conditions.</data>
  <data key="d9">capture,ownership</data>
  <data key="d10">chunk-b2acb4f3dcdc42f5db6c9c4797e01299</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849663</data>
  <data key="d13"></data>
</edge>
<edge source="Gia cầm" target="Đиều 232">
  <data key="d7">1.0</data>
  <data key="d8">Điều 232 provides the legal framework for establishing ownership of lost poultry.</data>
  <data key="d9">legal provision,ownership</data>
  <data key="d10">chunk-b2acb4f3dcdc42f5db6c9c4797e01299</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849663</data>
  <data key="d13"></data>
</edge>
<edge source="Chiếm hữu công khai" target="Suy đoán về tình trạng và quyền của người chiếm hữu">
  <data key="d7">1.0</data>
  <data key="d8">Chiếm hữu công khai is a basis for the presumption about the status and rights of the possessor.</data>
  <data key="d9">possession,presumption</data>
  <data key="d10">chunk-32dad3b53fda840a78aa833f5592a4d7</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849696</data>
  <data key="d13"></data>
</edge>
<edge source="Chiếm hữu công khai" target="Bảo vệ việc chiếm hữu">
  <data key="d7">1.0</data>
  <data key="d8">Bảo vệ việc chiếm hữu provides protection for the possessor, including the right to demand cessation of infringement and restoration of the original state.</data>
  <data key="d9">possession,protection</data>
  <data key="d10">chunk-32dad3b53fda840a78aa833f5592a4d7</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849696</data>
  <data key="d13"></data>
</edge>
<edge source="Quyền chiếm hữu của chủ sở hữu" target="Quyền sử dụng của chủ sở hữu">
  <data key="d7">1.0</data>
  <data key="d8">Quyền chiếm hữu của chủ sở hữu allows the owner to use the property according to their will without causing damage or affecting national, ethnic, public interests, or the rights and legitimate interests of others.</data>
  <data key="d9">ownership,usage</data>
  <data key="d10">chunk-32dad3b53fda840a78aa833f5592a4d7</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849696</data>
  <data key="d13"></data>
</edge>
<edge source="Quyền chiếm hữu của chủ sở hữu" target="Quyền chiếm hữu của người được chủ sở hữu ủy quyền quản lý tài sản">
  <data key="d7">1.0</data>
  <data key="d8">Quyền chiếm hữu của người được chủ sở hữu ủy quyền quản lý tài sản is the right of possession for a person authorized by the owner to manage the property within the scope, manner, and duration specified by the owner.</data>
  <data key="d9">authorization,ownership</data>
  <data key="d10">chunk-32dad3b53fda840a78aa833f5592a4d7</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849696</data>
  <data key="d13"></data>
</edge>
<edge source="Quyền chiếm hữu của chủ sở hữu" target="Quyền chiếm hữu của người được giao tài sản thông qua giao dịch dân sự">
  <data key="d7">1.0</data>
  <data key="d8">Quyền chiếm hữu của người được giao tài sản thông qua giao dịch dân sự is the right of possession for a person who receives property through a civil transaction without the transfer of ownership.</data>
  <data key="d9">ownership,transaction</data>
  <data key="d10">chunk-32dad3b53fda840a78aa833f5592a4d7</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849696</data>
  <data key="d13"></data>
</edge>
<edge source="Quyền sử dụng" target="Quyền sử dụng của chủ sở hữu">
  <data key="d7">1.0</data>
  <data key="d8">Quyền sử dụng is the right to exploit the utility of property and enjoy its fruits and benefits, which is also applicable to the owner.</data>
  <data key="d9">ownership,usage</data>
  <data key="d10">chunk-32dad3b53fda840a78aa833f5592a4d7</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849696</data>
  <data key="d13"></data>
</edge>
<edge source="Nghĩa Vụ Bảo Vệ Môi Trường" target="Chủ Thể">
  <data key="d7">1.0</data>
  <data key="d8">Chủ Thể must comply with legal provisions on environmental protection when exercising rights over property.</data>
  <data key="d9">environmental protection,legal obligation</data>
  <data key="d10">chunk-931c1ae4f95c0b01df5de17931b38de9</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849726</data>
  <data key="d13"></data>
</edge>
<edge source="Nghĩa Vụ Tôn Trọng, Bảo Đảm Trật Tự, An Toàn Xã Hội" target="Chủ Thể">
  <data key="d7">1.0</data>
  <data key="d8">Chủ Thể must respect and ensure social order and safety when exercising rights over property.</data>
  <data key="d9">legal obligation,social order</data>
  <data key="d10">chunk-931c1ae4f95c0b01df5de17931b38de9</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849726</data>
  <data key="d13"></data>
</edge>
<edge source="Ranh Giới Giữa Các Bất Động Sản" target="Người Sử Dụng Đất">
  <data key="d7">1.0</data>
  <data key="d8">Người Sử Dụng Đất must use the land within the determined boundaries and not affect the use of land by others.</data>
  <data key="d9">land use,property boundary</data>
  <data key="d10">chunk-931c1ae4f95c0b01df5de17931b38de9</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849726</data>
  <data key="d13"></data>
</edge>
<edge source="Chủ Thể" target="Pháp Luật Về Bảo Vệ Môi Trường">
  <data key="d7">1.0</data>
  <data key="d8">Chủ Thể must comply with legal provisions on environmental protection when exercising rights over property.</data>
  <data key="d9">environmental protection,legal compliance</data>
  <data key="d10">chunk-931c1ae4f95c0b01df5de17931b38de9</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849726</data>
  <data key="d13"></data>
</edge>
<edge source="Người Sử Dụng Đất" target="Thế Chấp Quyền Sử Dụng Đất">
  <data key="d7">1.0</data>
  <data key="d8">Thế Chấp Quyền Sử Dụng Đất involves collateralizing land use rights without collateralizing the assets attached to the land, depending on the relationship between the user and the owner of the assets.</data>
  <data key="d9">collateralization,land use rights</data>
  <data key="d10">chunk-ef30533c311bc88d4ba5ae54e8e8cca7</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849809</data>
  <data key="d13"></data>
</edge>
<edge source="Gia Cầm" target="Người Bắt Được Gia Cầm">
  <data key="d7">1.0</data>
  <data key="d8">Người Bắt Được Gia Cầm takes care of lost Gia Cầm and can claim certain rights until the original owner is found.</data>
  <data key="d9">care,ownership</data>
  <data key="d10">chunk-63e06b29bf3043507cfbd43beb81a47f</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849736</data>
  <data key="d13"></data>
</edge>
<edge source="Vật Nuôi Dưới Nước" target="Người Có Ruộng, Ao, Hồ">
  <data key="d7">1.0</data>
  <data key="d8">Người Có Ruộng, Ao, Hồ can claim ownership of Vetus Nuôi Dưới Nước that move into their property.</data>
  <data key="d9">discovery,ownership</data>
  <data key="d10">chunk-63e06b29bf3043507cfbd43beb81a47f</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849736</data>
  <data key="d13"></data>
</edge>
<edge source="Trường Hợp Vật Nuôi Dưới Nước Có Dấu Hiệu Riêng Biệt" target="Người Có Ruộng, Ao, Hồ">
  <data key="d7">1.0</data>
  <data key="d8">Người Có Ruộng, Ao, Hồ must publicly notify if Vetus Nuôi Dưới Nước have distinct marks that identify them as not belonging to the current owner.</data>
  <data key="d9">identification,notification</data>
  <data key="d10">chunk-63e06b29bf3043507cfbd43beb81a47f</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849736</data>
  <data key="d13"></data>
</edge>
<edge source="Điều 219" target="Tài sản chung">
  <data key="d7">1.0</data>
  <data key="d8">Điều 219 outlines the conditions under which jointly owned property can be divided.</data>
  <data key="d9">legal provision,ownership division</data>
  <data key="d10">chunk-e8a3f543a1762069fe562fe6a382e1b2</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849756</data>
  <data key="d13"></data>
</edge>
<edge source="Điều 220" target="Tài sản chung">
  <data key="d7">1.0</data>
  <data key="d8">Điều 220 specifies the conditions under which joint ownership of a property ends.</data>
  <data key="d9">legal provision,ownership termination</data>
  <data key="d10">chunk-e8a3f543a1762069fe562fe6a382e1b2</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849756</data>
  <data key="d13"></data>
</edge>
<edge source="Điều 221" target="Quyền sở hữu trí tuệ">
  <data key="d7">1.0</data>
  <data key="d8">Điều 221 defines the basis for establishing ownership rights, including intellectual property rights.</data>
  <data key="d9">legal provision,ownership establishment</data>
  <data key="d10">chunk-e8a3f543a1762069fe562fe6a382e1b2</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849756</data>
  <data key="d13"></data>
</edge>
<edge source="Quyền sở hữu trí tuệ" target="Tài sản góp vốn">
  <data key="d7">1.0</data>
  <data key="d8">Intellectual property rights can be used as capital contribution assets.</data>
  <data key="d9">capital contribution,intellectual property rights</data>
  <data key="d10">chunk-64b8fad75bc3785889ce216fbcf53556</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851714</data>
  <data key="d13"></data>
</edge>
<edge source="Quyền sở hữu trí tuệ" target="Công ty cổ phần">
  <data key="d7">1.0</data>
  <data key="d8">Quyền sở hữu trí tuệ is intellectual property rights used as a form of payment in the company.</data>
  <data key="d9">payment method,transaction</data>
  <data key="d10">chunk-9b892718f9850a0f9775f9a075fb4282</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773852753</data>
  <data key="d13"></data>
</edge>
<edge source="Bên Bảo Lãnh" target="Thù Lao">
  <data key="d7">1.0</data>
  <data key="d8">Bên Bảo Lãnh can receive remuneration (Thù Lao) if there is an agreement with Bên Được Bảo Lãnh.</data>
  <data key="d9">agreement,remuneration</data>
  <data key="d10">chunk-dac1d82b1ca37e1ac9e9211b39cad02e</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849804</data>
  <data key="d13"></data>
</edge>
<edge source="Bên Bảo Lãnh" target="Nhiệm Vụ Bảo Lãnh">
  <data key="d7">1.0</data>
  <data key="d8">Bên Bảo Lãnh must fulfill the Nhiệm Vụ Bảo Lãnh if Bên Được Bảo Lãnh fails to meet their obligations.</data>
  <data key="d9">guarantee,obligation</data>
  <data key="d10">chunk-dac1d82b1ca37e1ac9e9211b39cad02e</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849804</data>
  <data key="d13"></data>
</edge>
<edge source="Bên Bảo Lãnh" target="Miễn Việc Thực Hiện Nghĩa Vụ Bảo Lãnh">
  <data key="d7">1.0</data>
  <data key="d8">Bên Bảo Lãnh's obligation to fulfill the guarantee can be waived by Bên Nhận Bảo Lãnh.</data>
  <data key="d9">obligation,waiver</data>
  <data key="d10">chunk-dac1d82b1ca37e1ac9e9211b39cad02e</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849804</data>
  <data key="d13"></data>
</edge>
<edge source="Bên Bảo Lãnh" target="Trách Nhiệm Dân Sự Của Bên Bảo Lãnh">
  <data key="d7">1.0</data>
  <data key="d8">Bên Bảo Lãnh is liable for civil responsibilities if they fail to fulfill their guarantee obligations.</data>
  <data key="d9">liability,obligation</data>
  <data key="d10">chunk-dac1d82b1ca37e1ac9e9211b39cad02e</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849804</data>
  <data key="d13"></data>
</edge>
<edge source="Bên Bảo Lãnh" target="Chấm Dứt Bảo Lãnh">
  <data key="d7">1.0</data>
  <data key="d8">Bên Bảo Lãnh's guarantee can be terminated under certain conditions.</data>
  <data key="d9">obligation,termination</data>
  <data key="d10">chunk-dac1d82b1ca37e1ac9e9211b39cad02e</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849805</data>
  <data key="d13"></data>
</edge>
<edge source="Bên Bảo Lãnh" target="Nhiệm Vụ Phát Sinh Trong Tương Lai">
  <data key="d7">1.0</data>
  <data key="d8">Bên Bảo Lãnh provides a guarantee for future obligations (Nhiệm Vụ Phát Sinh Trong Tương Lai) until certain conditions are met.</data>
  <data key="d9">future obligations,guarantee</data>
  <data key="d10">chunk-dac1d82b1ca37e1ac9e9211b39cad02e</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849805</data>
  <data key="d13"></data>
</edge>
<edge source="Bên Bảo Lãnh" target="Bảo Đảm Bằng Tài Sản">
  <data key="d7">1.0</data>
  <data key="d8">Bảo Đảm Bằng Tài Sản is a method used by Bên Bảo Lãnh to secure the guarantee.</data>
  <data key="d9">collateral,guarantee</data>
  <data key="d10">chunk-dac1d82b1ca37e1ac9e9211b39cad02e</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849805</data>
  <data key="d13"></data>
</edge>
<edge source="Bên Bảo Lãnh" target="Bảo Lãnh">
  <data key="d7">1.0</data>
  <data key="d8">Bên Bảo Lãnh guarantees the obligations of the party being guaranteed and will fulfill them if the other party fails to do so.</data>
  <data key="d9">guarantee,obligation fulfillment</data>
  <data key="d10">chunk-3baa9f51dbe3abee94b2d6af0d80324d</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850113</data>
  <data key="d13"></data>
</edge>
<edge source="Bên Nhận Bảo Lãnh" target="Nhiệm Vụ Bảo Lãnh">
  <data key="d7">1.0</data>
  <data key="d8">Bên Nhận Bảo Lãnh has the right to demand the fulfillment of the Nhiệm Vụ Bảo Lãnh from Bên Bảo Lãnh.</data>
  <data key="d9">demand,obligation</data>
  <data key="d10">chunk-dac1d82b1ca37e1ac9e9211b39cad02e</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849804</data>
  <data key="d13"></data>
</edge>
<edge source="Bên Nhận Bảo Lãnh" target="Miễn Việc Thực Hiện Nghĩa Vụ Bảo Lãnh">
  <data key="d7">1.0</data>
  <data key="d8">Bên Nhận Bảo Lãnh can waive the obligation of Bên Bảo Lãnh to fulfill the guarantee.</data>
  <data key="d9">obligation,waiver</data>
  <data key="d10">chunk-dac1d82b1ca37e1ac9e9211b39cad02e</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849804</data>
  <data key="d13"></data>
</edge>
<edge source="Bên Nhận Bảo Lãnh" target="Trách Nhiệm Dân Sự Của Bên Bảo Lãnh">
  <data key="d7">1.0</data>
  <data key="d8">Bên Nhận Bảo Lãnh can demand the fulfillment of civil liabilities from Bên Bảo Lãnh if they fail to fulfill their guarantee obligations.</data>
  <data key="d9">demand,liability</data>
  <data key="d10">chunk-dac1d82b1ca37e1ac9e9211b39cad02e</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849804</data>
  <data key="d13"></data>
</edge>
<edge source="Bên Nhận Bảo Lãnh" target="Chấm Dứt Bảo Lãnh">
  <data key="d7">1.0</data>
  <data key="d8">Bên Nhận Bảo Lãnh can demand the termination of the guarantee under certain conditions.</data>
  <data key="d9">demand,termination</data>
  <data key="d10">chunk-dac1d82b1ca37e1ac9e9211b39cad02e</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849804</data>
  <data key="d13"></data>
</edge>
<edge source="Bên Nhận Bảo Lãnh" target="Bảo Lãnh">
  <data key="d7">1.0</data>
  <data key="d8">Bên Nhận Bảo Lãnh receives the guarantee from the third party and has the right to enforce it if the other party fails to fulfill their obligations.</data>
  <data key="d9">guarantee,obligation fulfillment</data>
  <data key="d10">chunk-3baa9f51dbe3abee94b2d6af0d80324d</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850113</data>
  <data key="d13"></data>
</edge>
<edge source="Bên Được Bảo Lãnh" target="Nhiệm Vụ Bảo Lãnh">
  <data key="d7">1.0</data>
  <data key="d8">Bên Được Bảo Lãnh's obligations are guaranteed by Bên Bảo Lãnh.</data>
  <data key="d9">guarantee,obligation</data>
  <data key="d10">chunk-dac1d82b1ca37e1ac9e9211b39cad02e</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849804</data>
  <data key="d13"></data>
</edge>
<edge source="Bên Được Bảo Lãnh" target="Miễn Việc Thực Hiện Nghĩa Vụ Bảo Lãnh">
  <data key="d7">1.0</data>
  <data key="d8">Bên Được Bảo Lãnh is not required to fulfill their obligations if the guarantee is waived by Bên Nhận Bảo Lãnh.</data>
  <data key="d9">obligation,waiver</data>
  <data key="d10">chunk-dac1d82b1ca37e1ac9e9211b39cad02e</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849804</data>
  <data key="d13"></data>
</edge>
<edge source="Bên Được Bảo Lãnh" target="Trách Nhiệm Dân Sự Của Bên Bảo Lãnh">
  <data key="d7">1.0</data>
  <data key="d8">Bên Được Bảo Lãnh's obligations are covered by the civil liability of Bên Bảo Lãnh.</data>
  <data key="d9">liability,obligation</data>
  <data key="d10">chunk-dac1d82b1ca37e1ac9e9211b39cad02e</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849805</data>
  <data key="d13"></data>
</edge>
<edge source="Bên Được Bảo Lãnh" target="Chấm Dứt Bảo Lãnh">
  <data key="d7">1.0</data>
  <data key="d8">Bên Được Bảo Lãnh's obligations are terminated when the guarantee is terminated.</data>
  <data key="d9">obligation,termination</data>
  <data key="d10">chunk-dac1d82b1ca37e1ac9e9211b39cad02e</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849805</data>
  <data key="d13"></data>
</edge>
<edge source="Bên Được Bảo Lãnh" target="Bảo Lãnh">
  <data key="d7">1.0</data>
  <data key="d8">Bên Được Bảo Lãnh is the party whose obligations are guaranteed by the third party and will be fulfilled if they fail to do so.</data>
  <data key="d9">guarantee,obligation fulfillment</data>
  <data key="d10">chunk-3baa9f51dbe3abee94b2d6af0d80324d</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850113</data>
  <data key="d13"></data>
</edge>
<edge source="Thù Lao" target="Hội Đồng Quản Trị">
  <data key="d7">1.0</data>
  <data key="d8">Thù Lao is the compensation paid to members of the Hội Đồng Quản Trị and is included in the company's business expenses.</data>
  <data key="d9">business expense,compensation</data>
  <data key="d10">chunk-65e07d9d273b5f52fb62308b1cffe434</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773853131</data>
  <data key="d13"></data>
</edge>
<edge source="Nhiệm Vụ Phát Sinh Trong Tương Lai" target="Pháp Nhân Bảo Lãnh">
  <data key="d7">1.0</data>
  <data key="d8">Pháp Nhân Bảo Lãnh provides a guarantee for future obligations (Nhiệm Vụ Phát Sinh Trong Tương Lai) until the legal entity ceases to exist.</data>
  <data key="d9">future obligations,legal entity</data>
  <data key="d10">chunk-dac1d82b1ca37e1ac9e9211b39cad02e</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849804</data>
  <data key="d13"></data>
</edge>
<edge source="Pháp Nhân Bảo Lãnh" target="Bảo Lãnh">
  <data key="d7">1.0</data>
  <data key="d8">Pháp Nhân Bảo Lãnh is a legal entity that provides a guarantee for the obligations of another party and will fulfill them if the other party fails to do so.</data>
  <data key="d9">guarantee,obligation fulfillment</data>
  <data key="d10">chunk-3baa9f51dbe3abee94b2d6af0d80324d</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850113</data>
  <data key="d13"></data>
</edge>
<edge source="Người Thứ Ba" target="Tài Sản Thế Chấp">
  <data key="d7">1.0</data>
  <data key="d8">Người Thứ Ba is responsible for managing and preserving the collateral asset and returning it as required.</data>
  <data key="d9">asset management,responsibility</data>
  <data key="d10">chunk-ef30533c311bc88d4ba5ae54e8e8cca7</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849809</data>
  <data key="d13"></data>
</edge>
<edge source="Người Thứ Ba" target="Bên Nhận Thế Chấp">
  <data key="d7">1.0</data>
  <data key="d8">Người Thứ Ba must return the collateral asset to the recipient of the collateral.</data>
  <data key="d9">asset transfer,responsibility</data>
  <data key="d10">chunk-ef30533c311bc88d4ba5ae54e8e8cca7</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849809</data>
  <data key="d13"></data>
</edge>
<edge source="Người Thứ Ba" target="Bên Thế Chấp">
  <data key="d7">1.0</data>
  <data key="d8">Người Thứ Ba must return the collateral asset to the provider of the collateral.</data>
  <data key="d9">asset transfer,responsibility</data>
  <data key="d10">chunk-ef30533c311bc88d4ba5ae54e8e8cca7</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849809</data>
  <data key="d13"></data>
</edge>
<edge source="Người Thứ Ba" target="Bên Bán">
  <data key="d7">1.0</data>
  <data key="d8">Bên Bán must ensure that the purchased property is not disputed by a third party, and if a dispute arises, the buyer has the right to cancel the contract and request compensation.</data>
  <data key="d9">legal responsibility,ownership dispute</data>
  <data key="d10">chunk-6fb0e6ef087a638bbb3f5e1626539a69</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850374</data>
  <data key="d13"></data>
</edge>
<edge source="Người Thứ Ba" target="Đиều 415">
  <data key="d7">1.0</data>
  <data key="d8">Đиều 415 specifies the execution of contracts for the benefit of a third party.</data>
  <data key="d9">contract execution,legal provision,third party rights</data>
  <data key="d10">chunk-9979a7994ede77b3cd590f1eb4f836e0</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850422</data>
  <data key="d13"></data>
</edge>
<edge source="Người Thứ Ba" target="Đиều 416">
  <data key="d7">1.0</data>
  <data key="d8">Đиều 416 grants the right of refusal to a third party in contracts.</data>
  <data key="d9">contract execution,legal provision,right of refusal</data>
  <data key="d10">chunk-9979a7994ede77b3cd590f1eb4f836e0</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850422</data>
  <data key="d13"></data>
</edge>
<edge source="Người Thứ Ba" target="Bên Được Ủy Quyền">
  <data key="d7">1.0</data>
  <data key="d8">Bên Được Ủy Quyền must communicate with Người Thứ Ba regarding the scope and execution of the authorized tasks.</data>
  <data key="d9">communication,task execution</data>
  <data key="d10">chunk-315d7e31800029ff10aa10797b03fa33</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850592</data>
  <data key="d13"></data>
</edge>
<edge source="Người Thứ Ba" target="Người Chiếm hữu">
  <data key="d7">1.0</data>
  <data key="d8">If a third party receives property from someone who possessed it without legal basis, the third party must return it.</data>
  <data key="d9">legal obligation,property transfer</data>
  <data key="d10">chunk-821c3a34361b8add641406062fd4a10e</data>
  <data key="d11">unknown_source</data>
