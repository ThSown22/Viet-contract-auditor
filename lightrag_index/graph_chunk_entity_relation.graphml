<node id="Súc Vật">
  <data key="d0">Súc Vật</data>
  <data key="d1">VĂN_BẢN_PHÁP_LUẬT</data>
  <data key="d2">Súc Vật refers to livestock or domestic animals that may cause damage when roaming freely.</data>
  <data key="d3">chunk-71c1c580c8f92c3838ab0f997647d588</data>
  <data key="d4">unknown_source</data>
