  <data key="d6"></data>
</node>
<node id="Nghĩa Vụ Của Bên Cho Vay">
  <data key="d0">Nghĩa Vụ Của Bên Cho Vay</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Nghĩa Vụ Của Bên Cho Vay includes the lender's obligations to provide assets in full and of the agreed quality, compensate for any damages, and not demand early return of the assets.</data>
  <data key="d3">chunk-e641f370052e6c1c0a156d3d338c15a4</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850865</data>
  <data key="d6"></data>
</node>
<node id="Nghĩa Vụ Trả Nợ Của Bên Vay">
  <data key="d0">Nghĩa Vụ Trả Nợ Của Bên Vay</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Nghĩa Vụ Trả Nợ Của Bên Vay includes the borrower's obligations to return the borrowed assets in full and of the agreed quality, and to pay interest if applicable.</data>
  <data key="d3">chunk-e641f370052e6c1c0a156d3d338c15a4</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850865</data>
  <data key="d6"></data>
</node>
<node id="Sử Dụng Tài Sản Vay">
  <data key="d0">Sử Dụng Tài Sản Vay</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Sử Dụng Tài Sản Vay refers to the use of borrowed assets and the lender's right to inspect and demand return of the assets if used improperly.</data>
  <data key="d3">chunk-e641f370052e6c1c0a156d3d338c15a4</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850865</data>
  <data key="d6"></data>
</node>
<node id="Điều 463">
  <data key="d0">Điều 463</data>
  <data key="d1">HÀNH_VI</data>
  <data key="d2">Điều 463 is a legal provision defining the contract for lending assets.</data>
  <data key="d3">chunk-e641f370052e6c1c0a156d3d338c15a4</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850866</data>
  <data key="d6"></data>
</node>
<node id="Điều 464">
  <data key="d0">Điều 464</data>
  <data key="d1">HÀNH_VI</data>
  <data key="d2">Điều 464 is a legal provision defining the ownership rights of the borrower over the borrowed assets.</data>
  <data key="d3">chunk-e641f370052e6c1c0a156d3d338c15a4</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850866</data>
  <data key="d6"></data>
</node>
<node id="Điều  465">
  <data key="d0">Điều  465</data>
  <data key="d1">HÀNH_VI</data>
  <data key="d2">Điều 465 is a legal provision outlining the obligations of the lender in a lending contract.</data>
  <data key="d3">chunk-e641f370052e6c1c0a156d3d338c15a4</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850866</data>
  <data key="d6"></data>
</node>
<node id="Điều 466">
  <data key="d0">Điều 466</data>
  <data key="d1">HÀNH_VI</data>
  <data key="d2">Điều 466 is a legal provision outlining the repayment obligations of the borrower in a lending contract.</data>
  <data key="d3">chunk-e641f370052e6c1c0a156d3d338c15a4</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850866</data>
  <data key="d6"></data>
</node>
<node id="Điều 467">
  <data key="d0">Điều 467</data>
  <data key="d1">HÀNH_VI</data>
  <data key="d2">Điều 467 is a legal provision regarding the use of borrowed assets and the lender's right to inspect and demand return of the assets if used improperly.</data>
  <data key="d3">chunk-e641f370052e6c1c0a156d3d338c15a4</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850866</data>
  <data key="d6"></data>
</node>
<node id="Điều 468">
  <data key="d0">Điều 468</data>
  <data key="d1">HÀNH_VI</data>
  <data key="d2">Điều 468 is a legal provision defining the interest rate in a lending contract.</data>
  <data key="d3">chunk-e641f370052e6c1c0a156d3d338c15a4</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850866</data>
  <data key="d6"></data>
</node>
<node id="Nghĩa Vust Trả Nợ Của Bên Vay">
  <data key="d0">Nghĩa Vust Trả Nợ Của Bên Vay</data>
  <data key="d3">chunk-e641f370052e6c1c0a156d3d338c15a4</data>
  <data key="d2">Bên Vay is responsible for fulfilling the obligations outlined in Nghĩa Vụ Trả Nợ Của Bên Vay.</data>
  <data key="d1">UNKNOWN</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850866</data>
  <data key="d6"></data>
</node>
