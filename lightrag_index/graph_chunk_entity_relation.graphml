<graph edgedefault="undirected"><node id="Cá nhân">
  <data key="d0">Cá nhân</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">Cá nhân refers to an individual who has the right to request changes to their name or ethnicity under certain conditions.&lt;SEP&gt;Cá nhân refers to an individual person, who has rights such as birth registration, nationality, image rights, and the right to life and safety.&lt;SEP&gt;Individuals are subjects of civil law with rights and obligations.&lt;SEP&gt;Cá nhân refers to an individual who can be a legal representative or can designate a representative for civil transactions.</data>
  <data key="d3">chunk-1123a80a811093ec5695cec4520ee7d2&lt;SEP&gt;chunk-985db81e6c3d846511cb280c2983fbf0&lt;SEP&gt;chunk-4c55b09e479fc060292314cb4f8f8302&lt;SEP&gt;chunk-737848ae2370b96df322ed1b985e715f&lt;SEP&gt;chunk-45f4215d40e0caccca1eaa62a7f0ec73</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773849397</data>
  <data key="d6"></data>
</node>
<node id="Quyền thay đổi tên">
  <data key="d0">Quyền thay đổi tên</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Quyền thay đổi tên is the right to change one's name under specific circumstances as outlined in the legal text.</data>
  <data key="d3">chunk-1123a80a811093ec5695cec4520ee7d2</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773848799</data>
  <data key="d6"></data>
</node>
<node id="Quyền xác định, xác định lại dân tộc">
  <data key="d0">Quyền xác định, xác định lại dân tộc</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Quyền xác định, xác định lại dân tộc is the right to determine or re-determine one's ethnic identity under certain conditions.</data>
  <data key="d3">chunk-1123a80a811093ec5695cec4520ee7d2</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773848799</data>
  <data key="d6"></data>
</node>
<node id="Cơ quan nhà nước có thẩm quyền">
  <data key="d0">Cơ quan nhà nước có thẩm quyền</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">Cơ quan nhà nước có thẩm quyền refers to authorized government agencies in Vietnam that possess broad legal authority to make decisions on various civil and legal matters. These agencies have the power to recognize changes in names or ethnicities, make legally binding decisions regarding civil rights and obligations, and enforce decisions on legal matters. They also have the authority to require the removal of trees or structures that pose a risk, enforce the cessation of infringement and restoration of the original state of property, and make decisions regarding ownership and property division. Additionally, Cơ quan nhà nước có thẩm quyền is responsible for managing estates when heirs have not been identified and for overseeing and regulating corporate activities.</data>
  <data key="d3">chunk-1123a80a811093ec5695cec4520ee7d2&lt;SEP&gt;chunk-6b3f59800e76e08387285066f5f36cdf&lt;SEP&gt;chunk-482a66c12f2040cbc0eabb425e1b6d97&lt;SEP&gt;chunk-7b345fbbc1125fb4f691693608eb8ffa&lt;SEP&gt;chunk-32dad3b53fda840a78aa833f5592a4d7&lt;SEP&gt;chunk-e8a3f543a1762069fe562fe6a382e1b2&lt;SEP&gt;chunk-2dbdbb74ad11a83bf1856f95ecdfa309&lt;SEP&gt;chunk-b0cdd7174a5289f85d735aa45cd8829d</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773852992</data>
  <data key="d6"></data>
</node>
<node id="Cha đẻ, mẹ đẻ">
  <data key="d0">Cha đẻ, mẹ đẻ</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">Cha đẻ, mẹ đẻ refers to the biological parents who have the right to request changes in their child's name or ethnicity.&lt;SEP&gt;Cha đẻ and mẹ đẻ refer to the biological father and mother of a child, who can request birth and death registration for their child.</data>
  <data key="d3">chunk-1123a80a811093ec5695cec4520ee7d2&lt;SEP&gt;chunk-985db81e6c3d846511cb280c2983fbf0</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773848836</data>
  <data key="d6"></data>
</node>
<node id="Cha nuôi, mẹ nuôi">
  <data key="d0">Cha nuôi, mẹ nuôi</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">Cha nuôi, mẹ nuôi refers to adoptive parents who have the right to request changes in their adopted child's name.</data>
  <data key="d3">chunk-1123a80a811093ec5695cec4520ee7d2</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773848799</data>
  <data key="d6"></data>
</node>
<node id="Người bị lưu lạc">
  <data key="d0">Người bị lưu lạc</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">Người bị lưu lạc refers to individuals who have been found after being lost and can request a change in their name.</data>
  <data key="d3">chunk-1123a80a811093ec5695cec4520ee7d2</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773848799</data>
  <data key="d6"></data>
</node>
<node id="Vợ, chồng">
  <data key="d0">Vợ, chồng</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">Vợ, chồng refers to spouses in international marriages who can request a change in their name to comply with foreign laws.</data>
  <data key="d3">chunk-1123a80a811093ec5695cec4520ee7d2</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773848799</data>
  <data key="d6"></data>
</node>
<node id="Người đã xác định lại giới tính, người đã chuyển đổi giới tính">
  <data key="d0">Người đã xác định lại giới tính, người đã chuyển đổi giới tính</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">Người đã xác định lại giới tính, người đã chuyển đổi giới tính refers to individuals who have legally changed their gender and can request a change in their name.</data>
  <data key="d3">chunk-1123a80a811093ec5695cec4520ee7d2</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773848799</data>
  <data key="d6"></data>
</node>
<node id="Trẻ em bị bỏ rơi">
  <data key="d0">Trẻ em bị bỏ rơi</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">Trẻ em bị bỏ rơi refers to abandoned children whose ethnic identity can be determined by the foster parents or the institution taking care of them.</data>
  <data key="d3">chunk-1123a80a811093ec5695cec4520ee7d2</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773848799</data>
  <data key="d6"></data>
</node>
<node id="Người đứng đầu cơ sở nuôi dưỡng trẻ em">
  <data key="d0">Người đứng đầu cơ sở nuôi dưỡng trẻ em</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">Người đứng đầu cơ sở nuôi dưỡng trẻ em refers to the head of the institution that takes care of abandoned children and can determine the child's ethnicity.</data>
  <data key="d3">chunk-1123a80a811093ec5695cec4520ee7d2</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773848799</data>
  <data key="d6"></data>
</node>
<node id="Người đang tạm thời nuôi dưỡng trẻ em">
  <data key="d0">Người đang tạm thời nuôi dưỡng trẻ em</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">Người đang tạm thời nuôi dưỡng trẻ em refers to temporary caregivers of abandoned children who can determine the child's ethnicity.</data>
  <data key="d3">chunk-1123a80a811093ec5695cec4520ee7d2</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773848799</data>
  <data key="d6"></data>
</node>
<node id="Điều 28">
  <data key="d0">Điều 28</data>
  <data key="d1">HÀNH_VI</data>
  <data key="d2">Điều 28 is a legal provision that outlines the rights and conditions for changing one's name.&lt;SEP&gt;Điều 28 outlines the rights and obligations of the Trung tâm trọng tài.</data>
  <data key="d3">chunk-1123a80a811093ec5695cec4520ee7d2&lt;SEP&gt;chunk-051c6a2f2eb7c0bc6325f96ce33195d9</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773853495</data>
  <data key="d6"></data>
</node>
<node id="Điều 29">
  <data key="d0">Điều 29</data>
  <data key="d1">HÀNH_VI</data>
  <data key="d2">Điều  29 is a legal provision that outlines the rights and conditions for determining or re-determining one's ethnic identity.&lt;SEP&gt;Điều 29 specifies the conditions for the termination of the activities of the Trung tâm trọng tài.</data>
  <data key="d3">chunk-1123a80a811093ec5695cec4520ee7d2&lt;SEP&gt;chunk-051c6a2f2eb7c0bc6325f96ce33195d9</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773853495</data>
  <data key="d6"></data>
</node>
<node id="Quyền được khai sinh, khai tử">
  <data key="d0">Quyền được khai sinh, khai tử</data>
  <data key="d1">HÀNH_VI</data>
  <data key="d2">This event refers to the legal process of registering births and deaths, as stipulated in Article 30.</data>
  <data key="d3">chunk-985db81e6c3d846511cb280c2983fbf0</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773848836</data>
  <data key="d6"></data>
</node>
<node id="Quyền đối với quốc tịch">
  <data key="d0">Quyền đối với quốc tịch</data>
  <data key="d1">HÀNH_VI</data>
  <data key="d2">This event refers to the legal process of determining, changing, acquiring, renouncing, or returning to Vietnamese nationality, as stipulated in Article 31.</data>
  <data key="d3">chunk-985db81e6c3d846511cb280c2983fbf0</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773848836</data>
  <data key="d6"></data>
</node>
<node id="Quyền của cá nhân đối với hình ảnh">
  <data key="d0">Quyền của cá nhân đối với hình ảnh</data>
  <data key="d1">HÀNH_VI</data>
  <data key="d2">This event refers to the legal rights of individuals over their own images, as stipulated in Article 32.</data>
  <data key="d3">chunk-985db81e6c3d846511cb280c2983fbf0</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773848836</data>
  <data key="d6"></data>
</node>
<node id="Quyền sống, quyền được bảo đảm an toàn về tính mạng, sức khỏe, thân thể">
  <data key="d0">Quyền sống, quyền được bảo đảm an toàn về tính mạng, sức khỏe, thân thể</data>
  <data key="d1">HÀNH_VI</data>
  <data key="d2">This event refers to the legal rights to life, safety of life, health, and body, as stipulated in Article 33.</data>
  <data key="d3">chunk-985db81e6c3d846511cb280c2983fbf0</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773848836</data>
  <data key="d6"></data>
</node>
<node id="Trẻ em">
  <data key="d0">Trẻ em</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">Trẻ em refers to children, who have specific rights regarding birth and death registration.</data>
  <data key="d3">chunk-985db81e6c3d846511cb280c2983fbf0</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773848836</data>
  <data key="d6"></data>
</node>
<node id="Người có hình ảnh">
  <data key="d0">Người có hình ảnh</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">Người có hình ảnh refers to the person whose image is being used, who has the right to consent to the use of their image.</data>
  <data key="d3">chunk-985db81e6c3d846511cb280c2983fbf0</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773848836</data>
