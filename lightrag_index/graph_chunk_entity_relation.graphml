<node id="G_2">
  <data key="d0">G_2</data>
  <data key="d3">chunk-6fef2e18615af027f8385abdb8209870</data>
  <data key="d2">Civil transactions by people whose capacity for civil conduct is limited can be declared invalid.</data>
