<edge source="Tòa án" target="Thời hiệu yêu cầu">
  <data key="d7">1.0</data>
  <data key="d8">Tòa án can declare a civil transaction as invalid within a specific statute of limitations.</data>
  <data key="d9">legal declaration,statute of limitations</data>
  <data key="d10">chunk-e91add69ab34542976bf62b9aca43ffa</data>
  <data key="d11">unknown_source</data>
