<node id="Hợp đồng vận chuyển tài sản">
  <data key="d0">Hợp đồng vận chuyển tài sản</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Hợp đồng vận chuyển tài sản is a contract for the transportation of goods that outlines the responsibilities of the transportation company and the client.</data>
  <data key="d3">chunk-1baf5b4c5d9b239e30e1e81e061a24dd</data>
