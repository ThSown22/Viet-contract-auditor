  <data key="d0">Bên bị áp dụng</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">Bên bị áp dụng is a person who is subject to the application of emergency measures.</data>
  <data key="d3">chunk-b47a7db90a1e526f1797874efef64872</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773853990</data>
  <data key="d6"></data>
</node>
<node id="Ngân hàng">
  <data key="d0">Ngân hàng</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">Ngân hàng is an organization that holds the funds in a blocked account as determined by Hội đồng trọng tài.</data>
  <data key="d3">chunk-b47a7db90a1e526f1797874efef64872</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773853990</data>
  <data key="d6"></data>
</node>
