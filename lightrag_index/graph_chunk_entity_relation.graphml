<edge source="Doanh Nghiệp" target="Tên Doanh Nghiệp">
  <data key="d7">1.0</data>
  <data key="d8">Doanh Nghiệp must use a unique name that does not overlap with existing names and must include its name on all transaction documents, financial records, and publications.</data>
  <data key="d9">business identification,naming regulation</data>
