<edge source="Bảo Đảm Thực Hiện Nghĩa Vụ Trong Tương Lai" target="Tài Sản Bảo Đảm">
  <data key="d7">1.0</data>
  <data key="d8">Tài Sản Bảo Đảm is used to secure future obligations under the concept of Bảo Đảm Thực Hiện Nghĩa Vụ Trong Tương Lai.</data>
  <data key="d9">collateral,obligation</data>
  <data key="d10">chunk-fc51b56c993488553c56dcd3c101b7ba</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849830</data>
  <data key="d13"></data>
</edge>
