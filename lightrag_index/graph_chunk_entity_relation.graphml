</edge>
<edge source="Luật" target="Điều 101">
  <data key="d7">1.0</data>
  <data key="d8">Điều 101 is a part of the law that outlines the standards and conditions for Directors and General Directors of a company.</data>
  <data key="d9">legal regulation,standards</data>
