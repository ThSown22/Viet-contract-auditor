  <data key="d1">HÀNH_VI</data>
  <data key="d2">Điều  242 is a legal provision that states that ownership rights over an asset terminate when the asset is consumed or destroyed.</data>
  <data key="d3">chunk-053b8a5c1f69c52703201366343dafa1</data>
