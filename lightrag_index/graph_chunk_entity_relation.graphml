  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Trách Nhiệm Tiếp Tục Thực Hiện Nghĩa Vụ refers to the responsibility to continue fulfilling an obligation when it has not been fulfilled correctly.</data>
  <data key="d3">chunk-e38fe034461862746b38b34d7647cf44</data>
