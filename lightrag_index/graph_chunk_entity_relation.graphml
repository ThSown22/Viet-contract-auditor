</edge>
<edge source="Bên thế chấp" target="Điều 321">
  <data key="d7">1.0</data>
  <data key="d8">Điều 321 outlines the rights of Bên thế chấp regarding the collateral asset.</data>
  <data key="d9">legal provision,rights</data>
  <data key="d10">chunk-35e5b9d9646a1753edafbdf0516edae4</data>
  <data key="d11">unknown_source</data>
