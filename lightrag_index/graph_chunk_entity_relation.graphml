<edge source="Cơ sở dữ liệu quốc gia về đăng ký doanh nghiệp" target="Công ty hợp nhất">
  <data key="d7">1.0</data>
  <data key="d8">Công ty hợp nhất is registered in the Cơ sở dữ liệu quốc gia về đăng ký doanh nghiệp, which updates the legal status of the company.</data>
  <data key="d9">legal registration,status update</data>
  <data key="d10">chunk-87d8fe2bdf778bad13a2e66311b71743</data>
  <data key="d11">unknown_source</data>
