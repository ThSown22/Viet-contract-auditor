  <data key="d0">Thông Tin Về Giấy Phép Kinh Doanh</data>
  <data key="d1">VĂN_BẢN_PHÁP_LUẬT</data>
  <data key="d2">Thông Tin Về Giấy Phép Kinh Doanh is information about business licenses.</data>
  <data key="d3">chunk-c5a052d442484a7e21099fd9dda00e96</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773853724</data>
  <data key="d6"></data>
</node>
<node id="Thông Tin Về Tình Hình Hoạt Động Và Nộp Thuế">
  <data key="d0">Thông Tin Về Tình Hình Hoạt Động Và Nộp Thuế</data>
  <data key="d1">VĂN_BẢN_PHÁP_LUẬT</data>
  <data key="d2">Thông Tin Về Tình Hình Hoạt Động Và Nộp Thuế is information about the operational status and tax payments of enterprises.</data>
  <data key="d3">chunk-c5a052d442484a7e21099fd9dda00e96</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773853724</data>
  <data key="d6"></data>
</node>
