<edge source="Chủ sở hữu" target="Điều 224">
  <data key="d7">1.0</data>
  <data key="d8">Điều 224 establishes that the owner of a property has rights over the produce or income from the property, starting from the time it is obtained.</data>
  <data key="d9">ownership rights,produce</data>
