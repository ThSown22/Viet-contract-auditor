</edge>
<edge source="Việt Nam" target="Phán quyết của trọng tài nước ngoài">
  <data key="d7">1.0</data>
  <data key="d8">Phán quyết của trọng tài nước ngoài is an arbitration decision made by foreign arbitrators, which can be recognized in Việt Nam.</data>
  <data key="d9">decision recognition,foreign arbitration</data>
  <data key="d10">chunk-30428dad2333a793ae10d4b854fbe88d</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773853578</data>
