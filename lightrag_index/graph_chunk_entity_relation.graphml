  <data key="d7">1.0</data>
  <data key="d8">Bên Cầm Cố pledges assets as part of their legal obligation.</data>
  <data key="d9">asset pledge,legal obligation</data>
  <data key="d10">chunk-3cdb3cd8d8583064c0301937b6f4744a</data>
  <data key="d11">unknown_source</data>
