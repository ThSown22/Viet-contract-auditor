<edge source="Kiểm soát viên" target="Trưởng Ban kiểm soát">
  <data key="d7">1.0</data>
  <data key="d8">Trưởng Ban kiểm soát and Kiểm soát viên are responsible for supervising and controlling the company's operations.</data>
  <data key="d9">control,supervision</data>
  <data key="d10">chunk-41835b63d2a39e7a4ba760332a2b8046</data>
