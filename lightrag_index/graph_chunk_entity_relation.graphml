  <data key="d11">unknown_source</data>
  <data key="d12">1773849946</data>
  <data key="d13"></data>
</edge>
<edge source="Bên thế chấp" target="Kho hàng">
  <data key="d7">1.0</data>
  <data key="d8">Bên thế chấp has the right to manage and use a warehouse as collateral under certain conditions.</data>
  <data key="d9">asset use,collateral management</data>
  <data key="d10">chunk-35e5b9d9646a1753edafbdf0516edae4</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849946</data>
  <data key="d13"></data>
</edge>
<edge source="Bên thế chấp" target="Giấy tờ liên quan đến tài sản thế chấp">
  <data key="d7">1.0</data>
  <data key="d8">Bên thế chap has the right to receive and manage documents related to the collateral asset.</data>
  <data key="d9">collateral management,document handling</data>
  <data key="d10">chunk-35e5b9d9646a1753edafbdf0516edae4</data>
