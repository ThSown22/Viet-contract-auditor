</edge>
<edge source="Bên Đề Nghị" target="Bên Được Đề Nghị">
  <data key="d7">1.0</data>
  <data key="d8">Bên Đề Nghị expresses the intention to enter into a contract and is willing to be bound by the proposal to Bên Được Đề Nghị.</data>
  <data key="d9">binding agreement,contract proposal</data>
  <data key="d10">chunk-b76bceedbe3231fcd1a7081ac9ec062b</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850346</data>
  <data key="d13"></data>
</edge>
<edge source="Bên Đề Nghị" target="Thời Hạn Trả Lời">
  <data key="d7">1.0</data>
  <data key="d8">Bên Đề Nghị specifies a deadline for responding to the proposal to enter into a contract.</data>
  <data key="d9">deadline,response</data>
  <data key="d10">chunk-b76bceedbe3231fcd1a7081ac9ec062b</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850346</data>
  <data key="d13"></data>
</edge>
<edge source="Bên Đề Nghị" target="Bồi Thường Thiệt Hại">
  <data key="d7">1.0</data>
  <data key="d8">Bên Đề Nghị must compensate for damages incurred if the proposal to enter into a contract is breached.</data>
  <data key="d9">compensation,damages</data>
  <data key="d10">chunk-b76bceedbe3231fcd1a7081ac9ec062b</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850346</data>
  <data key="d13"></data>
</edge>
<edge source="Bên Đề Nghị" target="Thông Báo Thay Đổi Hoặc Rút Lại Đề Nghị">
  <data key="d7">1.0</data>
  <data key="d8">Bên Đề Nghị can notify changes or withdrawal of the proposal to enter into a contract.</data>
  <data key="d9">change,notification,withdrawal</data>
  <data key="d10">chunk-b76bceedbe3231fcd1a7081ac9ec062b</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850346</data>
  <data key="d13"></data>
</edge>
<edge source="Bên Đề Nghị" target="Thỏa Thuận Thay Thế Hoặc Bồi Thường Thiệt Hại">
  <data key="d7">1.0</data>
  <data key="d8">Bên Đề Nghị can agree to replace the item or compensate for the loss when the specific item no longer exists.</data>
  <data key="d9">agreement,compensation,replacement</data>
  <data key="d10">chunk-b76bceedbe3231fcd1a7081ac9ec062b</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850346</data>
  <data key="d13"></data>
</edge>
<edge source="Bên Đề Nghị" target="Thay Đổi Nội Dung Đề Nghị">
  <data key="d7">1.0</data>
  <data key="d8">Bên Đề Nghị can modify the content of the proposal to enter into a contract.</data>
  <data key="d9">modification,proposal</data>
  <data key="d10">chunk-b76bceedbe3231fcd1a7081ac9ec062b</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850346</data>
  <data key="d13"></data>
</edge>
<edge source="Bên Đề Nghị" target="Đề Nghị Mới">
  <data key="d7">1.0</data>
  <data key="d8">Bên Đề Nghị can make a new proposal to enter into a contract.</data>
  <data key="d9">contract,new proposal</data>
  <data key="d10">chunk-b76bceedbe3231fcd1a7081ac9ec062b</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850346</data>
