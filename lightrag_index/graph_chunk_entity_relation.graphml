<edge source="Tài sản chung của vợ chồng" target="Chế độ tài sản theo thỏa thuận">
  <data key="d7">1.0</data>
  <data key="d8">Chế độ tài sản theo thỏa thuận is a legal arrangement for the division of shared property based on mutual agreement between spouses.</data>
  <data key="d9">legal arrangement,property division</data>
  <data key="d10">chunk-3c40b3ec985a74cfbf857d108074883e</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849453</data>
