  <data key="d0">Đề nghị của cổ đông</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Đề nghị của cổ đông refers to the request made by shareholders regarding lost, damaged, or destroyed shares and the responsibility for any disputes arising from the issuance of new shares.</data>
  <data key="d3">chunk-dc2c4537017d8abf8400a3fc36e9aa3e</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773852299</data>
  <data key="d6"></data>
</node>
