  <data key="d1">HÀNH_VI</data>
  <data key="d2">Điều 256 is a legal provision that outlines the conditions under which rights to adjacent real estate are terminated.</data>
  <data key="d3">chunk-3b5f857bd7e099346e71679265152a98</data>
