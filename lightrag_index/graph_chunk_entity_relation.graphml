  <data key="d7">1.0</data>
  <data key="d8">Bảo Đảm Thực Hiện Nghĩa Vụ Trong Tương Lai can include securing current obligations.</data>
  <data key="d9">obligation,security</data>
  <data key="d10">chunk-fc51b56c993488553c56dcd3c101b7ba</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849830</data>
  <data key="d13"></data>
</edge>
