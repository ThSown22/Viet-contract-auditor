<node id="Công trình xây dựng">
  <data key="d0">Công trình xây dựng</data>
  <data key="d1">VĂN_BẢN_PHÁP_LUẬT</data>
  <data key="d2">Structures that can pose a risk to adjacent properties and are subject to legal regulations.</data>
  <data key="d3">chunk-7b345fbbc1125fb4f691693608eb8ffa</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773849590</data>
  <data key="d6"></data>
</node>
<node id="Bất động sản liền kề">
  <data key="d0">Bất động sản liền kề</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">Adjacent properties that are protected from potential damage by trees or structures.</data>
  <data key="d3">chunk-7b345fbbc1125fb4f691693608eb8ffa</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773849590</data>
  <data key="d6"></data>
</node>
<node id="Chủ sở hữu tài sản">
  <data key="d0">Chủ sở hữu tài sản</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">The owner of the property who is responsible for taking measures to prevent damage to adjacent properties.</data>
  <data key="d3">chunk-7b345fbbc1125fb4f691693608eb8ffa</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773849590</data>
  <data key="d6"></data>
</node>
<node id="Mốc giới">
  <data key="d0">Mốc giới</data>
  <data key="d1">VĂN_BẢN_PHÁP_LUẬT</data>
  <data key="d2">Boundary markers that define the limits of property ownership.</data>
  <data key="d3">chunk-7b345fbbc1125fb4f691693608eb8ffa</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773849590</data>
  <data key="d6"></data>
</node>
<node id="Đào giếng, đào ao">
  <data key="d0">Đào giếng, đào ao</data>
  <data key="d1">HÀNH_VI</data>
  <data key="d2">Methods of digging wells or ponds that must be performed at a specified distance from boundary markers.</data>
  <data key="d3">chunk-7b345fbbc1125fb4f691693608eb8ffa</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773849590</data>
  <data key="d6"></data>
</node>
<node id="Kho chứa chất độc hại">
  <data key="d0">Kho chứa chất độc hại</data>
  <data key="d1">VĂN_BẢN_PHÁP_LUẬT</data>
  <data key="d2">Storage facilities for hazardous materials that must be built at a specified distance from boundary markers.</data>
  <data key="d3">chunk-7b345fbbc1125fb4f691693608eb8ffa</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773849590</data>
  <data key="d6"></data>
</node>
<node id="Chiếm hữu">
  <data key="d0">Chiếm hữu</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">The concept of possession, which includes both the possession of the owner and the possession of non-owners.</data>
  <data key="d3">chunk-7b345fbbc1125fb4f691693608eb8ffa</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773849590</data>
  <data key="d6"></data>
</node>
<node id="Chiếm hữu ngay tình">
  <data key="d0">Chiếm hữu ngay tình</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Good faith possession, where the possessor has a basis to believe they have a right to the property.</data>
  <data key="d3">chunk-7b345fbbc1125fb4f691693608eb8ffa</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773849590</data>
  <data key="d6"></data>
</node>
<node id="Chiếm hữu không ngay tình">
  <data key="d0">Chiếm hữu không ngay tình</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Bad faith possession, where the possessor knows or should know they do not have a right to the property.</data>
  <data key="d3">chunk-7b345fbbc1125fb4f691693608eb8ffa</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773849590</data>
  <data key="d6"></data>
</node>
<node id="Chiếm hữu liên tục">
  <data key="d0">Chiếm hữu liên tục</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Continuous possession, where the possession is uninterrupted and without legal dispute.</data>
  <data key="d3">chunk-7b345fbbc1125fb4f691693608eb8ffa</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773849590</data>
  <data key="d6"></data>
</node>
<node id="Trường hợp nhà xây riêng biệt nhưng tường sát liền nhau">
  <data key="d0">Trường hợp nhà xây riêng biệt nhưng tường sát liền nhau</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">A concept describing a situation where houses are built separately but with walls touching each other.</data>
  <data key="d3">chunk-7b345fbbc1125fb4f691693608eb8ffa</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773849590</data>
  <data key="d6"></data>
</node>
<node id="Cây là mốc giới chung">
  <data key="d0">Cây là mốc giới chung</data>
  <data key="d1">VĂN_BẢN_PHÁP_LUẬT</data>
  <data key="d2">Trees that serve as boundary markers between properties.</data>
  <data key="d3">chunk-7b345fbbc1125fb4f691693608eb8ffa</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773849590</data>
  <data key="d6"></data>
</node>
<node id="Hoa lợi thu được từ cây">
  <data key="d0">Hoa lợi thu được từ cây</data>
  <data key="d1">VĂN_BẢN_PHÁP_LUẬT</data>
  <data key="d2">The produce or yield obtained from trees that are shared between property owners.</data>
  <data key="d3">chunk-7b345fbbc1125fb4f691693608eb8ffa</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773849590</data>
  <data key="d6"></data>
</node>
<node id="Thỏa thuận khác">
  <data key="d0">Thỏa thuận khác</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">An alternative agreement between property owners regarding the use and maintenance of shared trees.</data>
  <data key="d3">chunk-7b345fbbc1125fb4f691693608eb8ffa</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773849590</data>
  <data key="d6"></data>
</node>
<node id="Bất động sản liền kề và xung quanh">
  <data key="d0">Bất động sản liền kề và xung quanh</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">Adjacent and surrounding properties that are affected by the actions of a property owner.</data>
  <data key="d3">chunk-7b345fbbc1125fb4f691693608eb8ffa</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773849590</data>
  <data key="d6"></data>
</node>
<node id="Giới hạn ngăn cách tường của mình">
  <data key="d0">Giới hạn ngăn cách tường của mình</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">The boundary limit of one's own wall that a property owner is allowed to modify.</data>
  <data key="d3">chunk-7b345fbbc1125fb4f691693608eb8ffa</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773849590</data>
  <data key="d6"></data>
</node>
<node id="Công trình vệ sinh">
  <data key="d0">Công trình vệ sinh</data>
  <data key="d1">VĂN_BẢN_PHÁP_LUẬT</data>
  <data key="d2">Sanitary facilities that must be built at a specified distance from boundary markers.</data>
  <data key="d3">chunk-7b345fbbc1125fb4f691693608eb8ffa</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773849590</data>
  <data key="d6"></data>
</node>
<node id="Đường đi chung">
  <data key="d0">Đường đi chung</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">Shared pathways that are subject to legal regulations regarding the opening of doors and windows.</data>
  <data key="d3">chunk-7b345fbbc1125fb4f691693608eb8ffa</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773849590</data>
  <data key="d6"></data>
</node>
<node id="Mái che trên cửa ra vào">
  <data key="d0">Mái che trên cửa ra vào</data>
  <data key="d1">VĂN_BẢN_PHÁP_LUẬT</data>
  <data key="d2">Roof over the entrance door that must be at least 2.5 meters above the ground.</data>
  <data key="d3">chunk-7b345fbbc1125fb4f691693608eb8ffa</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773849590</data>
  <data key="d6"></data>
</node>
<node id="Mái che cửa sổ quay ra đường đi chung">
  <data key="d0">Mái che cửa sổ quay ra đường đi chung</data>
  <data key="d1">VĂN_BẢN_PHÁP_LUẬT</data>
  <data key="d2">Roof over the window facing the shared pathway that must be at least 2.5 meters above the ground.</data>
  <data key="d3">chunk-7b345fbbc1125fb4f691693608eb8ffa</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773849590</data>
  <data key="d6"></data>
</node>
<node id="Trổ cửa nhìn sang bất động sản liền kề">
  <data key="d0">Trổ cửa nhìn sang bất động sản liền kề</data>
  <data key="d3">chunk-7b345fbbc1125fb4f691693608eb8ffa</data>
  <data key="d2">Đиều 178 regulates the opening of doors and windows towards adjacent properties.</data>
  <data key="d1">UNKNOWN</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773849590</data>
  <data key="d6"></data>
</node>
<node id="Đиều 177">
  <data key="d0">Đиều 177</data>
  <data key="d3">chunk-7b345fbbc1125fb4f691693608eb8ffa</data>
  <data key="d2">Đиều 177 regulates the management of structures that pose a risk to adjacent properties.</data>
  <data key="d1">UNKNOWN</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773849590</data>
  <data key="d6"></data>
</node>
<node id="Đиều 179">
  <data key="d0">Đиều 179</data>
  <data key="d3">chunk-7b345fbbc1125fb4f691693608eb8ffa</data>
  <data key="d2">Đиều 179 defines the concept of possession.</data>
  <data key="d1">UNKNOWN</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773849590</data>
  <data key="d6"></data>
</node>
<node id="Đиều 180">
  <data key="d0">Đиều 180</data>
  <data key="d3">chunk-7b345fbbc1125fb4f691693608eb8ffa&lt;SEP&gt;chunk-1efb55d02317343a2ef5f32d5d741bc9</data>
  <data key="d2">Đиều 180 defines good faith possession.</data>
  <data key="d1">UNKNOWN</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773849590</data>
  <data key="d6"></data>
</node>
<node id="Đиều 178">
  <data key="d0">Đиều 178</data>
  <data key="d3">chunk-7b345fbbc1125fb4f691693608eb8ffa</data>
  <data key="d2">Đиều 178 regulates the opening of doors and windows towards adjacent properties.</data>
  <data key="d1">UNKNOWN</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773849590</data>
  <data key="d6"></data>
</node>
<node id="Đиều 181">
  <data key="d0">Đиều 181</data>
  <data key="d3">chunk-7b345fbbc1125fb4f691693608eb8ffa</data>
  <data key="d2">Đиều 181 defines bad faith possession.</data>
  <data key="d1">UNKNOWN</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773849590</data>
  <data key="d6"></data>
</node>
<node id="Chủ thể có quyền khác đối với tài sản">
  <data key="d0">Chủ thể có quyền khác đối với tài sản</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Chủ thể có quyền khác đối với tài sản refers to entities that have other rights over a property or asset, distinct from ownership.</data>
  <data key="d3">chunk-b802398ca6d8541021416cdaf49468d1</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773849602</data>
  <data key="d6"></data>
</node>
<node id="Người chiếm hữu">
  <data key="d0">Người chiếm hữu</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">Người chiếm hữu refers to individuals who possess a property or asset, whether legally or unlawfully.&lt;SEP&gt;Người chiếm hữu refers to the possessor of property, who is presumed to be in good faith unless proven otherwise and has rights to protect their possession.</data>
  <data key="d3">chunk-b802398ca6d8541021416cdaf49468d1&lt;SEP&gt;chunk-32dad3b53fda840a78aa833f5592a4d7</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773849696</data>
  <data key="d6"></data>
</node>
<node id="Người được lợi về tài sản">
  <data key="d0">Người được lợi về tài sản</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Người được lợi về tài sản refers to individuals who benefit from a property or asset, whether legally or unlawfully.</data>
  <data key="d3">chunk-b802398ca6d8541021416cdaf49468d1</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773849602</data>
  <data key="d6"></data>
</node>
<node id="Người chiếm hữu ngay tình">
  <data key="d0">Người chiếm hữu ngay tình</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Người chiếm hữu ngay tình refers to individuals who possess a property or asset in good faith, without knowledge of the unlawful nature of their possession.</data>
  <data key="d3">chunk-b802398ca6d8541021416cdaf49468d1</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773849602</data>
  <data key="d6"></data>
</node>
<node id="Điều 166">
  <data key="d0">Điều 166</data>
  <data key="d1">HÀNH_VI</data>
  <data key="d2">Điều 166 is a legal provision that outlines the rights of owners and other right holders to demand the return of their property from unlawful possessors.</data>
  <data key="d3">chunk-b802398ca6d8541021416cdaf49468d1</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773849602</data>
  <data key="d6"></data>
</node>
<node id="Điều 168">
  <data key="d0">Điều 168</data>
  <data key="d1">HÀNH_VI</data>
  <data key="d2">Điều 168 is a legal provision that outlines the rights of owners to demand the return of registered movable property or immovable property from good faith possessors.</data>
  <data key="d3">chunk-b802398ca6d8541021416cdaf49468d1</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773849602</data>
  <data key="d6"></data>
</node>
<node id="Điều 169">
  <data key="d0">Điều 169</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Điều 169 is a legal provision that outlines the rights of owners and other right holders to demand the cessation of unlawful acts that obstruct the exercise of their rights.&lt;SEP&gt;Điều 169 is a legal provision that outlines the standards and conditions for the position of Kiểm soát viên.</data>
  <data key="d3">chunk-b802398ca6d8541021416cdaf49468d1&lt;SEP&gt;chunk-b8bb762ad781038843f3cf2f3790105d</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773853165</data>
  <data key="d6"></data>
</node>
<node id="Điều 170">
  <data key="d0">Điều 170</data>
  <data key="d1">HÀNH_VI</data>
  <data key="d2">Đиều 170 is a legal provision that outlines the rights of owners and other right holders to demand compensation for damages caused by unlawful acts that infringe upon their rights.</data>
  <data key="d3">chunk-b802398ca6d8541021416cdaf49468d1</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773849602</data>
  <data key="d6"></data>
</node>
<node id="Điều 171">
  <data key="d0">Điều 171</data>
  <data key="d1">HÀNH_VI</data>
  <data key="d2">Điều 171 is a legal provision that outlines the rights and obligations of owners and other right holders in situations of emergency.</data>
  <data key="d3">chunk-b802398ca6d8541021416cdaf49468d1</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773849602</data>
  <data key="d6"></data>
</node>
<node id="Điều 172">
  <data key="d0">Điều 172</data>
  <data key="d1">HÀNH_VI</data>
  <data key="d2">Điều 172 is a legal provision that outlines the obligations of owners and other right holders to protect the environment when exercising their rights.</data>
  <data key="d3">chunk-b802398ca6d8541021416cdaf49468d1</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773849602</data>
  <data key="d6"></data>
</node>
<node id="Tình thế cấp thiết">
  <data key="d0">Tình thế cấp thiết</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Tình thế cấp thiết refers to a situation where an individual must take action to avoid a direct threat to public interest, their own legal rights, or the rights of others, and there are no other means to prevent a greater harm.</data>
  <data key="d3">chunk-b802398ca6d8541021416cdaf49468d1</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773849602</data>
  <data key="d6"></data>
</node>
<node id="Chủ Sở Hữu Bất Động Sản">
  <data key="d0">Chủ Sở Hữu Bất Động Sản</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">Chủ sở hữu bất động sản is responsible for ensuring that their property does not cause inconvenience to neighboring properties, including managing drainage and water flow.</data>
  <data key="d3">chunk-9c073500583c9779361c25123a562132</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773849631</data>
  <data key="d6"></data>
</node>
<node id="Nước Mưa">
  <data key="d0">Nước Mưa</data>
  <data key="d1">VĂN_BẢN_PHÁP_LUẬT</data>
  <data key="d2">Nước mưa refers to rainwater that must be managed by property owners to prevent it from flowing onto neighboring properties.</data>
  <data key="d3">chunk-9c073500583c9779361c25123a562132</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773849631</data>
  <data key="d6"></data>
</node>
<node id="Nước Thải">
  <data key="d0">Nước Thải</data>
  <data key="d1">VĂN_BẢN_PHÁP_LUẬT</data>
  <data key="d2">Nước thải refers to wastewater that must be managed by property owners to prevent it from flowing onto neighboring properties or public areas.</data>
  <data key="d3">chunk-9c073500583c9779361c25123a562132</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773849631</data>
  <data key="d6"></data>
</node>
<node id="Đường Dẫn Nước">
  <data key="d0">Đường Dẫn Nước</data>
  <data key="d1">VĂN_BẢN_PHÁP_LUẬT</data>
  <data key="d2">Đường dẫn nước refers to drainage systems installed by property owners to manage rainwater and wastewater.</data>
  <data key="d3">chunk-9c073500583c9779361c25123a562132</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773849631</data>
  <data key="d6"></data>
</node>
<node id="Cống Ngầm">
  <data key="d0">Cống Ngầm</data>
  <data key="d1">VĂN_BẢN_PHÁP_LUẬT</data>
  <data key="d2">Cống ngầm refers to underground sewers installed by property owners to manage wastewater.</data>
  <data key="d3">chunk-9c073500583c9779361c25123a562132</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773849631</data>
  <data key="d6"></data>
</node>
<node id="Rãnh Thoát Nước">
  <data key="d0">Rãnh Thoát Nước</data>
  <data key="d1">VĂN_BẢN_PHÁP_LUẬT</data>
  <data key="d2">Rãnh thoát nước refers to drainage ditches installed by property owners to manage wastewater.</data>
