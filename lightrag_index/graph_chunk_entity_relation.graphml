  <data key="d1">VĂN_BẢN_PHÁP_LUẬT</data>
  <data key="d2">Sổ Kế Toán is the accounting book where the company records its financial transactions and assets.</data>
  <data key="d3">chunk-af079df7102c58f84652bfeb21c7a17a</data>
  <data key="d4">unknown_source</data>
