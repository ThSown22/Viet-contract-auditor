  <data key="d13"></data>
</edge>
<edge source="Doanh nghiệp" target="Cổng thông tin quốc gia về đăng ký doanh nghiệp">
  <data key="d7">2.0</data>
  <data key="d8">Doanh nghiệp must publicly announce its registration information on the National Portal for Business Registration.&lt;SEP&gt;Cổng thông tin quốc gia về đăng ký doanh nghiệp is used to publicly announce the dissolution of the business entity.</data>
  <data key="d9">public announcement,registration,registration information</data>
  <data key="d10">chunk-64b8fad75bc3785889ce216fbcf53556&lt;SEP&gt;chunk-873972be10253bbd19fcbea390d18db2</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773853539</data>
  <data key="d13"></data>
</edge>
<edge source="Doanh nghiệp" target="Tài sản góp vốn">
  <data key="d7">1.0</data>
  <data key="d8">Doanh nghiệp receives capital contribution assets from members and shareholders, which must be transferred to the company.</data>
  <data key="d9">asset transfer,capital contribution</data>
  <data key="d10">chunk-64b8fad75bc3785889ce216fbcf53556</data>
