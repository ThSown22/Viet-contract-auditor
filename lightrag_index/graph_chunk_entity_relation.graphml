  <data key="d0">Phán quyết Trọng tài</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Phán quyết Trọng tài is a legal decision made by an arbitration panel that can be enforced and potentially challenged.</data>
  <data key="d3">chunk-5c9e86e115e2f87b380e003f8d31484e</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773853801</data>
  <data key="d6"></data>
</node>
<node id="Cơ quan thi hành án dân sự">
  <data key="d0">Cơ quan thi hành án dân sự</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">Cơ quan thi hành án dân sự is an organization responsible for enforcing civil judgments, including arbitration decisions.&lt;SEP&gt;Cơ quan thi hành án dân sự is an organization responsible for enforcing arbitration decisions.&lt;SEP&gt;Cơ quan thi hành án dân sự is an organization responsible for enforcing decisions on emergency measures.</data>
  <data key="d3">chunk-5c9e86e115e2f87b380e003f8d31484e&lt;SEP&gt;chunk-105aefb96d31bdf83eb8694998c59506&lt;SEP&gt;chunk-b47a7db90a1e526f1797874efef64872</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773853990</data>
  <data key="d6"></data>
</node>
<node id="Đơn yêu cầu huỷ phán quyết trọng tài">
  <data key="d0">Đơn yêu cầu huỷ phán quyết trọng tài</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Đơn yêu cầu huỷ phán quyết trọng tài is a legal document submitted to a court requesting the annulment of an arbitration decision.&lt;SEP&gt;Đơn yêu cầu huỷ phán quyết trọng tài is the request to annul an arbitration award.</data>
  <data key="d3">chunk-5c9e86e115e2f87b380e003f8d31484e&lt;SEP&gt;chunk-967ef50a189d7b94846c22abc99c1f09</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773853867</data>
  <data key="d6"></data>
</node>
