  <data key="d7">1.0</data>
  <data key="d8">Người đang chấp hành biện pháp xử lý hành chính can have their will authenticated by the facility's responsible person.</data>
  <data key="d9">administrative measures,authentication</data>
  <data key="d10">chunk-c6c45985a08d6e2c0940eda170510a01</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851043</data>
  <data key="d13"></data>
</edge>
<edge source="Di chúc" target="Tổ chức hành nghề công chứng">
  <data key="d7">1.0</data>
  <data key="d8">Tổ chức hành nghề công chứng can store and validate wills.</data>
  <data key="d9">legal validation,storage</data>
  <data key="d10">chunk-c6c45985a08d6e2c0940eda170510a01</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851043</data>
  <data key="d13"></data>
</edge>
<edge source="Người lập di chúc" target="Di chúc hợp pháp">
  <data key="d7">1.0</data>
  <data key="d8">Người lập di chúc creates a Di chúc hợp pháp that meets all required conditions.</data>
  <data key="d9">legal validity,will creation</data>
  <data key="d10">chunk-47d8802df9ec7324759d67fe67eaf612</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850994</data>
  <data key="d13"></data>
</edge>
<edge source="Người lập di chúc" target="Điều 625">
  <data key="d7">1.0</data>
  <data key="d8">Điều 625 outlines the conditions under which a person can create a will, including age and mental capacity requirements.</data>
  <data key="d9">age requirement,mental capacity</data>
  <data key="d10">chunk-47d8802df9ec7324759d67fe67eaf612</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850994</data>
  <data key="d13"></data>
</edge>
<edge source="Người lập di chúc" target="Đиều 626">
  <data key="d7">1.0</data>
  <data key="d8">Đиều 626 details the rights of the person creating a will, including the ability to designate heirs and assign specific portions of the estate.</data>
  <data key="d9">asset distribution,rights</data>
  <data key="d10">chunk-47d8802df9ec7324759d67fe67eaf612</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850995</data>
  <data key="d13"></data>
</edge>
<edge source="Người lập di chúc" target="Bản di chúc">
  <data key="d7">1.0</data>
  <data key="d8">Người lập di chúc creates a written will, a legal document specifying asset distribution.</data>
  <data key="d9">creation,legal document</data>
  <data key="d10">chunk-c6c45985a08d6e2c0940eda170510a01</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851043</data>
  <data key="d13"></data>
</edge>
<edge source="Người lập di chúc" target="Phần bổ sung">
  <data key="d7">1.0</data>
  <data key="d8">Người lập di chúc can amend their will by adding a portion that has legal effect.</data>
  <data key="d9">amendment,legal document</data>
  <data key="d10">chunk-c6c45985a08d6e2c0940eda170510a01</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851043</data>
  <data key="d13"></data>
</edge>
<edge source="Người lập di chúc" target="Di chúc mới">
  <data key="d7">1.0</data>
  <data key="d8">Người lập di chúc can replace their existing will with a new one.</data>
  <data key="d9">legal document,replacement</data>
  <data key="d10">chunk-c6c45985a08d6e2c0940eda170510a01</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851043</data>
  <data key="d13"></data>
</edge>
<edge source="Di sản" target="Người chết">
  <data key="d7">1.0</data>
  <data key="d8">Người chết's estate includes their personal property and their share in jointly owned property.</data>
  <data key="d9">estate composition,ownership</data>
  <data key="d10">chunk-2dbdbb74ad11a83bf1856f95ecdfa309</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851096</data>
  <data key="d13"></data>
</edge>
<edge source="Di sản" target="Người quản lý di sản">
  <data key="d7">2.0</data>
  <data key="d8">Người quản lý di sản is responsible for managing the estate.&lt;SEP&gt;The person managing the estate has the duty to preserve and manage the estate.</data>
  <data key="d9">estate administration,management,preservation</data>
  <data key="d10">chunk-2dbdbb74ad11a83bf1856f95ecdfa309&lt;SEP&gt;chunk-fd15f05b480bf5c4a3b4b4e068a412cd</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851130</data>
  <data key="d13"></data>
</edge>
<edge source="Di sản" target="Người để lại di sản">
  <data key="d7">1.0</data>
  <data key="d8">The person who left the estate is the owner of the estate and determines its inheritance.</data>
  <data key="d9">inheritance,ownership</data>
  <data key="d10">chunk-fd15f05b480bf5c4a3b4b4e068a412cd</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851130</data>
  <data key="d13"></data>
</edge>
<edge source="Người làm chứng" target="Di chúc miệng">
  <data key="d7">1.0</data>
  <data key="d8">Người làm chứng attests to the validity of a Di chúc miệng.</data>
  <data key="d9">oral will validation,witness</data>
  <data key="d10">chunk-47d8802df9ec7324759d67fe67eaf612</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850994</data>
  <data key="d13"></data>
</edge>
<edge source="Người làm chứng" target="Hội đồng trọng tài">
  <data key="d7">1.0</data>
  <data key="d8">Hội đồng trọng tài has the authority to summon Người làm chứng to attend a hearing.</data>
  <data key="d9">summoning authority,witness attendance</data>
  <data key="d10">chunk-c0133fbf4562d8d0b8d51451c1447d8e</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773853899</data>
