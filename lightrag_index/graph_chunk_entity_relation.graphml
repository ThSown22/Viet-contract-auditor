<edge source="Người Hứa Thưởng" target="Điều 570">
  <data key="d7">1.0</data>
  <data key="d8">Điều 570 specifies the obligation of Người Hứa Thưởng to pay a reward to the party that completes the promised task.</data>
  <data key="d9">reward,task completion</data>
  <data key="d10">chunk-25258e0d46bb04acb5e0308a2108c231</data>
  <data key="d11">unknown_source</data>
