</edge>
<edge source="Tài Sản" target="Người Chiếm Hữu">
  <data key="d7">1.0</data>
  <data key="d8">A person who possesses another's property without legal basis must return the entire property.</data>
  <data key="d9">legal obligation,property possession</data>
  <data key="d10">chunk-821c3a34361b8add641406062fd4a10e</data>
