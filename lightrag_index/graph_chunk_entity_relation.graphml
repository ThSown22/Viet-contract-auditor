  <data key="d13"></data>
</edge>
<edge source="Điều 142" target="Chương trình họp Đại hội đồng cổ đông">
  <data key="d7">1.0</data>
  <data key="d8">Điều 142 specifies the preparation of the agenda and content for the Đại hội đồng cổ đông.</data>
  <data key="d9">agenda preparation,regulation</data>
  <data key="d10">chunk-29365a5c3fbe3ae076f76826fc009a7a</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773852661</data>
  <data key="d13"></data>
</edge>
<edge source="Điều 142" target="Người triệu tập họp Đại hội đồng cổ đông">
  <data key="d7">1.0</data>
  <data key="d8">Người triệu tập họp Đại hội đồng cổ đông is responsible for preparing the agenda and content of the meeting according to Điều 142.</data>
  <data key="d9">agenda preparation,meeting organization</data>
  <data key="d10">chunk-29365a5c3fbe3ae076f76826fc009a7a</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773852661</data>
  <data key="d13"></data>
</edge>
<edge source="Đại diện theo pháp luật chấm dứt" target="Người được đại diện là cá nhân chết">
  <data key="d7">1.0</data>
  <data key="d8">The termination of legal representation occurs when the represented individual dies.</data>
  <data key="d9">legal representation,termination condition</data>
  <data key="d10">chunk-5cb7db3cfef705b914008825e4c276e6</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849276</data>
  <data key="d13"></data>
</edge>
<edge source="Đại diện theo pháp luật chấm dứt" target="Người được đại diện là pháp nhân chấm dứt tồn tại">
  <data key="d7">1.0</data>
  <data key="d8">The termination of legal representation occurs when the represented legal entity ceases to exist.</data>
  <data key="d9">legal representation,termination condition</data>
  <data key="d10">chunk-5cb7db3cfef705b914008825e4c276e6</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849276</data>
  <data key="d13"></data>
</edge>
<edge source="Đại diện theo pháp luật chấm dứt" target="Căn cứ khác theo quy định của Bộ luật này hoặc luật khác có liên quan">
  <data key="d7">1.0</data>
  <data key="d8">The termination of legal representation can also occur based on other legal bases defined by the Civil Code or other related laws.</data>
  <data key="d9">legal representation,termination condition</data>
  <data key="d10">chunk-5cb7db3cfef705b914008825e4c276e6</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849276</data>
  <data key="d13"></data>
</edge>
<edge source="Điều 144" target="Thời hạn">
  <data key="d7">1.0</data>
  <data key="d8">Điều 144 defines the concept of a time limit and its measurement.</data>
  <data key="d9">definition,explanation</data>
  <data key="d10">chunk-7fce420202370c7c711321549129cd6e</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849299</data>
  <data key="d13"></data>
</edge>
<edge source="Điều 145" target="Thời hạn">
  <data key="d7">1.0</data>
  <data key="d8">Điều 145 specifies the application of time limit calculation methods as per the Civil Code, except where there is a different agreement or law.</data>
  <data key="d9">application,calculation</data>
  <data key="d10">chunk-7fce420202370c7c711321549129cd6e</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849299</data>
  <data key="d13"></data>
</edge>
<edge source="Điều 146" target="Đại hội đồng cổ đông">
  <data key="d7">1.0</data>
  <data key="d8">Điều 146 provides the legal framework for the procedures of the shareholders' meeting.</data>
  <data key="d9">legal provision,meeting procedures</data>
  <data key="d10">chunk-8ec2f0c0c76fa5e26ffa97f0626d61d8</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773852817</data>
  <data key="d13"></data>
</edge>
<edge source="Thời hạn" target="Đиều 146">
  <data key="d7">1.0</data>
  <data key="d8">Đиều 146 provides rules for time limits and the calculation of time points, including specific durations and definitions for the beginning, middle, and end of months and years.</data>
  <data key="d9">calculation,rules</data>
  <data key="d10">chunk-7fce420202370c7c711321549129cd6e</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849299</data>
  <data key="d13"></data>
</edge>
<edge source="Thời hạn" target="Đиều 147">
  <data key="d7">1.0</data>
  <data key="d8">Đиều 147 outlines the starting point of a time limit, which can be based on minutes, hours, days, weeks, months, or years, and may start from a specific event.</data>
  <data key="d9">calculation,starting point</data>
  <data key="d10">chunk-7fce420202370c7c711321549129cd6e</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849299</data>
  <data key="d13"></data>
</edge>
<edge source="Thời hạn" target="Đиều 148">
  <data key="d7">1.0</data>
  <data key="d8">Đиều 148 details the end of a time limit, which can be based on days, weeks, months, or years, and may end on a specific day or the next working day after a holiday.</data>
  <data key="d9">calculation,ending point</data>
  <data key="d10">chunk-7fce420202370c7c711321549129cd6e</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849299</data>
  <data key="d13"></data>
</edge>
<edge source="Thời hạn" target="Người triệu tập họp">
  <data key="d7">1.0</data>
  <data key="d8">Người triệu tập họp must comply with the deadlines specified in the company's charter for sending out meeting notifications.</data>
  <data key="d9">deadline compliance,meeting organization</data>
  <data key="d10">chunk-3c9b32b2b806556ed1dd36c13de6e313</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773852721</data>
  <data key="d13"></data>
</edge>
<edge source="Thời hạn" target="Ngày lễ">
  <data key="d7">1.0</data>
  <data key="d8">If the last day of the time period is a holiday, the deadline will be extended to the first working day after the holiday.</data>
  <data key="d9">holiday,time period</data>
  <data key="d10">chunk-f4e87b9226945fe55349146eaa7dc3c3</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773853605</data>
  <data key="d13"></data>
</edge>
<edge source="Thời hạn" target="Ngày nghỉ">
  <data key="d7">1.0</data>
  <data key="d8">If the last day of the time period is a day off, the deadline will be extended to the first working day after the day off.</data>
  <data key="d9">day off,time period</data>
  <data key="d10">chunk-f4e87b9226945fe55349146eaa7dc3c3</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773853605</data>
  <data key="d13"></data>
</edge>
<edge source="Thời hiệu" target="Đиều 149">
  <data key="d7">1.0</data>
  <data key="d8">Đиều 149 defines the concept of statute of limitations and its application by the court.</data>
  <data key="d9">application,definition</data>
  <data key="d10">chunk-7fce420202370c7c711321549129cd6e</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849299</data>
  <data key="d13"></data>
</edge>
<edge source="Điều 88" target="Kiểm soát viên">
  <data key="d7">1.0</data>
