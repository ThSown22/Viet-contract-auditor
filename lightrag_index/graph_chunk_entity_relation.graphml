  <data key="d0">Thủ tục hành chính</data>
  <data key="d1">HÀNH_VI</data>
  <data key="d2">Administrative procedures for transferring ownership of contributed assets.</data>
  <data key="d3">chunk-2eb9bbbcf6b6e613956612e1bdbdc127</data>
