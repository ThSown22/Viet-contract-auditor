<edge source="Công ty bị hợp nhất" target="Hợp đồng hợp nhất">
  <data key="d7">1.0</data>
  <data key="d8">Công ty bị hợp nhất prepares the Hợp đồng hợp nhất, which outlines the terms and conditions of the merger.</data>
  <data key="d9">contract preparation,merger terms</data>
  <data key="d10">chunk-87d8fe2bdf778bad13a2e66311b71743</data>
  <data key="d11">unknown_source</data>
