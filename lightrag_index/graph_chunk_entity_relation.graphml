</edge>
<edge source="Ủy ban nhân dân cấp xã" target="Tài sản">
  <data key="d7">1.0</data>
  <data key="d8">Ủy ban nhân dân cấp xã receives and publicly announces lost or abandoned property.</data>
  <data key="d9">public announcement,reception</data>
  <data key="d10">chunk-b2acb4f3dcdc42f5db6c9c4797e01299</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849663</data>
