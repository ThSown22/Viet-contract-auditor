  <data key="d0">Article 359</data>
  <data key="d1">HÀNH_VI</data>
  <data key="d2">Article 359 of the Civil Code outlines the responsibilities for delayed acceptance of the performance of obligations.</data>
  <data key="d3">chunk-428a1a2119667172b8e431b501835f64</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850228</data>
