  <data key="d13"></data>
</edge>
<edge source="Tòa án" target="Điều 133">
  <data key="d7">1.0</data>
  <data key="d8">Điều 133 involves the court's role in declaring civil transactions invalid and protecting the rights of a bona fide third party.</data>
  <data key="d9">court ruling,legal decision</data>
  <data key="d10">chunk-482a66c12f2040cbc0eabb425e1b6d97</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849361</data>
  <data key="d13"></data>
</edge>
<edge source="Tòa án" target="Điều 136">
  <data key="d7">1.0</data>
  <data key="d8">Điều 136 specifies that the court designates a legal representative in certain cases.</data>
  <data key="d9">court designation,legal representation</data>
