<edge source="Chuyển Đổi Giới Tính" target="Luật">
  <data key="d7">1.0</data>
  <data key="d8">The process of gender transition is regulated by law, allowing individuals to change their gender and update their legal records accordingly.</data>
  <data key="d9">gender transition,legal regulation</data>
  <data key="d10">chunk-846633705870effa2d882763f1693f90</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773848982</data>
  <data key="d13"></data>
</edge>
<edge source="Đời Sống Riêng Tư" target="Bí Mật Cá Nhân">
  <data key="d7">1.0</data>
  <data key="d8">Both private life and personal secrets are protected by law and cannot be violated without consent.</data>
  <data key="d9">personal secrets,privacy protection</data>
  <data key="d10">chunk-846633705870effa2d882763f1693f90</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773848981</data>
  <data key="d13"></data>
</edge>
<edge source="Bí Mật Cá Nhân" target="Bí Mật Gia Đình">
  <data key="d7">1.0</data>
  <data key="d8">Both personal and family secrets are protected by law and cannot be disclosed without consent.</data>
  <data key="d9">family secrets,privacy protection</data>
  <data key="d10">chunk-846633705870effa2d882763f1693f90</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773848981</data>
  <data key="d13"></data>
</edge>
<edge source="Thư Tín" target="Điện Thoại">
  <data key="d7">1.0</data>
  <data key="d8">Both letters and telephone communications are protected by law and cannot be intercepted or disclosed without legal justification.</data>
  <data key="d9">communication protection,private information</data>
  <data key="d10">chunk-846633705870effa2d882763f1693f90</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773848981</data>
  <data key="d13"></data>
</edge>
<edge source="Điện Thoại" target="Điện Tín">
  <data key="d7">1.0</data>
  <data key="d8">Both telephone and telegrams are protected by law and cannot be intercepted or disclosed without legal justification.</data>
  <data key="d9">communication protection,electronic communication</data>
  <data key="d10">chunk-846633705870effa2d882763f1693f90</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773848982</data>
  <data key="d13"></data>
</edge>
<edge source="Điện Tín" target="Cơ Sở Dữ Liệu Điện Tử">
  <data key="d7">1.0</data>
  <data key="d8">Both telegrams and electronic databases are protected by law and cannot be accessed or disclosed without legal justification.</data>
  <data key="d9">communication protection,electronic data</data>
  <data key="d10">chunk-846633705870effa2d882763f1693f90</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773848981</data>
  <data key="d13"></data>
</edge>
