  <data key="d1">VĂN_BẢN_PHÁP_LUẬT</data>
  <data key="d2">Số Tiền Đã Trả refers to the amount of money that has already been paid by the buyer.</data>
  <data key="d3">chunk-4623833cd0cb1b86833b9050e09612fd</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850374</data>
  <data key="d6"></data>
</node>
