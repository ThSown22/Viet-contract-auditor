<edge source="Cộng hòa xã hội chủ nghĩa Việt Nam" target="Điều 664">
  <data key="d7">1.0</data>
  <data key="d8">Cộng hòa xã hội chủ nghĩa Việt Nam is a member of international treaties that determine the applicable law for civil relations with foreign elements, as outlined in Điều 664.</data>
  <data key="d9">international treaty member,legal provision</data>
  <data key="d10">chunk-651ba86aa84dcd7fdcb6fe6cfa6aacef</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851459</data>
  <data key="d13"></data>
</edge>
<edge source="Người mất năng lực hành vi dân sự" target="Người đại diện theo pháp luật">
  <data key="d7">1.0</data>
  <data key="d8">Người đại diện theo pháp luật acts on behalf of individuals who have lost their legal capacity in civil transactions.</data>
  <data key="d9">civil transactions,legal representation</data>
  <data key="d10">chunk-b10203f42f3e19a8ee82cd4453e46d58</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849086</data>
  <data key="d13"></data>
</edge>
<edge source="Người mất năng lực hành vi dân sự" target="Giao dịch dân sự">
  <data key="d7">2.0</data>
  <data key="d8">Individuals who have lost their legal capacity cannot independently engage in civil transactions and require a legal representative.&lt;SEP&gt;Civil transactions by people who have lost their capacity for civil conduct can be declared invalid.</data>
  <data key="d9">civil transaction,civil transactions,legal capacity,legal incapacity</data>
  <data key="d10">chunk-b10203f42f3e19a8ee82cd4453e46d58&lt;SEP&gt;chunk-6fef2e18615af027f8385abdb8209870</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849117</data>
  <data key="d13"></data>
</edge>
<edge source="Người mất năng lực hành vi dân sự" target="Người đại diện">
  <data key="d7">1.0</data>
  <data key="d8">Individuals who have lost their legal capacity require a legal representative.</data>
  <data key="d9">guardianship,legal representation</data>
  <data key="d10">chunk-a4a95c6c117e21012baec10d4e1fb78c</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849189</data>
  <data key="d13"></data>
</edge>
<edge source="Người đại diện theo pháp luật" target="Giao dịch dân sự">
  <data key="d7">1.0</data>
  <data key="d8">Người đại diện theo pháp luật acts on behalf of individuals with limited or no legal capacity in civil transactions.</data>
  <data key="d9">civil transactions,legal representation</data>
  <data key="d10">chunk-b10203f42f3e19a8ee82cd4453e46d58</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849086</data>
  <data key="d13"></data>
</edge>
<edge source="Người đại diện theo pháp luật" target="Người có khó khăn trong nhận thức, làm chủ hành vi">
  <data key="d7">1.0</data>
  <data key="d8">Người đại diện theo pháp luật acts on behalf of individuals who have difficulties in understanding and controlling their behavior but have not lost their legal capacity in civil transactions.</data>
  <data key="d9">civil transactions,legal representation</data>
  <data key="d10">chunk-b10203f42f3e19a8ee82cd4453e46d58</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849086</data>
  <data key="d13"></data>
</edge>
<edge source="Người đại diện theo pháp luật" target="Người từ đủ mười lăm tuổi đến chưa đủ mười tám tuổi">
  <data key="d7">1.0</data>
  <data key="d8">Người đại diện theo pháp luật acts on behalf of individuals between the ages of 15 and 18 in certain types of civil transactions.</data>
  <data key="d9">civil transactions,legal representation</data>
  <data key="d10">chunk-b10203f42f3e19a8ee82cd4453e46d58</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849086</data>
  <data key="d13"></data>
</edge>
<edge source="Người đại diện theo pháp luật" target="Người bị hạn chế năng lực hành vi dân sự">
  <data key="d7">1.0</data>
  <data key="d8">Người đại diện theo pháp luật acts on behalf of individuals whose legal capacity is restricted due to drug addiction or other conditions in civil transactions.</data>
  <data key="d9">civil transactions,legal representation</data>
  <data key="d10">chunk-b10203f42f3e19a8ee82cd4453e46d58</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849086</data>
  <data key="d13"></data>
</edge>
