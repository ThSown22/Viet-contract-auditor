</edge>
<edge source="Phạt vi phạm" target="Điều 418">
  <data key="d7">1.0</data>
  <data key="d8">Điều 418 outlines the agreement on penalties for contract violations, including the amount of the penalty and the conditions under which the penalty is applied.</data>
  <data key="d9">contract violation,penalty agreement</data>
  <data key="d10">chunk-f99273835b3b6031602578494c58acd7</data>
  <data key="d11">unknown_source</data>
