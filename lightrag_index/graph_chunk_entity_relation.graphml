  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Trách Nhiệm Do Chậm Thực Hiện Nghĩa Vụ Trả Tiền refers to the responsibility for delaying the payment of money.</data>
  <data key="d3">chunk-e38fe034461862746b38b34d7647cf44</data>
