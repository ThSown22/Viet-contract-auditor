<edge source="Doanh nghiệp" target="Chi nhánh">
  <data key="d7">1.0</data>
  <data key="d8">Doanh nghiệp can establish branches that perform all or part of the business entity's functions.</data>
  <data key="d9">branch establishment,business functions</data>
  <data key="d10">chunk-d7fe6829fe23e522eebc6b5e94e0f4e3</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851870</data>
  <data key="d13"></data>
</edge>
<edge source="Doanh nghiệp" target="Địa điểm kinh doanh">
  <data key="d7">1.0</data>
  <data key="d8">Doanh nghiệp conducts specific business activities at designated business locations.</data>
  <data key="d9">activity conduct,business location</data>
  <data key="d10">chunk-d7fe6829fe23e522eebc6b5e94e0f4e3</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851870</data>
  <data key="d13"></data>
</edge>
<edge source="Doanh nghiệp" target="Hồ sơ đăng ký hoạt động">
  <data key="d7">1.0</data>
  <data key="d8">Doanh nghiệp submits a registration file to the registration authority for the establishment of branches or representative offices.</data>
  <data key="d9">registration file,submission</data>
  <data key="d10">chunk-d7fe6829fe23e522eebc6b5e94e0f4e3</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851870</data>
  <data key="d13"></data>
</edge>
<edge source="Doanh nghiệp" target="Điều  207">
  <data key="d7">1.0</data>
  <data key="d8">Business entities must follow regulations concerning the conditions and circumstances for their dissolution.</data>
  <data key="d9">dissolution regulation,responsibility</data>
  <data key="d10">chunk-4751985bdb7ed5cd1ede693d8fa04ae4</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773853316</data>
  <data key="d13"></data>
</edge>
<edge source="Doanh nghiệp" target="Hợp đồng đã ký">
  <data key="d7">1.0</data>
  <data key="d8">Business entities must fulfill contracts signed with customers and employees during the period of temporary suspension.</data>
  <data key="d9">contract fulfillment,obligation</data>
  <data key="d10">chunk-4751985bdb7ed5cd1ede693d8fa04ae4</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773853316</data>
  <data key="d13"></data>
</edge>
<edge source="Doanh nghiệp" target="Thanh toán các khoản nợ">
  <data key="d7">1.0</data>
  <data key="d8">Doanh nghiệp must pay off debts, including taxes, after the termination of a branch.</data>
  <data key="d9">obligation,payment</data>
  <data key="d10">chunk-485e8c7bee0cdf1c48988e4c3d34522f</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773853538</data>
  <data key="d13"></data>
</edge>
<edge source="Doanh nghiệp" target="Giải quyết đủ quyền lợi hợp pháp cho người lao động">
  <data key="d7">1.0</data>
  <data key="d8">Doanh nghiệp must ensure the legal rights of employees who worked at the terminated branch.</data>
  <data key="d9">obligation,rights</data>
  <data key="d10">chunk-485e8c7bee0cdf1c48988e4c3d34522f</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773853538</data>
  <data key="d13"></data>
</edge>
<edge source="Doanh nghiệp" target="Người quản lý">
  <data key="d7">1.0</data>
  <data key="d8">Người quản lý is responsible for ensuring the business entity's debts are settled before dissolution.</data>
  <data key="d9">management,responsibility</data>
  <data key="d10">chunk-873972be10253bbd19fcbea390d18db2</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773853538</data>
  <data key="d13"></data>
</edge>
<edge source="Doanh nghiệp" target="Trọng tài">
  <data key="d7">1.0</data>
  <data key="d8">Doanh nghiệp must not be involved in dispute resolution processes at Trọng tài during dissolution.</data>
  <data key="d9">dispute resolution,legal process</data>
  <data key="d10">chunk-873972be10253bbd19fcbea390d18db2</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773853539</data>
  <data key="d13"></data>
</edge>
<edge source="Doanh nghiệp" target="Chủ doanh nghiệp tư nhân">
  <data key="d7">1.0</data>
  <data key="d8">Chủ doanh nghiệp tư nhân is the owner and manager of the business entity.</data>
  <data key="d9">management,ownership</data>
  <data key="d10">chunk-873972be10253bbd19fcbea390d18db2</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773853539</data>
  <data key="d13"></data>
</edge>
<edge source="Doanh nghiệp" target="Chủ tịch Hội đồng thành viên">
  <data key="d7">1.0</data>
  <data key="d8">Chủ tịch Hội đồng thành viên leads the board of members in managing the business entity.</data>
  <data key="d9">leadership,management</data>
  <data key="d10">chunk-873972be10253bbd19fcbea390d18db2</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773853539</data>
  <data key="d13"></data>
</edge>
<edge source="Doanh nghiệp" target="Chủ tịch Hội đồng quản trị">
  <data key="d7">1.0</data>
  <data key="d8">Chủ tịch Hội đồng quản trị leads the board of directors in managing the business entity.</data>
  <data key="d9">leadership,management</data>
  <data key="d10">chunk-873972be10253bbd19fcbea390d18db2</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773853539</data>
  <data key="d13"></data>
</edge>
<edge source="Doanh nghiệp" target="Cơ quan thuế">
  <data key="d7">2.0</data>
  <data key="d8">Cơ quan thuế is responsible for ensuring the business entity complies with tax regulations.&lt;SEP&gt;Doanh nghiệp must notify Cơ quan thuế of its activities.</data>
  <data key="d9">compliance,legal process,notification,tax compliance</data>
  <data key="d10">chunk-873972be10253bbd19fcbea390d18db2&lt;SEP&gt;chunk-45f9f1328d58ac04c74cf2a1422490ab</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773853703</data>
  <data key="d13"></data>
</edge>
<edge source="Doanh nghiệp" target="Người lao động">
  <data key="d7">1.0</data>
  <data key="d8">Người lao động are employees of the business entity and have rights and obligations during the dissolution process.</data>
  <data key="d9">employment,legal process</data>
  <data key="d10">chunk-873972be10253bbd19fcbea390d18db2</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773853539</data>
  <data key="d13"></data>
</edge>
<edge source="Doanh nghiệp" target="Chủ nợ">
  <data key="d7">1.0</data>
  <data key="d8">Chủ nợ are creditors of the business entity and must be informed of the dissolution process.</data>
  <data key="d9">creditor,debt settlement</data>
  <data key="d10">chunk-873972be10253bbd19fcbea390d18db2</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773853539</data>
  <data key="d13"></data>
</edge>
<edge source="Doanh nghiệp" target="Cơ sở dữ liệu quốc gia về đăng ký doanh nghiệp">
  <data key="d7">1.0</data>
  <data key="d8">Cơ sở dữ liệu quốc gia về đăng ký doanh nghiệp is used to update the legal status of the business entity during the dissolution process.</data>
  <data key="d9">legal status,registration</data>
  <data key="d10">chunk-873972be10253bbd19fcbea390d18db2</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773853539</data>
  <data key="d13"></data>
</edge>
<edge source="Doanh nghiệp" target="Nghị quyết">
  <data key="d7">1.0</data>
  <data key="d8">Nghị quyết is a resolution document used in the process of dissolving the business entity.</data>
  <data key="d9">dissolution,legal document</data>
  <data key="d10">chunk-873972be10253bbd19fcbea390d18db2</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773853539</data>
  <data key="d13"></data>
</edge>
<edge source="Doanh nghiệp" target="Quyết định giải thể doanh nghiệp">
  <data key="d7">1.0</data>
  <data key="d8">Quyết định giải thể doanh nghiệp is a decision document used in the process of dissolving the business entity.</data>
  <data key="d9">dissolution,legal document</data>
  <data key="d10">chunk-873972be10253bbd19fcbea390d18db2</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773853539</data>
  <data key="d13"></data>
</edge>
<edge source="Doanh nghiệp" target="Biên bản họp">
  <data key="d7">1.0</data>
  <data key="d8">Biên bản họp is a meeting minutes document used in the process of dissolving the business entity.</data>
  <data key="d9">legal document,meeting minutes</data>
  <data key="d10">chunk-873972be10253bbd19fcbea390d18db2</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773853539</data>
  <data key="d13"></data>
</edge>
<edge source="Doanh nghiệp" target="Phương án giải quyết nợ">
  <data key="d7">1.0</data>
  <data key="d8">Phương án giải quyết nợ is a debt resolution plan document used in the process of dissolving the  business entity.</data>
  <data key="d9">debt resolution,legal document</data>
  <data key="d10">chunk-873972be10253bbd19fcbea390d18db2</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773853539</data>
  <data key="d13"></data>
</edge>
<edge source="Công ty trách nhiệm hữu hạn" target="Phần vốn góp">
  <data key="d7">1.0</data>
  <data key="d8">Phần vốn góp is a concept applicable to Công ty trách nhiệm hữu hạn.</data>
  <data key="d9">company type,ownership</data>
  <data key="d10">chunk-4c4083a7e93b6ad10b316c67434aca7b</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851808</data>
  <data key="d13"></data>
</edge>
<edge source="Công ty trách nhiệm hữu hạn" target="Điều lệ công ty">
  <data key="d7">1.0</data>
  <data key="d8">Điều lệ công ty is the charter for a Công ty trách nhiệm hữu hạn.</data>
  <data key="d9">charter,company type</data>
  <data key="d10">chunk-4c4083a7e93b6ad10b316c67434aca7b</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851808</data>
  <data key="d13"></data>
</edge>
<edge source="Công ty trách nhiệm hữu hạn" target="Doanh nghiệp Nhà nước">
  <data key="d7">1.0</data>
  <data key="d8">Doanh nghiệp Nhà nước can be organized under the form of a Công ty trách nhiệm hữu hạn.</data>
  <data key="d9">management structure,organizational form</data>
  <data key="d10">chunk-246618b082091a628ff89e93d59fc956</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773852018</data>
  <data key="d13"></data>
</edge>
<edge source="Công ty trách nhiệm hữu hạn" target="Doanh nghiệp tư nhân">
  <data key="d7">1.0</data>
  <data key="d8">Doanh nghiệp tư nhân can be converted into a Công ty trách nhiệm hữu hạn.</data>
  <data key="d9">business type,conversion</data>
  <data key="d10">chunk-8da64b48c80fc4788c324e08350a340e</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773853285</data>
  <data key="d13"></data>
</edge>
<edge source="Công ty trách nhiệm hữu hạn" target="Công ty cổ phần">
  <data key="d7">1.0</data>
  <data key="d8">Công ty trách nhiệm hữu hạn can convert into a Công ty cổ phần and must register this conversion with the business registration agency.</data>
  <data key="d9">company conversion,legal registration</data>
  <data key="d10">chunk-e4a657b345d0676b5a5d6451a2c7c13d</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773853385</data>
  <data key="d13"></data>
</edge>
<edge source="Công ty trách nhiệm hữu hạn" target="Cơ quan đăng ký kinh doanh">
  <data key="d7">1.0</data>
  <data key="d8">Công ty trách nhiệm hữu hạn must register its conversion with the business registration agency, which updates the company's legal status in the National Database on Business Registration.</data>
  <data key="d9">legal registration,status update</data>
  <data key="d10">chunk-e4a657b345d0676b5a5d6451a2c7c13d</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773853385</data>
  <data key="d13"></data>
</edge>
<edge source="Công ty trách nhiệm hữu hạn" target="Điều 202">
  <data key="d7">1.0</data>
  <data key="d8">Điều 202 outlines the procedures for the conversion of limited liability companies into joint-stock companies, including the registration and legal status updates.</data>
  <data key="d9">conversion process,regulation</data>
  <data key="d10">chunk-e4a657b345d0676b5a5d6451a2c7c13d</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773853385</data>
  <data key="d13"></data>
</edge>
<edge source="Công ty cổ phần" target="Doanh nghiệp Nhà nước">
  <data key="d7">1.0</data>
  <data key="d8">Doanh nghiệp Nhà nước can be organized under the form of a Công ty cổ phần.</data>
  <data key="d9">management structure,organizational form</data>
  <data key="d10">chunk-246618b082091a628ff89e93d59fc956</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773852018</data>
  <data key="d13"></data>
</edge>
<edge source="Công ty cổ phần" target="Sổ đăng ký cổ đông">
  <data key="d7">2.0</data>
  <data key="d8">Công ty cổ phần is responsible for maintaining the Sổ đăng ký cổ đông.&lt;SEP&gt;Sổ đăng ký cổ đông records the ownership of shares in a company.</data>
  <data key="d9">maintenance,ownership record,registration,responsibility</data>
  <data key="d10">chunk-dc2c4537017d8abf8400a3fc36e9aa3e&lt;SEP&gt;chunk-d4c6a296c5e1b248b6b79c98f9b16e6d</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773852598</data>
  <data key="d13"></data>
</edge>
<edge source="Công ty cổ phần" target="Điều lệ công ty">
  <data key="d7">4.0</data>
  <data key="d8">Công ty cổ phần must comply with the requirements of the Điều lệ công ty regarding the maintenance of the Sổ đăng ký cổ đông.&lt;SEP&gt;Điều lệ công ty contains rules and regulations for the company's operations.&lt;SEP&gt;Điều lệ công ty is the charter of the company that specifies the rules and regulations.&lt;SEP&gt;Công ty cổ phần must publish the Điều lệ công ty on its electronic information site.</data>
  <data key="d9">articles of association,company charter,disclosure,governance,publication,regulation,requirement</data>
  <data key="d10">chunk-dc2c4537017d8abf8400a3fc36e9aa3e&lt;SEP&gt;chunk-d4c6a296c5e1b248b6b79c98f9b16e6d&lt;SEP&gt;chunk-9b892718f9850a0f9775f9a075fb4282&lt;SEP&gt;chunk-b0cdd7174a5289f85d735aa45cd8829d</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773852994</data>
  <data key="d13"></data>
</edge>
<edge source="Công ty cổ phần" target="Cổ đông sáng lập">
  <data key="d7">1.0</data>
  <data key="d8">Cổ đông sáng lập are the founding shareholders of a company and have specific rights and obligations.</data>
  <data key="d9">founding,ownership</data>
  <data key="d10">chunk-705217d07d78fdf7f9b9f642d9c62131</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773852337</data>
  <data key="d13"></data>
</edge>
<edge source="Công ty cổ phần" target="Cổ phiếu">
  <data key="d7">1.0</data>
  <data key="d8">Cổ phiếu is a share certificate issued by a company and represents ownership.</data>
  <data key="d9">issuance,ownership</data>
  <data key="d10">chunk-705217d07d78fdf7f9b9f642d9c62131</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773852337</data>
  <data key="d13"></data>
</edge>
<edge source="Công ty cổ phần" target="Cổ phần">
  <data key="d7">4.0</data>
  <data key="d8">Công ty cổ phần issues and manages shares as part of its capital structure.&lt;SEP&gt;Công ty cổ phần divides its registered capital into equal parts called Cổ phần, which are owned by shareholders.&lt;SEP&gt;Cổ phần represents shares in a company, which can be owned by individuals or organizations.&lt;SEP&gt;Cổ phần are shares in a company that can be purchased and sold.</data>
  <data key="d9">company shares,equity division,financial regulation,ownership,ownership structure,share issuance,shareholding</data>
  <data key="d10">chunk-181537e875bd1f5ba6572b043272e618&lt;SEP&gt;chunk-643d72cdd6873e78e2d39abbf824c8bc&lt;SEP&gt;chunk-d4c6a296c5e1b248b6b79c98f9b16e6d&lt;SEP&gt;chunk-9b892718f9850a0f9775f9a075fb4282</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773852753</data>
  <data key="d13"></data>
</edge>
<edge source="Công ty cổ phần" target="Điều 112">
  <data key="d7">1.0</data>
  <data key="d8">Công ty cổ phần's capital management is regulated by Điều 112.</data>
  <data key="d9">capital management,legal regulation</data>
  <data key="d10">chunk-181537e875bd1f5ba6572b043272e618</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773852482</data>
  <data key="d13"></data>
</edge>
<edge source="Công ty cổ phần" target="Đиều 133">
  <data key="d7">1.0</data>
  <data key="d8">Công ty cổ phần's operations are regulated by Điều 133.</data>
  <data key="d9">legal regulation,operations</data>
  <data key="d10">chunk-181537e875bd1f5ba6572b043272e618</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773852482</data>
  <data key="d13"></data>
</edge>
<edge source="Công ty cổ phần" target="Điều 113">
  <data key="d7">1.0</data>
  <data key="d8">Công ty cổ phần's capital management is regulated by Điều 113.</data>
  <data key="d9">capital management,legal regulation</data>
  <data key="d10">chunk-181537e875bd1f5ba6572b043272e618</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773852482</data>
  <data key="d13"></data>
</edge>
<edge source="Công ty cổ phần" target="Trái phiếu">
  <data key="d7">2.0</data>
  <data key="d8">Công ty cổ phần has the right to issue Trái phiếu and other securities.&lt;SEP&gt;Trái phiếu are bonds issued by a company that can be converted into shares.</data>
  <data key="d9">company bonds,conversion,financial instrument,issuance</data>
  <data key="d10">chunk-643d72cdd6873e78e2d39abbf824c8bc&lt;SEP&gt;chunk-9b892718f9850a0f9775f9a075fb4282</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773852753</data>
  <data key="d13"></data>
</edge>
<edge source="Công ty cổ phần" target="Điều 111">
  <data key="d7">1.0</data>
  <data key="d8">Điều 111 defines the characteristics and rights of a Công ty cổ phần.</data>
  <data key="d9">legal definition,regulation</data>
  <data key="d10">chunk-643d72cdd6873e78e2d39abbf824c8bc</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773852486</data>
  <data key="d13"></data>
</edge>
<edge source="Công ty cổ phần" target="Điều 125">
  <data key="d7">1.0</data>
  <data key="d8">Điều 125 regulates the private placement of shares in a company that is not publicly traded.</data>
  <data key="d9">private placement,regulation</data>
  <data key="d10">chunk-d4c6a296c5e1b248b6b79c98f9b16e6d</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773852598</data>
  <data key="d13"></data>
</edge>
<edge source="Công ty cổ phần" target="Điều 126">
  <data key="d7">1.0</data>
  <data key="d8">Điều 126 regulates the sale of shares in a company.</data>
  <data key="d9">regulation,share sale</data>
  <data key="d10">chunk-d4c6a296c5e1b248b6b79c98f9b16e6d</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773852598</data>
  <data key="d13"></data>
</edge>
<edge source="Công ty cổ phần" target="Điều 127">
  <data key="d7">1.0</data>
  <data key="d8">Điều 127 regulates the transfer of shares in a company.</data>
  <data key="d9">regulation,share transfer</data>
  <data key="d10">chunk-d4c6a296c5e1b248b6b79c98f9b16e6d</data>
