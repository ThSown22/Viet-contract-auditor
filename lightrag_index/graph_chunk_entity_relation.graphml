</edge>
<edge source="Điều 132" target="Công ty">
  <data key="d7">1.0</data>
  <data key="d8">Điều 132 outlines the rules for the company to repurchase shares.</data>
  <data key="d9">legal compliance,share repurchase</data>
  <data key="d10">chunk-afb6321b2b86d4ca9f69b3b408f671a7</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773852413</data>
  <data key="d13"></data>
</edge>
<edge source="Điều 132" target="Công ty cổ phần">
  <data key="d7">1.0</data>
  <data key="d8">Công ty cổ phần's operations are regulated by Điều 132.</data>
  <data key="d9">legal regulation,operations</data>
  <data key="d10">chunk-181537e875bd1f5ba6572b043272e618</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773852482</data>
  <data key="d13"></data>
</edge>
<edge source="Đại diện theo pháp luật" target="Người được đại diện">
  <data key="d7">1.0</data>
  <data key="d8">Legal representation is the concept that defines the rights and responsibilities of a representative in conducting civil transactions on behalf of another party.</data>
  <data key="d9">legal authority,representation</data>
  <data key="d10">chunk-5cb7db3cfef705b914008825e4c276e6</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849275</data>
  <data key="d13"></data>
</edge>
<edge source="Đại diện theo pháp luật" target="Phạm vi đại diện">
  <data key="d7">1.0</data>
  <data key="d8">Legal representation is defined by the scope of representation, which limits the actions a representative can take on behalf of another party.</data>
  <data key="d9">legal authority,representation scope</data>
  <data key="d10">chunk-5cb7db3cfef705b914008825e4c276e6</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849276</data>
  <data key="d13"></data>
</edge>
<edge source="Người được đại diện" target="Đại diện theo pháp luật chấm dứt">
  <data key="d7">1.0</data>
  <data key="d8">The termination of legal representation can occur when the represented party reaches adulthood or regains civil capacity.</data>
  <data key="d9">legal representation,termination condition</data>
  <data key="d10">chunk-5cb7db3cfef705b914008825e4c276e6</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849276</data>
  <data key="d13"></data>
</edge>
<edge source="Người được đại diện" target="Người giao dịch">
  <data key="d7">1.0</data>
  <data key="d8">Người giao dịch engages in a transaction with Người đại diện and may be held responsible for any damage caused to Người được đại diện.</data>
  <data key="d9">legal responsibility,transaction</data>
  <data key="d10">chunk-7fce420202370c7c711321549129cd6e</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849299</data>
  <data key="d13"></data>
</edge>
<edge source="Người được đại diện" target="Điều 134">
  <data key="d7">1.0</data>
  <data key="d8">Điều 134 defines the role of the individual or legal entity on whose behalf another acts for civil transactions.</data>
  <data key="d9">legal action,representation</data>
  <data key="d10">chunk-482a66c12f2040cbc0eabb425e1b6d97</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849361</data>
  <data key="d13"></data>
</edge>
<edge source="Phạm vi đại diện" target="Quyết định của cơ quan có thẩm quyền">
  <data key="d7">1.0</data>
  <data key="d8">Decisions by authorized bodies can establish the scope of representation.</data>
  <data key="d9">authorization,legal provision</data>
  <data key="d10">chunk-5cb7db3cfef705b914008825e4c276e6</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849276</data>
  <data key="d13"></data>
</edge>
<edge source="Phạm vi đại diện" target="Điều lệ của pháp nhân">
  <data key="d7">1.0</data>
  <data key="d8">The articles of association of a legal entity can define the scope of representation.</data>
  <data key="d9">authorization,legal provision</data>
  <data key="d10">chunk-5cb7db3cfef705b914008825e4c276e6</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849276</data>
  <data key="d13"></data>
</edge>
<edge source="Phạm vi đại diện" target="Nội dung ủy quyền">
  <data key="d7">1.0</data>
  <data key="d8">The content of authorization can specify the scope of representation.</data>
  <data key="d9">authorization,legal provision</data>
  <data key="d10">chunk-5cb7db3cfef705b914008825e4c276e6</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849276</data>
  <data key="d13"></data>
</edge>
<edge source="Phạm vi đại diện" target="Quy định khác của pháp luật">
  <data key="d7">1.0</data>
  <data key="d8">Other legal provisions can define the scope of representation.</data>
  <data key="d9">authorization,legal provision</data>
  <data key="d10">chunk-5cb7db3cfef705b914008825e4c276e6</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849276</data>
  <data key="d13"></data>
</edge>
<edge source="Phạm vi đại diện" target="Người đại diện xác lập, thực hiện vượt quá phạm vi đại diện">
  <data key="d7">1.0</data>
  <data key="d8">A representative who conducts transactions beyond the scope of representation exceeds the authorized limits of representation.</data>
  <data key="d9">exceeding scope,legal consequence</data>
  <data key="d10">chunk-5cb7db3cfef705b914008825e4c276e6</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849276</data>
  <data key="d13"></data>
</edge>
<edge source="Phạm vi đại diện" target="Điều 141">
  <data key="d7">1.0</data>
  <data key="d8">Article 141 defines the scope of representation in civil transactions.</data>
  <data key="d9">legal provision,representation scope</data>
  <data key="d10">chunk-5cb7db3cfef705b914008825e4c276e6</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849276</data>
  <data key="d13"></data>
</edge>
<edge source="Người không có quyền đại diện" target="Điều 142">
  <data key="d7">1.0</data>
  <data key="d8">Article 142 outlines the consequences of civil transactions conducted by unauthorized representatives.</data>
  <data key="d9">legal provision,unauthorized representation</data>
  <data key="d10">chunk-5cb7db3cfef705b914008825e4c276e6</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849276</data>
  <data key="d13"></data>
</edge>
