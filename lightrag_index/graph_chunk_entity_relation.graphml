  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">People with family relationships include spouses, parents, children, siblings, and in-laws.</data>
  <data key="d3">chunk-6e46e77902b28cf799e37bb0e795f60c</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773851381</data>
  <data key="d6"></data>
</node>
<node id="Người Có Liên Quan">
  <data key="d0">Người Có Liên Quan</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">People or organizations with direct or indirect relationships to a business.&lt;SEP&gt;Individuals related to the company owner who are involved in transactions with the company.</data>
  <data key="d3">chunk-6e46e77902b28cf799e37bb0e795f60c&lt;SEP&gt;chunk-823e07d4a480b69d7f6ec00924cb4793</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773851979</data>
  <data key="d6"></data>
</node>
<node id="Công Ty Mẹ">
  <data key="d0">Công Ty Mẹ</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">Parent company, its managers, and legal representatives.&lt;SEP&gt;A parent company is a company that has significant control over another company through share ownership or decision-making power.&lt;SEP&gt;Công Ty Mẹ is the parent company that has responsibilities and rights towards its subsidiaries.</data>
  <data key="d3">chunk-6e46e77902b28cf799e37bb0e795f60c&lt;SEP&gt;chunk-8d59be88d8f39c9fce708d8b3f0c8014&lt;SEP&gt;chunk-b12f2587388d6a4e9e558de512dc2860</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773853348</data>
  <data key="d6"></data>
</node>
<node id="Công Ty Con">
  <data key="d0">Công Ty Con</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">Subsidiary company, its managers, and legal representatives.&lt;SEP&gt;A subsidiary company is a company that is controlled by a parent company through share ownership or decision-making power.&lt;SEP&gt;Công Ty Con is a subsidiary company that is owned or controlled by a parent company.</data>
  <data key="d3">chunk-6e46e77902b28cf799e37bb0e795f60c&lt;SEP&gt;chunk-8d59be88d8f39c9fce708d8b3f0c8014&lt;SEP&gt;chunk-b12f2587388d6a4e9e558de512dc2860</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773853348</data>
  <data key="d6"></data>
</node>
