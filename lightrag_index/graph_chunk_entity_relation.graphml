  <data key="d0">Giấy tờ liên quan đến tài sản thế chấp</data>
  <data key="d1">VĂN_BẢN_PHÁP_LUẬT</data>
  <data key="d2">Giấy tờ liên quan đến tài sản thế chấp refers to documents related to the collateral asset.</data>
  <data key="d3">chunk-35e5b9d9646a1753edafbdf0516edae4</data>
