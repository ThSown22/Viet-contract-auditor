  <data key="d7">1.0</data>
  <data key="d8">Đиều 229 establishes the rights of ownership for buried, hidden, or sunken property that is found.</data>
  <data key="d9">legal provision,ownership</data>
  <data key="d10">chunk-abefb366f0615b56504281fccf7e1528</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849498</data>
  <data key="d13"></data>
</edge>
<edge source="Tài Sản Bị Chôn, Giấu, Bị Vùi Lấp, Chìm Đắm" target="Quyền Sở Hữu">
  <data key="d7">1.0</data>
  <data key="d8">Tài Sản Bị Chôn, Giấu, Bị Vùi Lấp, Chìm Đắm can be claimed under Quyền Sở Hữu if discovered.</data>
  <data key="d9">discovery,ownership</data>
