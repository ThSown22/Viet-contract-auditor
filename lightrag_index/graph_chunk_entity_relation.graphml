  <data key="d11">unknown_source</data>
  <data key="d12">1773853538</data>
  <data key="d13"></data>
</edge>
<edge source="Chủ Sở Hữu" target="Nguyên Vật Liệu">
  <data key="d7">1.0</data>
  <data key="d8">The owner of the raw materials retains ownership of the new object created from those materials.</data>
  <data key="d9">ownership,raw materials</data>
