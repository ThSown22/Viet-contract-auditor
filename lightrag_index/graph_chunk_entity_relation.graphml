  <data key="d7">1.0</data>
  <data key="d8">Đиều 515 outlines the obligations of the Bên Sử Dụng Dịch Vụ in a service contract.</data>
  <data key="d9">legal provision,service user obligations</data>
  <data key="d10">chunk-63bea5bd12d1af991f494c7882f65825</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850693</data>
