  <data key="d0">Nghĩa Vụ Cung Cấp Thông Tin</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Nghĩa Vụ Cung Cấp Thông Tin refers to the obligation of the seller to provide necessary information about the purchased property and guide the buyer on its use.</data>
  <data key="d3">chunk-6fb0e6ef087a638bbb3f5e1626539a69</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850373</data>
  <data key="d6"></data>
</node>
