</edge>
<edge source="Kiểm soát viên" target="Thuế thu nhập doanh nghiệp">
  <data key="d7">1.0</data>
  <data key="d8">Kiểm soát viên must ensure that the company complies with Thuế thu nhập doanh nghiệp regulations and manages its finances accordingly.</data>
  <data key="d9">compliance,financial management</data>
  <data key="d10">chunk-4d51643ce273eae22725bc9b7424a745</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773852912</data>
  <data key="d13"></data>
</edge>
<edge source="Kiểm soát viên" target="Thu nhập và lợi ích khác">
  <data key="d7">1.0</data>
  <data key="d8">Kiểm soát viên must return any additional income or benefits obtained through a violation to the company.</data>
  <data key="d9">income,return</data>
  <data key="d10">chunk-b0cdd7174a5289f85d735aa45cd8829d</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773852993</data>
