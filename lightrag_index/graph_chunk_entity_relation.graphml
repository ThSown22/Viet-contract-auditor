</node>
<node id="Người Đứng Đầu Cơ Sở Khám Bệnh, Chữa Bệnh">
  <data key="d0">Người Đứng Đầu Cơ Sở Khám Bệnh, Chữa Bệnh</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">The person in charge of a medical facility who can authorize the examination of a deceased body.</data>
  <data key="d3">chunk-ba16bb9ed3be84682d4bd14bebf5eaba</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773848901</data>
