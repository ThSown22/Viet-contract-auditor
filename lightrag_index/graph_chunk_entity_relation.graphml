<edge source="Bên Bảo Đảm" target="Điều 307">
  <data key="d7">1.0</data>
  <data key="d8">Bên Bảo Đảm is involved in the payment of proceeds from the disposal of collateral as per the regulations outlined in Điều 307.</data>
  <data key="d9">legal obligation,proceeds payment</data>
  <data key="d10">chunk-3cdb3cd8d8583064c0301937b6f4744a</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850053</data>
  <data key="d13"></data>
</edge>
<edge source="Bên Bảo Đảm" target="Điều 308">
  <data key="d7">1.0</data>
  <data key="d8">Bên Bảo Đảm is involved in the priority order of payment as per the regulations outlined in Điều 308.</data>
  <data key="d9">legal obligation,priority payment</data>
  <data key="d10">chunk-3cdb3cd8d8583064c0301937b6f4744a</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850053</data>
