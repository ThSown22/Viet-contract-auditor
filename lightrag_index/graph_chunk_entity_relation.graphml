  <data key="d1">HÀNH_VI</data>
  <data key="d2">Điều 200 is a legal provision that outlines the state's role in managing public property invested in enterprises.</data>
  <data key="d3">chunk-7d82c525b3c62a646037cf7bc6fec6a5</data>
  <data key="d4">unknown_source</data>
