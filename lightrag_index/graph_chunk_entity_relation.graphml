  <data key="d1">VĂN_BẢN_PHÁP_LUẬT</data>
  <data key="d2">Phần Hoặc Bộ Phận Còn Thiếu refers to the missing parts or components of the delivered items that are required to make them complete and functional.</data>
  <data key="d3">chunk-4623833cd0cb1b86833b9050e09612fd</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850374</data>
  <data key="d6"></data>
</node>
