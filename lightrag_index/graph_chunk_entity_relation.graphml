  <data key="d0">Bản Tự Bảo Vệ</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Bản Tự Bảo Vệ is a self-defense statement submitted by the parties in an arbitration case.</data>
  <data key="d3">chunk-4467037e5832a3ba479e5bed20f265c7</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773853841</data>
  <data key="d6"></data>
</node>
<node id="Quyết Định Đình Chỉ Giải Quyết Tranh Chấp">
  <data key="d0">Quyết Định Đình Chỉ Giải Quyết Tranh Chấp</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Quyết Định Đình Chỉ Giải Quyết Tranh Chấp is a decision issued by the Chairman of Trung Tâm Trọng Tài to terminate the dispute resolution process if the parties reach an agreement.&lt;SEP&gt;Quyết Định Đình Chỉ Giải Quyết Tranh Chấp is a decision that stops the resolution of a dispute.</data>
  <data key="d3">chunk-4467037e5832a3ba479e5bed20f265c7&lt;SEP&gt;chunk-6520e05120076623f2042182e932b3ec</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773854008</data>
  <data key="d6"></data>
</node>
<node id="Thương Lượng Trong Tố Tụng Trọng Tài">
  <data key="d0">Thương Lượng Trong Tố Tụng Trọng Tài</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Thương Lượng Trong Tố Tụng Trọng Tài is the concept of negotiation between parties during the arbitration process to resolve disputes.</data>
  <data key="d3">chunk-4467037e5832a3ba479e5bed20f265c7</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773853841</data>
  <data key="d6"></data>
</node>
<node id="Thành Phần Hội Đồng Trọng Tài">
  <data key="d0">Thành Phần Hội Đồng Trọng Tài</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Thành Phần Hội Đồng Trọng Tài refers to the composition of the arbitration panel, which can include one or more arbitrators.</data>
  <data key="d3">chunk-4467037e5832a3ba479e5bed20f265c7</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773853841</data>
  <data key="d6"></data>
</node>
<node id="Chủ Tịch Trung Tâm Trọng Tài">
  <data key="d0">Chủ Tịch Trung Tâm Trọng Tài</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">Chủ Tịch Trung Tâm Trọng Tài is the Chairman of Trung Tâm Trọng Tài who has the authority to make decisions and appoint arbitrators.</data>
  <data key="d3">chunk-4467037e5832a3ba479e5bed20f265c7</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773853841</data>
  <data key="d6"></data>
</node>
<node id="Trọng Tài Viên">
  <data key="d0">Trọng Tài Viên</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">Trọng Tài Viên is an arbitrator who is appointed to resolve disputes in arbitration cases.&lt;SEP&gt;Trọng Tài Viên is an individual member of the Hội Đồng Trọng Tài who participates in the decision-making process and signs the arbitration decision.</data>
  <data key="d3">chunk-4467037e5832a3ba479e5bed20f265c7&lt;SEP&gt;chunk-6520e05120076623f2042182e932b3ec</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773854008</data>
  <data key="d6"></data>
</node>
<node id="Viện kiểm sát cùng cấp">
  <data key="d0">Viện kiểm sát cùng cấp</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">Viện kiểm sát cùng cấp is the same-level prosecution office that participates in the examination process.</data>
  <data key="d3">chunk-967ef50a189d7b94846c22abc99c1f09</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773853867</data>
  <data key="d6"></data>
</node>
<node id="Hội đồng xét đơn yêu cầu">
  <data key="d0">Hội đồng xét đơn yêu cầu</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">Hội đồng xét đơn yêu cầu is the panel that examines the request to annul an arbitration award.&lt;SEP&gt;Hội đồng xét đơn yêu cầu is an organization responsible for reviewing requests to annul arbitration awards.</data>
  <data key="d3">chunk-967ef50a189d7b94846c22abc99c1f09&lt;SEP&gt;chunk-d91f2a7788f7464204ab346b8f178828</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773853954</data>
  <data key="d6"></data>
</node>
