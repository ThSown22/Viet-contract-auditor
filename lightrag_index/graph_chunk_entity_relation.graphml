<edge source="Bên Bảo Đảm" target="Điều 306">
  <data key="d7">1.0</data>
  <data key="d8">Bên Bảo Đảm is involved in the valuation of collateral as per the regulations outlined in Điều 306.</data>
  <data key="d9">collateral valuation,legal obligation</data>
