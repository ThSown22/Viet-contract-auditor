<edge source="Người Thứ Ba" target="Người Chiếm Hữu">
  <data key="d7">1.0</data>
  <data key="d8">If a third party receives property from someone who possessed it without legal basis, the third party must return it.</data>
  <data key="d9">legal obligation,property transfer</data>
  <data key="d10">chunk-821c3a34361b8add641406062fd4a10e</data>
  <data key="d11">unknown_source</data>
