</edge>
<edge source="Viện kiểm sát cùng cấp" target="Hội đồng xét đơn yêu cầu">
  <data key="d7">1.0</data>
  <data key="d8">Hội đồng xét đơn yêu cầu collaborates with the same-level prosecution office in the examination process.</data>
  <data key="d9">collaboration,communication</data>
  <data key="d10">chunk-967ef50a189d7b94846c22abc99c1f09</data>
  <data key="d11">unknown_source</data>
