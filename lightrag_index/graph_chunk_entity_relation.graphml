<node id="Giấy chứng nhận phần vốn góp">
  <data key="d0">Giấy chứng nhận phần vốn góp</data>
  <data key="d1">VĂN_BẢN_PHÁP_LUẬT</data>
  <data key="d2">Certificate of capital contribution.&lt;SEP&gt;Giấy chứng nhận phần vốn góp is a document that certifies the contribution of capital by a member to the company.</data>
  <data key="d3">chunk-2eb9bbbcf6b6e613956612e1bdbdc127&lt;SEP&gt;chunk-1efb55d02317343a2ef5f32d5d741bc9</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773853200</data>
