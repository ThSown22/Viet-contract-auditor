  <data key="d0">Điều lệ công ty nhận sáp nhập</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Điều lệ công ty nhận sáp nhập is the charter of the receiving company that is prepared during the merger process.</data>
  <data key="d3">chunk-e4a657b345d0676b5a5d6451a2c7c13d</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773853384</data>
  <data key="d6"></data>
</node>
