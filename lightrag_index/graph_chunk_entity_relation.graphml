<edge source="Bên Tranh Chấp" target="Cơ Quan Thi Hành Án Dân Sự">
  <data key="d7">1.0</data>
  <data key="d8">Decisions regarding Biện Pháp Khẩn Cấp Tạm Thời must be sent to Bên Tranh Chấp and Cơ Quan Thi Hành Án Dân Sự.</data>
  <data key="d9">enforcement,notification</data>
  <data key="d10">chunk-a36e099bae803eeaad0a5160e83464d5</data>
