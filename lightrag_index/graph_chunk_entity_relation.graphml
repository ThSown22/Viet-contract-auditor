</node>
<node id="Hội đồng trọng tài vụ việc">
  <data key="d0">Hội đồng trọng tài vụ việc</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">Hội đồng trọng tài vụ việc is the arbitration panel formed to resolve a dispute.&lt;SEP&gt;Hội đồng trọng tài vụ việc is the Arbitration Board that resolves specific disputes.</data>
  <data key="d3">chunk-d4b1824dac8b182589cb4f697dad3e4f&lt;SEP&gt;chunk-4ad943b03a3a1bf95a1e1d6e04f2b581</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773854048</data>
