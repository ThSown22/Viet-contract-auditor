  <data key="d0">Báo Cáo Tổng Hợp Về Mua, Bán và Giao Dịch Khác với Công Ty Mẹ</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Báo Cáo Tổng Hợp Về Mua, Bán và Giao Dịch Khác với Công Ty Mẹ is a report that summarizes the transactions between the subsidiary and the parent company.</data>
  <data key="d3">chunk-b12f2587388d6a4e9e558de512dc2860</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773853349</data>
  <data key="d6"></data>
</node>
<node id="Công ty bị sáp nhập">
  <data key="d0">Công ty bị sáp nhập</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">Công ty bị sáp nhập is a company that merges into another company, transferring all assets, rights, obligations, and legal interests to the receiving company.</data>
  <data key="d3">chunk-e4a657b345d0676b5a5d6451a2c7c13d</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773853384</data>
  <data key="d6"></data>
</node>
<node id="Công ty nhận sáp nhập">
  <data key="d0">Công ty nhận sáp nhập</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">Công ty nhận sáp nhập is a company that receives another company through a merger, inheriting all assets, rights, obligations, and legal interests.</data>
  <data key="d3">chunk-e4a657b345d0676b5a5d6451a2c7c13d</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773853384</data>
  <data key="d6"></data>
</node>
<node id="Luật Cạnh tranh">
  <data key="d0">Luật Cạnh tranh</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Luật Cạnh tranh is the Competition Law that companies must comply with during mergers.&lt;SEP&gt;Luật Cạnh tranh is a law that provides regulations for the merger of companies.</data>
  <data key="d3">chunk-e4a657b345d0676b5a5d6451a2c7c13d&lt;SEP&gt;chunk-87d8fe2bdf778bad13a2e66311b71743</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773853442</data>
  <data key="d6"></data>
</node>
<node id="Hợp đồng sáp nhập">
  <data key="d0">Hợp đồng sáp nhập</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Hợp đồng sáp nhập is the merger contract that includes details such as the names and addresses of the companies involved, procedures, and conditions for the merger.</data>
  <data key="d3">chunk-e4a657b345d0676b5a5d6451a2c7c13d</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773853384</data>
  <data key="d6"></data>
</node>
