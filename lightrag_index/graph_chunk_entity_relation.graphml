  <data key="d0">Ủy Ban Nhân Dân Cấp Tỉnh</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">Ủy Ban Nhân Dân Cấp Tỉnh is a provincial-level government body responsible for managing enterprises within its jurisdiction.</data>
  <data key="d3">chunk-c5a052d442484a7e21099fd9dda00e96</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773853724</data>
  <data key="d6"></data>
</node>
