<node id="Điều 133">
  <data key="d0">Điều 133</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Điều 133 is a legal provision that outlines the protection of rights for a bona fide third party when a civil transaction is declared invalid.&lt;SEP&gt;Điều 133 is a specific article in the law that outlines the rules for the company to repurchase shares.&lt;SEP&gt;Điều 133 is a legal article that specifies regulations related to the operations of a joint-stock company.</data>
  <data key="d3">chunk-482a66c12f2040cbc0eabb425e1b6d97&lt;SEP&gt;chunk-afb6321b2b86d4ca9f69b3b408f671a7&lt;SEP&gt;chunk-181537e875bd1f5ba6572b043272e618</data>
  <data key="d4">unknown_source</data>
