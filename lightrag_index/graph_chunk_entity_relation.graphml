  <data key="d2">Trách Nhiệm Do Không Thực Hiện Nghĩa Vụ Giao Vật refers to the responsibility for not fulfilling an obligation to deliver a specific item.</data>
  <data key="d3">chunk-e38fe034461862746b38b34d7647cf44</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773849907</data>
