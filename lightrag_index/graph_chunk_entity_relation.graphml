</edge>
<edge source="Chủ Sở Hữu" target="Quyền Sở Hữu">
  <data key="d7">1.0</data>
  <data key="d8">Chủ Sở Hữu can transfer Quyền Sở Hữu to others through various legal means.</data>
  <data key="d9">ownership transfer,rights</data>
  <data key="d10">chunk-63e06b29bf3043507cfbd43beb81a47f</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849736</data>
  <data key="d13"></data>
</edge>
<edge source="Chủ Sở Hữu" target="Quyền Hưởng Dụng">
  <data key="d7">1.0</data>
  <data key="d8">Quyền Hưởng Dụng is a legal right that allows the user to exploit and benefit from the utility and income of another's property, while the owner retains ownership.</data>
  <data key="d9">legal right,property ownership</data>
  <data key="d10">chunk-3b5f857bd7e099346e71679265152a98</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849889</data>
  <data key="d13"></data>
</edge>
<edge source="Chủ Sở Hữu" target="Người Hưởng Dụng">
  <data key="d7">1.0</data>
  <data key="d8">Người Hưởng Dụng has the right to use the property of the owner for a specified period.</data>
  <data key="d9">legal relationship,property use</data>
  <data key="d10">chunk-3b5f857bd7e099346e71679265152a98</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849889</data>
  <data key="d13"></data>
</edge>
<edge source="Chủ Sở Hữu" target="Điều 255">
  <data key="d7">1.0</data>
  <data key="d8">Điều 255 allows the owner of real estate to install power lines and communication lines through other properties reasonably, ensuring safety and convenience.</data>
  <data key="d9">legal provision,property rights</data>
  <data key="d10">chunk-3b5f857bd7e099346e71679265152a98</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849889</data>
  <data key="d13"></data>
</edge>
<edge source="Chủ Sở Hữu" target="Đиều 263">
  <data key="d7">1.0</data>
  <data key="d8">Đиều 263 outlines the rights and obligations of the property owner.</data>
  <data key="d9">legal provision,owner rights and obligations</data>
  <data key="d10">chunk-3b5f857bd7e099346e71679265152a98</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849889</data>
  <data key="d13"></data>
</edge>
<edge source="Chủ Sở Hữu" target="Điều 263">
  <data key="d7">1.0</data>
  <data key="d8">Điều 263 outlines the rights and obligations of the property owner.</data>
  <data key="d9">legal provision,owner rights and obligations</data>
  <data key="d10">chunk-3b5f857bd7e099346e71679265152a98</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849889</data>
  <data key="d13"></data>
</edge>
<edge source="Chủ Sở Hữu" target="Người Chiếm Hữu">
  <data key="d7">1.0</data>
  <data key="d8">A person who possesses another's property without legal basis must return it to the rightful owner.</data>
  <data key="d9">legal obligation,property return</data>
  <data key="d10">chunk-821c3a34361b8add641406062fd4a10e</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851194</data>
  <data key="d13"></data>
</edge>
<edge source="Chủ Sở Hữu" target="Người Sử Dụng Tài Sản">
  <data key="d7">1.0</data>
  <data key="d8">A person who uses another's property without legal basis must return it to the rightful owner.</data>
  <data key="d9">legal obligation,property return</data>
  <data key="d10">chunk-821c3a34361b8add641406062fd4a10e</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851194</data>
  <data key="d13"></data>
</edge>
<edge source="Chủ Sở Hữu" target="Người Đại Diện Theo Ủy Quyền">
  <data key="d7">1.0</data>
  <data key="d8">Người Đại Diện Theo Ủy Quyền is authorized by the Chủ Sở Hữu to represent their interests.</data>
  <data key="d9">authorization,representation</data>
  <data key="d10">chunk-dd4fb2094298c5037722675df8cc46f3</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851463</data>
  <data key="d13"></data>
</edge>
<edge source="Nguyên Vật Liệu" target="Người Dùng">
  <data key="d7">1.0</data>
  <data key="d8">The person who uses the raw materials to create a new object.</data>
  <data key="d9">processing,use</data>
  <data key="d10">chunk-abefb366f0615b56504281fccf7e1528</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849497</data>
  <data key="d13"></data>
</edge>
<edge source="Nguyên Vật Liệu" target="Người Chế Biến">
  <data key="d7">1.0</data>
  <data key="d8">The person who processes the raw materials into a new object may become the owner if they are in good faith.</data>
  <data key="d9">ownership,processing</data>
  <data key="d10">chunk-abefb366f0615b56504281fccf7e1528</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849497</data>
  <data key="d13"></data>
</edge>
<edge source="Nguyên Vật Liệu" target="Bên Đặt Gia Công">
  <data key="d7">1.0</data>
  <data key="d8">Bên Đặt Gia Công provides the raw materials and retains ownership of them until the processing is complete.</data>
  <data key="d9">material provision,ownership</data>
  <data key="d10">chunk-b1c19a83d55829491343a14f74bec683</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850652</data>
  <data key="d13"></data>
</edge>
<edge source="Nguyên Vật Liệu" target="Bên Nhận Gia Công">
  <data key="d7">1.0</data>
  <data key="d8">Bên Nhận Gia Công processes the raw materials and bears the risk associated with them until the finished product is delivered.</data>
  <data key="d9">material processing,risk</data>
  <data key="d10">chunk-b1c19a83d55829491343a14f74bec683</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850652</data>
  <data key="d13"></data>
</edge>
<edge source="Tài Sản Vô Chủ" target="Người Phát Hiện">
  <data key="d7">1.0</data>
  <data key="d8">The person who discovers property or assets that have no known owner may become the owner under certain conditions.</data>
  <data key="d9">discovery,ownership</data>
  <data key="d10">chunk-abefb366f0615b56504281fccf7e1528</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849497</data>
  <data key="d13"></data>
</edge>
<edge source="Tài Sản Vô Chủ" target="Nhà Nước">
  <data key="d7">1.0</data>
  <data key="d8">If the discovered property or assets are immovable, they belong to the state.</data>
  <data key="d9">ownership,state property</data>
  <data key="d10">chunk-abefb366f0615b56504281fccf7e1528</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849497</data>
  <data key="d13"></data>
</edge>
<edge source="Tài Sản Vô Chủ" target="Điều 228">
  <data key="d7">1.0</data>
  <data key="d8">Điều 228 establishes the rights of ownership for ownerless property or property with an unknown owner.</data>
  <data key="d9">legal provision,ownership</data>
  <data key="d10">chunk-abefb366f0615b56504281fccf7e1528</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849498</data>
  <data key="d13"></data>
</edge>
<edge source="Người Phát Hiện" target="Công An Cấp Xã">
  <data key="d7">1.0</data>
  <data key="d8">The person who discovers property or assets must report to the local police body.</data>
  <data key="d9">handling,reporting</data>
  <data key="d10">chunk-abefb366f0615b56504281fccf7e1528</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849497</data>
  <data key="d13"></data>
</edge>
<edge source="Nhà Nước" target="Di Tích Lịch Sử - Văn Hóa">
  <data key="d7">1.0</data>
  <data key="d8">Historical and cultural relics belong to the state.</data>
  <data key="d9">cultural relics,ownership</data>
  <data key="d10">chunk-abefb366f0615b56504281fccf7e1528</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849498</data>
  <data key="d13"></data>
</edge>
<edge source="Nhà Nước" target="Tài Sản Công">
  <data key="d7">1.0</data>
  <data key="d8">Nhà Nước represents the state as the owner of public property and manages it uniformly.</data>
  <data key="d9">management,state ownership</data>
  <data key="d10">chunk-7d82c525b3c62a646037cf7bc6fec6a5</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849534</data>
  <data key="d13"></data>
</edge>
<edge source="Nhà Nước" target="Điều 198">
  <data key="d7">1.0</data>
  <data key="d8">Nhà Nước acts as the representative and exercises the rights of the owner of public property according to the law.</data>
  <data key="d9">property management,state role</data>
  <data key="d10">chunk-7d82c525b3c62a646037cf7bc6fec6a5</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849534</data>
  <data key="d13"></data>
</edge>
<edge source="Nhà Nước" target="Điều 199">
  <data key="d7">1.0</data>
  <data key="d8">Nhà Nước manages the possession, use, and disposition of public property within the scope and procedures prescribed by law.</data>
  <data key="d9">property management,state role</data>
  <data key="d10">chunk-7d82c525b3c62a646037cf7bc6fec6a5</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849534</data>
  <data key="d13"></data>
</edge>
<edge source="Nhà Nước" target="Điều 200">
  <data key="d7">1.0</data>
  <data key="d8">Nhà Nước manages public property invested in enterprises according to the law.</data>
  <data key="d9">property management,state role</data>
  <data key="d10">chunk-7d82c525b3c62a646037cf7bc6fec6a5</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849534</data>
  <data key="d13"></data>
</edge>
<edge source="Nhà Nước" target="Doanh Nghiệp">
  <data key="d7">1.0</data>
  <data key="d8">Nhà Nước recognizes and protects the existence and development of various types of enterprises, ensuring equality before the law and protecting the legal rights and interests of enterprises and their owners.</data>
  <data key="d9">legal protection,recognition</data>
  <data key="d10">chunk-870356636a26bb390c46554c34ceb657</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851504</data>
  <data key="d13"></data>
</edge>
<edge source="Nhà Nước" target="Vốn Đầu Tư">
  <data key="d7">1.0</data>
  <data key="d8">Nhà Nước ensures that the investments of enterprises and their owners are protected by the law and cannot be nationalized or confiscated without proper compensation.</data>
  <data key="d9">legal protection,nationalization</data>
  <data key="d10">chunk-870356636a26bb390c46554c34ceb657</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851504</data>
  <data key="d13"></data>
</edge>
<edge source="Nhà Nước" target="Thu Nhập">
  <data key="d7">1.0</data>
  <data key="d8">Nhà Nước ensures that the income of enterprises and their owners is protected by the law and cannot be nationalized or confiscated without proper compensation.</data>
  <data key="d9">legal protection,nationalization</data>
  <data key="d10">chunk-870356636a26bb390c46554c34ceb657</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851504</data>
  <data key="d13"></data>
</edge>
