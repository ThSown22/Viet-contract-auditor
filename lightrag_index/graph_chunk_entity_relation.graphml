  <data key="d0">Bộ trưởng Bộ Tư pháp</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">Bộ trưởng Bộ Tư pháp is the official responsible for issuing permits for the establishment of arbitration centers.</data>
  <data key="d3">chunk-1881019a36e766412bad88d7a1e3d088</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773853762</data>
  <data key="d6"></data>
</node>
