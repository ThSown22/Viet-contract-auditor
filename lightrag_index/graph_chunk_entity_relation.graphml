<edge source="Tổ chức Định Giá Tài Sản" target="Điều 306">
  <data key="d7">1.0</data>
  <data key="d8">Tổ chức Định Giá Tài Sản is responsible for valuing collateral as per the regulations outlined in Điều  306.</data>
  <data key="d9">collateral valuation,legal responsibility</data>
  <data key="d10">chunk-3cdb3cd8d8583064c0301937b6f4744a</data>
  <data key="d11">unknown_source</data>
