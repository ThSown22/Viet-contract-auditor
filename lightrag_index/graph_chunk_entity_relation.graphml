  <data key="d7">1.0</data>
  <data key="d8">Meeting materials can be posted on the company's electronic information website.</data>
  <data key="d9">electronic communication,meeting materials</data>
  <data key="d10">chunk-3c9b32b2b806556ed1dd36c13de6e313</data>
  <data key="d11">unknown_source</data>
