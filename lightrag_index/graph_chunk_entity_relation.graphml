  <data key="d7">1.0</data>
  <data key="d8">Chủ Sở Hữu can erect boundary markers by mutual agreement or with the consent of the adjacent property owner.</data>
  <data key="d9">boundary marker,mutual agreement</data>
  <data key="d10">chunk-931c1ae4f95c0b01df5de17931b38de9</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849726</data>
  <data key="d13"></data>
</edge>
<edge source="Chủ Sở Hữu" target="Pháp Luật Về Xây Dựng">
  <data key="d7">1.0</data>
  <data key="d8">Chủ Sở Hữu must follow construction regulations when building structures.</data>
  <data key="d9">construction regulations,legal compliance</data>
