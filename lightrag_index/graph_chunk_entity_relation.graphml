  <data key="d7">1.0</data>
  <data key="d8">Người đại diện theo pháp luật can represent the company in arbitration proceedings.</data>
  <data key="d9">legal representation,rights and obligations</data>
  <data key="d10">chunk-ead2cea9ac10e43e52710b6f386da07d</data>
  <data key="d11">unknown_source</data>
