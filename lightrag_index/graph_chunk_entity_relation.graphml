<edge source="Cá Nhân" target="Hộ Tịch">
  <data key="d7">2.0</data>
  <data key="d8">An individual must register changes to their identity in the legal document known as the household registration.&lt;SEP&gt;Individuals have the right to update their legal records, such as their household registration, after a gender transition.</data>
  <data key="d9">identity registration,legal record,legal requirement,personal information</data>
  <data key="d10">chunk-ba16bb9ed3be84682d4bd14bebf5eaba&lt;SEP&gt;chunk-846633705870effa2d882763f1693f90</data>
