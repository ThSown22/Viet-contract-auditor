<edge source="Ủy ban nhân dân cấp xã" target="Người giám hộ">
  <data key="d7">1.0</data>
  <data key="d8">A local government body is responsible for appointing a guardian if there is no natural guardian.</data>
  <data key="d9">guardianship,local government responsibility</data>
