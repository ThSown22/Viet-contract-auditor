  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Bản án refers to a court decision that can affect the ownership of property in civil transactions.</data>
  <data key="d3">chunk-482a66c12f2040cbc0eabb425e1b6d97</data>
