  <data key="d7">1.0</data>
  <data key="d8">Doanh nghiệp is responsible for registering changes to its branch or representative office within 10 days of any changes.</data>
  <data key="d9">registration,responsibility</data>
  <data key="d10">chunk-fef4d2c27b6430834254a2ffeefda111</data>
