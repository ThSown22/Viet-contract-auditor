  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Labor law refers to the legal framework that the owner of a private enterprise must comply with.</data>
  <data key="d3">chunk-8d59be88d8f39c9fce708d8b3f0c8014</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773853269</data>
  <data key="d6"></data>
</node>
