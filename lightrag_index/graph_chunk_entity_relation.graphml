  <data key="d0">Người Quản Lý Công Ty Mẹ</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">Người Quản Lý Công Ty Mẹ is the manager of the parent company who is responsible for the actions taken towards the subsidiary.</data>
  <data key="d3">chunk-b12f2587388d6a4e9e558de512dc2860</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773853348</data>
