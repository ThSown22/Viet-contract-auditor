</edge>
<edge source="Tài sản chung hỗn hợp" target="Chủ sở hữu">
  <data key="d7">1.0</data>
  <data key="d8">Tài sản chung hỗn hợp is mixed collective ownership of property contributed by owners from different economic sectors.</data>
  <data key="d9">mixed ownership,property rights</data>
  <data key="d10">chunk-3c40b3ec985a74cfbf857d108074883e</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849453</data>
  <data key="d13"></data>
</edge>
<edge source="Quản lý tài sản chung" target="Chủ sở hữu chung">
  <data key="d7">1.0</data>
  <data key="d8">Quản lý tài sản chung is the concept of managing shared property collectively by all owners.</data>
  <data key="d9">collective ownership,property management</data>
  <data key="d10">chunk-3c40b3ec985a74cfbf857d108074883e</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849453</data>
  <data key="d13"></data>
</edge>
<edge source="Sử dụng tài sản chung" target="Chủ sở hữu chung">
  <data key="d7">1.0</data>
  <data key="d8">Sử dụng tài sản chung is the concept of using shared property collectively by all owners.</data>
  <data key="d9">collective ownership,property use</data>
  <data key="d10">chunk-3c40b3ec985a74cfbf857d108074883e</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849453</data>
  <data key="d13"></data>
</edge>
