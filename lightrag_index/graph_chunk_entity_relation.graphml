  <data key="d7">1.0</data>
  <data key="d8">The interest rate for delayed payment is related to the responsibility for not performing a task.</data>
  <data key="d9">compensation,financial obligation</data>
  <data key="d10">chunk-428a1a2119667172b8e431b501835f64</data>
