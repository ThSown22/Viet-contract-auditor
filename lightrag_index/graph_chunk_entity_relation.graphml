</edge>
<edge source="Người vắng mặt" target="Quản lý tài sản">
  <data key="d7">1.0</data>
  <data key="d8">The assets of a missing person are managed according to the legal provisions.</data>
  <data key="d9">asset ownership,management</data>
  <data key="d10">chunk-10d3e6bb3412e6c6eab3d00101010d92</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773848909</data>
  <data key="d13"></data>
</edge>
<edge source="Người có quyền, lợi ích liên quan" target="Quản lý tài sản">
  <data key="d7">1.0</data>
  <data key="d8">Individuals with rights or interests related to the missing person can request the management of the missing person's assets.</data>
  <data key="d9">asset management,legal rights</data>
  <data key="d10">chunk-10d3e6bb3412e6c6eab3d00101010d92</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773848909</data>
  <data key="d13"></data>
</edge>
<edge source="Bộ luật này" target="Quan hệ dân sự">
  <data key="d7">1.0</data>
  <data key="d8">The Civil Code regulates civil relations formed on the basis of equality, freedom of will, and independent property.</data>
  <data key="d9">legal framework,regulation</data>
  <data key="d10">chunk-4c55b09e479fc060292314cb4f8f8302</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849050</data>
  <data key="d13"></data>
</edge>
<edge source="Bộ luật này" target="Tập quán">
  <data key="d7">1.0</data>
  <data key="d8">The Civil Code allows for the application of customs in the absence of agreements and legal provisions.</data>
  <data key="d9">application,legal reference</data>
  <data key="d10">chunk-4c55b09e479fc060292314cb4f8f8302</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849050</data>
  <data key="d13"></data>
</edge>
<edge source="Bộ luật này" target="Điều 1">
  <data key="d7">1.0</data>
  <data key="d8">Article 1 of the Civil Code defines the scope of regulation of the Civil Code.</data>
  <data key="d9">definition,scope</data>
  <data key="d10">chunk-4c55b09e479fc060292314cb4f8f8302</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849050</data>
  <data key="d13"></data>
</edge>
<edge source="Bộ luật này" target="Điều 3">
  <data key="d7">1.0</data>
  <data key="d8">Article 3 of the Civil Code outlines the basic principles of civil law.</data>
  <data key="d9">guidelines,principles</data>
  <data key="d10">chunk-4c55b09e479fc060292314cb4f8f8302</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849050</data>
  <data key="d13"></data>
</edge>
<edge source="Bộ luật này" target="Điều 4">
  <data key="d7">1.0</data>
  <data key="d8">Article 4 of the Civil Code specifies the application of the Civil Code.</data>
  <data key="d9">application,legal framework</data>
  <data key="d10">chunk-4c55b09e479fc060292314cb4f8f8302</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849050</data>
  <data key="d13"></data>
</edge>
<edge source="Bộ luật này" target="Điều 6">
  <data key="d7">1.0</data>
  <data key="d8">Article 6 of the Civil Code addresses the application of analogous laws.</data>
  <data key="d9">application,legal reference</data>
  <data key="d10">chunk-4c55b09e479fc060292314cb4f8f8302</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849050</data>
  <data key="d13"></data>
</edge>
<edge source="Bộ luật này" target="Cộng hòa xã hội chủ nghĩa Việt Nam">
  <data key="d7">1.0</data>
  <data key="d8">The Civil Code is applied in the Socialist Republic of Vietnam to regulate civil relations and ensure civil rights.</data>
  <data key="d9">application,legal framework</data>
  <data key="d10">chunk-4c55b09e479fc060292314cb4f8f8302</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849050</data>
  <data key="d13"></data>
</edge>
<edge source="Bộ luật này" target="Thời hiệu khởi kiện">
  <data key="d7">1.0</data>
  <data key="d8">Bộ luật này includes provisions for exceptions to the time limit for initiating a lawsuit.</data>
  <data key="d9">exception,legal provision</data>
  <data key="d10">chunk-6b3f59800e76e08387285066f5f36cdf</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849144</data>
  <data key="d13"></data>
</edge>
<edge source="Bộ luật này" target="Thời hiệu yêu cầu giải quyết việc dân sự">
  <data key="d7">1.0</data>
  <data key="d8">Bộ luật này includes provisions for exceptions to the time limit for requesting the resolution of a civil matter.</data>
  <data key="d9">exception,legal provision</data>
  <data key="d10">chunk-6b3f59800e76e08387285066f5f36cdf</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849144</data>
  <data key="d13"></data>
</edge>
<edge source="Bộ luật này" target="Pháp nhân">
  <data key="d7">1.0</data>
  <data key="d8">The legal code recognizes the conditions for a legal entity to be formed.</data>
  <data key="d9">legal code,recognition</data>
  <data key="d10">chunk-12ce4f076c1ad11637bf7e2f3ae95048</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849153</data>
  <data key="d13"></data>
</edge>
<edge source="Bộ luật này" target="Pháp nhân thương mại">
  <data key="d7">1.0</data>
  <data key="d8">The legal code governs the establishment, operation, and dissolution of commercial entities.</data>
  <data key="d9">formation,legal code</data>
  <data key="d10">chunk-12ce4f076c1ad11637bf7e2f3ae95048</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849153</data>
  <data key="d13"></data>
</edge>
<edge source="Bộ luật này" target="Pháp nhân phi thương mại">
  <data key="d7">1.0</data>
  <data key="d8">The legal code governs the establishment, operation, and dissolution of non-commercial entities.</data>
  <data key="d9">formation,legal code</data>
  <data key="d10">chunk-12ce4f076c1ad11637bf7e2f3ae95048</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849153</data>
  <data key="d13"></data>
</edge>
<edge source="Bộ luật này" target="Quyền khác đối với tài sản">
  <data key="d7">1.0</data>
  <data key="d8">The current legal code regulates the establishment and exercise of other rights over property.</data>
  <data key="d9">legal regulation,property rights</data>
  <data key="d10">chunk-a4a95c6c117e21012baec10d4e1fb78c</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849189</data>
  <data key="d13"></data>
</edge>
<edge source="Bộ luật này" target="91/2015/qh13">
  <data key="d7">1.0</data>
  <data key="d8">Bộ luật này refers to the legal document 91/2015/qh13, which contains the regulations and rules related to collateral and its management.</data>
  <data key="d9">legal reference,source document</data>
  <data key="d10">chunk-35e5b9d9646a1753edafbdf0516edae4</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849946</data>
  <data key="d13"></data>
</edge>
<edge source="Bộ luật này" target="Điều 428">
  <data key="d7">1.0</data>
  <data key="d8">Điều 428 outlines the conditions for contract termination as per the legal code.</data>
  <data key="d9">contract termination,legal code</data>
  <data key="d10">chunk-fd76a1e6d7896b3bdcaa4bbcae2b9dea</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850248</data>
  <data key="d13"></data>
</edge>
<edge source="Bộ luật này" target="Người thực hiện công việc không có ủy quyền">
  <data key="d7">1.0</data>
  <data key="d8">The person performing work without authorization must adhere to the legal framework provided by this law.</data>
  <data key="d9">legal framework,work performance</data>
  <data key="d10">chunk-50c919d97de369bc8d7562186f764b91</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850909</data>
  <data key="d13"></data>
</edge>
<edge source="Người thân thích" target="Người thực hiện công việc không có ủy quyền">
  <data key="d7">1.0</data>
  <data key="d8">If the person performing the work without authorization cannot continue the work, they must inform the close relative of the person for whom the work is performed.</data>
  <data key="d9">notification,work continuation</data>
  <data key="d10">chunk-50c919d97de369bc8d7562186f764b91</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850908</data>
  <data key="d13"></data>
</edge>
<edge source="Người Được Giám Hộ" target="Điều 47">
  <data key="d7">1.0</data>
  <data key="d8">Article 47 lists the categories of people who are under guardianship.</data>
  <data key="d9">categories of guardianship,legal provision</data>
  <data key="d10">chunk-ab2df971c594abe37164d58e7533c291</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773848936</data>
  <data key="d13"></data>
</edge>
<edge source="Người Được Giám Hộ" target="Nơi Cư Trú">
  <data key="d7">1.0</data>
  <data key="d8">The place of residence for individuals under guardianship is typically determined by their guardian.</data>
  <data key="d9">guardian residence,legal residence</data>
  <data key="d10">chunk-846633705870effa2d882763f1693f90</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773848982</data>
  <data key="d13"></data>
</edge>
<edge source="Người Được Giám Hộ" target="Người Thân Thích">
  <data key="d7">1.0</data>
  <data key="d8">Người Thân Thích can be chosen as supervisors or make decisions regarding the guardianship of Người Được Giám Hộ.</data>
  <data key="d9">family relationship,guardianship</data>
  <data key="d10">chunk-651dc401f3963fbef4dfe8d51ab78119</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849024</data>
  <data key="d13"></data>
</edge>
<edge source="Nơi Cư Trú" target="Quân Nhân">
  <data key="d7">1.0</data>
  <data key="d8">The place of residence for military personnel is the location where their unit is stationed.</data>
  <data key="d9">military residence,unit location</data>
  <data key="d10">chunk-ab2df971c594abe37164d58e7533c291</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773848936</data>
  <data key="d13"></data>
</edge>
<edge source="Nơi Cư Trú" target="Vợ, Chồng">
  <data key="d7">2.0</data>
  <data key="d8">The place of residence for spouses is where they commonly live together.&lt;SEP&gt;The place of residence for spouses is typically determined by their shared living arrangements.</data>
  <data key="d9">common living place,shared residence,spouse residence</data>
  <data key="d10">chunk-ab2df971c594abe37164d58e7533c291&lt;SEP&gt;chunk-846633705870effa2d882763f1693f90</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773848982</data>
  <data key="d13"></data>
</edge>
<edge source="Nơi Cư Trú" target="Người Làm Nghề Lưu Động">
  <data key="d7">1.0</data>
  <data key="d8">The place of residence for itinerant workers is the location where their vessel or mobile equipment is registered.</data>
  <data key="d9">itinerant worker residence,registration location</data>
  <data key="d10">chunk-ab2df971c594abe37164d58e7533c291</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773848936</data>
  <data key="d13"></data>
</edge>
<edge source="Nơi Cư Trú" target="Người Chưa Thành Niên">
  <data key="d7">1.0</data>
  <data key="d8">The place of residence for minors is typically determined by their parents.</data>
  <data key="d9">minor residence,parental residence</data>
  <data key="d10">chunk-846633705870effa2d882763f1693f90</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773848981</data>
  <data key="d13"></data>
</edge>
<edge source="Nơi Cư Trú" target="Quan Hệ Dân Sự">
  <data key="d7">1.0</data>
  <data key="d8">In civil relationships, changes in residence must be communicated to the other party if it affects rights and obligations.</data>
  <data key="d9">civil relationship,residence change</data>
