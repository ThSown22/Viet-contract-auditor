<edge source="Giao dịch dân sự" target="Điều 132">
  <data key="d7">1.0</data>
  <data key="d8">Điều 132 specifies the statute of limitations for requesting the court to declare a civil transaction as invalid.</data>
  <data key="d9">legal provision,statute of limitations</data>
