</edge>
<edge source="Bên Thuê" target="Bồi Thường Thiệt Hại">
  <data key="d7">1.0</data>
  <data key="d8">Bên Thuê may be entitled to compensation for damages if the other party breaches the lease agreement.</data>
  <data key="d9">breach of contract,compensation</data>
  <data key="d10">chunk-ce15824853c084575e7d85b3e8d79015</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850555</data>
  <data key="d13"></data>
</edge>
<edge source="Bên Thuê" target="Sửa Chữa">
  <data key="d7">1.0</data>
  <data key="d8">Bên Thuê is responsible for minor repairs and maintenance of the Tài Sản Thuê, but not for natural wear and tear.</data>
  <data key="d9">maintenance,repair</data>
  <data key="d10">chunk-ce15824853c084575e7d85b3e8d79015</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850555</data>
  <data key="d13"></data>
</edge>
<edge source="Bên Thuê" target="Giảm Giá Thuê">
  <data key="d7">1.0</data>
  <data key="d8">Bên Thuê may be entitled to a reduction in rent if the Tài Sản Thuê is defective or not in the agreed-upon condition.</data>
  <data key="d9">defects,rent reduction</data>
  <data key="d10">chunk-ce15824853c084575e7d85b3e8d79015</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850555</data>
  <data key="d13"></data>
</edge>
<edge source="Bên Thuê" target="Đổi Tài Sản Khác">
  <data key="d7">1.0</data>
  <data key="d8">Bên Thuê may request to replace the Tài Sản Thuê with another property if it is defective or cannot be repaired.</data>
  <data key="d9">defective property,replacement</data>
  <data key="d10">chunk-ce15824853c084575e7d85b3e8d79015</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850555</data>
  <data key="d13"></data>
</edge>
<edge source="Bên Thuê" target="Tranh Chấp Về Quyền Sở Hữu">
  <data key="d7">1.0</data>
  <data key="d8">Bên Thuê has the right to terminate the lease agreement if there is a dispute over the ownership of the Tài Sản Thuê.</data>
  <data key="d9">dispute,ownership</data>
  <data key="d10">chunk-ce15824853c084575e7d85b3e8d79015</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850555</data>
  <data key="d13"></data>
</edge>
<edge source="Bên Thuê" target="Hao Mòn Tự Nhiên">
  <data key="d7">1.0</data>
  <data key="d8">Bên Thuê is not responsible for natural wear and tear that occurs from the use of the Tài Sản Thuê.</data>
  <data key="d9">natural wear and tear,responsibility</data>
  <data key="d10">chunk-ce15824853c084575e7d85b3e8d79015</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850555</data>
  <data key="d13"></data>
</edge>
<edge source="Bên Thuê" target="Tu Sửa">
  <data key="d7">1.0</data>
  <data key="d8">Bên Thuê may improve or enhance the Tài Sản Thuê if approved by the Bên Cho Thuê and may request compensation for reasonable costs.</data>
  <data key="d9">improvement,property enhancement</data>
  <data key="d10">chunk-ce15824853c084575e7d85b3e8d79015</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850555</data>
  <data key="d13"></data>
</edge>
<edge source="Bên Thuê" target="Pháp Luật">
  <data key="d7">1.0</data>
  <data key="d8">Bên Thuê must comply with legal regulations that govern the terms and conditions of the lease agreement.</data>
  <data key="d9">lease agreement,legal regulations</data>
  <data key="d10">chunk-ce15824853c084575e7d85b3e8d79015</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850555</data>
  <data key="d13"></data>
</edge>
<edge source="Bên Thuê" target="Thông Báo">
  <data key="d7">1.0</data>
  <data key="d8">Bên Thuê must provide a notification to the landlord before terminating the lease agreement.</data>
  <data key="d9">notification,termination</data>
  <data key="d10">chunk-ce15824853c084575e7d85b3e8d79015</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850555</data>
  <data key="d13"></data>
</edge>
<edge source="Bên Thuê" target="Cho Thuê Lại">
  <data key="d7">1.0</data>
  <data key="d8">Bên Thuê has the right to sublease the leased property with the landlord's consent.</data>
  <data key="d9">consent,subleasing</data>
