  <data key="d1">VĂN_BẢN_PHÁP_LUẬT</data>
  <data key="d2">Legal documents required for the registration of a business and the issuance of capital contribution certificates.</data>
  <data key="d3">chunk-2eb9bbbcf6b6e613956612e1bdbdc127</data>
