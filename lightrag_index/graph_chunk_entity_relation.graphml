<edge source="Bên Bán" target="Thông Tin Cần Thiết">
  <data key="d7">1.0</data>
  <data key="d8">Bên Bán is obligated to provide necessary information about the goods.</data>
  <data key="d9">contract enforcement,information obligations</data>
