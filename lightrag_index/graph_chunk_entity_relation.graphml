  <data key="d0">Điều 202</data>
  <data key="d1">HÀNH_VI</data>
  <data key="d2">Điều  202 is a regulation concerning the conversion of limited liability companies into joint-stock companies, detailing the procedures and requirements for such conversions.</data>
  <data key="d3">chunk-e4a657b345d0676b5a5d6451a2c7c13d</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773853385</data>
  <data key="d6"></data>
