</edge>
<edge source="Người thừa kế" target="Thành viên hợp danh">
  <data key="d7">1.0</data>
  <data key="d8">Người thừa kế has the right to inherit the name or assets of a former Thành viên hợp danh.</data>
  <data key="d9">inheritance,rights</data>
  <data key="d10">chunk-45f4215d40e0caccca1eaa62a7f0ec73</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773853252</data>
  <data key="d13"></data>
</edge>
<edge source="Pháp nhân thương mại" target="Luật doanh nghiệp">
  <data key="d7">1.0</data>
  <data key="d8">The business law governs the establishment, operation, and dissolution of commercial entities.</data>
  <data key="d9">business law,commercial entity</data>
  <data key="d10">chunk-12ce4f076c1ad11637bf7e2f3ae95048</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849153</data>
