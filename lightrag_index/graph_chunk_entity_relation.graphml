</edge>
<edge source="Cơ quan nhà nước có thẩm quyền" target="Điều 134">
  <data key="d7">1.0</data>
  <data key="d8">Điều 134 specifies that the government authority with the power to make decisions regarding legal matters is involved in representation rights.</data>
  <data key="d9">legal authority,representation rights</data>
  <data key="d10">chunk-482a66c12f2040cbc0eabb425e1b6d97</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849362</data>
