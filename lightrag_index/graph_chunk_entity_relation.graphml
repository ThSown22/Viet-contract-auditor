  <data key="d1">HÀNH_VI</data>
  <data key="d2">Điều 86 outlines the civil legal capacity of a legal entity, which is the ability to have civil rights and obligations.</data>
  <data key="d3">chunk-6d584ac3c571de434dd905552d6d296b</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773849344</data>
