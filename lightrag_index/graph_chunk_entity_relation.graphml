  <data key="d7">1.0</data>
  <data key="d8">Transactions between the company and related individuals must be recorded and kept as a separate file of the company.</data>
  <data key="d9">record keeping,related party transactions</data>
  <data key="d10">chunk-823e07d4a480b69d7f6ec00924cb4793</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851980</data>
  <data key="d13"></data>
</edge>
<edge source="Công Ty Mẹ" target="Tập Đoàn Kinh Tế">
  <data key="d7">1.0</data>
  <data key="d8">An economic group or holding company is a group of companies with interrelated ownership through shares or other forms of association, and a parent company has significant control over a subsidiary.</data>
  <data key="d9">control,ownership structure</data>
  <data key="d10">chunk-8d59be88d8f39c9fce708d8b3f0c8014</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773853274</data>
  <data key="d13"></data>
</edge>
<edge source="Công Ty Mẹ" target="Công Ty Con">
  <data key="d7">2.0</data>
  <data key="d8">A parent company has significant control over a subsidiary through share ownership or decision-making power.&lt;SEP&gt;Công Ty Mẹ has responsibilities and rights towards its subsidiary, Công Ty Con.</data>
  <data key="d9">control,ownership structure,parent company,subsidiary</data>
  <data key="d10">chunk-8d59be88d8f39c9fce708d8b3f0c8014&lt;SEP&gt;chunk-b12f2587388d6a4e9e558de512dc2860</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773853349</data>
  <data key="d13"></data>
</edge>
<edge source="Công Ty Mẹ" target="Chính Phủ">
  <data key="d7">1.0</data>
  <data key="d8">Chính Phủ provides detailed regulations for the actions of the parent company, Công Ty Mẹ.</data>
  <data key="d9">governance,regulation</data>
  <data key="d10">chunk-b12f2587388d6a4e9e558de512dc2860</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773853349</data>
  <data key="d13"></data>
</edge>
<edge source="Công Ty Mẹ" target="Chủ Nợ">
  <data key="d7">1.0</data>
  <data key="d8">Chủ Nợ has the right to demand compensation from the parent company, Công Ty Mẹ, on behalf of the subsidiary.</data>
  <data key="d9">compensation,creditor rights</data>
  <data key="d10">chunk-b12f2587388d6a4e9e558de512dc2860</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773853349</data>
  <data key="d13"></data>
</edge>
<edge source="Công Ty Mẹ" target="Thành Viên, Cổ Đông">
  <data key="d7">1.0</data>
  <data key="d8">Thành Viên, Cổ Đông have the right to demand compensation from the parent company, Công Ty Mẹ, on behalf of the subsidiary.</data>
  <data key="d9">compensation,shareholder rights</data>
  <data key="d10">chunk-b12f2587388d6a4e9e558de512dc2860</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773853349</data>
  <data key="d13"></data>
</edge>
<edge source="Công Ty Mẹ" target="Báo Cáo Tài Chính Hợp Nhất">
  <data key="d7">1.0</data>
  <data key="d8">Công Ty Mẹ is responsible for preparing the consolidated financial report, Báo Cáo Tài Chính Hợp Nhất, which includes the financial information of both the parent and subsidiary companies.</data>
  <data key="d9">financial information,reporting</data>
  <data key="d10">chunk-b12f2587388d6a4e9e558de512dc2860</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773853349</data>
  <data key="d13"></data>
</edge>
<edge source="Công Ty Mẹ" target="Báo Cáo Tổng Hợp Kết Quả Kinh Doanh">
  <data key="d7">1.0</data>
  <data key="d8">Công Ty Mẹ is responsible for preparing the report that summarizes the annual business results of both the parent and subsidiary companies, Báo Cáo Tổng Hợp Kết Quả Kinh Doanh.</data>
  <data key="d9">business results,reporting</data>
  <data key="d10">chunk-b12f2587388d6a4e9e558de512dc2860</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773853349</data>
  <data key="d13"></data>
</edge>
<edge source="Công Ty Mẹ" target="Báo Cáo Tổng Hợp Công Tác Quản Lý, Điều Hành">
  <data key="d7">1.0</data>
  <data key="d8">Công Ty Mẹ is responsible for preparing the report that summarizes the management and operation activities of both the parent and subsidiary companies, Báo Cáo Tổng Hợp Công Tác Quản Lý, Điều Hành.</data>
  <data key="d9">management activities,reporting</data>
  <data key="d10">chunk-b12f2587388d6a4e9e558de512dc2860</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773853349</data>
  <data key="d13"></data>
</edge>
<edge source="Công Ty Con" target="Hội Đồng Quản Trị">
  <data key="d7">1.0</data>
  <data key="d8">The board of directors is responsible for making decisions and managing the operations of a subsidiary company.</data>
  <data key="d9">decision-making,management</data>
  <data key="d10">chunk-8d59be88d8f39c9fce708d8b3f0c8014</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773853274</data>
  <data key="d13"></data>
</edge>
<edge source="Công Ty Con" target="Giám Đốc">
  <data key="d7">1.0</data>
  <data key="d8">The director is a senior manager responsible for the operations of a subsidiary company.</data>
  <data key="d9">management,operations</data>
  <data key="d10">chunk-8d59be88d8f39c9fce708d8b3f0c8014</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773853274</data>
  <data key="d13"></data>
</edge>
<edge source="Công Ty Con" target="Tổng Giám Đốc">
  <data key="d7">1.0</data>
  <data key="d8">The general director is a senior manager responsible for the operations of a subsidiary company.</data>
  <data key="d9">management,operations</data>
  <data key="d10">chunk-8d59be88d8f39c9fce708d8b3f0c8014</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773853274</data>
  <data key="d13"></data>
</edge>
<edge source="Công Ty Con" target="Người Quản Lý Công Ty Mẹ">
  <data key="d7">1.0</data>
  <data key="d8">Người Quản Lý Công Ty Mẹ is responsible for the actions taken towards the subsidiary, Công Ty Con.</data>
  <data key="d9">management,responsibility</data>
  <data key="d10">chunk-b12f2587388d6a4e9e558de512dc2860</data>
  <data key="d11">unknown_source</data>
