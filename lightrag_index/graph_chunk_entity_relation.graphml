  <data key="d7">1.0</data>
  <data key="d8">Chủ sở hữu has rights over the produce or income from a property.</data>
  <data key="d9">ownership rights,produce</data>
  <data key="d10">chunk-79babcd2cf4aac518b57f409f34a0382</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849468</data>
