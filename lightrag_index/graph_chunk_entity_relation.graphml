  <data key="d12">1773852753</data>
  <data key="d13"></data>
</edge>
<edge source="Công ty cổ phần" target="Đồng Việt Nam">
  <data key="d7">1.0</data>
  <data key="d8">Đồng Việt Nam is the national currency of Vietnam used for transactions in the company.</data>
  <data key="d9">currency,transaction</data>
  <data key="d10">chunk-9b892718f9850a0f9775f9a075fb4282</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773852753</data>
  <data key="d13"></data>
</edge>
<edge source="Công ty cổ phần" target="Ngoại tệ tự do chuyển đổi">
  <data key="d7">1.0</data>
  <data key="d8">Ngoại tệ tự do chuyển đổi refers to freely convertible foreign currencies used for transactions in the company.</data>
  <data key="d9">currency,transaction</data>
  <data key="d10">chunk-9b892718f9850a0f9775f9a075fb4282</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773852753</data>
  <data key="d13"></data>
</edge>
<edge source="Công ty cổ phần" target="Vàng">
  <data key="d7">1.0</data>
  <data key="d8">Vàng is gold used as a form of payment in the company.</data>
  <data key="d9">payment method,transaction</data>
  <data key="d10">chunk-9b892718f9850a0f9775f9a075fb4282</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773852753</data>
