  <data key="d3">chunk-e892e20c0d7efd608322517a03188b51</data>
  <data key="d2">Đиều 382 addresses the termination of Nghĩa Vụ when the party with the right is an individual who has died or a legal entity that has ceased to exist.</data>
  <data key="d1">UNKNOWN</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850481</data>
