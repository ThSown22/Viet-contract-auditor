  <data key="d0">Tư vấn độc lập</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">Tư vấn độc lập is an independent consulting body that can be used by the company to perform assigned tasks.</data>
  <data key="d3">chunk-4d51643ce273eae22725bc9b7424a745</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773852906</data>
  <data key="d6"></data>
</node>
<node id="Bộ phận kiểm toán nội bộ">
  <data key="d0">Bộ phận kiểm toán nội bộ</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">Bộ phận kiểm toán nội bộ is the internal audit department of the company that can be used to perform assigned tasks.&lt;SEP&gt;Internal audit department of the company that is supervised by the Audit Committee.&lt;SEP&gt;Bộ phận kiểm toán nội bộ is an internal auditing department responsible for monitoring the company's financial activities and internal controls.</data>
  <data key="d3">chunk-4d51643ce273eae22725bc9b7424a745&lt;SEP&gt;chunk-df9831e320198a4b066f7cdd1b9bbfe0&lt;SEP&gt;chunk-8031309e714112ffe63df75b002d2d14</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773853082</data>
  <data key="d6"></data>
</node>
<node id="Kiểm toán nội bộ">
  <data key="d0">Kiểm toán nội bộ</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">Kiểm toán nội bộ is the internal audit department responsible for reviewing and evaluating internal controls.</data>
  <data key="d3">chunk-795fb9faa3ff64c104def58573301724</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773852942</data>
  <data key="d6"></data>
</node>
