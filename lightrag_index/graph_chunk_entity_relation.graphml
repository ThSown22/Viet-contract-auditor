  <data key="d3">chunk-6b3f59800e76e08387285066f5f36cdf</data>
  <data key="d2">Đиều 151 explains how the time limit for being exempt from civil obligations is calculated.</data>
  <data key="d1">UNKNOWN</data>
  <data key="d4">unknown_source</data>
