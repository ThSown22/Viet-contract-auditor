</edge>
<edge source="Người đại diện theo ủy quyền" target="Bên thứ ba">
  <data key="d7">1.0</data>
  <data key="d8">Người đại diện theo ủy quyền acts on behalf of the shareholders, members, or owners and is responsible for their actions towards third parties.</data>
  <data key="d9">representation,responsibility</data>
  <data key="d10">chunk-2619cf455665fecc350d8c72d83e850d</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851328</data>
