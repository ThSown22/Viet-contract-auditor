  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Báo cáo kết quả kinh doanh is a report detailing the business performance of the company, which must be submitted to the Đại hội đồng cổ đông.</data>
  <data key="d3">chunk-b0cdd7174a5289f85d735aa45cd8829d</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773852988</data>
