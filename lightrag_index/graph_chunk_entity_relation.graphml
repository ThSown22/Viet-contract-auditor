  <data key="d0">Bên Nhận Tài Sản</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">Bên Nhận Tài Sản is the party that receives the transported assets and has rights and obligations as defined in the legal text.</data>
  <data key="d3">chunk-9ff345e6f27025707a8c3c4dd1e82b5a</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850606</data>
  <data key="d6"></data>
</node>
