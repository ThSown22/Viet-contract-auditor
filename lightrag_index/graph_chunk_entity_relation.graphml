  <data key="d7">1.0</data>
  <data key="d8">Nhà nước takes ownership of abandoned property shares in the absence of heirs.</data>
  <data key="d9">abandoned property,state ownership</data>
  <data key="d10">chunk-3c40b3ec985a74cfbf857d108074883e</data>
  <data key="d11">unknown_source</data>
