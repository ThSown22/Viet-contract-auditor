<edge source="Người bị tuyên bố là đã chết" target="Quan hệ tài sản">
  <data key="d7">1.0</data>
  <data key="d8">The property relations of a person declared dead are handled according to inheritance laws.</data>
  <data key="d9">inheritance,property relations</data>
  <data key="d10">chunk-12ce4f076c1ad11637bf7e2f3ae95048</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849153</data>
