</edge>
<edge source="Chủ Sở Hữu Công Ty" target="Người Đại Diện">
  <data key="d7">1.0</data>
  <data key="d8">If the owner is incapacitated or has limited legal capacity, a representative can act on their behalf in managing the company.</data>
  <data key="d9">incapacitation,legal representation</data>
  <data key="d10">chunk-b489c4747b69390bb9811e4c1b6ee278</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851943</data>
  <data key="d13"></data>
</edge>
<edge source="Chủ Sở Hữu Công Ty" target="Công Ty Trách Nhiệm Hữu Hạn Một Thành Viên">
  <data key="d7">1.0</data>
  <data key="d8">The owner of a company can decide on the increase or decrease of the registered capital.</data>
  <data key="d9">capital management,ownership</data>
  <data key="d10">chunk-823e07d4a480b69d7f6ec00924cb4793</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851980</data>
  <data key="d13"></data>
</edge>
<edge source="Chủ Sở Hữu Công Ty" target="Nghị Quyết, Quyết Định Chia Công Ty">
  <data key="d7">1.0</data>
  <data key="d8">The owner of the company makes decisions to divide the company and form new companies.</data>
  <data key="d9">company division,decision making</data>
  <data key="d10">chunk-9aff8a680816d92d14d4a77e34dbfc7d</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773853233</data>
  <data key="d13"></data>
</edge>
<edge source="Chủ Tịch Công Ty" target="Công Ty Được Tách">
  <data key="d7">1.0</data>
  <data key="d8">The new company elects or appoints the Chairman of the Company.</data>
  <data key="d9">appointment,election</data>
  <data key="d10">chunk-20a5aa4a830d11b31ecf4b23667e2bb4</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773853315</data>
  <data key="d13"></data>
</edge>
<edge source="Người Đại Diện" target="Phiên Hợp Giải Quyết Tranh Chấp">
  <data key="d7">1.0</data>
  <data key="d8">Người Đại Diện can represent a party in the Phiên Hợp Giải Quyết Tranh Chấp.</data>
  <data key="d9">participation,representation</data>
  <data key="d10">chunk-a36e099bae803eeaad0a5160e83464d5</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773853928</data>
  <data key="d13"></data>
</edge>
<edge source="Chủ tịch công ty" target="Giám đốc">
  <data key="d7">1.0</data>
  <data key="d8">The Chairman of the company can appoint the Director to manage the company's daily business operations.</data>
  <data key="d9">appointment,responsibility</data>
  <data key="d10">chunk-96b35fb948543da5055202eeb7113790</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773852026</data>
  <data key="d13"></data>
</edge>
<edge source="Chủ tịch công ty" target="Tổng giám đốc">
  <data key="d7">1.0</data>
  <data key="d8">The Chairman of the company can appoint the General Director to manage the company's daily business operations.</data>
  <data key="d9">appointment,responsibility</data>
  <data key="d10">chunk-96b35fb948543da5055202eeb7113790</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773852026</data>
  <data key="d13"></data>
</edge>
<edge source="Chủ tịch công ty" target="Kiểm soát viên">
  <data key="d7">1.0</data>
  <data key="d8">The Supervisor ensures compliance with the law, the company charter, and the decisions of the company owner.</data>
  <data key="d9">responsibility,supervision</data>
  <data key="d10">chunk-96b35fb948543da5055202eeb7113790</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773852026</data>
  <data key="d13"></data>
</edge>
<edge source="Chủ tịch công ty" target="Quy chế quản lý tài chính của công ty">
  <data key="d7">1.0</data>
  <data key="d8">The Chairman of the company uses the company's financial management regulations to manage financial costs, including expert consultation fees.</data>
  <data key="d9">cost allocation,financial management</data>
  <data key="d10">chunk-17a82be5a9b46c4919412e37814adb6d</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773852369</data>
  <data key="d13"></data>
</edge>
<edge source="Chủ tịch công ty" target="Quy chế quản lý nội bộ của công ty">
  <data key="d7">1.0</data>
  <data key="d8">The Chairman of the company uses the company's internal management regulations to manage internal operations and delegate authority.</data>
  <data key="d9">delegation of authority,internal management</data>
  <data key="d10">chunk-17a82be5a9b46c4919412e37814adb6d</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773852369</data>
  <data key="d13"></data>
</edge>
<edge source="Giám đốc" target="Quy chế quản lý nội bộ của công ty">
  <data key="d7">1.0</data>
  <data key="d8">The Director establishes the internal management regulations of the company.</data>
  <data key="d9">establishment,responsibility</data>
  <data key="d10">chunk-96b35fb948543da5055202eeb7113790</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773852026</data>
  <data key="d13"></data>
</edge>
<edge source="Giám đốc" target="Hợp đồng lao động">
  <data key="d7">2.0</data>
  <data key="d8">The Director's rights and obligations are defined in the labor contract.&lt;SEP&gt;Giám đốc or Tổng giám đốc is responsible for employment contracts within the company.</data>
  <data key="d9">definition,employment,management,responsibility</data>
  <data key="d10">chunk-96b35fb948543da5055202eeb7113790&lt;SEP&gt;chunk-6d99794c741473468cfbf38d98973119</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773852229</data>
  <data key="d13"></data>
</edge>
<edge source="Giám đốc" target="Kiểm soát viên">
  <data key="d7">2.0</data>
  <data key="d8">The Supervisor ensures compliance with the law, the company charter, and the decisions of the company owner.&lt;SEP&gt;Kiểm soát viên cannot be a family member of the Giám đốc.</data>
  <data key="d9">family relationship prohibition,responsibility,supervision</data>
  <data key="d10">chunk-96b35fb948543da5055202eeb7113790&lt;SEP&gt;chunk-b8bb762ad781038843f3cf2f3790105d</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773853166</data>
  <data key="d13"></data>
</edge>
<edge source="Giám đốc" target="Kế hoạch kinh doanh">
  <data key="d7">1.0</data>
  <data key="d8">Giám đốc or Tổng giám đốc is responsible for implementing business plans and investment strategies.</data>
  <data key="d9">implementation,management</data>
  <data key="d10">chunk-6d99794c741473468cfbf38d98973119</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773852229</data>
  <data key="d13"></data>
</edge>
<edge source="Giám đốc" target="Quy chế quản lý nội bộ">
  <data key="d7">1.0</data>
  <data key="d8">Giám đốc or Tổng giám đốc is responsible for implementing internal management regulations.</data>
  <data key="d9">implementation,management</data>
  <data key="d10">chunk-6d99794c741473468cfbf38d98973119</data>
  <data key="d11">unknown_source</data>
