</edge>
<edge source="Ủy ban kiểm toán" target="Bộ phận kiểm toán nội bộ">
  <data key="d7">2.0</data>
  <data key="d8">The Audit Committee supervises the internal audit department of the company.&lt;SEP&gt;Ủy ban kiểm toán is responsible for supervising the internal auditing department.</data>
  <data key="d9">audit,monitoring,oversight,supervision</data>
