  <data key="d11">unknown_source</data>
  <data key="d12">1773850555</data>
  <data key="d13"></data>
</edge>
<edge source="Bên Thuê" target="Bảo Dưỡng">
  <data key="d7">1.0</data>
  <data key="d8">Bên Thuê is responsible for maintaining the leased property to prevent damage and ensure its usability.</data>
