</edge>
<edge source="Công ty cổ phần" target="Hội đồng quản trị">
  <data key="d7">2.0</data>
  <data key="d8">Hội đồng quản trị is the board of directors that manages the company.&lt;SEP&gt;Hội đồng quản trị is the board of directors of a company.</data>
  <data key="d9">board of directors,management</data>
  <data key="d10">chunk-d4c6a296c5e1b248b6b79c98f9b16e6d&lt;SEP&gt;chunk-9b892718f9850a0f9775f9a075fb4282</data>
