  <data key="d0">Phương Tiện Thông Tin Đại Chúng</data>
  <data key="d1">VĂN_BẢN_PHÁP_LUẬT</data>
  <data key="d2">A medium of public information, such as newspapers or television, where information can be published and corrected.</data>
