<edge source="Luật này" target="Hội đồng trọng tài">
  <data key="d7">1.0</data>
  <data key="d8">Luật này provides the legal framework and authority for Hội đồng trọng tài to resolve disputes and make decisions.</data>
  <data key="d9">authority,legal framework</data>
  <data key="d10">chunk-7ebb1fe9cf67432030a08132511452a1</data>
  <data key="d11">unknown_source</data>
