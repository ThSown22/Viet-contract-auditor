  <data key="d0">Thời hạn chuộc lại</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Thời hạn chuộc lại is the redemption period during which the seller can reclaim the sold property.</data>
  <data key="d3">chunk-fb927ff207ca7e0465d21f05d999a0f9</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850409</data>
  <data key="d6"></data>
</node>
