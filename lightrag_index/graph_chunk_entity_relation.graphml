</edge>
<edge source="Tài Sản Bảo Đảm" target="Bên Nhận Bảo Đảm">
  <data key="d7">2.0</data>
  <data key="d8">Bên Nhận Bảo Đảm has the right to process collateral if obligations are not fulfilled.&lt;SEP&gt;Bên Nhận Bảo Đảm receives collateral as part of their legal right.</data>
  <data key="d9">collateral processing,collateral receipt,legal right,obligation enforcement</data>
  <data key="d10">chunk-c152b6a16d5764e941499e3920fc0f1d&lt;SEP&gt;chunk-3cdb3cd8d8583064c0301937b6f4744a</data>
