  <data key="d7">1.0</data>
  <data key="d8">Phạm Vi Nghĩa V_ụ Được Bảo Đảm refers to the scope of an obligation that can be secured, which can be partial or full, and can include current, future, or conditional obligations.</data>
  <data key="d9">obligation fulfillment,scope of security</data>
  <data key="d10">chunk-09260b73faf8f3666f58d4852700adf4</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849853</data>
  <data key="d13"></data>
</edge>
