</edge>
<edge source="Bên Thế Chấp" target="Tài Sản Thế Chấp">
  <data key="d7">1.0</data>
  <data key="d8">Bên Thế Chấp provides the collateral asset and is involved in its management.</data>
  <data key="d9">asset provision,collateral management</data>
  <data key="d10">chunk-ef30533c311bc88d4ba5ae54e8e8cca7</data>
  <data key="d11">unknown_source</data>
