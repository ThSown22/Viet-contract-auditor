</edge>
<edge source="Bên thế chấp" target="Hàng hóa luân chuyển">
  <data key="d7">1.0</data>
  <data key="d8">Bên thế chấp has the right to manage and use goods in circulation as collateral under certain conditions.</data>
  <data key="d9">asset use,collateral management</data>
