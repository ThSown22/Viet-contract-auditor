<edge source="Bên Cung Ứng Dịch Vụ" target="Bên Sử Dụng Dịch Vụ">
  <data key="d7">2.0</data>
  <data key="d8">Bên cung ứng dịch vụ provides services to Bên sử dụng dịch vụ, and Bên sử dụng dịch vụ pays for the services.&lt;SEP&gt;Bên Sử Dụng Dịch Vụ can request the service provider to perform the service according to the agreed quality, quantity, time frame, location, and other terms.</data>
  <data key="d9">agreement,payment,service provision,service request</data>
  <data key="d10">chunk-63bea5bd12d1af991f494c7882f65825&lt;SEP&gt;chunk-e729376fa2e1544912532baf7015b267</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850703</data>
  <data key="d13"></data>
</edge>
<edge source="Bên Cung Ứng Dịch Vụ" target="Bảo Mật Thông Tin">
  <data key="d7">1.0</data>
  <data key="d8">Bên Cung Ứng Dịch Vụ must maintain the confidentiality of information obtained during the service.</data>
  <data key="d9">agreement,confidentiality</data>
  <data key="d10">chunk-e729376fa2e1544912532baf7015b267</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850703</data>
  <data key="d13"></data>
</edge>
<edge source="Bên Cung Ứng Dịch Vụ" target="Tiền Dịch Vụ">
  <data key="d7">1.0</data>
  <data key="d8">Bên Cung Ứng Dịch Vụ can request payment from the service user according to the agreement.</data>
  <data key="d9">agreement,payment</data>
  <data key="d10">chunk-e729376fa2e1544912532baf7015b267</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850703</data>
  <data key="d13"></data>
</edge>
<edge source="Bên Cung Ứng Dịch Vụ" target="Thông Tin, Tài Liệu, Phương Tiện">
  <data key="d7">1.0</data>
  <data key="d8">Bên Cung Ứng Dịch Vụ receives information, documents, and means from the service user to facilitate the service.</data>
  <data key="d9">agreement,reception</data>
  <data key="d10">chunk-e729376fa2e1544912532baf7015b267</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850703</data>
  <data key="d13"></data>
</edge>
