<edge source="Tín chấp" target="Tổ chức chính trị - xã hội">
  <data key="d7">1.0</data>
  <data key="d8">Tín chấp is provided by political-social organizations to support individuals or poor households in borrowing money from financial institutions.</data>
  <data key="d9">financial support,guarantee provision</data>
  <data key="d10">chunk-ef889492cadc79ff9fffe71fb37a420f</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849980</data>
  <data key="d13"></data>
</edge>
<edge source="Tín chấp" target="Tổ chức tín dụng">
  <data key="d7">1.0</data>
  <data key="d8">Tín chấp is used as a guarantee for loans provided by financial institutions to individuals or poor households.</data>
  <data key="d9">financial transaction,loan guarantee</data>
  <data key="d10">chunk-ef889492cadc79ff9fffe71fb37a420f</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849981</data>
  <data key="d13"></data>
</edge>
<edge source="Tín chấp" target="Điều 345">
  <data key="d7">1.0</data>
  <data key="d8">Điều 345 specifies the forms and contents of credit guarantees (tín chấp).</data>
  <data key="d9">formalization,legal requirements</data>
  <data key="d10">chunk-ef889492cadc79ff9fffe71fb37a420f</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849981</data>
  <data key="d13"></data>
</edge>
