</edge>
<edge source="Ký Cược" target="Bên Cho Thuê">
  <data key="d7">1.0</data>
  <data key="d8">Ký Cược involves the lessor (Bên Cho Thuê) receiving an asset (Tài Sản K_ Ký Cược) to ensure the return of the leased asset.</data>
  <data key="d9">asset management,security</data>
  <data key="d10">chunk-ef30533c311bc88d4ba5ae54e8e8cca7</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849809</data>
