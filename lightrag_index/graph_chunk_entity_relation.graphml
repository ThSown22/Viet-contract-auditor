</edge>
<edge source="Công ty bị hợp nhất" target="Thủ tục hợp nhất công ty">
  <data key="d7">1.0</data>
  <data key="d8">Công ty bị hợp nhất must follow the Thủ tục hợp nhất công ty to ensure legal compliance during the merger process.</data>
  <data key="d9">legal compliance,merger procedure</data>
  <data key="d10">chunk-87d8fe2bdf778bad13a2e66311b71743</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773853442</data>
