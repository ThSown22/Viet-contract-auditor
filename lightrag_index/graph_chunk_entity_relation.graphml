<node id="Điều 135">
  <data key="d0">Điều 135</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Điều 135 is a legal provision that establishes the basis for the right of representation, either by authorization or by law.&lt;SEP&gt;Điều 135 is a legal provision that outlines the conditions for paying dividends to shareholders.</data>
  <data key="d3">chunk-482a66c12f2040cbc0eabb425e1b6d97&lt;SEP&gt;chunk-af079df7102c58f84652bfeb21c7a17a</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773852554</data>
  <data key="d6"></data>
</node>
