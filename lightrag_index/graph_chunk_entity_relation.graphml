  <data key="d7">1.0</data>
  <data key="d8">Hội đồng trọng tài makes decisions on arbitration awards and emergency measures, which are enforced by Cơ quan thi hành án dân sự tỉnh.</data>
  <data key="d9">decision making,enforcement</data>
  <data key="d10">chunk-61550f768622f38a6cce8665b746a20a</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773853684</data>
