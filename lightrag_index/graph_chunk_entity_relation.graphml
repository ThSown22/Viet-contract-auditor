  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Customs are rules of conduct that are widely recognized and applied in specific civil relations.</data>
  <data key="d3">chunk-4c55b09e479fc060292314cb4f8f8302</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773849050</data>
  <data key="d6"></data>
</node>
<node id="Điều 1">
  <data key="d0">Điều 1</data>
  <data key="d1">HÀNH_VI</data>
  <data key="d2">Article 1 of the Civil Code defines the scope of regulation.</data>
  <data key="d3">chunk-4c55b09e479fc060292314cb4f8f8302</data>
  <data key="d4">unknown_source</data>
