</node>
<node id="Người góp vốn">
  <data key="d0">Người góp vốn</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">Capital contributor who becomes a member of the company after contributing capital.&lt;SEP&gt;Người góp vốn refers to the person who contributes assets to capital and is involved in the valuation process.&lt;SEP&gt;Người góp vốn refers to individuals who contribute capital to become shareholders of a company after paying for their shares.</data>
  <data key="d3">chunk-2eb9bbbcf6b6e613956612e1bdbdc127&lt;SEP&gt;chunk-32bedb7a710b05aeaa67ceee9734170a&lt;SEP&gt;chunk-dd21806392f264f4bbe4bbe4d4c4686a</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773852262</data>
  <data key="d6"></data>
</node>
<node id="Trái phiếu">
  <data key="d0">Trái phiếu</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Bonds that can be issued by a limited liability company with two or more members.&lt;SEP&gt;Bonds issued by the company, subject to legal regulations.&lt;SEP&gt;Trái phiếu refers to bonds and other securities that a company can issue.&lt;SEP&gt;Trái phiếu refers to bonds issued by a company that can be converted into shares.</data>
  <data key="d3">chunk-2eb9bbbcf6b6e613956612e1bdbdc127&lt;SEP&gt;chunk-21e60fc19506b5cf181276cb00664680&lt;SEP&gt;chunk-643d72cdd6873e78e2d39abbf824c8bc&lt;SEP&gt;chunk-9b892718f9850a0f9775f9a075fb4282</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773852748</data>
  <data key="d6"></data>
</node>
