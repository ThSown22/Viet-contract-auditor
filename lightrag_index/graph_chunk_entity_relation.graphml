  <data key="d7">1.0</data>
  <data key="d8">Tòa án nhân dân tỉnh and Tòa án nhân dân thành phố trực thuộc trung ương have jurisdiction over arbitration activities.</data>
  <data key="d9">court authority,jurisdiction</data>
