  <data key="d7">1.0</data>
  <data key="d8">The main office address of the business entity is included in the Certificate of Business Registration.</data>
  <data key="d9">inclusion,registration</data>
  <data key="d10">chunk-a8de4c57592fe998c634734476be0f10</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851651</data>
  <data key="d13"></data>
</edge>
