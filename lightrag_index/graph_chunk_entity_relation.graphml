</edge>
<edge source="Cơ quan nhà nước có thẩm quyền" target="Đиều 177">
  <data key="d7">1.0</data>
  <data key="d8">Đиều 177 grants authority to government agencies to require the removal of trees or structures that pose a risk.</data>
  <data key="d9">enforcement,legal authority</data>
  <data key="d10">chunk-7b345fbbc1125fb4f691693608eb8ffa</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849591</data>
  <data key="d13"></data>
</edge>
<edge source="Cơ quan nhà nước có thẩm quyền" target="Bảo vệ việc chiếm hữu">
  <data key="d7">1.0</data>
  <data key="d8">Cơ quan nhà nước có thẩm quyền can enforce the cessation of infringement and restoration of the original state of the property.</data>
