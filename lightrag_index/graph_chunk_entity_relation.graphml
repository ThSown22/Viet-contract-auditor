  <data key="d7">1.0</data>
  <data key="d8">Bên Sử Dụng Dịch Vụ must pay the service provider according to the agreement.</data>
  <data key="d9">agreement,payment</data>
  <data key="d10">chunk-e729376fa2e1544912532baf7015b267</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850703</data>
