</edge>
<edge source="Thỏa thuận trọng tài" target="Luật Trọng Tài">
  <data key="d7">1.0</data>
  <data key="d8">Thỏa thuận trọng tài signed before the new law takes effect is to be executed according to the laws in place at the time of signing.</data>
  <data key="d9">execution,legal compliance</data>
  <data key="d10">chunk-44b958e89c37ebae08442548c41df280</data>
