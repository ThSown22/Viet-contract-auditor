  <data key="d7">1.0</data>
  <data key="d8">Chủ sở hữu các căn hộ have equal rights and obligations in managing shared property in apartment buildings.</data>
  <data key="d9">ownership rights,property management</data>
  <data key="d10">chunk-3c40b3ec985a74cfbf857d108074883e</data>
  <data key="d11">unknown_source</data>
