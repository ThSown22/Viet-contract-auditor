</node>
<node id="Article 363">
  <data key="d0">Article 363</data>
  <data key="d1">HÀNH_VI</data>
  <data key="d2">Article 363 of the Civil Code outlines the compensation for damages when the party being violated is at fault.</data>
  <data key="d3">chunk-428a1a2119667172b8e431b501835f64</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850228</data>
