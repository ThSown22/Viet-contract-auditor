<node id="Luật quốc tịch Việt Nam">
  <data key="d0">Luật quốc tịch Việt Nam</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Luật quốc tịch Việt Nam refers to the Vietnamese Nationality Law, which governs the determination, change, acquisition, renunciation, or return to Vietnamese nationality.</data>
  <data key="d3">chunk-985db81e6c3d846511cb280c2983fbf0</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773848837</data>
