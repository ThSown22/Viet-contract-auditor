  <data key="d13"></data>
</edge>
<edge source="Hợp đồng vận chuyển hành khách" target="Hành khách">
  <data key="d7">2.0</data>
  <data key="d8">Hành khách is the party that uses the transportation service and is required to pay the transportation fee as per the terms of the Hợp đồng vận chuyển hành khách.&lt;SEP&gt;Hành khách has rights under the Hợp đồng vận chuyển hành khách, including the right to receive luggage at the agreed location and time.</data>
  <data key="d9">contractual obligations,contractual rights,transportation service</data>
  <data key="d10">chunk-ab83736c7458e42bbefffad0de52acd0&lt;SEP&gt;chunk-1baf5b4c5d9b239e30e1e81e061a24dd</data>
