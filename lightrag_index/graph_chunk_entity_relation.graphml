<edge source="Hợp đồng" target="Bên hủy bỏ hợp đồng">
  <data key="d7">1.0</data>
  <data key="d8">Bên hủy bỏ hợp đồng is the party in a contract who has the right to cancel the contract under certain conditions.</data>
  <data key="d9">contract cancellation,party right</data>
