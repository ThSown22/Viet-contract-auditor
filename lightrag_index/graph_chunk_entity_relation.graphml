  <data key="d0">Địa Điểm Giao Tài Sản</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">Địa Điểm Giao Tài Sản is the location where the assets are to be delivered as specified in the contract.</data>
  <data key="d3">chunk-4623833cd0cb1b86833b9050e09612fd</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850373</data>
  <data key="d6"></data>
</node>
<node id="Phương Thức Giao Tài Sản">
  <data key="d0">Phương Thức Giao Tài Sản</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Phương Thức Giao Tài Sản refers to the method of delivery of the assets as agreed upon by the parties.</data>
  <data key="d3">chunk-4623833cd0cb1b86833b9050e09612fd</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850373</data>
  <data key="d6"></data>
</node>
<node id="Tài Sản Mua Bán">
  <data key="d0">Tài Sản Mua Bán</data>
  <data key="d1">VĂN_BẢN_PHÁP_LUẬT</data>
  <data key="d2">Tài Sản Mua Bán refers to the property or item being bought and sold, which must be free from disputes over ownership and must meet the quality standards agreed upon by the parties.</data>
  <data key="d3">chunk-6fb0e6ef087a638bbb3f5e1626539a69</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850373</data>
  <data key="d6"></data>
</node>
<node id="Thời Hạn Bảo Hành">
  <data key="d0">Thời Hạn Bảo Hành</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Thời Hạn Bảo Hành is the warranty period during which the seller is responsible for repairing or replacing defective items and compensating for any damages caused by technical defects.</data>
  <data key="d3">chunk-6fb0e6ef087a638bbb3f5e1626539a69</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850373</data>
  <data key="d6"></data>
</node>
<node id="Khuyết Tật">
  <data key="d0">Khuyết Tật</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Khuyết Tật refers to defects in the purchased item that can reduce its value or usability, and the buyer has the right to request repairs, replacements, or refunds for such defects within the warranty period.</data>
  <data key="d3">chunk-6fb0e6ef087a638bbb3f5e1626539a69</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850373</data>
  <data key="d6"></data>
</node>
