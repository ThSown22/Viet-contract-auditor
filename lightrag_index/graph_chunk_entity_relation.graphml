  <data key="d11">unknown_source</data>
  <data key="d12">1773852753</data>
  <data key="d13"></data>
</edge>
<edge source="Công ty cổ phần" target="Bí quyết kỹ thuật">
  <data key="d7">1.0</data>
  <data key="d8">Bí quyết kỹ thuật is technical know-how used as a form of payment in the company.</data>
  <data key="d9">payment method,transaction</data>
  <data key="d10">chunk-9b892718f9850a0f9775f9a075fb4282</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773852753</data>
  <data key="d13"></data>
</edge>
<edge source="Công ty cổ phần" target="Tài sản khác">
  <data key="d7">1.0</data>
  <data key="d8">Tài sản khác is other assets used as a form of payment in the company.</data>
  <data key="d9">payment method,transaction</data>
  <data key="d10">chunk-9b892718f9850a0f9775f9a075fb4282</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773852753</data>
