  <data key="d7">1.0</data>
  <data key="d8">Thủ tục đăng ký thay đổi are the procedures for registering changes in a Doanh nghiệp's registration content.</data>
  <data key="d9">business entity,registration procedure</data>
  <data key="d10">chunk-3fed1e090b51d7382ec575f352792a42</data>
