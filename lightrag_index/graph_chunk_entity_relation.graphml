  <data key="d0">Người đại diện phần vốn nhà nước</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">Người đại diện phần vốn nhà nước is a representative of state-owned equity.</data>
  <data key="d3">chunk-795fb9faa3ff64c104def58573301724</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773852943</data>
  <data key="d6"></data>
</node>
<node id="Công ty mẹ">
  <data key="d0">Công ty mẹ</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">Công ty mẹ is the parent company with specific regulations regarding supervisors.&lt;SEP&gt;Công ty mẹ is a parent company, and Kiểm soát viên cannot be a family member of the managers of the parent company or the company.</data>
  <data key="d3">chunk-795fb9faa3ff64c104def58573301724&lt;SEP&gt;chunk-b8bb762ad781038843f3cf2f3790105d</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773853165</data>
  <data key="d6"></data>
</node>
<node id="Luật về chứng khoán">
  <data key="d0">Luật về chứng khoán</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Luật về chứng khoán is the law governing securities and the regulations for publicly traded companies.</data>
  <data key="d3">chunk-b0cdd7174a5289f85d735aa45cd8829d</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773852988</data>
