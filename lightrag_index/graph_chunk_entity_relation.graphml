</edge>
<edge source="Người có nghĩa vụ" target="Đиều 419">
  <data key="d7">1.0</data>
  <data key="d8">Đиều 419 defines the compensation for damages resulting from a breach of contract, including the right to claim compensation for the benefits that would have been received from the contract and the right to claim compensation for costs incurred due to the breach, affecting the party that is responsible for fulfilling the terms of the contract.</data>
  <data key="d9">compensation for damages,contract breach</data>
  <data key="d10">chunk-f99273835b3b6031602578494c58acd7</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850193</data>
  <data key="d13"></data>
</edge>
<edge source="Người có quyền" target="Đиều 419">
  <data key="d7">1.0</data>
  <data key="d8">Đиều 419 defines the compensation for damages resulting from a breach of contract, including the right to claim compensation for the benefits that would have been received from the contract and the right to claim compensation for costs incurred due to the breach, affecting the party that has the right to claim compensation.</data>
  <data key="d9">compensation for damages,contract breach</data>
  <data key="d10">chunk-f99273835b3b6031602578494c58acd7</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850193</data>
  <data key="d13"></data>
</edge>
<edge source="Điều 417" target="Phạt vi phạm">
  <data key="d7">1.0</data>
  <data key="d8">Điều 417 ensures that a contract for the benefit of a third party cannot be modified or canceled without the third party's consent, which is related to the concept of penalties for contract violations.</data>
  <data key="d9">contractual obligation,penalty agreement</data>
  <data key="d10">chunk-f99273835b3b6031602578494c58acd7</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850193</data>
  <data key="d13"></data>
</edge>
<edge source="Điều 419" target="Thiệt hại được bồi thường">
  <data key="d7">1.0</data>
  <data key="d8">Điều 419 defines the compensation for damages resulting from a breach of contract, including the right to claim compensation for the benefits that would have been received from the contract and the right to claim compensation for costs incurred due to the breach.</data>
  <data key="d9">compensation for damages,contract breach</data>
  <data key="d10">chunk-f99273835b3b6031602578494c58acd7</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850193</data>
  <data key="d13"></data>
</edge>
<edge source="Điều 420" target="Hoàn cảnh thay đổi cơ bản">
  <data key="d7">1.0</data>
  <data key="d8">Điều 420 addresses the execution of a contract when there is a fundamental change in circumstances, including the conditions for such a change and the rights of the affected party to renegotiate or terminate the contract.</data>
  <data key="d9">contract execution,fundamental change in circumstances</data>
  <data key="d10">chunk-f99273835b3b6031602578494c58acd7</data>
