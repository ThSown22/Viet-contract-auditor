  <data key="d0">Bên cầm giữ</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">Bên cầm giữ is the party that legally holds the assets when the debtor fails to fulfill their obligations.</data>
  <data key="d3">chunk-ef889492cadc79ff9fffe71fb37a420f</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773849980</data>
  <data key="d6"></data>
</node>
<node id="Tổ chức tín dụng">
  <data key="d0">Tổ chức tín dụng</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">Tổ chức tín dụng are financial institutions that provide loans to individuals or households.</data>
  <data key="d3">chunk-ef889492cadc79ff9fffe71fb37a420f</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773849980</data>
  <data key="d6"></data>
</node>
<node id="Vi phạm nghĩa vụ">
  <data key="d0">Vi phạm nghĩa vụ</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Vi phạm nghĩa vụ refers to the failure to fulfill obligations as agreed upon in a contract.</data>
