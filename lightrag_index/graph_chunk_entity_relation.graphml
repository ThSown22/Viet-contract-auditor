  <data key="d0">Cổ đông công ty cổ phần</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">Shareholders of a joint-stock company are required to transfer ownership of their capital contribution assets to the company.</data>
  <data key="d3">chunk-64b8fad75bc3785889ce216fbcf53556</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773851713</data>
  <data key="d6"></data>
