  <data key="d1">HÀNH_VI</data>
  <data key="d2">Điều 87 details the civil liability of a legal entity, which includes responsibility for actions taken by its representatives.</data>
  <data key="d3">chunk-6d584ac3c571de434dd905552d6d296b</data>
