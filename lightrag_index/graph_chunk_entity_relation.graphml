<edge source="Bên Thuê Khoán" target="Tài Sản Thuê Khoán">
  <data key="d7">1.0</data>
  <data key="d8">Bên Thuê Khoán is responsible for using the Tài Sản Thuê Khoán as agreed in the lease agreement.</data>
  <data key="d9">lease agreement,property use</data>
  <data key="d10">chunk-c98a39a79e1becf58880e1971e3ad611</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850787</data>
  <data key="d13"></data>
</edge>
<edge source="Bên Thuê Khoán" target="Hợp Đồng Thuê Khoán">
  <data key="d7">1.0</data>
  <data key="d8">Bên Thuê Khoán is bound by the terms of the Hợp Đồng Thuê Khoán, including payment and use of the leased property.</data>
  <data key="d9">contractual obligations,lease agreement</data>
  <data key="d10">chunk-c98a39a79e1becf58880e1971e3ad611</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850787</data>
  <data key="d13"></data>
</edge>
<edge source="Bên Thuê Khoán" target="Hợp Đồng Mượn Tài Sản">
  <data key="d7">1.0</data>
  <data key="d8">Bên Thuê Khoán may also be involved in a Hợp Đồng Mượn Tài Sản, where they borrow property for use without payment.</data>
  <data key="d9">borrowing agreement,property use</data>
  <data key="d10">chunk-c98a39a79e1becf58880e1971e3ad611</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850787</data>
  <data key="d13"></data>
</edge>
<edge source="Bên Thuê Khoán" target="Tình Trạng Tài Sản">
  <data key="d7">1.0</data>
  <data key="d8">Bên Thuê Khoán must report the condition of the Tài Sản Thuê Khoán to the Bên Cho Thuê Khoán periodically.</data>
  <data key="d9">property condition,reporting</data>
  <data key="d10">chunk-c98a39a79e1becf58880e1971e3ad611</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850787</data>
  <data key="d13"></data>
</edge>
<edge source="Bên Thuê Khoán" target="Bảo Quản, Bảo Dưỡng Tài Sản Thuê Khoán">
  <data key="d7">1.0</data>
  <data key="d8">Bên Thuê Khoán is responsible for maintaining and preserving the Tài Sản Thuê Khoán at their own expense.</data>
  <data key="d9">maintenance,property preservation</data>
  <data key="d10">chunk-c98a39a79e1becf58880e1971e3ad611</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850787</data>
  <data key="d13"></data>
</edge>
<edge source="Bên Thuê Khoán" target="Hoa Lợi, Thiệt Hại Về Gia Súc Thuê Khoán">
  <data key="d7">1.0</data>
  <data key="d8">Bên Thuê Khoán shares profits and losses related to leased livestock with the Bên Cho Thuê Khoán.</data>
  <data key="d9">loss sharing,profit sharing</data>
  <data key="d10">chunk-c98a39a79e1becf58880e1971e3ad611</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850787</data>
  <data key="d13"></data>
</edge>
<edge source="Bên Thuê Khoán" target="Đơn Phương Chấm Dứt Thực Hiện Hợp Đồng Thuê Khoán">
  <data key="d7">1.0</data>
  <data key="d8">Bên Thuê Khoán may unilaterally terminate the lease agreement with a reasonable notice period.</data>
  <data key="d9">contract termination,notice period</data>
  <data key="d10">chunk-c98a39a79e1becf58880e1971e3ad611</data>
  <data key="d11">unknown_source</data>
