  <data key="d7">1.0</data>
  <data key="d8">Hội đồng thành viên can appoint a new legal representative.</data>
  <data key="d9">appointment,legal representation</data>
  <data key="d10">chunk-ead2cea9ac10e43e52710b6f386da07d</data>
