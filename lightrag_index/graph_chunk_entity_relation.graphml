<edge source="Người Lập Di Chúc" target="Di Chúc Miệng">
  <data key="d7">1.0</data>
  <data key="d8">Người Lập Di Chúc creates an oral will, which must be authenticated by a notary or authorized body within 5 working days.</data>
  <data key="d9">authentication,creation</data>
  <data key="d10">chunk-a522f9aff4b603ac455ec99a8440d150</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851182</data>
