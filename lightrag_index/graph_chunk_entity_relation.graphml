</edge>
<edge source="Bên Bán" target="Tài Sản Mua Bán">
  <data key="d7">1.0</data>
  <data key="d8">Bên Bán is responsible for ensuring the ownership rights of the purchased property and guaranteeing the quality of the purchased item.</data>
  <data key="d9">ownership,quality guarantee</data>
