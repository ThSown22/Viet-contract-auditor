  <data key="d1">HÀNH_VI</data>
  <data key="d2">Article  360 of the Civil Code outlines the responsibility for compensating damages caused by the violation of obligations.</data>
  <data key="d3">chunk-428a1a2119667172b8e431b501835f64</data>
  <data key="d4">unknown_source</data>
