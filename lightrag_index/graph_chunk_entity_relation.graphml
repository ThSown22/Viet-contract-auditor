<edge source="Người đại diện theo pháp luật" target="Chủ sở hữu công ty">
  <data key="d7">1.0</data>
  <data key="d8">Chủ sở hữu công ty can appoint a new legal representative.</data>
  <data key="d9">appointment,legal representation</data>
  <data key="d10">chunk-ead2cea9ac10e43e52710b6f386da07d</data>
  <data key="d11">unknown_source</data>
