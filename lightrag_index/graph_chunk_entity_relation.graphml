  <data key="d7">1.0</data>
  <data key="d8">Bên cầm giữ is responsible for legally holding assets when the debtor fails to fulfill their obligations.</data>
  <data key="d9">asset holding,legal possession</data>
  <data key="d10">chunk-ef889492cadc79ff9fffe71fb37a420f</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849980</data>
  <data key="d13"></data>
</edge>
