  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">Công ty đại chúng is a type of company that is publicly traded and its shares are available to the general public.&lt;SEP&gt;Công ty đại chúng is a publicly traded company that is subject to specific regulations regarding the disclosure and publication of information.&lt;SEP&gt;Publicly traded companies that must meet certain standards and conditions.</data>
  <data key="d3">chunk-d4c6a296c5e1b248b6b79c98f9b16e6d&lt;SEP&gt;chunk-b0cdd7174a5289f85d735aa45cd8829d&lt;SEP&gt;chunk-df9831e320198a4b066f7cdd1b9bbfe0</data>
  <data key="d4">unknown_source</data>
