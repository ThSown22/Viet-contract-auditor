  <data key="d7">1.0</data>
  <data key="d8">Chủ Sở Hữu Súc Vật is responsible for compensating for any damage caused by Súc Vật.</data>
  <data key="d9">liability,ownership</data>
  <data key="d10">chunk-71c1c580c8f92c3838ab0f997647d588</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851025</data>
