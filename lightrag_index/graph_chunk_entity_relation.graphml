  <data key="d7">1.0</data>
  <data key="d8">Hội đồng quản trị evaluates and reports on the status of the Thành viên độc lập Hội đồng quản trị to the Đại hội đồng cổ đông.</data>
  <data key="d9">evaluation,reporting</data>
