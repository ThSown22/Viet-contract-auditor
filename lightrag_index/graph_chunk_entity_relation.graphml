<edge source="Bên giao kết hợp đồng" target="Đиều 420">
  <data key="d7">1.0</data>
  <data key="d8">Đиều 420 addresses the execution of a contract when there is a fundamental change in circumstances, including the conditions for such a change and the rights of the affected party to renegotiate or terminate the contract, affecting the parties involved in the contract.</data>
  <data key="d9">contract execution,fundamental change in circumstances</data>
  <data key="d10">chunk-f99273835b3b6031602578494c58acd7</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773850193</data>
