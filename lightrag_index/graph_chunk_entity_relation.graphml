  <data key="d7">1.0</data>
  <data key="d8">Misunderstandings can lead to civil transactions being declared invalid.</data>
  <data key="d9">invalidation,misunderstanding</data>
  <data key="d10">chunk-6fef2e18615af027f8385abdb8209870</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773849117</data>
  <data key="d13"></data>
</edge>
