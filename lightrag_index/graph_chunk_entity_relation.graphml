</edge>
<edge source="Người đại diện theo pháp luật" target="30 ngày">
  <data key="d7">1.0</data>
  <data key="d8">Người đại diện theo pháp luật must be present in Việt Nam or appoint a substitute if absent for more than 30 days.</data>
  <data key="d9">absence period,legal requirement</data>
  <data key="d10">chunk-ead2cea9ac10e43e52710b6f386da07d</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851421</data>
