  <data key="d0">Luat Bao Ve Quyen Loi Nguoi Tiêu Dùng</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Luat Bao Ve Quyen Loi Nguoi Tiêu Dùng is a law that provides guidelines for the quality of assets being bought and sold.</data>
  <data key="d3">chunk-4623833cd0cb1b86833b9050e09612fd</data>
  <data key="d4">unknown_source</data>
  <data key="d5">1773850373</data>
