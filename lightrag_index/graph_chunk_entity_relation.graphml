<node id="Bên Vận Chuyển">
  <data key="d0">Bên Vận Chuyển</data>
  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">Bên Vận Chuyển is responsible for transporting assets and has rights and obligations as defined in the legal text.</data>
  <data key="d3">chunk-9ff345e6f27025707a8c3c4dd1e82b5a</data>
