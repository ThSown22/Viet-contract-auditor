  <data key="d1">CHỦ_THỂ</data>
  <data key="d2">Bên yêu cầu refers to the party requesting the registration of an arbitration decision.&lt;SEP&gt;Bên yêu cầu is a person who requests the application of emergency measures.</data>
  <data key="d3">chunk-105aefb96d31bdf83eb8694998c59506&lt;SEP&gt;chunk-b47a7db90a1e526f1797874efef64872</data>
