</edge>
<edge source="Doanh Nghiệp" target="Người Đại Diện Theo Pháp Luật">
  <data key="d7">1.0</data>
  <data key="d8">Người Đại Diện Theo Pháp Luật is responsible for acting in the best interest of the Doanh Nghiệp.</data>
  <data key="d9">legal responsibility,representation</data>
  <data key="d10">chunk-dd4fb2094298c5037722675df8cc46f3</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851463</data>
  <data key="d13"></data>
</edge>
<edge source="Doanh Nghiệp" target="Người Lao Động">
  <data key="d7">3.0</data>
  <data key="d8">Người Lao Động has the right to participate in labor organizations and is protected by the enterprise in terms of their legal rights and interests.&lt;SEP&gt;Doanh Nghiệp has the right to employ labor and has obligations to protect the legal rights and interests of employees.&lt;SEP&gt;Doanh Nghiệp must ensure the rights of Người Lao Động who have worked at a branch are legally addressed after the branch's closure.</data>
  <data key="d9">employment,responsibility,rights protection,worker rights</data>
  <data key="d10">chunk-870356636a26bb390c46554c34ceb657&lt;SEP&gt;chunk-6f6b7c08fc56b324472ca75d1984ba36</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773853554</data>
  <data key="d13"></data>
</edge>
<edge source="Doanh Nghiệp" target="Quyền Sở Hữu Trí Tuệ">
  <data key="d7">1.0</data>
  <data key="d8">Doanh Nghiệp has the right to apply science and technology to improve business efficiency and competitiveness and is protected by the law regarding intellectual property rights.</data>
  <data key="d9">intellectual property,protection</data>
  <data key="d10">chunk-870356636a26bb390c46554c34ceb657</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851504</data>
  <data key="d13"></data>
</edge>
<edge source="Doanh Nghiệp" target="Tổ Chức Chính Trị">
  <data key="d7">1.0</data>
  <data key="d8">Tổ Chức Chính Trị operates within enterprises according to the constitution, laws, and their own bylaws.</data>
  <data key="d9">operation,political organization</data>
  <data key="d10">chunk-870356636a26bb390c46554c34ceb657</data>
  <data key="d11">unknown_source</data>
  <data key="d12">1773851504</data>
  <data key="d13"></data>
</edge>
