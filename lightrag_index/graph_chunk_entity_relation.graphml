<edge source="Chi phí khởi kiện" target="Bị bác yêu cầu khởi kiện">
  <data key="d7">1.0</data>
  <data key="d8">The costs associated with initiating a lawsuit may not be covered by the company if the lawsuit request is rejected.</data>
