<edge source="Doanh Nghiệp" target="Vốn Đầu Tư">
  <data key="d7">1.0</data>
  <data key="d8">Doanh Nghiệp has the right to own and manage its investments, and can use them freely within the legal framework.</data>
  <data key="d9">management,ownership</data>
  <data key="d10">chunk-870356636a26bb390c46554c34ceb657</data>
