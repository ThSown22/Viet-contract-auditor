  <data key="d0">Người thứ ba ngay tình</data>
  <data key="d1">QUYỀN_NGHĨA_VỤ</data>
  <data key="d2">Người thứ ba ngay tình refers to a bona fide third party who receives property through a civil transaction.</data>
  <data key="d3">chunk-482a66c12f2040cbc0eabb425e1b6d97</data>
  <data key="d4">unknown_source</data>
